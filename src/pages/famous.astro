// src/pages/famous.astro
import Layout from '../layouts/Layout.astro';

// Math Helper: draws an SVG wedge from (cx, cy) out to radius r
function getWedgePath(cx: number, cy: number, r: number, startAngle: number, endAngle: number) {
  const rad = Math.PI / 180;
  const x1 = cx + r * Math.cos(startAngle * rad);
  const y1 = cy + r * Math.sin(startAngle * rad);
  const x2 = cx + r * Math.cos(endAngle * rad);
  const y2 = cy + r * Math.sin(endAngle * rad);
  const largeArcFlag = endAngle - startAngle <= 180 ? 0 : 1;
  return `M ${cx},${cy} L ${x1},${y1} A ${r},${r} 0 ${largeArcFlag},1 ${x2},${y2} Z`;
}

// Generate concentric ring sectors for Moving Circles & Rotating Snakes
function generateRingSectors(cx: number, cy: number, r: number, count: number, reversed: boolean) {
  const sectors = [];
  const colors = [
    'fill-slate-950 dark:fill-slate-900',          // Black
    'fill-indigo-600 dark:fill-indigo-500',       // Blue
    'fill-white dark:fill-slate-100',              // White
    'fill-yellow-400 dark:fill-yellow-300'         // Yellow
  ];
  if (reversed) {
    colors.reverse();
  }
  for (let i = 0; i < count; i++) {
    const baseAngle = (i * 360) / count;
    const step = 360 / count / 4;
    for (let c = 0; c < 4; c++) {
      sectors.push({
        path: getWedgePath(cx, cy, r, baseAngle + c * step, baseAngle + (c + 1) * step),
        color: colors[c]
      });
    }
  }
  return sectors;
}

// Generate concentric dashed loops for Fraser Spiral
function generateFraserDashes(cx: number, cy: number, r: number, count: number, tilt: number, length: number) {
  const dashes = [];
  const rad = Math.PI / 180;
  for (let i = 0; i < count; i++) {
    const angle = (i * 360) / count;
    const x1 = cx + r * Math.cos(angle * rad);
    const y1 = cy + r * Math.sin(angle * rad);
    const x2 = cx + (r - length) * Math.cos((angle + tilt) * rad);
    const y2 = cy + (r - length) * Math.sin((angle + tilt) * rad);
    dashes.push({
      d: `M ${x1},${y1} L ${x2},${y2}`,
      color: i % 2 === 0 ? 'stroke-slate-950 dark:stroke-slate-900' : 'stroke-white dark:stroke-slate-100'
    });
  }
  return dashes;
}

// Pre-render loops for Fraser Spiral
const fraserRing1 = generateFraserDashes(100, 100, 80, 32, 25, 12);
const fraserRing2 = generateFraserDashes(100, 100, 52, 20, -25, 9);
const fraserRing3 = generateFraserDashes(100, 100, 28, 12, 25, 6);
