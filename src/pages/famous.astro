      100% { transform: rotate(360deg); }
    }

    @keyframes spin-clockwise {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes spin-counter {
      0% { transform: rotate(360deg); }
      100% { transform: rotate(0deg); }
    }
  </style>

  <!-- Script for Card Interactivity -->
  <script>
    // ----------------------------------------------------
    // GLOBAL SPEED MULTIPLIER / INTENSITY SLIDER
    // ----------------------------------------------------
    const speedSlider = document.getElementById('global-speed-slider') as HTMLInputElement;
    const speedLevelBadge = document.getElementById('speed-level-badge');

    const updateGlobalSpeed = () => {
      if (!speedSlider) return;
      const level = parseInt(speedSlider.value);
      let multiplier = 1.0;

      if (level <= 5) {
        multiplier = 0.2 + (level - 1) * 0.2;
      } else {
        multiplier = 1.0 + (level - 5) * 0.4;
      }

      // Set CSS custom property
      document.documentElement.style.setProperty('--speed-multiplier', multiplier.toString());
      
      // Save to localStorage for other pages
      localStorage.setItem('speed-multiplier-level', level.toString());

      let desc = 'Normal';
      if (level <= 2) desc = 'Slow Speed';
      else if (level <= 4) desc = 'Relaxed';
      else if (level === 5) desc = 'Normal';
      else if (level <= 7) desc = 'Scrambling';
      else if (level <= 9) desc = 'Warp Speed';
      else desc = 'MAX SCRAMBLE 💀';

      if (speedLevelBadge) {
        speedLevelBadge.textContent = `${level} (${desc} — ${multiplier.toFixed(1)}x)`;
      }
    };

    // Initialize slider value from localStorage
    const savedLevel = localStorage.getItem('speed-multiplier-level') || '5';
    if (speedSlider) {
      speedSlider.value = savedLevel;
      speedSlider.addEventListener('input', updateGlobalSpeed);
    }
    updateGlobalSpeed();

    // Listen to storage events to sync speed slider dynamically
    window.addEventListener('storage', () => {
      const currentLevel = localStorage.getItem('speed-multiplier-level') || '5';
      if (speedSlider && speedSlider.value !== currentLevel) {
        speedSlider.value = currentLevel;
        updateGlobalSpeed();
      }
    });

    // ----------------------------------------------------
    // PREVENT CARD CLICK NAVIGATION ON CONTROLS CLICK
    // ----------------------------------------------------
    const controls = document.querySelectorAll('.illusion-card button, .illusion-card input, .illusion-card label, .illusion-card select, .illusion-card details, .illusion-card summary, .illusion-card .demo-area');
    controls.forEach(ctrl => {
      ctrl.addEventListener('click', (e) => {
        // Stop bubbling so it doesn't trigger the card's parent <a> navigation
        e.stopPropagation();
      });
    });


    // ----------------------------------------------------
    // SHARE LINK TO CLIPBOARD FUNCTIONALITY
    // ----------------------------------------------------
    const shareBtns = document.querySelectorAll('.share-btn');
    shareBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        const card = (e.currentTarget as HTMLElement).closest('.illusion-card');
        if (!card) return;
        
        const cardId = card.id;
        const shareUrl = `${window.location.origin}${window.location.pathname}#${cardId}`;
        
        navigator.clipboard.writeText(shareUrl).then(() => {
          const toast = btn.querySelector('.share-toast');
          if (toast) {
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            
            setTimeout(() => {
              toast.classList.remove('opacity-100');
              toast.classList.add('opacity-0');
            }, 2000);
          }
        });
      });
    });


    // ----------------------------------------------------
    // INDIVIDUAL CARD INTERACTIVITY SCRIPTS
    // ----------------------------------------------------

    // 1. Spinning Dancer
    const dancerContainer = document.getElementById('dancer-illusion');
    const toggleDancerBtn = dancerContainer?.querySelector('.toggle-dancer');
    const leftLimb = dancerContainer?.querySelector('.dancer-left-limb');
    const rightLimb = dancerContainer?.querySelector('.dancer-right-limb');
    let dancerColored = false;

    toggleDancerBtn?.addEventListener('click', () => {
      dancerColored = !dancerColored;
      if (dancerColored) {
        leftLimb?.setAttribute('fill', '#ef4444');
        rightLimb?.setAttribute('fill', '#3b82f6');
        toggleDancerBtn.textContent = 'Hide Color Guide';
      } else {
        leftLimb?.setAttribute('fill', 'currentColor');
        rightLimb?.setAttribute('fill', 'currentColor');
        toggleDancerBtn.textContent = 'Toggle Color Guide';
      }
    });

    // 2. Rubin's Vase
    const rubinContainer = document.getElementById('rubin-illusion');
    const rubinBtns = rubinContainer?.querySelectorAll('.rubin-btn');
    const vasePath = rubinContainer?.querySelector('.rubin-vase');
    const faceLeftPath = rubinContainer?.querySelector('.rubin-face-left');
    const faceRightPath = rubinContainer?.querySelector('.rubin-face-right');

    rubinBtns?.forEach(btn => {
      btn.addEventListener('click', (e) => {
        rubinBtns.forEach(b => {
          b.classList.remove('bg-purple-600', 'text-white');
          b.classList.add('text-slate-400', 'hover:text-white');
        });

        const target = e.target as HTMLButtonElement;
        target.classList.remove('text-slate-400', 'hover:text-white');
        target.classList.add('bg-purple-600', 'text-white');
        const mode = target.getAttribute('data-mode');

        if (mode === 'vase') {
          vasePath?.setAttribute('class', 'rubin-vase fill-purple-600 transition-all duration-500');
          faceLeftPath?.setAttribute('class', 'rubin-face-left fill-slate-800 transition-all duration-500 opacity-30');
          faceRightPath?.setAttribute('class', 'rubin-face-right fill-slate-800 transition-all duration-500 opacity-30');
        } else if (mode === 'faces') {
          vasePath?.setAttribute('class', 'rubin-vase fill-slate-900 transition-all duration-500 opacity-20');
          faceLeftPath?.setAttribute('class', 'rubin-face-left fill-indigo-500 transition-all duration-500');
          faceRightPath?.setAttribute('class', 'rubin-face-right fill-indigo-500 transition-all duration-500');
        } else {
          vasePath?.setAttribute('class', 'rubin-vase fill-slate-100 dark:fill-slate-200 transition-all duration-500');
          faceLeftPath?.setAttribute('class', 'rubin-face-left fill-slate-950 transition-all duration-500');
          faceRightPath?.setAttribute('class', 'rubin-face-right fill-slate-950 transition-all duration-500');
        }
      });
    });

    // 3. Penrose Triangle
    const penroseContainer = document.getElementById('penrose-illusion');
    const penroseSlider = penroseContainer?.querySelector('.penrose-slider') as HTMLInputElement;
    const penroseG = penroseContainer?.querySelector('.penrose-g') as SVGElement;
    const togglePenroseBtn = penroseContainer?.querySelector('.toggle-penrose-spin');
    let penroseSpinning = false;

    penroseSlider?.addEventListener('input', (e) => {
      if (penroseSpinning && togglePenroseBtn && penroseG) {
        penroseSpinning = false;
        penroseG.style.animationPlayState = 'paused';
        togglePenroseBtn.textContent = 'Start Spin';
      }
      const val = (e.target as HTMLInputElement).value;
      if (penroseG) {
        penroseG.style.transform = `translate(100px, 100px) scale(0.65) rotate(${val}deg)`;
      }
    });

    togglePenroseBtn?.addEventListener('click', () => {
      penroseSpinning = !penroseSpinning;
      if (penroseG) {
        if (penroseSpinning) {
          penroseG.style.animationPlayState = 'running';
          togglePenroseBtn.textContent = 'Pause';
        } else {
          penroseG.style.animationPlayState = 'paused';
          togglePenroseBtn.textContent = 'Start Spin';
        }
      }
    });

    // 4. The Dress
    const dressContainer = document.getElementById('dress-illusion');
    const dressSlider = dressContainer?.querySelector('.dress-slider') as HTMLInputElement;
    const dressTintVal = dressContainer?.querySelector('.dress-tint-val');
    const dressLightStripes = dressContainer?.querySelectorAll('.dress-light-stripe');
    const dressDarkStripes = dressContainer?.querySelectorAll('.dress-dark-stripe');

    const lerpColor = (c1: string, c2: string, f: number) => {
      const r1 = parseInt(c1.substring(1, 3), 16);
      const g1 = parseInt(c1.substring(3, 5), 16);
      const b1 = parseInt(c1.substring(5, 7), 16);
      const r2 = parseInt(c2.substring(1, 3), 16);
      const g2 = parseInt(c2.substring(3, 5), 16);
      const b2 = parseInt(c2.substring(5, 7), 16);
      const r = Math.round(r1 + (r2 - r1) * f);
      const g = Math.round(g1 + (g2 - g1) * f);
      const b = Math.round(b1 + (b2 - b1) * f);
      const hex = (val: number) => val.toString(16).padStart(2, '0');
      return `#${hex(r)}${hex(g)}${hex(b)}`;
    };

    dressSlider?.addEventListener('input', (e) => {
      const val = parseInt((e.target as HTMLInputElement).value);
      const factor = val / 100;
      const lightCol = lerpColor('#ffffff', '#6d8ae3', factor);
      const darkCol = lerpColor('#c5a059', '#1d1b2b', factor);

      dressLightStripes?.forEach(el => el.setAttribute('fill', lightCol));
      dressDarkStripes?.forEach(el => el.setAttribute('fill', darkCol));

      if (dressTintVal) {
        if (factor < 0.25) dressTintVal.textContent = 'White / Gold';
        else if (factor < 0.75) dressTintVal.textContent = 'Ambiguous Color';
        else dressTintVal.textContent = 'Blue / Black';
      }
    });

    // 5. Müller-Lyer
    const mullerContainer = document.getElementById('muller-illusion');
    const toggleMullerBtn = mullerContainer?.querySelector('.toggle-muller');
    const mullerGuides = mullerContainer?.querySelectorAll('.muller-guide');
    let mullerTruthShown = false;

    toggleMullerBtn?.addEventListener('click', () => {
      mullerTruthShown = !mullerTruthShown;
      mullerGuides?.forEach(guide => {
        if (mullerTruthShown) {
          guide.classList.remove('opacity-0');
          guide.classList.add('opacity-100');
        } else {
          guide.classList.remove('opacity-100');
          guide.classList.add('opacity-0');
        }
      });
      toggleMullerBtn.textContent = mullerTruthShown ? 'Hide Guidelines' : 'Reveal Truth';
    });

    // 6. Café Wall
    const cafeContainer = document.getElementById('cafe-illusion');
    const cafeSlider = cafeContainer?.querySelector('.cafe-slider') as HTMLInputElement;
    const cafeShiftVal = cafeContainer?.querySelector('.cafe-shift-val');
    const cafeRows = cafeContainer?.querySelectorAll('.cafe-row');
    const groutCheckbox = cafeContainer?.querySelector('.cafe-grout-checkbox') as HTMLInputElement;

    const updateCafeWall = () => {
      const shift = cafeSlider?.value || '12';
      const showGrout = groutCheckbox ? groutCheckbox.checked : true;
      if (cafeShiftVal) cafeShiftVal.textContent = `${shift}px`;
      
      cafeRows?.forEach(row => {
        const isEven = row.getAttribute('data-even') === 'true';
        (row as HTMLElement).style.transform = `translateX(${isEven ? shift : 0}px)`;
        if (showGrout) {
          row.classList.remove('border-transparent');
          row.classList.add('border-slate-500/80');
        } else {
          row.classList.remove('border-slate-500/80');
          row.classList.add('border-transparent');
        }
      });
    };

    cafeSlider?.addEventListener('input', updateCafeWall);
    groutCheckbox?.addEventListener('change', updateCafeWall);

    // 7. Necker Cube
    const neckerContainer = document.getElementById('necker-illusion');
    const neckerBtns = neckerContainer?.querySelectorAll('.necker-btn');
    const shadeA = neckerContainer?.querySelector('.necker-shade-a');
    const shadeB = neckerContainer?.querySelector('.necker-shade-b');

    neckerBtns?.forEach(btn => {
      btn.addEventListener('click', (e) => {
        neckerBtns.forEach(b => {
          b.classList.remove('bg-purple-600', 'text-white');
          b.classList.add('text-slate-400', 'hover:text-white');
        });

        const target = e.target as HTMLButtonElement;
        target.classList.remove('text-slate-400', 'hover:text-white');
        target.classList.add('bg-purple-600', 'text-white');
        const face = target.getAttribute('data-face');

        if (face === 'a') {
          shadeA?.classList.remove('opacity-0');
          shadeA?.classList.add('opacity-100');
          shadeB?.classList.remove('opacity-100');
          shadeB?.classList.add('opacity-0');
        } else if (face === 'b') {
          shadeB?.classList.remove('opacity-0');
          shadeB?.classList.add('opacity-100');
          shadeA?.classList.remove('opacity-100');
          shadeA?.classList.add('opacity-0');
        } else {
          shadeA?.classList.remove('opacity-100');
          shadeA?.classList.add('opacity-0');
          shadeB?.classList.remove('opacity-100');
          shadeB?.classList.add('opacity-0');
        }
      });
    });

    // 8. Kanizsa Triangle
    const kanizsaContainer = document.getElementById('kanizsa-illusion');
    const kanizsaSlider = kanizsaContainer?.querySelector('.kanizsa-slider') as HTMLInputElement;
    const toggleOutlineBtn = kanizsaContainer?.querySelector('.toggle-kanizsa-outline');
    const pacmen = kanizsaContainer?.querySelectorAll('.kanizsa-pacman');
    const guides = kanizsaContainer?.querySelectorAll('.kanizsa-guide');
    let outlineShown = false;

    kanizsaSlider?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      pacmen?.forEach(pac => {
        (pac as HTMLElement).style.transform = `rotate(${val}deg)`;
      });
    });

    toggleOutlineBtn?.addEventListener('click', () => {
      outlineShown = !outlineShown;
      guides?.forEach(guide => {
        if (outlineShown) {
          guide.classList.remove('opacity-0');
          guide.classList.add('opacity-100');
        } else {
          guide.classList.remove('opacity-100');
          guide.classList.add('opacity-0');
        }
      });
      if (toggleOutlineBtn) toggleOutlineBtn.textContent = outlineShown ? 'Hide Outline' : 'Show Outline';
    });

    // 9. Ponzo Illusion
    const ponzoContainer = document.getElementById('ponzo-illusion');
    const togglePonzoBtn = ponzoContainer?.querySelector('.toggle-ponzo');
    const topBar = ponzoContainer?.querySelector('.ponzo-bar-top');
    const bottomBar = ponzoContainer?.querySelector('.ponzo-bar-bottom');
    const ponzoGuides = ponzoContainer?.querySelectorAll('.ponzo-guide');
    let ponzoTruthShown = false;

    togglePonzoBtn?.addEventListener('click', () => {
      ponzoTruthShown = !ponzoTruthShown;
      if (ponzoTruthShown) {
        topBar?.setAttribute('transform', 'translate(0, 82)');
        ponzoGuides?.forEach(g => {
          g.classList.remove('opacity-0');
          g.classList.add('opacity-100');
        });
        if (togglePonzoBtn) togglePonzoBtn.textContent = 'Reset';
      } else {
        topBar?.removeAttribute('transform');
        ponzoGuides?.forEach(g => {
          g.classList.remove('opacity-100');
          g.classList.add('opacity-0');
        });
        if (togglePonzoBtn) togglePonzoBtn.textContent = 'Reveal Truth';
      }
    });

    // 10. Zöllner Illusion
    const zoellnerContainer = document.getElementById('zoellner-illusion');
    const zoellnerSlider = zoellnerContainer?.querySelector('.zoellner-slider') as HTMLInputElement;
    const zoellnerVal = zoellnerContainer?.querySelector('.zoellner-val');
    const hatchesGroup = zoellnerContainer?.querySelector('.zoellner-hatches') as SVGElement;

    zoellnerSlider?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      if (zoellnerVal) zoellnerVal.textContent = `${val}%`;
      if (hatchesGroup) {
        hatchesGroup.style.opacity = (parseFloat(val) / 100).toString();
      }
    });

    // 11. Ames Room
    const amesContainer = document.getElementById('ames-illusion');
    const toggleAmesBtn = amesContainer?.querySelector('.toggle-ames');
    const pLeft = amesContainer?.querySelector('#ames-p-left-famous') as SVGElement;
    const pRight = amesContainer?.querySelector('#ames-p-right-famous') as SVGElement;
    let isAmesSwapped = false;

    toggleAmesBtn?.addEventListener('click', () => {
      isAmesSwapped = !isAmesSwapped;
      if (isAmesSwapped) {
        if (pLeft) pLeft.style.transform = 'translate(155px, 166px) scale(0.65)';
        if (pRight) pRight.style.transform = 'translate(45px, 128px) scale(1.65)';
      } else {
        if (pLeft) pLeft.style.transform = 'translate(45px, 128px) scale(1.65)';
        if (pRight) pRight.style.transform = 'translate(155px, 166px) scale(0.65)';
      }
    });

    // 12. Hollow Face
    const hollowContainer = document.getElementById('hollow-illusion');
    const hollowCard = hollowContainer?.closest('.demo-area');
    const hollowFeatures = hollowContainer?.querySelector('.hollow-mask-features') as SVGElement;
    const hollowOutline = hollowContainer?.querySelector('.hollow-mask-outline') as SVGElement;
    const toggleHollowBtn = hollowContainer?.querySelector('.toggle-hollow-physics');
    
    let isReversePhysics = true;
    let hx = 0, hy = 0;
    let htx = 0, hty = 0;

    toggleHollowBtn?.addEventListener('click', () => {
      isReversePhysics = !isReversePhysics;
      toggleHollowBtn.textContent = isReversePhysics ? 'Hollow Face (Reverse)' : 'Normal Face (Direct)';
    });

    hollowCard?.addEventListener('mousemove', (e: any) => {
      const rect = hollowCard.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      htx = (e.clientX - cx) / (rect.width / 2);
      hty = (e.clientY - cy) / (rect.height / 2);
    });

    hollowCard?.addEventListener('mouseleave', () => {
      htx = 0;
      hty = 0;
    });

    const updateHollowFace = () => {
      hx += (htx - hx) * 0.15;
      hy += (hty - hy) * 0.15;
      
      if (hollowFeatures && hollowOutline) {
        const factor = isReversePhysics ? -16 : 14;
        hollowFeatures.style.transform = `translate(${hx * factor}px, ${hy * factor}px)`;
        hollowOutline.style.transform = `translate(${hx * 4}px, ${hy * 4}px)`;
      }
      requestAnimationFrame(updateHollowFace);
    };
    requestAnimationFrame(updateHollowFace);

    // 13. Rotating Snakes
    const snakesContainer = document.getElementById('snakes-illusion');
    const toggleSnakesBtn = snakesContainer?.querySelector('.toggle-snakes');
    const snakeWheels = snakesContainer?.querySelectorAll('.snake-wheel');
    let snakesSpinning = false;

    toggleSnakesBtn?.addEventListener('click', () => {
      snakesSpinning = !snakesSpinning;
      snakeWheels?.forEach(wheel => {
        (wheel as SVGElement).style.animationPlayState = snakesSpinning ? 'running' : 'paused';
      });
      if (toggleSnakesBtn) {
        toggleSnakesBtn.textContent = snakesSpinning ? 'Stop Rotation' : 'Start Real Spin';
      }
    });

    // 14. Fraser Spiral
    const fraserContainer = document.getElementById('fraser-illusion');
    const toggleFraserBtn = fraserContainer?.querySelector('.toggle-fraser');
    const fraserTraces = fraserContainer?.querySelector('.fraser-traces');
    let fraserTracesShown = false;

    toggleFraserBtn?.addEventListener('click', () => {
      fraserTracesShown = !fraserTracesShown;
      if (fraserTraces) {
        if (fraserTracesShown) {
          fraserTraces.classList.remove('opacity-0');
          fraserTraces.classList.add('opacity-100');
          if (toggleFraserBtn) toggleFraserBtn.textContent = 'Hide Circles';
        } else {
          fraserTraces.classList.remove('opacity-100');
          fraserTraces.classList.add('opacity-0');
          if (toggleFraserBtn) toggleFraserBtn.textContent = 'Trace Circles';
        }
      }
    });

    // 15. Hermann Grid
    const hermannContainer = document.getElementById('hermann-illusion');
    const hermannSlider = hermannContainer?.querySelector('.hermann-slider') as HTMLInputElement;
    const toggleHermannBtn = hermannContainer?.querySelector('.toggle-hermann');
    const hermannBlocks = hermannContainer?.querySelectorAll('.hermann-blocks rect');
    const hermannMarkers = hermannContainer?.querySelector('.hermann-markers');
    let hermannMarkersShown = false;

    hermannSlider?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value;
      hermannBlocks?.forEach(block => {
        block.setAttribute('rx', val);
      });
    });

    toggleHermannBtn?.addEventListener('click', () => {
      hermannMarkersShown = !hermannMarkersShown;
      if (hermannMarkers) {
        if (hermannMarkersShown) {
          hermannMarkers.classList.remove('opacity-0');
          hermannMarkers.classList.add('opacity-100');
          if (toggleHermannBtn) toggleHermannBtn.textContent = 'Hide Truth';
        } else {
          hermannMarkers.classList.remove('opacity-100');
          hermannMarkers.classList.add('opacity-0');
          if (toggleHermannBtn) toggleHermannBtn.textContent = 'Show Truth';
        }
      }
    });

  
    // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation on famous cards
    const famousCards = document.querySelectorAll('.illusion-card');
    famousCards.forEach(card => {
      card.querySelectorAll('button, input, select, details, summary, label, a, .toggle-dancer, .rubin-btn').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
    });
  
  </script>

</Layout>
