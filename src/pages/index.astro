---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import PoggendorffDemo from '../components/illusions/PoggendorffDemo.astro';
import ColorSpheresDemo from '../components/illusions/ColorSpheresDemo.astro';
import CurvatureBlindnessDemo from '../components/illusions/CurvatureBlindnessDemo.astro';
import KanizsaTriangleDemo from '../components/illusions/KanizsaTriangleDemo.astro';
import TroxlerFadingDemo from '../components/illusions/TroxlerFadingDemo.astro';
import ReverseSpokeDemo from '../components/illusions/ReverseSpokeDemo.astro';
import AfterimageBulbDemo from '../components/illusions/AfterimageBulbDemo.astro';
import PinnaBrelstaffDemo from '../components/illusions/PinnaBrelstaffDemo.astro';
---

<Layout 
  title="Optical Illusions — Trick Your Brain | Optical Illusion Lab" 
  description="Explore the ultimate interactive gallery of 11 upgraded optical illusions. Test your brain with Troxler Fading, Curvature Blindness, Poggendorff, and more."
>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are optical illusions?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An optical illusion is a visual perception that differs from physical reality. It occurs when the visual system (eyes and brain) interprets visual sensory inputs in a way that deviates from the actual properties of the stimulus."
          }
        },
        {
          "@type": "Question",
          "name": "How do optical illusions work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Optical illusions work by exploiting the brain's shortcut mechanisms for visual processing. Instead of passively recording what is in front of us, the brain constructs a predicted model based on context, shadows, lighting, and past experience."
          }
        },
        {
          "@type": "Question",
          "name": "Why do optical illusions trick the brain?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "They trick the brain by feeding it ambiguous visual cues. The brain processes information rapidly to make quick survival decisions, and illusions represent rare edge cases where these speed-over-accuracy shortcuts fail."
          }
        },
        {
          "@type": "Question",
          "name": "What are the 3 types of optical illusions?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The three main categories are: Literal illusions (physically different from their component parts), Physiological illusions (caused by visual/neural fatigue from excessive contrast, brightness, or color channels), and Cognitive illusions (where top-down assumptions construct phantom lines or shapes)."
          }
        },
        {
          "@type": "Question",
          "name": "Are optical illusions bad for your eyes?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No, optical illusions are completely safe. They showcase the limits and rules of visual processing and do not cause any harm to the visual cells or the brain."
          }
        }
      ]
    }
  </script>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-28 px-4 sm:px-6 lg:px-8 border-b border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-950 text-slate-900 dark:text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(147,51,234,0.05),transparent_40%)]"></div>
    <div class="absolute -top-40 -left-40 h-80 w-80 rounded-full bg-purple-600/5 dark:bg-purple-600/10 blur-3xl"></div>
    
    <!-- Animated background geometric shapes -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none select-none opacity-[0.05] dark:opacity-[0.08]" aria-hidden="true">
      <div class="absolute top-[10%] left-[8%] w-20 h-20 border border-purple-500 rounded-full animate-float-slow"></div>
      <div class="absolute top-[65%] left-[12%] w-0 h-0 border-l-[30px] border-l-transparent border-r-[30px] border-r-transparent border-b-[50px] border-b-indigo-500 animate-float-medium"></div>
      <div class="absolute top-[18%] right-[10%] w-14 h-14 border border-purple-500 rotate-45 animate-float-fast"></div>
      <div class="absolute top-[75%] right-[15%] w-28 h-28 border border-indigo-500 rounded-full animate-float-reverse"></div>
    </div>
    
    <div class="relative mx-auto max-w-4xl text-center space-y-6">
      <div class="inline-flex items-center space-x-2 rounded-full border border-purple-200 dark:border-purple-500/20 bg-purple-50 dark:bg-purple-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-purple-600 dark:text-purple-300">
        ✨ Interactive Brain Playground
      </div>
      <h1 class="font-display text-4xl sm:text-6xl font-black tracking-tight text-slate-900 dark:text-white">
        Optical Illusions — Trick Your Brain
      </h1>
      <p class="mx-auto max-w-2xl text-base sm:text-lg text-slate-600 dark:text-slate-400 font-medium">
        Welcome to the <span class="text-slate-900 dark:text-white font-bold">Optical Illusion Lab</span>. Explore our interactive library of visual anomalies, challenge your spatial perception, and discover the fascinating science of how your mind constructs reality.
      </p>
      <div class="flex justify-center space-x-4">
        <a href="#illusion-gallery" class="rounded-xl bg-purple-600 hover:bg-purple-500 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-purple-500/10 hover:shadow-lg hover:shadow-purple-500/25 transition-all duration-200">
          Explore Illusions
        </a>
        <a href="#how-it-works" class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 hover:bg-slate-50 dark:hover:bg-slate-900 px-6 py-3 text-sm font-semibold text-slate-700 dark:text-slate-200 transition-all duration-200">
          Learn the Science
        </a>
      </div>
    </div>
  </section>

  <!-- Illusion of the Day Banner Section -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="rounded-2xl bg-gradient-to-r from-purple-500 to-indigo-500 p-[1.5px] shadow-lg">
      <div id="illusion-of-the-day" class="relative rounded-[15px] bg-white dark:bg-slate-900/90 p-6 flex flex-col md:flex-row items-center justify-between gap-6 transition-all duration-300">
        <div class="space-y-2 text-center md:text-left">
          <div class="inline-flex items-center space-x-2 rounded-md bg-purple-50 dark:bg-purple-500/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide text-purple-600 dark:text-purple-300 border border-purple-100 dark:border-purple-500/20">
            <svg class="h-3 w-3 inline mr-1 text-purple-600 dark:text-purple-300 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            Illusion of the Day
          </div>
          <h3 class="today-illusion-name font-display text-2xl font-bold text-slate-900 dark:text-white">Loading...</h3>
          <p class="today-illusion-tease text-slate-600 dark:text-slate-400 text-sm max-w-xl">Find out how your visual processing handles this visual trickery.</p>
        </div>
        <button id="view-today-btn" class="shrink-0 rounded-xl bg-purple-600 hover:bg-purple-500 text-white font-extrabold text-sm px-8 py-3.5 transition-all shadow-md hover:shadow-purple-500/25 active:scale-95 hover:scale-105">
          View Today's Illusion →
        </button>
      </div>
    </div>
  </section>

  <!-- Gallery Control / Speed Slider Section -->
  <section id="illusion-gallery" class="pt-20 pb-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    
    <!-- Intensity Slider Banner -->
    <div class="mb-16 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
      <div class="space-y-1 text-center md:text-left">
        <h3 class="font-display text-lg font-bold text-slate-900 dark:text-white">Brain Scramble Level (Speed Control)</h3>
        <p class="text-xs text-slate-500 dark:text-slate-400">Scale visual movement in real-time. Slow down to analyze the science, or speed up to warp your vision.</p>
      </div>
      <div class="w-full md:w-80 flex flex-col space-y-1">
        <div class="flex items-center justify-between text-xs font-bold uppercase text-slate-400 dark:text-slate-500 mb-1">
          <span>Level</span>
          <span id="speed-level-badge" class="text-purple-600 dark:text-purple-400 font-mono">5 (Normal)</span>
        </div>
        <div class="flex items-center space-x-2.5">
          <span class="text-sm select-none" title="Slow">🐌</span>
          <input 
            id="global-speed-slider" 
            type="range" 
            min="1" 
            max="10" 
            value="5" 
            class="w-full h-2 bg-gradient-to-r from-blue-500 via-purple-500 to-red-500 rounded-lg appearance-none cursor-pointer focus:outline-none shadow-inner" 
          />
          <span class="text-sm select-none" title="Fast">🚀</span>
        </div>
        <div class="flex items-center justify-between text-[10px] text-slate-400 dark:text-slate-500 mt-1">
          <span>1 (0.2x Slow)</span>
          <span>10 (3.0x Scrambled)</span>
        </div>
      </div>
    </div>

    <!-- Gallery Headline -->
    <div class="text-center mb-16 space-y-4">
      <h2 class="font-display text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
        Visual Laboratory Grid
      </h2>
      <p class="text-slate-500 dark:text-slate-400 max-w-xl mx-auto text-sm sm:text-base">
        Click on any card to visit its dedicated page, or interact with its visual parameters directly inside the grid cards.
      </p>
    </div>

    <!-- The 12 Illusion Cards Grid (Anchors linking to sub-pages) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
      
      <!-- Card 1: Poggendorff Illusion (Amber Accent) -->
      <a href="/illusions/poggendorff" id="poggendorff-illusion" class="illusion-card flex flex-col justify-between rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-8 shadow-sm hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(245,158,11,0.12)] hover:border-amber-500/40 cursor-pointer transition-all duration-300 relative group border-l-4 border-l-yellow-500">
        <button class="share-btn absolute top-6 right-6 p-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white border-none transition-colors z-20 cursor-pointer" aria-label="Share this illusion">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
          <span class="share-toast absolute bottom-full right-0 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-600 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
        </button>
        
        <div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2 flex flex-col xs:flex-row xs:items-center gap-2 pr-10">
            <span>Poggendorff Illusion</span>
            <span class="text-[9px] font-bold px-2 py-0.5 rounded bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20 w-fit">Geometry</span>
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
            Diagonal line segments interrupted by a thick vertical rectangle look misaligned, but are actually continuous.
          </p>
        </div>

        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Align your eyes with the black diagonal line. Drag the overlap slider to see if the two segments align.
          </div>
        </div>

        <PoggendorffDemo isCard={true} />
        <div class="mt-5 flex items-center justify-between text-xs font-bold text-purple-600 dark:text-purple-400 group-hover:text-purple-500 transition-colors">
          <span>Interactive Details</span>
          <span>Explore &rarr;</span>
        </div>
      
        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            The Poggendorff Illusion is a geometrical-optical distortion where a diagonal line segment is interrupted by a vertical block. The brain misjudges the angle of the segment, making the two halves appear misaligned. This occurs because the visual system processes obtuse angles as larger and acute angles as smaller than they physically are.
          </p>
        </details>
</a>


      <!-- Card 3: Color Spheres Illusion (Purple Accent) -->
      <a href="/illusions/color-spheres" id="spheres-illusion" class="illusion-card flex flex-col justify-between rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-[#1a1a2e] p-8 shadow-sm hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.12)] hover:border-purple-500/40 cursor-pointer transition-all duration-300 relative group border-l-4 border-l-yellow-500">
        <button class="share-btn absolute top-6 right-6 p-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white border-none transition-colors z-20 cursor-pointer" aria-label="Share this illusion">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
          <span class="share-toast absolute bottom-full right-0 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-600 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
        </button>

        <div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2 flex flex-col xs:flex-row xs:items-center gap-2 pr-10">
            <span>Color Spheres Illusion</span>
            <span class="text-[9px] font-bold px-2 py-0.5 rounded bg-purple-50 dark:bg-purple-500/10 text-purple-600 dark:text-purple-400 border border-purple-200 dark:border-purple-500/20 w-fit">Color</span>
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
            Nine spheres appear red, blue, and green, but all are actually identical grey. Overlapping colored lines create the color.
          </p>
        </div>

        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Observe the spheres. Click 'Remove Lines' to see that they are actually the exact same shade of gray.
          </div>
        </div>
        <ColorSpheresDemo isCard={true} />
        <div class="mt-5 flex items-center justify-between text-xs font-bold text-purple-600 dark:text-purple-400 group-hover:text-purple-500 transition-colors">
          <span>Interactive Details</span>
          <span>Explore &rarr;</span>
        </div>
      
        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            The Color Spheres (Munker-White) illusion is caused by chromatic assimilation. The color of the foreground stripes bleeds into our perception of the gray spheres behind them, tricking our visual cortex into resolving them as red, blue, or green.
          </p>
        </details>
</a>

      <!-- Card 4: Curvature Blindness (Amber Accent) -->
      <a href="/illusions/curvature-blindness" id="curvature-illusion" class="illusion-card flex flex-col justify-between rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-8 shadow-sm hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(245,158,11,0.12)] hover:border-amber-500/40 cursor-pointer transition-all duration-300 relative group border-l-4 border-l-emerald-500">
        <button class="share-btn absolute top-6 right-6 p-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white border-none transition-colors z-20 cursor-pointer" aria-label="Share this illusion">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
          <span class="share-toast absolute bottom-full right-0 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-600 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
        </button>

        <div>
          <span class="text-[9px] font-bold px-2 py-0.5 rounded bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20 w-fit mb-2 block">Shape</span>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2 pr-10">
            Curvature Blindness
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 italic">
            Identical wavy lines appear as sharp zig-zags or smooth curves depending entirely on where the color changes.
          </p>
        </div>

        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Look at the wavy paths. Click 'Show True Geometry' to prove they are all identical smooth curves.
          </div>
        </div>
        <CurvatureBlindnessDemo isCard={true} />
        <div class="mt-5 flex items-center justify-between text-xs font-bold text-purple-600 dark:text-purple-400 group-hover:text-purple-500 transition-colors">
          <span>Interactive Details</span>
          <span>Explore &rarr;</span>
        </div>

        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            Curvature Blindness occurs because our brain processes curves and corners differently. The visual system groups segments by vertex contrast: when the vertex highlights align with the curvature, it groups them as smooth waves; when they contrast, it groups them as sharp zig-zag corners.
          </p>
        </details>
      </a>

      <!-- Card 5: Kanizsa Triangle (Emerald Accent) -->
      <a href="/illusions/kanizsa-triangle" id="kanizsa-illusion" class="illusion-card flex flex-col justify-between rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-8 shadow-sm hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(16,185,129,0.12)] hover:border-emerald-500/40 cursor-pointer transition-all duration-300 relative group border-l-4 border-l-emerald-500">
        <button class="share-btn absolute top-6 right-6 p-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white border-none transition-colors z-20 cursor-pointer" aria-label="Share this illusion">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
          <span class="share-toast absolute bottom-full right-0 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-600 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
        </button>

        <div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2 flex flex-col xs:flex-row xs:items-center gap-2 pr-10">
            <span>Kanizsa Triangle</span>
            <span class="text-[9px] font-bold px-2 py-0.5 rounded bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20 w-fit">Gestalt</span>
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-6">
            A white triangle appears to float in the center, yet not a single triangle boundary is actually drawn.
          </p>
        </div>

        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Stare at the center. Do you see a bright white triangle floating on top of the pac-man shapes?
          </div>
        </div>
        <KanizsaTriangleDemo isCard={true} />
        <div class="mt-5 flex items-center justify-between text-xs font-bold text-purple-600 dark:text-purple-400 group-hover:text-purple-500 transition-colors">
          <span>Interactive Details</span>
          <span>Explore &rarr;</span>
        </div>
      
        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            The Kanizsa Triangle is a Gestalt illusion showing boundary completion. The visual cortex fills in non-existent contours between the pac-man mouths and circles because it prefers to construct a complete, overlapping white triangle in the foreground.
          </p>
        </details>
</a>

      <!-- Card 6: Troxler Fading (Purple Accent) -->
      <a href="/illusions/troxler-fading" id="troxler-illusion" class="illusion-card flex flex-col justify-between rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-[#1a1a2e] p-8 shadow-sm hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.12)] hover:border-purple-500/40 cursor-pointer transition-all duration-300 relative group border-l-4 border-l-rose-500">
        <button class="share-btn absolute top-6 right-6 p-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white border-none transition-colors z-20 cursor-pointer" aria-label="Share this illusion">
