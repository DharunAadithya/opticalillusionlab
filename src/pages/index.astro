  <!-- Interactive JavaScript Scripts -->
  <script>
    // ----------------------------------------------------
    // GLOBAL SPEED MULTIPLIER / INTENSITY SLIDER
    // ----------------------------------------------------
    const speedSlider = document.getElementById('global-speed-slider') as HTMLInputElement;
    const speedLevelBadge = document.getElementById('speed-level-badge');

    const updateGlobalSpeed = () => {
      if (!speedSlider) return;
      const level = parseInt(speedSlider.value);
      let multiplier = 1.0;

      if (level <= 5) {
        multiplier = 0.2 + (level - 1) * 0.2;
      } else {
        multiplier = 1.0 + (level - 5) * 0.4;
      }

      // Set CSS custom property
      document.documentElement.style.setProperty('--speed-multiplier', multiplier.toString());
      
      // Save to localStorage for sub-pages
      localStorage.setItem('speed-multiplier-level', level.toString());

      let desc = 'Normal';
      if (level <= 2) desc = 'Slow Speed';
      else if (level <= 4) desc = 'Relaxed';
      else if (level === 5) desc = 'Normal';
      else if (level <= 7) desc = 'Scrambling';
      else if (level <= 9) desc = 'Warp Speed';
      else desc = 'MAX SCRAMBLE 💀';

      if (speedLevelBadge) {
        speedLevelBadge.textContent = `${level} (${desc} — ${multiplier.toFixed(1)}x)`;
      }
    };

    speedSlider?.addEventListener('input', updateGlobalSpeed);
    updateGlobalSpeed();


    // ----------------------------------------------------
    // PREVENT CARD CLICK NAVIGATION ON CONTROLS CLICK
    // ----------------------------------------------------
    const stopPropagationHandler = (e: Event) => {
      e.stopPropagation();
    };

    const interactiveWidgets = document.querySelectorAll(
      '.illusion-card button, .illusion-card input, .illusion-card label, .illusion-card select'
    );
    interactiveWidgets.forEach(widget => {
      widget.addEventListener('click', stopPropagationHandler);
      widget.addEventListener('mousedown', stopPropagationHandler);
      widget.addEventListener('touchstart', stopPropagationHandler);
    });


    // ----------------------------------------------------
    // ILLUSION OF THE DAY BANNER ROTATION
    // ----------------------------------------------------
    const illusions = [
      { id: 'poggendorff-illusion', name: 'Poggendorff Illusion', tease: 'Diagonal line segments interrupted by a thick vertical rectangle look misaligned, but are actually continuous.' },
      { id: 'spheres-illusion', name: 'Color Spheres Illusion', tease: 'Nine spheres appear red, blue, and green, but all are actually identical grey. Overlapping colored lines create the color.' },
      { id: 'curvature-illusion', name: 'Curvature Blindness', tease: 'Identical wavy lines appear as sharp zig-zags or smooth curves depending entirely on where the color changes.' },
      { id: 'kanizsa-illusion', name: 'Kanizsa Triangle', tease: 'A white triangle appears to float in the center, yet not a single triangle boundary is actually drawn.' },
      { id: 'troxler-illusion', name: 'Troxler Fading', tease: 'Stare at the central cross for 20 seconds. Pink dots may fade in your peripheral vision — a real neural adaptation effect.' }
    ];

    const todayIndex = new Date().getDay() % illusions.length;
    const todayIllusion = illusions[todayIndex];

    const bannerNameEl = document.querySelector('.today-illusion-name');
    const bannerTeaseEl = document.querySelector('.today-illusion-tease');
    const bannerBtn = document.getElementById('view-today-btn');

    if (bannerNameEl && bannerTeaseEl && bannerBtn) {
      bannerNameEl.textContent = todayIllusion.name;
      bannerTeaseEl.textContent = todayIllusion.tease;
      bannerBtn.addEventListener('click', () => {
        document.getElementById(todayIllusion.id)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }


    // ----------------------------------------------------
    // SHARE LINK TO CLIPBOARD FUNCTIONALITY
    // ----------------------------------------------------
    const shareBtns = document.querySelectorAll('.share-btn');
    shareBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        const card = (e.currentTarget as HTMLElement).closest('.illusion-card');
        if (!card) return;
        
        const cardId = card.id;
        const shareUrl = `${window.location.origin}${window.location.pathname}#${cardId}`;
        
        navigator.clipboard.writeText(shareUrl).then(() => {
          const toast = btn.querySelector('.share-toast');
          if (toast) {
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            
            setTimeout(() => {
              toast.classList.remove('opacity-100');
              toast.classList.add('opacity-0');
            }, 2000);
          }
        });
      });
    });


    // ----------------------------------------------------
    // ILLUSION INTERACTIVITY LOGIC
    // ----------------------------------------------------



    // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation on cards
    const homepageCards = document.querySelectorAll('.illusion-card');
    homepageCards.forEach(card => {
      card.querySelectorAll('button, input, select, details, summary, label, a, .toggle-dancer, .rubin-btn').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
    });
  </script>
