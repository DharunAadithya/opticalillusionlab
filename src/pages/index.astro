  <!-- Interactive JavaScript Scripts -->
  <script>
    // ----------------------------------------------------
    // GLOBAL SPEED MULTIPLIER / INTENSITY SLIDER
    // ----------------------------------------------------
    const speedSlider = document.getElementById('global-speed-slider') as HTMLInputElement;
    const speedLevelBadge = document.getElementById('speed-level-badge');

    const updateGlobalSpeed = () => {
      if (!speedSlider) return;
      const level = parseInt(speedSlider.value);
      let multiplier = 1.0;

      if (level <= 5) {
        multiplier = 0.2 + (level - 1) * 0.2;
      } else {
        multiplier = 1.0 + (level - 5) * 0.4;
      }

      // Set CSS custom property
      document.documentElement.style.setProperty('--speed-multiplier', multiplier.toString());
      
      // Save to localStorage for sub-pages
      localStorage.setItem('speed-multiplier-level', level.toString());

      let desc = 'Normal';
      if (level <= 2) desc = 'Slow Speed';
      else if (level <= 4) desc = 'Relaxed';
      else if (level === 5) desc = 'Normal';
      else if (level <= 7) desc = 'Scrambling';
      else if (level <= 9) desc = 'Warp Speed';
      else desc = 'MAX SCRAMBLE 💀';

      if (speedLevelBadge) {
        speedLevelBadge.textContent = `${level} (${desc} — ${multiplier.toFixed(1)}x)`;
      }
    };

    speedSlider?.addEventListener('input', updateGlobalSpeed);
    updateGlobalSpeed();


    // ----------------------------------------------------
    // PREVENT CARD CLICK NAVIGATION ON CONTROLS CLICK
    // ----------------------------------------------------
    const stopPropagationHandler = (e: Event) => {
      e.stopPropagation();
    };

    const interactiveWidgets = document.querySelectorAll(
      '.illusion-card button, .illusion-card input, .illusion-card label, .illusion-card select'
    );
    interactiveWidgets.forEach(widget => {
      widget.addEventListener('click', stopPropagationHandler);
      widget.addEventListener('mousedown', stopPropagationHandler);
      widget.addEventListener('touchstart', stopPropagationHandler);
    });


    // ----------------------------------------------------
    // ILLUSION OF THE DAY BANNER ROTATION
    // ----------------------------------------------------
    const illusions = [
      { id: 'poggendorff-illusion', name: 'Poggendorff Illusion', tease: 'Diagonal line segments interrupted by a thick vertical rectangle look misaligned, but are actually continuous.' },
      { id: 'adelson-illusion', name: 'Adelson Checkerboard', tease: 'Tile A in the light and Tile B in the cylinder shadow are identical gray colors, though your brain insists B is much lighter.' },
      { id: 'spheres-illusion', name: 'Color Spheres Illusion', tease: 'Nine spheres appear red, blue, and green, but all are actually identical grey. Overlapping colored lines create the color.' },
      { id: 'curvature-illusion', name: 'Curvature Blindness', tease: 'Identical wavy lines appear as sharp zig-zags or smooth curves depending entirely on where the color changes.' },
      { id: 'kanizsa-illusion', name: 'Kanizsa Triangle', tease: 'A white triangle appears to float in the center, yet not a single triangle boundary is actually drawn.' },
      { id: 'troxler-illusion', name: 'Troxler Fading', tease: 'Stare at the central cross for 20 seconds. The pink dots will disappear, replaced by a non-existent green dot.' },
      { id: 'hole-illusion', name: 'Expanding Hole', tease: 'A completely static radial gradient black hole that appears to expand toward you as you stare at it.' }
    ];

    const todayIndex = new Date().getDay() % illusions.length;
    const todayIllusion = illusions[todayIndex];

    const bannerNameEl = document.querySelector('.today-illusion-name');
    const bannerTeaseEl = document.querySelector('.today-illusion-tease');
    const bannerBtn = document.getElementById('view-today-btn');

    if (bannerNameEl && bannerTeaseEl && bannerBtn) {
      bannerNameEl.textContent = todayIllusion.name;
      bannerTeaseEl.textContent = todayIllusion.tease;
      bannerBtn.addEventListener('click', () => {
        document.getElementById(todayIllusion.id)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }


    // ----------------------------------------------------
    // SHARE LINK TO CLIPBOARD FUNCTIONALITY
    // ----------------------------------------------------
    const shareBtns = document.querySelectorAll('.share-btn');
    shareBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();

        const card = (e.currentTarget as HTMLElement).closest('.illusion-card');
        if (!card) return;
        
        const cardId = card.id;
        const shareUrl = `${window.location.origin}${window.location.pathname}#${cardId}`;
        
        navigator.clipboard.writeText(shareUrl).then(() => {
          const toast = btn.querySelector('.share-toast');
          if (toast) {
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            
            setTimeout(() => {
              toast.classList.remove('opacity-100');
              toast.classList.add('opacity-0');
            }, 2000);
          }
        });
      });
    });


    // ----------------------------------------------------
    // ILLUSION INTERACTIVITY LOGIC
    // ----------------------------------------------------

    // 1. Poggendorff
    const poggContainer = document.getElementById('poggendorff-illusion');
    const poggRect = poggContainer?.querySelector('.pogg-rect') as HTMLElement;
    const poggBtn = poggContainer?.querySelector('.toggle-pogg');
    let poggShown = true;
    poggBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      poggShown = !poggShown;
      if (poggRect) poggRect.style.opacity = poggShown ? '1' : '0';
      if (poggBtn) poggBtn.textContent = poggShown ? 'Hide Rectangle' : 'Show Rectangle';
    });

    // 2. Adelson's Checkerboard
    const adelsonContainer = document.getElementById('adelson-illusion');
    const adelsonBridge = adelsonContainer?.querySelector('.checker-bridge') as HTMLElement;
    const adelsonShadow = adelsonContainer?.querySelector('.cylinder-shadow') as HTMLElement;
    const adelsonBridgeBtn = adelsonContainer?.querySelector('.toggle-bridge');
    const adelsonShadowBtn = adelsonContainer?.querySelector('.toggle-shadow');

    let adelsonBridgeShown = false;
    let adelsonShadowShown = true;

    adelsonBridgeBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      adelsonBridgeShown = !adelsonBridgeShown;
      if (adelsonBridge) adelsonBridge.style.opacity = adelsonBridgeShown ? '1' : '0';
      if (adelsonBridgeBtn) {
        adelsonBridgeBtn.textContent = adelsonBridgeShown ? 'Hide Bridge' : 'Reveal Truth';
        if (adelsonBridgeShown) {
          adelsonBridgeBtn.classList.add('bg-purple-600', 'text-white');
        } else {
          adelsonBridgeBtn.classList.remove('bg-purple-600', 'text-white');
        }
      }
    });

    adelsonShadowBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      adelsonShadowShown = !adelsonShadowShown;
      if (adelsonShadow) adelsonShadow.style.opacity = adelsonShadowShown ? '1' : '0';
      if (adelsonShadowBtn) {
        adelsonShadowBtn.textContent = adelsonShadowShown ? 'Remove Shadow' : 'Restore Shadow';
        if (!adelsonShadowShown) {
          adelsonShadowBtn.classList.add('bg-purple-600', 'text-white');
        } else {
          adelsonShadowBtn.classList.remove('bg-purple-600', 'text-white');
        }
      }
    });

    // 3. Color Spheres
    const spheresContainer = document.getElementById('spheres-illusion');
    const spheresStripes = spheresContainer?.querySelector('.spheres-stripes') as HTMLElement;
    spheresContainer?.addEventListener('mouseenter', () => {
      if (spheresStripes) spheresStripes.style.opacity = '0';
    });
    spheresContainer?.addEventListener('mouseleave', () => {
      if (spheresStripes) spheresStripes.style.opacity = '1';
    });
    spheresContainer?.addEventListener('touchstart', () => {
      if (spheresStripes) spheresStripes.style.opacity = '0';
    });
    spheresContainer?.addEventListener('touchend', () => {
      if (spheresStripes) spheresStripes.style.opacity = '1';
    });

    // 4. Curvature Blindness
    const curveContainer = document.getElementById('curvature-illusion');
    const curveSlider = curveContainer?.querySelector('.curve-slider') as HTMLInputElement;
    const curvePeaks = curveContainer?.querySelector('.peaks-coloring') as HTMLElement;
    const curveInflections = curveContainer?.querySelector('.inflections-coloring') as HTMLElement;
    const curveModeText = curveContainer?.querySelector('.color-mode-text');

    curveSlider?.addEventListener('input', (e) => {
      e.stopPropagation();
      const val = (e.target as HTMLInputElement).value;
      if (val === '0') {
        if (curvePeaks) curvePeaks.style.opacity = '1';
        if (curveInflections) curveInflections.style.opacity = '0';
        if (curveModeText) curveModeText.textContent = 'Peak-colored (Zig-zag)';
      } else {
        if (curvePeaks) curvePeaks.style.opacity = '0';
        if (curveInflections) curveInflections.style.opacity = '1';
        if (curveModeText) curveModeText.textContent = 'Inflection-colored (Curved)';
      }
    });

    // 5. Kanizsa Triangle
    const kanizsaContainer = document.getElementById('kanizsa-illusion');
    const kanizsaSlider = kanizsaContainer?.querySelector('.kanizsa-slider') as HTMLInputElement;
    const kanizsaBtn = kanizsaContainer?.querySelector('.toggle-kanizsa-outline');
    const kanizsaPacmen = kanizsaContainer?.querySelectorAll('.kanizsa-pacman');
    const kanizsaGuides = kanizsaContainer?.querySelectorAll('.kanizsa-guide');
    
    let kanizsaOutlineShown = false;

    kanizsaSlider?.addEventListener('input', (e) => {
      e.stopPropagation();
      const val = (e.target as HTMLInputElement).value;
      kanizsaPacmen?.forEach((pac) => {
        (pac as HTMLElement).style.transform = `rotate(${val}deg)`;
      });
    });

    kanizsaBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      kanizsaOutlineShown = !kanizsaOutlineShown;
      kanizsaGuides?.forEach(guide => {
        if (kanizsaOutlineShown) {
          guide.classList.remove('opacity-0');
          guide.classList.add('opacity-100');
        } else {
          guide.classList.remove('opacity-100');
          guide.classList.add('opacity-0');
        }
      });
      if (kanizsaBtn) kanizsaBtn.textContent = kanizsaOutlineShown ? 'Hide Outline' : 'Show Outline';
    });

    // 6. Troxler Fading
    const troxlerContainer = document.getElementById('troxler-illusion');
    const troxlerDots = troxlerContainer?.querySelectorAll('.troxler-dot');
    const troxlerStartBtn = troxlerContainer?.querySelector('.start-troxler');
    const troxlerTime = troxlerContainer?.querySelector('.troxler-time');
    
    let troxlerDotsInterval: any = null;
    let troxlerTimerInterval: any = null;
    let troxlerCurrentMissing = 0;
    let troxlerSecondsLeft = 20.0;
    let troxlerIsRunning = false;

    const runTroxler = () => {
      troxlerDotsInterval = setInterval(() => {
        troxlerDots?.forEach((dot, idx) => {
          if (idx === troxlerCurrentMissing) {
            (dot as HTMLElement).style.opacity = '0';
          } else {
            (dot as HTMLElement).style.opacity = '1';
          }
        });
        troxlerCurrentMissing = (troxlerCurrentMissing + 1) % 12;
      }, 150);
    };

    troxlerStartBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (troxlerIsRunning) {
        clearInterval(troxlerDotsInterval);
        clearInterval(troxlerTimerInterval);
        troxlerDots?.forEach(dot => (dot as HTMLElement).style.opacity = '1');
        troxlerSecondsLeft = 20.0;
        if (troxlerTime) troxlerTime.textContent = '20.0s';
        if (troxlerStartBtn) troxlerStartBtn.textContent = 'Start Timer';
        troxlerIsRunning = false;
        return;
      }

      troxlerIsRunning = true;
      if (troxlerStartBtn) troxlerStartBtn.textContent = 'Reset';
      runTroxler();

      const startTime = Date.now();
      troxlerTimerInterval = setInterval(() => {
        const elapsed = (Date.now() - startTime) / 1000;
        troxlerSecondsLeft = 20.0 - elapsed;
        if (troxlerSecondsLeft <= 0) {
          troxlerSecondsLeft = 0;
          clearInterval(troxlerTimerInterval);
        }
        if (troxlerTime) troxlerTime.textContent = `${troxlerSecondsLeft.toFixed(1)}s`;
      }, 100);
    });

    // 7. Expanding Hole
    const holeContainer = document.getElementById('hole-illusion');
    const holeBtn = holeContainer?.querySelector('.toggle-static');
    holeBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      alert("Nothing changed, because this image is already 100% static! The expanding motion is completely fabricated inside your brain.");
    });

    // 8. Breathing Square
    const breathingContainer = document.getElementById('breathing-square-illusion');
    const breathingOccluders = breathingContainer?.querySelector('.breathing-occluders') as HTMLElement;
    const breathingBtn = breathingContainer?.querySelector('.toggle-occluders');
    let breathingShown = true;
    breathingBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      breathingShown = !breathingShown;
      if (breathingOccluders) breathingOccluders.style.opacity = breathingShown ? '1' : '0';
      if (breathingBtn) breathingBtn.textContent = breathingShown ? 'Hide Green Occluders' : 'Show Green Occluders';
    });

    // 9. Reverse Spoke
    const spokeContainer = document.getElementById('spoke-illusion');
    const spokeBgWheel = spokeContainer?.querySelector('.spoke-bg-wheel') as SVGElement;
    const spokeBtn = spokeContainer?.querySelector('.toggle-spoke-spin');
    let spokeSpinning = true;
    spokeBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      spokeSpinning = !spokeSpinning;
      if (spokeBgWheel) {
        spokeBgWheel.style.animationPlayState = spokeSpinning ? 'running' : 'paused';
      }
      if (spokeBtn) spokeBtn.textContent = spokeSpinning ? 'Pause' : 'Play';
    });

    // 10. Motion Binding
    const bindingContainer = document.getElementById('binding-illusion');
    const bindingOccluders = bindingContainer?.querySelector('.motion-occluders') as HTMLElement;
    bindingContainer?.addEventListener('mouseenter', () => {
      if (bindingOccluders) bindingOccluders.style.opacity = '0';
    });
    bindingContainer?.addEventListener('mouseleave', () => {
      if (bindingOccluders) bindingOccluders.style.opacity = '1';
    });
    bindingContainer?.addEventListener('touchstart', () => {
      if (bindingOccluders) bindingOccluders.style.opacity = '0';
    });
    bindingContainer?.addEventListener('touchend', () => {
      if (bindingOccluders) bindingOccluders.style.opacity = '1';
    });

    // 11. Wertheimer-Koffka Ring
    const koffkaContainer = document.getElementById('koffka-illusion');
    const koffkaSlider = koffkaContainer?.querySelector('.koffka-slider') as HTMLInputElement;
    const koffkaLeftRing = koffkaContainer?.querySelector('.koffka-ring-left') as SVGElement;
    const koffkaRightRing = koffkaContainer?.querySelector('.koffka-ring-right') as SVGElement;
    const koffkaDivider = koffkaContainer?.querySelector('.koffka-divider') as SVGElement;
    const koffkaValText = koffkaContainer?.querySelector('.koffka-val');

    koffkaSlider?.addEventListener('input', (e) => {
      e.stopPropagation();
      const val = parseInt((e.target as HTMLInputElement).value);
      if (koffkaValText) koffkaValText.textContent = `${val}px`;
      if (koffkaLeftRing) koffkaLeftRing.style.transform = `translateX(${-val/2}px)`;
      if (koffkaRightRing) koffkaRightRing.style.transform = `translateX(${val/2}px)`;
      if (koffkaDivider) koffkaDivider.style.opacity = val > 0 ? '0' : '1';
    });

    // 12. Pinna-Brelstaff
    const pinnaContainer = document.getElementById('pinna-illusion');
    const pinnaRing1 = pinnaContainer?.querySelector('.pinna-ring-1') as SVGElement;
    const pinnaRing2 = pinnaContainer?.querySelector('.pinna-ring-2') as SVGElement;
    const pinnaBtn = pinnaContainer?.querySelector('.toggle-pinna-spin');
    let pinnaSpinning = false;

    pinnaBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      pinnaSpinning = !pinnaSpinning;
      if (pinnaRing1 && pinnaRing2) {
        if (pinnaSpinning) {
          pinnaRing1.style.animation = 'spin-clockwise calc(20s / var(--speed-multiplier, 1)) linear infinite';
          pinnaRing2.style.animation = 'spin-counter calc(25s / var(--speed-multiplier, 1)) linear infinite';
          if (pinnaBtn) pinnaBtn.textContent = 'Stop Spin';
        } else {
          pinnaRing1.style.animation = '';
          pinnaRing2.style.animation = '';
          if (pinnaBtn) pinnaBtn.textContent = 'Start Spin (Prove static same)';
        }
      }
    });
  </script>
