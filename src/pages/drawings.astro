      <!-- FAQ 1 -->
      <div class="border border-slate-800 rounded-2xl overflow-hidden bg-slate-900/40">
        <button class="faq-toggle w-full p-5 text-left font-bold text-white flex justify-between items-center hover:bg-slate-900 transition-colors">
          <span>How to draw optical illusions?</span>
