---
// src/pages/drawings.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="How to Draw Optical Illusions Step by Step | Optical Illusion Lab" 
  description="Learn how to draw optical illusions step by step with our free tutorials. Easy optical illusions to draw for beginners, kids, and advanced artists."
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-900 via-purple-950 to-slate-950 text-white border-b border-indigo-500/10 no-print">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(168,85,247,0.15),transparent_50%)]"></div>
    
    <div class="relative mx-auto max-w-4xl text-center space-y-6">
      <div class="inline-flex items-center space-x-2 rounded-full border border-purple-500/30 bg-purple-500/15 px-4 py-1.5 text-xs font-black uppercase tracking-wider text-purple-300 backdrop-blur-sm">
        ✏️ Step-by-Step Drawing Guide ✏️
      </div>
      <h1 class="font-display text-4xl sm:text-6xl font-black tracking-tight bg-gradient-to-r from-pink-400 via-purple-400 to-indigo-400 bg-clip-text text-transparent">
        How to Draw Optical Illusions — Step by Step
      </h1>
      <p class="mx-auto max-w-2xl text-lg sm:text-xl text-slate-200 font-medium leading-relaxed">
        Learn to draw 8 mind-bending optical illusions. No art skills needed — just a pencil and paper!
      </p>

      <!-- Intro Text -->
      <div class="mx-auto max-w-3xl text-sm sm:text-base text-slate-350 leading-relaxed bg-slate-950/40 p-6 rounded-2xl border border-indigo-500/10">
        <p>
          Welcome to the ultimate guide on <strong>how to draw optical illusions step by step</strong>! Visual tricks aren't just for computer screens — with a simple pencil, ruler, and paper, you can create mind-bending depth on a flat sheet. Whether you are searching for <strong>easy optical illusions to draw</strong> for kids or looking to master complex dimensional shading, these 8 hand-drawn guides make it simple. We cover the entire spectrum of <strong>optical illusions drawings</strong>: from impossible geometries like the Penrose triangle to tricks that play with motion. You will even learn <strong>how to draw moving optical illusions</strong> that seem to dance and tilt right off your notebook page. Grab your sketching materials and follow along to unlock the fascinating geometry of visual deception.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-wrap justify-center gap-4 pt-2">
        <button id="download-all-pdf" class="rounded-2xl bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 px-6 py-3 text-sm font-bold text-white shadow-lg hover:scale-102 transition-all">
          📄 Download All as PDF (Printable)
        </button>
        <a href="#tutorials-section" class="rounded-2xl border border-white/20 bg-white/5 hover:bg-white/10 px-6 py-3 text-sm font-bold text-slate-200 hover:text-white transition-all">
          Explore Tutorials 🖍️
        </a>
      </div>
    </div>
  </section>

  <!-- Filter & Subscription waitlist banner -->
  <section id="tutorials-section" class="py-8 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-8 no-print">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 bg-slate-900/40 border border-indigo-500/10 rounded-2xl p-6">
      <!-- Difficulty Filters -->
      <div class="space-y-2">
        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest block">Filter by Difficulty</span>
        <div class="flex flex-wrap gap-2" id="filter-buttons">
          <button class="filter-btn active px-4 py-2 text-xs font-bold rounded-xl bg-purple-600 text-white transition-colors" data-difficulty="all">All Levels</button>
          <button class="filter-btn px-4 py-2 text-xs font-bold rounded-xl bg-slate-800 text-slate-300 hover:bg-slate-750 transition-colors" data-difficulty="beginner">🟢 Beginner</button>
          <button class="filter-btn px-4 py-2 text-xs font-bold rounded-xl bg-slate-800 text-slate-300 hover:bg-slate-750 transition-colors" data-difficulty="intermediate">🟡 Intermediate</button>
          <button class="filter-btn px-4 py-2 text-xs font-bold rounded-xl bg-slate-800 text-slate-300 hover:bg-slate-750 transition-colors" data-difficulty="advanced">🔴 Advanced</button>
        </div>
      </div>

      <!-- Waitlist Form -->
      <div class="bg-indigo-950/20 border border-indigo-500/20 rounded-xl p-4 flex flex-col sm:flex-row sm:items-center gap-4 max-w-md w-full">
        <div class="flex-1 space-y-1">
          <div class="text-sm font-bold text-white flex items-center gap-2">
            🎬 Video Guides Waitlist
            <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500 animate-ping"></span>
          </div>
          <p class="text-xs text-slate-400">Join <span id="waitlist-counter-display" class="font-semibold text-purple-300">12,450</span> artists for video tutorials!</p>
        </div>
        <form id="waitlist-form" class="flex gap-2">
          <input 
            type="email" 
            required 
            placeholder="Your email" 
            class="px-3 py-1.5 text-xs bg-slate-950 border border-slate-750 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:border-purple-500 max-w-[160px]"
          />
          <button type="submit" class="px-3 py-1.5 text-xs font-bold bg-purple-600 hover:bg-purple-500 text-white rounded-lg transition-colors">Join</button>
        </form>
      </div>
    </div>
  </section>

  <!-- Tutorials Cards Grid -->
  <section class="py-8 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto no-print">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="tutorials-grid">

      <!-- ==================== TUTORIAL 1 ==================== -->
      <div class="tutorial-card bg-slate-900/60 border border-purple-500/20 rounded-3xl p-6 flex flex-col justify-between hover:translate-y-[-4px] hover:shadow-2xl transition-all duration-300 relative" 
           data-difficulty="beginner" 
           data-id="1"
           data-instructions='[
             "Step 1: Draw a large, simple outer triangle with equal sides using a ruler.",
             "Step 2: Add parallel inner lines inside each side of the triangle to establish the bar thickness.",
             "Step 3: Extend the lines at each corner to connect impossibly with the opposite inner bar edges.",
             "Step 4: Shade the faces: leave the top face light gray, shade the right side medium, and the bottom face dark.",
             "Step 5: Outline your lines in black marker and erase guidelines. Your impossible Penrose triangle is complete!"
           ]'>
        <div class="absolute top-4 right-4 bg-purple-600 text-white text-[10px] font-black uppercase px-2.5 py-1 rounded-full shadow-md tracking-wider">
          🔥 Most Popular
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">🟢 Beginner</span>
            <span class="text-xs text-slate-400">⏱️ 5 mins</span>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white mb-1">1. The Impossible Triangle</h2>
            <p class="text-xs text-slate-400">Master the famous Penrose Triangle that cannot exist in 3D space.</p>
          </div>

          <!-- Drawing Canvas -->
          <div class="flex items-center justify-center bg-slate-950/50 rounded-2xl p-4 border border-slate-800 aspect-square relative overflow-hidden group">
            <svg class="w-full h-full max-h-[220px]" viewBox="0 0 300 300">
              <!-- Grid background placeholder -->
              <g opacity="0.05">
                <path d="M 0,50 L 300,50 M 0,100 L 300,100 M 0,150 L 300,150 M 0,200 L 300,200 M 0,250 L 300,250" stroke="#a78bfa" stroke-width="1"/>
                <path d="M 50,0 L 50,300 M 100,0 L 100,300 M 150,0 L 150,300 M 200,0 L 200,300 M 250,0 L 250,300" stroke="#a78bfa" stroke-width="1"/>
              </g>
              
              <!-- STEP 1: Base Triangle -->
              <g class="step-group" data-step="1">
                <polygon points="150,45 260,235 40,235" class="stroke-indigo-400 fill-none" stroke-width="3" stroke-dasharray="1000" stroke-dashoffset="0"/>
              </g>
              <!-- STEP 2: Inner Parallel Lines -->
              <g class="step-group" data-step="2">
                <polygon points="150,90 220,210 80,210" class="stroke-purple-400 fill-none" stroke-width="2.5" stroke-dasharray="1000" stroke-dashoffset="0"/>
                <polygon points="150,135 180,185 120,185" class="stroke-purple-500 fill-none" stroke-width="1.5" stroke-dasharray="1000" stroke-dashoffset="0" opacity="0.6"/>
              </g>
              <!-- STEP 3: Impossible Corner joints -->
              <g class="step-group" data-step="3">
                <line x1="150" y1="45" x2="150" y2="90" class="stroke-indigo-300" stroke-width="3" />
                <line x1="260" y1="235" x2="220" y2="210" class="stroke-indigo-300" stroke-width="3" />
                <line x1="40" y1="235" x2="80" y2="210" class="stroke-indigo-300" stroke-width="3" />
                <path d="M 150,90 L 120,185 M 220,210 L 180,185 M 80,210 L 150,135" class="stroke-indigo-300" stroke-width="2" />
              </g>
              <!-- STEP 4: Face shading -->
              <g class="step-group" data-step="4">
                <!-- Face A (Light) -->
                <polygon points="150,45 150,90 120,185 80,210 40,235" class="fill-indigo-400/20 stroke-none" />
                <!-- Face B (Medium) -->
                <polygon points="150,45 260,235 220,210 180,185 150,90" class="fill-purple-500/30 stroke-none" />
                <!-- Face C (Dark) -->
                <polygon points="40,235 80,210 220,210 260,235" class="fill-indigo-900/60 stroke-none" />
              </g>
              <!-- STEP 5: Final Result (Thick black outlines and glows) -->
              <g class="step-group" data-step="5">
                <!-- Inner borders -->
                <path d="M 150,90 L 80,210 L 220,210 M 150,90 L 150,45 M 220,210 L 260,235 M 80,210 L 40,235" class="stroke-indigo-300 fill-none" stroke-width="3.5" />
                <!-- Outer borders -->
                <polygon points="150,45 260,235 40,235" class="stroke-purple-400 fill-none" stroke-width="4" />
              </g>
            </svg>
          </div>

          <!-- Step navigation -->
          <div class="space-y-4">
            <div class="flex items-center justify-between text-xs">
              <span class="step-counter font-bold text-purple-400">Step 1 of 5</span>
              <span class="text-slate-500">Materials: pencil, ruler, paper</span>
            </div>
            <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-3 min-h-[64px] flex items-center">
              <p class="step-instruction text-xs text-slate-350 leading-relaxed"></p>
            </div>
            <div class="flex gap-2">
              <button class="prev-btn flex-1 py-2 rounded-xl bg-slate-800 hover:bg-slate-750 disabled:opacity-30 text-xs font-bold text-white transition-colors">← Previous</button>
              <button class="next-btn flex-1 py-2 rounded-xl bg-purple-600 hover:bg-purple-500 disabled:opacity-30 text-xs font-bold text-white transition-colors">Next →</button>
            </div>
          </div>
        </div>

        <div class="border-t border-slate-850 mt-6 pt-4 flex items-center justify-between">
          <button class="print-tutorial-btn text-[11px] font-bold text-slate-400 hover:text-white flex items-center gap-1">
            🖨️ Print Tutorial
          </button>
          <button class="share-tutorial-btn text-[11px] font-bold text-purple-400 hover:text-purple-300 flex items-center gap-1">
            📤 Share Drawing
          </button>
        </div>
      </div>

      <!-- ==================== TUTORIAL 2 ==================== -->
      <div class="tutorial-card bg-slate-900/60 border border-purple-500/20 rounded-3xl p-6 flex flex-col justify-between hover:translate-y-[-4px] hover:shadow-2xl transition-all duration-300 relative" 
           data-difficulty="beginner" 
           data-id="2"
           data-instructions='[
             "Step 1: Sketch a flat, wide oval in the middle of your page using a light pencil.",
             "Step 2: Draw horizontal grid lines across the paper, stopping at the oval boundary and curving down sharply inside it.",
             "Step 3: Shade the center of the oval pitch black, gradually blending it outwards to form a dark radial gradient.",
             "Step 4: Draw tiny wrinkle folds and depth cracks around the oval edges to simulate paper tearing downward.",
             "Step 5: Deepen the shadow inside the hole and add light pencil highlights outside the rim to enhance the floating 3D illusion."
           ]'>
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">🟢 Beginner</span>
            <span class="text-xs text-slate-400">⏱️ 10 mins</span>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white mb-1">2. The 3D Hole in Paper</h2>
            <p class="text-xs text-slate-400">Create a realistic illusion of a deep chasm dropping through your page.</p>
          </div>

          <!-- Drawing Canvas -->
          <div class="flex items-center justify-center bg-slate-950/50 rounded-2xl p-4 border border-slate-800 aspect-square relative overflow-hidden">
            <svg class="w-full h-full max-h-[220px]" viewBox="0 0 300 300">
              <defs>
                <clipPath id="hole-clip">
                  <ellipse cx="150" cy="150" rx="80" ry="35" />
                </clipPath>
                <radialGradient id="hole-gradient" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#020617" />
                  <stop offset="60%" stop-color="#1e1b4b" />
                  <stop offset="100%" stop-color="#4338ca" stop-opacity="0.1" />
                </radialGradient>
              </defs>
              <!-- STEP 1: Center Oval -->
              <g class="step-group" data-step="1">
                <ellipse cx="150" cy="150" rx="80" ry="35" class="stroke-indigo-400 fill-none" stroke-width="2.5" />
              </g>
              <!-- STEP 2: Curved Grid Lines Inside -->
              <g class="step-group" data-step="2">
                <!-- Straight grid outside -->
                <path d="M 20,90 L 280,90 M 20,110 L 280,110 M 20,130 L 280,130 M 20,170 L 280,170 M 20,190 L 280,190 M 20,210 L 280,210" class="stroke-slate-700/40 fill-none" stroke-width="1.5" />
                <!-- Curved grid inside clip -->
                <g clip-path="url(#hole-clip)">
                  <path d="M 70,120 Q 150,165 230,120" class="stroke-indigo-400 fill-none" stroke-width="2" />
                  <path d="M 70,140 Q 150,185 230,140" class="stroke-indigo-400 fill-none" stroke-width="2" />
                  <path d="M 70,160 Q 150,205 230,160" class="stroke-indigo-400 fill-none" stroke-width="2" />
                  <!-- vertical lines bending down -->
                  <path d="M 90,115 Q 110,150 110,185" class="stroke-indigo-500 fill-none" stroke-width="1.5" />
                  <path d="M 120,115 Q 135,150 135,185" class="stroke-indigo-500 fill-none" stroke-width="1.5" />
                  <path d="M 150,115 Q 150,150 150,185" class="stroke-indigo-500 fill-none" stroke-width="1.5" />
                  <path d="M 180,115 Q 165,150 165,185" class="stroke-indigo-500 fill-none" stroke-width="1.5" />
                  <path d="M 210,115 Q 190,150 190,185" class="stroke-indigo-500 fill-none" stroke-width="1.5" />
                </g>
              </g>
              <!-- STEP 3: Dark Radial Gradient -->
              <g class="step-group" data-step="3">
                <ellipse cx="150" cy="150" rx="80" ry="35" fill="url(#hole-gradient)" opacity="0.85" />
              </g>
              <!-- STEP 4: Wrinkle / rim creases -->
              <g class="step-group" data-step="4">
                <path d="M 70,135 L 60,130 M 80,120 L 70,110 M 220,125 L 235,115 M 230,145 L 245,150 M 150,185 L 150,195 M 120,180 L 115,190" class="stroke-indigo-300 fill-none" stroke-width="2" />
              </g>
              <!-- STEP 5: Color shading and light highlights -->
              <g class="step-group" data-step="5">
                <!-- Outer shading overlay -->
                <ellipse cx="150" cy="155" rx="83" ry="38" class="stroke-indigo-500/30 fill-none" stroke-width="4" />
                <ellipse cx="150" cy="150" rx="77" ry="32" class="stroke-white/20 fill-none" stroke-width="2" />
              </g>
            </svg>
          </div>

          <!-- Step navigation -->
          <div class="space-y-4">
            <div class="flex items-center justify-between text-xs">
              <span class="step-counter font-bold text-purple-400">Step 1 of 5</span>
              <span class="text-slate-500">Materials: pencil, soft eraser</span>
            </div>
            <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-3 min-h-[64px] flex items-center">
              <p class="step-instruction text-xs text-slate-350 leading-relaxed"></p>
            </div>
            <div class="flex gap-2">
              <button class="prev-btn flex-1 py-2 rounded-xl bg-slate-800 hover:bg-slate-750 disabled:opacity-30 text-xs font-bold text-white transition-colors">← Previous</button>
              <button class="next-btn flex-1 py-2 rounded-xl bg-purple-600 hover:bg-purple-500 disabled:opacity-30 text-xs font-bold text-white transition-colors">Next →</button>
            </div>
          </div>
        </div>

        <div class="border-t border-slate-850 mt-6 pt-4 flex items-center justify-between">
          <button class="print-tutorial-btn text-[11px] font-bold text-slate-400 hover:text-white flex items-center gap-1">
            🖨️ Print Tutorial
          </button>
          <button class="share-tutorial-btn text-[11px] font-bold text-purple-400 hover:text-purple-300 flex items-center gap-1">
            📤 Share Drawing
          </button>
        </div>
      </div>

      <!-- ==================== TUTORIAL 3 ==================== -->
      <div class="tutorial-card bg-slate-900/60 border border-purple-500/20 rounded-3xl p-6 flex flex-col justify-between hover:translate-y-[-4px] hover:shadow-2xl transition-all duration-300 relative" 
           data-difficulty="beginner" 
           data-id="3"
           data-instructions='[
             "Step 1: Sketch a simple square in the left-center of your canvas.",
             "Step 2: Sketch an identical square offset slightly upward and to the right.",
             "Step 3: Connect each of the 4 corners of the first square to the corresponding corner of the second square with diagonal lines.",
             "Step 4: Use dashed lines (or erase guidelines) for the back-facing wires to make the wireframe structure easier to read.",
             "Step 5: Apply light shading to the top, front, and side faces of the cube to give it a solid 3D form that flips perspective."
           ]'>
        <div class="absolute top-4 right-4 bg-purple-600 text-white text-[10px] font-black uppercase px-2.5 py-1 rounded-full shadow-md tracking-wider">
          🔥 Most Popular
        </div>
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">🟢 Beginner</span>
            <span class="text-xs text-slate-400">⏱️ 5 mins</span>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white mb-1">3. The Necker Cube</h2>
            <p class="text-xs text-slate-400">Draw the classic wireframe cube that tricks your brain into shifting depth.</p>
          </div>

          <!-- Drawing Canvas -->
          <div class="flex items-center justify-center bg-slate-950/50 rounded-2xl p-4 border border-slate-800 aspect-square relative overflow-hidden">
            <svg class="w-full h-full max-h-[220px]" viewBox="0 0 300 300">
              <!-- STEP 1: Square 1 -->
              <g class="step-group" data-step="1">
                <rect x="70" y="100" width="110" height="110" class="stroke-indigo-400 fill-none" stroke-width="2.5" />
              </g>
              <!-- STEP 2: Square 2 -->
              <g class="step-group" data-step="2">
                <rect x="120" y="60" width="110" height="110" class="stroke-purple-400 fill-none" stroke-width="2.5" />
              </g>
              <!-- STEP 3: Connecting Corners -->
              <g class="step-group" data-step="3">
                <line x1="70" y1="100" x2="120" y2="60" class="stroke-indigo-300" stroke-width="2.5" />
                <line x1="180" y1="100" x2="230" y2="60" class="stroke-indigo-300" stroke-width="2.5" />
                <line x1="180" y1="210" x2="230" y2="170" class="stroke-indigo-300" stroke-width="2.5" />
                <line x1="70" y1="210" x2="120" y2="170" class="stroke-indigo-300" stroke-width="2.5" />
              </g>
              <!-- STEP 4: Wireframe effect -->
              <g class="step-group" data-step="4">
                <!-- Turn back-facing lines dashed -->
                <line x1="120" y1="60" x2="120" y2="170" class="stroke-slate-500" stroke-width="2.5" stroke-dasharray="4,4" />
                <line x1="120" y1="170" x2="230" y2="170" class="stroke-slate-500" stroke-width="2.5" stroke-dasharray="4,4" />
                <line x1="70" y1="210" x2="120" y2="170" class="stroke-slate-500" stroke-width="2.5" stroke-dasharray="4,4" />
              </g>
              <!-- STEP 5: Shade faces -->
              <g class="step-group" data-step="5">
                <!-- Top Face -->
                <polygon points="70,100 120,60 230,60 180,100" class="fill-indigo-400/20 stroke-none" />
                <!-- Side Face -->
                <polygon points="180,100 230,60 230,170 180,210" class="fill-purple-400/30 stroke-none" />
                <!-- Front Face -->
                <rect x="70" y="100" width="110" height="110" class="fill-indigo-300/10 stroke-indigo-400" stroke-width="3" />
              </g>
            </svg>
          </div>

          <!-- Step navigation -->
          <div class="space-y-4">
            <div class="flex items-center justify-between text-xs">
              <span class="step-counter font-bold text-purple-400">Step 1 of 5</span>
              <span class="text-slate-500">Materials: pencil, ruler</span>
            </div>
            <div class="bg-slate-950/60 border border-slate-800 rounded-xl p-3 min-h-[64px] flex items-center">
              <p class="step-instruction text-xs text-slate-350 leading-relaxed"></p>
            </div>
            <div class="flex gap-2">
              <button class="prev-btn flex-1 py-2 rounded-xl bg-slate-800 hover:bg-slate-750 disabled:opacity-30 text-xs font-bold text-white transition-colors">← Previous</button>
              <button class="next-btn flex-1 py-2 rounded-xl bg-purple-600 hover:bg-purple-500 disabled:opacity-30 text-xs font-bold text-white transition-colors">Next →</button>
            </div>
          </div>
        </div>

        <div class="border-t border-slate-850 mt-6 pt-4 flex items-center justify-between">
          <button class="print-tutorial-btn text-[11px] font-bold text-slate-400 hover:text-white flex items-center gap-1">
            🖨️ Print Tutorial
          </button>
          <button class="share-tutorial-btn text-[11px] font-bold text-purple-400 hover:text-purple-300 flex items-center gap-1">
            📤 Share Drawing
          </button>
        </div>
      </div>

      <!-- ==================== TUTORIAL 4 ==================== -->
      <div class="tutorial-card bg-slate-900/60 border border-purple-500/20 rounded-3xl p-6 flex flex-col justify-between hover:translate-y-[-4px] hover:shadow-2xl transition-all duration-300 relative" 
           data-difficulty="intermediate" 
           data-id="4"
           data-instructions='[
             "Step 1: Sketch light guide lines at 30-degree angles to establish an isometric grid system.",
             "Step 2: Draw the horizontal tread and vertical rise of the first stair block in isometric view.",
             "Step 3: Draw three ascending steps rising clockwise, following the isometric coordinate layout.",
             "Step 4: Connect the top stair back to the first step impossibly, defying gravity and logic.",
             "Step 5: Shade top surfaces light gray, left sides medium, and right risers dark to lock in the endless staircase illusion."
           ]'>
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">🟡 Intermediate</span>
            <span class="text-xs text-slate-400">⏱️ 15 mins</span>
          </div>
          <div>
            <h2 class="text-xl font-bold text-white mb-1">4. The Infinite Staircase</h2>
