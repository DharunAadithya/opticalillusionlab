  <!-- JavaScript logic -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      
      // 1. Interactive Step-by-Step Navigation
      const cards = document.querySelectorAll('.tutorial-card');
      
      cards.forEach(card => {
        const id = card.dataset.id;
        const steps = card.querySelectorAll('.step-group');
        const prevBtn = card.querySelector('.prev-btn');
        const nextBtn = card.querySelector('.next-btn');
        const counterEl = card.querySelector('.step-counter');
        const instructionEl = card.querySelector('.step-instruction');
        const instructions = JSON.parse(card.dataset.instructions || '[]');
        
        let currentStep = 1;
        const totalSteps = steps.length;
        
        function updateStep() {
          steps.forEach((group, idx) => {
            const stepNum = idx + 1;
            if (stepNum <= currentStep) {
              group.style.display = 'block';
              
              // Animate paths inside the newly selected step
              if (stepNum === currentStep) {
                const paths = group.querySelectorAll('path, line, circle, ellipse, rect, polygon, polyline');
                paths.forEach(path => {
                  const length = path.getTotalLength ? path.getTotalLength() : 600;
                  path.style.strokeDasharray = length;
                  path.style.strokeDashoffset = length;
                  path.getBoundingClientRect(); // reflow
                  path.style.transition = 'stroke-dashoffset 1.2s ease-in-out';
                  path.style.strokeDashoffset = '0';
                });
              } else {
                // Keep older steps solid/drawn
                const paths = group.querySelectorAll('path, line, circle, ellipse, rect, polygon, polyline');
                paths.forEach(path => {
                  path.style.strokeDasharray = '';
                  path.style.strokeDashoffset = '';
                  path.style.transition = '';
                });
              }
            } else {
              group.style.display = 'none';
            }
          });
          
          if (instructionEl && instructions[currentStep - 1]) {
            instructionEl.textContent = instructions[currentStep - 1];
          }
          if (counterEl) {
            counterEl.textContent = `Step ${currentStep} of ${totalSteps}`;
          }
          
          prevBtn.disabled = currentStep === 1;
          nextBtn.disabled = currentStep === totalSteps;
        }
        
        prevBtn.addEventListener('click', () => {
          if (currentStep > 1) {
            currentStep--;
            updateStep();
          }
        });
        
        nextBtn.addEventListener('click', () => {
          if (currentStep < totalSteps) {
            currentStep++;
            updateStep();
          }
        });
        
        // Init
        updateStep();
      });

      // 2. Difficulty Filter Logic
      const filterButtons = document.querySelectorAll('#filter-buttons button');
      const tutorialCards = document.querySelectorAll('.tutorial-card');
      
      filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const diff = btn.dataset.difficulty;
          
          // Toggle active visual states
          filterButtons.forEach(b => {
            b.classList.remove('active', 'bg-purple-600', 'text-white');
            b.classList.add('bg-slate-800', 'text-slate-300');
          });
          btn.classList.add('active', 'bg-purple-600', 'text-white');
          btn.classList.remove('bg-slate-800', 'text-slate-300');
          
          // Hide/Show cards
          tutorialCards.forEach(card => {
            if (diff === 'all' || card.dataset.difficulty === diff) {
              card.style.display = 'flex';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });

      // 3. Print Tutorial Functionality (Clipped Print Booklet Layout)
      function printSingleTutorial(cardEl) {
        const title = cardEl.querySelector('h2').textContent;
        const steps = cardEl.querySelectorAll('.step-group');
        const instructions = JSON.parse(cardEl.dataset.instructions || '[]');
        const svgElement = cardEl.querySelector('svg');
        const printContainer = document.getElementById('print-container');
        
        let html = `
          <div style="font-family: sans-serif; padding: 20px; max-width: 800px; margin: 0 auto; color: black; background: white;">
            <h1 style="font-size: 24px; font-weight: bold; border-bottom: 2px solid #000; padding-bottom: 8px; margin-bottom: 20px;">
              How to Draw: ${title} — Step-by-Step Drawing Guide
            </h1>
            <p style="font-size: 13px; margin-bottom: 24px;">Follow each step sequentially. Use a light pencil for guidelines, then darken outer borders and apply shading.</p>
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px;">
        `;
        
        steps.forEach((step, idx) => {
          const svgClone = svgElement.cloneNode(true);
          // Set black stroke for clean visibility on paper
          svgClone.style.color = '#000000';
          const paths = svgClone.querySelectorAll('path, line, circle, ellipse, rect, polygon, polyline');
          paths.forEach(p => {
            p.style.stroke = '#000000';
            p.style.strokeWidth = p.style.strokeWidth || '2px';
            if (p.classList.contains('fill-none') === false && p.getAttribute('fill') !== 'none') {
              p.style.fill = p.getAttribute('fill') ? p.getAttribute('fill').replace('indigo-400/20', '#cccccc').replace('purple-500/30', '#aaaaaa').replace('indigo-900/60', '#555555') : '#cccccc';
            }
          });
          
          // Make sure step-groups are shown appropriately in the printed clones
          const clonedGroups = svgClone.querySelectorAll('.step-group');
          clonedGroups.forEach((g, gIdx) => {
            if (gIdx <= idx) {
              g.style.display = 'block';
            } else {
              g.style.display = 'none';
            }
          });
          
          html += `
            <div style="border: 1px solid #ddd; padding: 15px; border-radius: 8px; display: flex; flex-direction: column; align-items: center; background: #fff;">
              <h3 style="margin-top: 0; margin-bottom: 10px; font-size: 16px; border-bottom: 1px solid #eee; width: 100%; text-align: center; padding-bottom: 4px;">Step ${idx + 1}</h3>
              <div style="width: 180px; height: 180px; display: flex; items-center: center; justify-content: center; margin-bottom: 10px;">
                ${svgClone.outerHTML}
              </div>
              <p style="font-size: 12px; line-height: 1.4; text-align: center; margin: 0;">${instructions[idx] || ''}</p>
            </div>
          `;
        });
        
        html += `
            </div>
            <div style="margin-top: 40px; font-size: 10px; text-align: center; color: #666; border-top: 1px solid #eee; padding-top: 10px;">
              Printed from Optical Illusion Lab — Your guide to visual brain science.
            </div>
          </div>
        `;
        
        printContainer.innerHTML = html;
        window.print();
      }

      // Hook print buttons
      document.querySelectorAll('.print-tutorial-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const card = e.target.closest('.tutorial-card');
          printSingleTutorial(card);
        });
      });

      // Print ALL button
      document.getElementById('download-all-pdf').addEventListener('click', () => {
        const printContainer = document.getElementById('print-container');
        let html = `
          <div style="font-family: sans-serif; padding: 20px; color: black; background: white;">
            <h1 style="font-size: 28px; font-weight: bold; border-bottom: 3px solid #000; padding-bottom: 10px; text-align: center; margin-bottom: 30px;">
              Optical Illusion Drawing Booklet — Step-by-Step
            </h1>
            <p style="text-align: center; font-size: 14px; margin-bottom: 40px;">Learn to sketch 8 mind-bending illusions. Complete grid systems and depth guides inside.</p>
        `;
        
        document.querySelectorAll('.tutorial-card').forEach((card, cIdx) => {
          const title = card.querySelector('h2').textContent;
          const steps = card.querySelectorAll('.step-group');
          const instructions = JSON.parse(card.dataset.instructions || '[]');
          const svgElement = card.querySelector('svg');
          
          html += `
            <div style="page-break-after: always; margin-bottom: 50px;">
              <h2 style="font-size: 20px; border-bottom: 1.5px solid #333; padding-bottom: 6px; margin-bottom: 16px;">
                ${title}
              </h2>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px;">
          `;
          
          steps.forEach((step, idx) => {
            const svgClone = svgElement.cloneNode(true);
            svgClone.style.color = '#000000';
            const paths = svgClone.querySelectorAll('path, line, circle, ellipse, rect, polygon, polyline');
            paths.forEach(p => {
              p.style.stroke = '#000000';
              p.style.strokeWidth = p.style.strokeWidth || '2px';
              if (p.classList.contains('fill-none') === false && p.getAttribute('fill') !== 'none') {
                p.style.fill = p.getAttribute('fill') ? p.getAttribute('fill').replace('indigo-400/20', '#cccccc').replace('purple-500/30', '#aaaaaa').replace('indigo-900/60', '#555555') : '#cccccc';
              }
            });
            
            const clonedGroups = svgClone.querySelectorAll('.step-group');
            clonedGroups.forEach((g, gIdx) => {
              if (gIdx <= idx) {
                g.style.display = 'block';
