                g.style.display = 'none';
              }
            });
            
            html += `
              <div style="border: 1px solid #ddd; padding: 12px; border-radius: 6px; display: flex; flex-direction: column; align-items: center; background: #fff;">
                <h4 style="margin-top: 0; margin-bottom: 6px; font-size: 13px;">Step ${idx + 1}</h4>
                <div style="width: 140px; height: 140px; display: flex; items-center: center; justify-content: center; margin-bottom: 6px;">
                  ${svgClone.outerHTML}
                </div>
                <p style="font-size: 11px; line-height: 1.3; text-align: center; margin: 0;">${instructions[idx] || ''}</p>
              </div>
            `;
          });
          
          html += `
              </div>
            </div>
          `;
        });
        
        html += `
            <div style="text-align: center; font-size: 10px; color: #888; border-top: 1px solid #ddd; padding-top: 20px;">
              Optical Illusion Lab Booklet. Use Ctrl+P / Cmd+P to save as PDF.
            </div>
          </div>
        `;
        
        printContainer.innerHTML = html;
        window.print();
      });

      // 4. Waitlist subscription forms
      function initWaitlist() {
        const seedValue = localStorage.getItem('drawings_waitlist_count');
        let currentCount = seedValue ? parseInt(seedValue) : 12450;
        
        const displays = [
          document.getElementById('waitlist-counter-display'),
          document.getElementById('waitlist-display-large')
        ];
        
        function updateWaitlistCount() {
          displays.forEach(d => {
            if (d) d.textContent = currentCount.toLocaleString();
          });
        }
        
        updateWaitlistCount();
        
        const form1 = document.getElementById('waitlist-form');
        const form2 = document.getElementById('video-waitlist-btn')?.closest('div');
        const emailInput2 = document.getElementById('video-waitlist-email');
        
        function handleSubscribe(email) {
          if (!email) return;
          
          // Save to list
          const existing = JSON.parse(localStorage.getItem('drawings_waitlist_emails') || '[]');
          if (!existing.includes(email)) {
            existing.push(email);
            localStorage.setItem('drawings_waitlist_emails', JSON.stringify(existing));
            
            // Increment subscriber count
            currentCount++;
            localStorage.setItem('drawings_waitlist_count', currentCount.toString());
            updateWaitlistCount();
          }
          
          // Toast or Alert
          alert('🚀 Thank you! You have been successfully added to the optical drawings video waitlist.');
        }
        
        if (form1) {
          form1.addEventListener('submit', (e) => {
            e.preventDefault();
            const input = form1.querySelector('input');
            handleSubscribe(input.value);
            input.value = '';
          });
        }
        
        if (form2 && emailInput2) {
          document.getElementById('video-waitlist-btn').addEventListener('click', () => {
            if (emailInput2.reportValidity()) {
              handleSubscribe(emailInput2.value);
              emailInput2.value = '';
            }
          });
        }
      }
      
      initWaitlist();

      // 5. Share Drawing link copy
      document.querySelectorAll('.share-tutorial-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const card = e.target.closest('.tutorial-card');
          const title = card.querySelector('h2').textContent;
          const url = `${window.location.origin}${window.location.pathname}#tutorials-section`;
          
          navigator.clipboard.writeText(`Check out how to draw "${title}" step-by-step at: ${url}`).then(() => {
            alert(`🔗 Share link for "${title}" copied to clipboard!`);
          }).catch(err => {
            console.error('Failed to copy', err);
          });
        });
      });

      // 6. FAQ Accordion Toggle
      const faqToggles = document.querySelectorAll('.faq-toggle');
      faqToggles.forEach(toggle => {
        toggle.addEventListener('click', () => {
          const content = toggle.nextElementSibling;
          const icon = toggle.querySelector('.faq-icon');
          
          content.classList.toggle('hidden');
          if (content.classList.contains('hidden')) {
            icon.style.transform = 'rotate(0deg)';
          } else {
            icon.style.transform = 'rotate(180deg)';
          }
        });
      });

    });
  </script>

