  <!-- How to Use Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto border-t border-slate-800 text-center space-y-8">
    <h3 class="font-display text-2xl sm:text-3xl font-bold text-white">How to Create Optical Illusions Online</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
      <div class="bg-slate-950/40 border border-slate-850 rounded-2xl p-6 space-y-3">
        <div class="h-10 w-10 rounded-xl bg-purple-600/20 text-purple-400 flex items-center justify-center font-black">1</div>
        <h4 class="font-bold text-white">Choose Your Illusion</h4>
        <p class="text-xs text-slate-400">Select one of our four classic modules from the top tabs: Café Wall, Hermann Grid, Rotating Rings, or Stripes.</p>
      </div>

      <div class="bg-slate-950/40 border border-slate-850 rounded-2xl p-6 space-y-3">
        <div class="h-10 w-10 rounded-xl bg-purple-600/20 text-purple-400 flex items-center justify-center font-black">2</div>
        <h4 class="font-bold text-white">Adjust the Sliders</h4>
        <p class="text-xs text-slate-400">Fine-tune spacing, colors, gaps, or animation speed. Each change updates the live preview instantly.</p>
      </div>

      <div class="bg-slate-950/40 border border-slate-850 rounded-2xl p-6 space-y-3">
        <div class="h-10 w-10 rounded-xl bg-purple-600/20 text-purple-400 flex items-center justify-center font-black">3</div>
        <h4 class="font-bold text-white">Export & Share</h4>
        <p class="text-xs text-slate-400">Download a high-resolution PNG file to print out, or generate a unique shareable link containing your settings.</p>
      </div>
    </div>
  </section>

  <!-- Client-side Logic Script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {

      // Centralized configuration state
      let config = {
        activeTab: 'cafe',
        cafe: {
          rows: 10,
          cols: 10,
          offset: 50,
          tileColor1: '#000000',
          tileColor2: '#ffffff',
          groutColor: '#808080',
          groutThickness: 3,
          rowHeight: 30
        },
        hermann: {
          gridSize: 8,
          squareSize: 38,
          gapSize: 8,
          squareColor: '#000000',
          backgroundColor: '#ffffff',
          coloredMode: false
        },
        rings: {
          ringsCount: 4,
          segmentsCount: 16,
          colorA: '#eab308',
          colorB: '#06b6d4',
          spacing: 20,
          chevronAngle: 30,
          speed: 0
        },
        stripes: {
          linesCount: 10,
          lineColor: '#ec4899',
          backgroundColor: '#0f172a',
          dashPattern: 12,
          dashAngle: 30,
          alternating: true,
          thickness: 3
        }
      };

      // Select DOM Elements
      const svgEl = document.getElementById('generator-svg');
      const tabs = document.querySelectorAll('#generator-tabs button');
      const controlContainers = document.querySelectorAll('.generator-controls');

      // 1. RENDERERS

      // Café Wall
      function renderCafeWall(svg, params) {
        const { rows, cols, offset, tileColor1, tileColor2, groutColor, groutThickness, rowHeight } = params;
        let html = '';
        html += `
          <defs>
            <clipPath id="cafe-clip">
              <rect x="0" y="0" width="400" height="400" rx="16" />
            </clipPath>
          </defs>
          <g clip-path="url(#cafe-clip)">
            <rect x="0" y="0" width="400" height="400" fill="${groutColor}" />
        `;

        const totalHeight = rows * rowHeight;
        const startY = (400 - totalHeight) / 2;
        const tileWidth = (400 / cols) * 1.5;

        for (let r = 0; r < rows; r++) {
          const y = startY + r * rowHeight;
          const isShifted = r % 2 === 1;
          const shiftPercent = isShifted ? (offset / 100) : 0;
          const shiftX = -tileWidth + (shiftPercent * tileWidth);

          html += `<g transform="translate(0, ${y})">`;
          for (let c = 0; c < cols * 2; c++) {
            const x = shiftX + c * tileWidth;
            const fillColor = c % 2 === 0 ? tileColor1 : tileColor2;
            html += `<rect x="${x}" y="0" width="${tileWidth - groutThickness/2}" height="${rowHeight - groutThickness}" fill="${fillColor}" />`;
          }
          html += `</g>`;

          if (r < rows - 1) {
            html += `<line x1="0" y1="${y + rowHeight - groutThickness/2}" x2="400" y2="${y + rowHeight - groutThickness/2}" stroke="${groutColor}" stroke-width="${groutThickness}" />`;
          }
        }
        html += `</g>`;
        svg.innerHTML = html;
      }

      // Hermann Grid
      function renderHermannGrid(svg, params) {
        const { gridSize, squareSize, gapSize, squareColor, backgroundColor, coloredMode } = params;
        let html = '';
        html += `
          <defs>
            <clipPath id="hermann-clip">
              <rect x="0" y="0" width="400" height="400" rx="16" />
            </clipPath>
          </defs>
          <g clip-path="url(#hermann-clip)">
            <rect x="0" y="0" width="400" height="400" fill="${backgroundColor}" />
        `;

        const gridWidth = (gridSize * squareSize) + ((gridSize - 1) * gapSize);
        const startX = (400 - gridWidth) / 2;
        const startY = (400 - gridWidth) / 2;
        const colors = ["#f87171", "#fb923c", "#facc15", "#4ade80", "#60a5fa", "#c084fc", "#f472b6"];

        for (let r = 0; r < gridSize; r++) {
          for (let c = 0; c < gridSize; c++) {
            const x = startX + c * (squareSize + gapSize);
            const y = startY + r * (squareSize + gapSize);
            const color = coloredMode ? colors[(r + c) % colors.length] : squareColor;

            html += `<rect x="${x}" y="${y}" width="${squareSize}" height="${squareSize}" fill="${color}" />`;
          }
        }
        html += `</g>`;
        svg.innerHTML = html;
      }

      // Rotating Rings
      function renderRotatingRings(svg, params) {
        const { ringsCount, segmentsCount, colorA, colorB, spacing, chevronAngle, speed } = params;
        let html = '';
        html += `
          <defs>
            <clipPath id="rings-clip">
              <rect x="0" y="0" width="400" height="400" rx="16" />
            </clipPath>
            <style>
              @keyframes rot-cw {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
              }
              @keyframes rot-ccw {
                from { transform: rotate(0deg); }
                to { transform: rotate(-360deg); }
              }
            </style>
          </defs>
          <g clip-path="url(#rings-clip)">
            <rect x="0" y="0" width="400" height="400" fill="#0f172a" />
        `;

        for (let r = 0; r < ringsCount; r++) {
          const radius = 50 + (r * spacing);
          const isEven = r % 2 === 0;
          const animName = isEven ? 'rot-cw' : 'rot-ccw';
          const duration = speed > 0 ? (35 / (speed * (r + 1) * 0.4)) : 0;
          
          let animStyle = '';
          if (speed > 0) {
            animStyle = `style="animation: ${animName} ${duration}s linear infinite; transform-origin: 200px 200px;"`;
          }

          html += `<g ${animStyle}>`;
          const W = spacing * 0.9;
          const H = spacing * 0.5;

          for (let s = 0; s < segmentsCount; s++) {
            const theta = (2 * Math.PI * s) / segmentsCount;
            const x = 200 + radius * Math.cos(theta);
            const y = 200 + radius * Math.sin(theta);
            
            const radialAngleDeg = (theta * 180) / Math.PI;
            const tilt = isEven ? chevronAngle : -chevronAngle;
            const angle = radialAngleDeg + tilt;

            let fill = colorA;
            let stroke = '#000000';
            const phase = s % 4;
            if (phase === 1) {
              fill = '#000000';
              stroke = colorB;
            } else if (phase === 2) {
              fill = colorB;
              stroke = '#ffffff';
            } else if (phase === 3) {
              fill = '#ffffff';
              stroke = colorA;
            }

            html += `
              <g transform="translate(${x}, ${y}) rotate(${angle})">
                <polygon points="${-W/2},${-H/2} ${W/2},0 ${-W/2},${H/2} ${-W/3},0" fill="${fill}" stroke="${stroke}" stroke-width="1.2" />
              </g>
            `;
          }
          html += `</g>`;
        }
        html += `</g>`;
        svg.innerHTML = html;
      }

      // Stripes
      function renderStripes(svg, params) {
        const { linesCount, lineColor, backgroundColor, dashPattern, dashAngle, alternating, thickness } = params;
        let html = '';
        html += `
          <defs>
            <clipPath id="stripes-clip">
              <rect x="0" y="0" width="400" height="400" rx="16" />
            </clipPath>
          </defs>
          <g clip-path="url(#stripes-clip)">
            <rect x="0" y="0" width="400" height="400" fill="${backgroundColor}" />
        `;

        const totalHeight = 360;
        const startY = 20;
        const spacing = totalHeight / (linesCount - 1 || 1);

        for (let l = 0; l < linesCount; l++) {
          const y = startY + l * spacing;
          html += `<line x1="20" y1="${y}" x2="380" y2="${y}" stroke="${lineColor}" stroke-width="${thickness}" stroke-linecap="round" />`;

          const angleRad = (dashAngle * Math.PI) / 180;
          const isEven = l % 2 === 0;
          const activeAngleRad = (alternating && isEven) ? -angleRad : angleRad;

          const dashLen = 14;
          const dx = dashLen * Math.sin(activeAngleRad);
          const dy = dashLen * Math.cos(activeAngleRad);

          const stepX = 360 / (dashPattern + 1);
          for (let d = 0; d < dashPattern; d++) {
            const cx = 20 + (d + 1) * stepX;
            const x1 = cx - dx / 2;
            const y1 = y - dy / 2;
            const x2 = cx + dx / 2;
            const y2 = y + dy / 2;

            html += `<line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${lineColor}" stroke-width="${thickness * 0.75}" stroke-linecap="round" opacity="0.85" />`;
          }
        }
        html += `</g>`;
        svg.innerHTML = html;
      }

      // 2. DISPATCH RENDER
      function renderActiveGenerator() {
        const tab = config.activeTab;
        if (tab === 'cafe') {
          renderCafeWall(svgEl, config.cafe);
        } else if (tab === 'hermann') {
          renderHermannGrid(svgEl, config.hermann);
        } else if (tab === 'rings') {
          renderRotatingRings(svgEl, config.rings);
        } else if (tab === 'stripes') {
          renderStripes(svgEl, config.stripes);
        }
      }

      // 3. EVENT HANDLERS & BINDINGS
      function bindInputs() {
        // Cafe Inputs
        document.getElementById('cafe-rows').addEventListener('input', (e) => {
          config.cafe.rows = parseInt(e.target.value);
          document.getElementById('cafe-rows-val').textContent = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('cafe-cols').addEventListener('input', (e) => {
          config.cafe.cols = parseInt(e.target.value);
          document.getElementById('cafe-cols-val').textContent = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('cafe-offset').addEventListener('input', (e) => {
          config.cafe.offset = parseInt(e.target.value);
          document.getElementById('cafe-offset-val').textContent = e.target.value + '%';
          renderActiveGenerator();
        });
        document.getElementById('cafe-thickness').addEventListener('input', (e) => {
          config.cafe.groutThickness = parseInt(e.target.value);
          document.getElementById('cafe-thickness-val').textContent = e.target.value + 'px';
          renderActiveGenerator();
        });
        document.getElementById('cafe-height').addEventListener('input', (e) => {
          config.cafe.rowHeight = parseInt(e.target.value);
          document.getElementById('cafe-height-val').textContent = e.target.value + 'px';
          renderActiveGenerator();
        });
        document.getElementById('cafe-color1').addEventListener('input', (e) => {
          config.cafe.tileColor1 = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('cafe-color2').addEventListener('input', (e) => {
          config.cafe.tileColor2 = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('cafe-grout').addEventListener('input', (e) => {
          config.cafe.groutColor = e.target.value;
          renderActiveGenerator();
        });

        // Hermann Inputs
        document.getElementById('hermann-grid').addEventListener('input', (e) => {
          config.hermann.gridSize = parseInt(e.target.value);
          document.getElementById('hermann-grid-val').textContent = `${e.target.value} x ${e.target.value}`;
          renderActiveGenerator();
        });
        document.getElementById('hermann-size').addEventListener('input', (e) => {
          config.hermann.squareSize = parseInt(e.target.value);
          document.getElementById('hermann-size-val').textContent = e.target.value + 'px';
          renderActiveGenerator();
        });
        document.getElementById('hermann-gap').addEventListener('input', (e) => {
          config.hermann.gapSize = parseInt(e.target.value);
          document.getElementById('hermann-gap-val').textContent = e.target.value + 'px';
          renderActiveGenerator();
        });
        document.getElementById('hermann-color').addEventListener('input', (e) => {
          config.hermann.squareColor = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('hermann-bg').addEventListener('input', (e) => {
          config.hermann.backgroundColor = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('hermann-colored').addEventListener('change', (e) => {
          config.hermann.coloredMode = e.target.checked;
          renderActiveGenerator();
        });

        // Rings Inputs
        document.getElementById('rings-count').addEventListener('input', (e) => {
          config.rings.ringsCount = parseInt(e.target.value);
          document.getElementById('rings-count-val').textContent = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('rings-segments').addEventListener('input', (e) => {
          config.rings.segmentsCount = parseInt(e.target.value);
          document.getElementById('rings-segments-val').textContent = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('rings-spacing').addEventListener('input', (e) => {
          config.rings.spacing = parseInt(e.target.value);
          document.getElementById('rings-spacing-val').textContent = e.target.value + 'px';
          renderActiveGenerator();
        });
        document.getElementById('rings-angle').addEventListener('input', (e) => {
          config.rings.chevronAngle = parseInt(e.target.value);
          document.getElementById('rings-angle-val').textContent = e.target.value + '°';
          renderActiveGenerator();
        });
        document.getElementById('rings-speed').addEventListener('input', (e) => {
          config.rings.speed = parseFloat(e.target.value);
          document.getElementById('rings-speed-val').textContent = config.rings.speed === 0 ? '0 (Static)' : config.rings.speed;
          renderActiveGenerator();
        });
        document.getElementById('rings-colorA').addEventListener('input', (e) => {
          config.rings.colorA = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('rings-colorB').addEventListener('input', (e) => {
          config.rings.colorB = e.target.value;
          renderActiveGenerator();
        });

        // Stripes Inputs
        document.getElementById('stripes-count').addEventListener('input', (e) => {
          config.stripes.linesCount = parseInt(e.target.value);
          document.getElementById('stripes-count-val').textContent = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('stripes-pattern').addEventListener('input', (e) => {
          config.stripes.dashPattern = parseInt(e.target.value);
          document.getElementById('stripes-pattern-val').textContent = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('stripes-angle').addEventListener('input', (e) => {
          config.stripes.dashAngle = parseInt(e.target.value);
          document.getElementById('stripes-angle-val').textContent = e.target.value + '°';
          renderActiveGenerator();
        });
        document.getElementById('stripes-thickness').addEventListener('input', (e) => {
          config.stripes.thickness = parseInt(e.target.value);
          document.getElementById('stripes-thickness-val').textContent = e.target.value + 'px';
          renderActiveGenerator();
        });
        document.getElementById('stripes-lineColor').addEventListener('input', (e) => {
          config.stripes.lineColor = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('stripes-bg').addEventListener('input', (e) => {
          config.stripes.backgroundColor = e.target.value;
          renderActiveGenerator();
        });
        document.getElementById('stripes-alternating').addEventListener('change', (e) => {
          config.stripes.alternating = e.target.checked;
          renderActiveGenerator();
        });
      }

      // Sync DOM controls to current config state
      function syncDOMFromConfig() {
        // Tab styling
        tabs.forEach(t => {
          if (t.dataset.tab === config.activeTab) {
            t.classList.add('border-purple-500', 'text-purple-400');
            t.classList.remove('border-transparent', 'text-slate-400');
          } else {
            t.classList.remove('border-purple-500', 'text-purple-400');
            t.classList.add('border-transparent', 'text-slate-400');
          }
        });

        // Hide/Show Controls panels
        controlContainers.forEach(container => {
          if (container.dataset.tab === config.activeTab) {
            container.classList.remove('hidden');
          } else {
            container.classList.add('hidden');
          }
        });

        // Cafe
        document.getElementById('cafe-rows').value = config.cafe.rows;
        document.getElementById('cafe-rows-val').textContent = config.cafe.rows;
        document.getElementById('cafe-cols').value = config.cafe.cols;
        document.getElementById('cafe-cols-val').textContent = config.cafe.cols;
        document.getElementById('cafe-offset').value = config.cafe.offset;
        document.getElementById('cafe-offset-val').textContent = config.cafe.offset + '%';
        document.getElementById('cafe-thickness').value = config.cafe.groutThickness;
        document.getElementById('cafe-thickness-val').textContent = config.cafe.groutThickness + 'px';
        document.getElementById('cafe-height').value = config.cafe.rowHeight;
        document.getElementById('cafe-height-val').textContent = config.cafe.rowHeight + 'px';
        document.getElementById('cafe-color1').value = config.cafe.tileColor1;
        document.getElementById('cafe-color2').value = config.cafe.tileColor2;
        document.getElementById('cafe-grout').value = config.cafe.groutColor;

        // Hermann
        document.getElementById('hermann-grid').value = config.hermann.gridSize;
        document.getElementById('hermann-grid-val').textContent = `${config.hermann.gridSize} x ${config.hermann.gridSize}`;
        document.getElementById('hermann-size').value = config.hermann.squareSize;
        document.getElementById('hermann-size-val').textContent = config.hermann.squareSize + 'px';
        document.getElementById('hermann-gap').value = config.hermann.gapSize;
        document.getElementById('hermann-gap-val').textContent = config.hermann.gapSize + 'px';
        document.getElementById('hermann-color').value = config.hermann.squareColor;
        document.getElementById('hermann-bg').value = config.hermann.backgroundColor;
        document.getElementById('hermann-colored').checked = config.hermann.coloredMode;

        // Rings
        document.getElementById('rings-count').value = config.rings.ringsCount;
        document.getElementById('rings-count-val').textContent = config.rings.ringsCount;
        document.getElementById('rings-segments').value = config.rings.segmentsCount;
        document.getElementById('rings-segments-val').textContent = config.rings.segmentsCount;
        document.getElementById('rings-spacing').value = config.rings.spacing;
        document.getElementById('rings-spacing-val').textContent = config.rings.spacing + 'px';
        document.getElementById('rings-angle').value = config.rings.chevronAngle;
        document.getElementById('rings-angle-val').textContent = config.rings.chevronAngle + '°';
        document.getElementById('rings-speed').value = config.rings.speed;
        document.getElementById('rings-speed-val').textContent = config.rings.speed === 0 ? '0 (Static)' : config.rings.speed;
        document.getElementById('rings-colorA').value = config.rings.colorA;
        document.getElementById('rings-colorB').value = config.rings.colorB;

        // Stripes
        document.getElementById('stripes-count').value = config.stripes.linesCount;
        document.getElementById('stripes-count-val').textContent = config.stripes.linesCount;
        document.getElementById('stripes-pattern').value = config.stripes.dashPattern;
        document.getElementById('stripes-pattern-val').textContent = config.stripes.dashPattern;
        document.getElementById('stripes-angle').value = config.stripes.dashAngle;
        document.getElementById('stripes-angle-val').textContent = config.stripes.dashAngle + '°';
        document.getElementById('stripes-thickness').value = config.stripes.thickness;
        document.getElementById('stripes-thickness-val').textContent = config.stripes.thickness + 'px';
        document.getElementById('stripes-lineColor').value = config.stripes.lineColor;
        document.getElementById('stripes-bg').value = config.stripes.backgroundColor;
        document.getElementById('stripes-alternating').checked = config.stripes.alternating;
      }

      // 4. ACTION BUTTONS: Download, Share, Reset

      // Download PNG via Canvas API
      function downloadPNG() {
        const svgString = new XMLSerializer().serializeToString(svgEl);
        // Include SVG namespace headers to prevent canvas drawing failures
        const cleanSvgString = svgString.includes('xmlns') ? svgString : svgString.replace('<svg', '<svg xmlns="http://www.w3.org/2000/svg"');
        const svgBlob = new Blob([cleanSvgString], { type: 'image/svg+xml;charset=utf-8' });
        const URL = window.URL || window.webkitURL || window;
        const blobURL = URL.createObjectURL(svgBlob);
        
        const image = new Image();
        image.onload = () => {
          const canvas = document.createElement('canvas');
          canvas.width = 800; // High quality output
          canvas.height = 800;
          const context = canvas.getContext('2d');
          context.fillStyle = config.activeTab === 'rings' ? '#0f172a' : (config.activeTab === 'hermann' ? config.hermann.backgroundColor : (config.activeTab === 'stripes' ? config.stripes.backgroundColor : config.cafe.groutColor));
          context.fillRect(0, 0, 800, 800);
          
          context.drawImage(image, 0, 0, 800, 800);
          
          const png = canvas.toDataURL('image/png');
          const downloadLink = document.createElement('a');
          downloadLink.href = png;
          downloadLink.download = `${config.activeTab}-optical-illusion.png`;
          document.body.appendChild(downloadLink);
          downloadLink.click();
          document.body.removeChild(downloadLink);
          
          URL.revokeObjectURL(blobURL);
        };
        image.src = blobURL;
      }

      document.getElementById('download-png-btn').addEventListener('click', downloadPNG);

      // URL Query params serialization (Share link)
      function shareLink() {
        const params = new URLSearchParams();
        params.set('tab', config.activeTab);
        
        const subConfig = config[config.activeTab];
        for (const key in subConfig) {
          params.set(key, subConfig[key]);
        }
        
        const shareURL = `${window.location.origin}${window.location.pathname}?${params.toString()}`;
        
        navigator.clipboard.writeText(shareURL).then(() => {
          alert('🔗 Share URL copied to clipboard! Share this link to load this exact illusion configuration.');
        }).catch(err => {
          console.error('Failed to copy share link', err);
        });
      }

      document.getElementById('share-link-btn').addEventListener('click', shareLink);

      // Reset Defaults
      function resetDefaults() {
        const defaults = {
          cafe: {
            rows: 10,
            cols: 10,
            offset: 50,
            tileColor1: '#000000',
            tileColor2: '#ffffff',
            groutColor: '#808080',
            groutThickness: 3,
            rowHeight: 30
          },
          hermann: {
            gridSize: 8,
            squareSize: 38,
            gapSize: 8,
            squareColor: '#000000',
            backgroundColor: '#ffffff',
            coloredMode: false
          },
          rings: {
            ringsCount: 4,
            segmentsCount: 16,
            colorA: '#eab308',
            colorB: '#06b6d4',
            spacing: 20,
            chevronAngle: 30,
            speed: 0
          },
          stripes: {
            linesCount: 10,
            lineColor: '#ec4899',
            backgroundColor: '#0f172a',
            dashPattern: 12,
            dashAngle: 30,
            alternating: true,
            thickness: 3
          }
        };

        config[config.activeTab] = JSON.parse(JSON.stringify(defaults[config.activeTab]));
        syncDOMFromConfig();
        renderActiveGenerator();
      }

      document.getElementById('reset-btn').addEventListener('click', resetDefaults);

      // 5. TAB CLICKS
      tabs.forEach(t => {
        t.addEventListener('click', () => {
          config.activeTab = t.dataset.tab;
          syncDOMFromConfig();
          renderActiveGenerator();
        });
      });

      // 6. PRESETS GALLERY
      const presetDefinitions = {
        'classic-cafe': {
          tab: 'cafe',
          rows: 10,
          cols: 10,
          offset: 50,
          tileColor1: '#000000',
          tileColor2: '#ffffff',
          groutColor: '#808080',
          groutThickness: 3,
          rowHeight: 30
        },
        'ghost-grid': {
          tab: 'hermann',
          gridSize: 8,
          squareSize: 38,
          gapSize: 8,
          squareColor: '#000000',
          backgroundColor: '#ffffff',
          coloredMode: false
        },
        'subtle-spin': {
          tab: 'rings',
          ringsCount: 4,
          segmentsCount: 16,
          colorA: '#eab308',
          colorB: '#06b6d4',
          spacing: 20,
          chevronAngle: 30,
          speed: 0
        },
        'zoellner-maze': {
          tab: 'stripes',
          linesCount: 10,
          lineColor: '#ec4899',
          backgroundColor: '#0f172a',
          dashPattern: 12,
          dashAngle: 30,
          alternating: true,
          thickness: 3
        },
        'rainbow-grid': {
          tab: 'hermann',
          gridSize: 8,
          squareSize: 38,
          gapSize: 8,
          squareColor: '#000000',
          backgroundColor: '#ffffff',
          coloredMode: true
        },
        'max-confusion': {
          tab: 'rings',
          ringsCount: 6,
          segmentsCount: 24,
          colorA: '#a855f7',
          colorB: '#10b981',
          spacing: 16,
          chevronAngle: 45,
          speed: 1.5
        }
      };

      document.querySelectorAll('.preset-card').forEach(card => {
        card.addEventListener('click', () => {
          const name = card.dataset.preset;
          const def = presetDefinitions[name];
          if (def) {
            config.activeTab = def.tab;
            config[def.tab] = JSON.parse(JSON.stringify(def));
            syncDOMFromConfig();
            renderActiveGenerator();
            window.scrollTo({ top: document.getElementById('generator-tabs').offsetTop - 80, behavior: 'smooth' });
          }
        });
      });

      // 7. INITIAL URL QUERY PARAMS DECODER
      function decodeURLParams() {
        const params = new URLSearchParams(window.location.search);
        const tab = params.get('tab');
        if (tab && ['cafe', 'hermann', 'rings', 'stripes'].includes(tab)) {
          config.activeTab = tab;
          
          const subConfig = config[tab];
          for (const key in subConfig) {
            const val = params.get(key);
            if (val !== null) {
              if (val === 'true') {
                subConfig[key] = true;
              } else if (val === 'false') {
                subConfig[key] = false;
              } else if (!isNaN(val)) {
                subConfig[key] = parseFloat(val);
              } else {
                subConfig[key] = val;
              }
            }
          }
        }
      }

      // Initialize workspace
      decodeURLParams();
      bindInputs();
      syncDOMFromConfig();
      renderActiveGenerator();
    });
  </script>

</Layout>
