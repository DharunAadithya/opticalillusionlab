---
// src/pages/generator.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Optical Illusion Maker Online Free — Create Custom Illusions | Optical Illusion Lab" 
  description="Free optical illusion generator online. Create custom café wall, Hermann grid, and rotating ring illusions. Download as PNG. No account needed."
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-900 via-purple-950 to-slate-950 text-white border-b border-indigo-500/10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(168,85,247,0.15),transparent_50%)]"></div>
    
    <div class="relative mx-auto max-w-4xl text-center space-y-6">
      <div class="inline-flex items-center space-x-2 rounded-full border border-purple-500/30 bg-purple-500/15 px-4 py-1.5 text-xs font-black uppercase tracking-wider text-purple-300 backdrop-blur-sm">
        🌀 Interactive Visual Sandbox 🌀
      </div>
      <h1 class="font-display text-4xl sm:text-6xl font-black tracking-tight bg-gradient-to-r from-pink-400 via-purple-400 to-indigo-400 bg-clip-text text-transparent">
        Optical Illusion Generator — Create Your Own
      </h1>
      <p class="mx-auto max-w-2xl text-lg sm:text-xl text-slate-200 font-medium leading-relaxed">
        Design and download custom optical illusions for free. No account needed.
      </p>
    </div>
  </section>

  <!-- Main Generator Workspace -->
  <section class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-8">
    
    <!-- Tab Switcher -->
    <div class="flex justify-center border-b border-slate-800">
      <div class="flex flex-wrap -mb-px space-x-2 sm:space-x-4" id="generator-tabs">
        <button class="tab-btn active inline-block p-4 border-b-2 border-purple-500 text-purple-400 text-sm sm:text-base font-black uppercase tracking-wider focus:outline-none" data-tab="cafe">
          🧱 Café Wall
        </button>
        <button class="tab-btn inline-block p-4 border-b-2 border-transparent text-slate-400 hover:text-white text-sm sm:text-base font-black uppercase tracking-wider focus:outline-none" data-tab="hermann">
          👻 Hermann Grid
        </button>
        <button class="tab-btn inline-block p-4 border-b-2 border-transparent text-slate-400 hover:text-white text-sm sm:text-base font-black uppercase tracking-wider focus:outline-none" data-tab="rings">
          🌀 Rotating Rings
        </button>
        <button class="tab-btn inline-block p-4 border-b-2 border-transparent text-slate-400 hover:text-white text-sm sm:text-base font-black uppercase tracking-wider focus:outline-none" data-tab="stripes">
          ↗️ Stripes
        </button>
      </div>
    </div>

    <!-- Workspace Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left Panel: Controls (lg:col-span-5) -->
      <div class="lg:col-span-5 bg-slate-900/60 border border-purple-500/20 rounded-3xl p-6 sm:p-8 shadow-2xl space-y-6">
        <h2 class="text-xl font-bold text-white flex items-center gap-2 border-b border-slate-850 pb-4">
          🔧 Configuration Settings
        </h2>
        
        <!-- ==================== CONTROLS: CAFÉ WALL ==================== -->
        <div class="generator-controls space-y-4" data-tab="cafe">
          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="cafe-rows">Rows Count</label>
              <span id="cafe-rows-val" class="text-purple-400">10</span>
            </div>
            <input type="range" id="cafe-rows" min="4" max="20" value="10" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="cafe-cols">Columns Count</label>
              <span id="cafe-cols-val" class="text-purple-400">10</span>
            </div>
            <input type="range" id="cafe-cols" min="4" max="20" value="10" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="cafe-offset">Row Offset (%)</label>
              <span id="cafe-offset-val" class="text-purple-400">50%</span>
            </div>
            <input type="range" id="cafe-offset" min="0" max="100" value="50" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="cafe-thickness">Grout Thickness (px)</label>
              <span id="cafe-thickness-val" class="text-purple-400">3px</span>
            </div>
            <input type="range" id="cafe-thickness" min="1" max="8" value="3" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="cafe-height">Row Height (px)</label>
              <span id="cafe-height-val" class="text-purple-400">30px</span>
            </div>
            <input type="range" id="cafe-height" min="15" max="60" value="30" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="grid grid-cols-3 gap-3 pt-2">
            <div class="space-y-1">
              <label for="cafe-color1" class="text-[11px] font-bold text-slate-400 block">Tile Color 1</label>
              <input type="color" id="cafe-color1" value="#000000" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
            <div class="space-y-1">
              <label for="cafe-color2" class="text-[11px] font-bold text-slate-400 block">Tile Color 2</label>
              <input type="color" id="cafe-color2" value="#ffffff" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
            <div class="space-y-1">
              <label for="cafe-grout" class="text-[11px] font-bold text-slate-400 block">Grout Color</label>
              <input type="color" id="cafe-grout" value="#808080" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
          </div>
        </div>

        <!-- ==================== CONTROLS: HERMANN GRID ==================== -->
        <div class="generator-controls space-y-4 hidden" data-tab="hermann">
          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="hermann-grid">Grid Size</label>
              <span id="hermann-grid-val" class="text-purple-400">8 x 8</span>
            </div>
            <input type="range" id="hermann-grid" min="4" max="20" value="8" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="hermann-size">Square Size (px)</label>
              <span id="hermann-size-val" class="text-purple-400">38px</span>
            </div>
            <input type="range" id="hermann-size" min="20" max="80" value="38" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="hermann-gap">Gap Size (px)</label>
              <span id="hermann-gap-val" class="text-purple-400">8px</span>
            </div>
            <input type="range" id="hermann-gap" min="2" max="20" value="8" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="grid grid-cols-2 gap-4 pt-2">
            <div class="space-y-1">
              <label for="hermann-color" class="text-[11px] font-bold text-slate-400 block">Square Color</label>
              <input type="color" id="hermann-color" value="#000000" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
            <div class="space-y-1">
              <label for="hermann-bg" class="text-[11px] font-bold text-slate-400 block">Background Color</label>
              <input type="color" id="hermann-bg" value="#ffffff" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <input type="checkbox" id="hermann-colored" class="h-4 w-4 rounded border-slate-800 text-purple-600 focus:ring-purple-500 bg-slate-950" />
            <label for="hermann-colored" class="text-xs font-bold text-slate-300">Enable Colored Mode (weakens illusion)</label>
          </div>
        </div>

        <!-- ==================== CONTROLS: ROTATING RINGS ==================== -->
        <div class="generator-controls space-y-4 hidden" data-tab="rings">
          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="rings-count">Number of Rings</label>
              <span id="rings-count-val" class="text-purple-400">4</span>
            </div>
            <input type="range" id="rings-count" min="2" max="8" value="4" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="rings-segments">Segments per Ring</label>
              <span id="rings-segments-val" class="text-purple-400">16</span>
            </div>
            <input type="range" id="rings-segments" min="8" max="32" value="16" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="rings-spacing">Ring Spacing (px)</label>
              <span id="rings-spacing-val" class="text-purple-400">20px</span>
            </div>
            <input type="range" id="rings-spacing" min="5" max="30" value="20" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="rings-angle">Chevron Angle (deg)</label>
              <span id="rings-angle-val" class="text-purple-400">30°</span>
            </div>
            <input type="range" id="rings-angle" min="0" max="90" value="30" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="rings-speed">Rotation Speed</label>
              <span id="rings-speed-val" class="text-purple-400">0 (Static)</span>
            </div>
            <input type="range" id="rings-speed" min="0" max="3" step="0.2" value="0" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="grid grid-cols-2 gap-4 pt-2">
            <div class="space-y-1">
              <label for="rings-colorA" class="text-[11px] font-bold text-slate-400 block">Color A</label>
              <input type="color" id="rings-colorA" value="#eab308" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
            <div class="space-y-1">
              <label for="rings-colorB" class="text-[11px] font-bold text-slate-400 block">Color B</label>
              <input type="color" id="rings-colorB" value="#06b6d4" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
          </div>
        </div>

        <!-- ==================== CONTROLS: STRIPES ==================== -->
        <div class="generator-controls space-y-4 hidden" data-tab="stripes">
          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="stripes-count">Horizontal Lines</label>
              <span id="stripes-count-val" class="text-purple-400">10</span>
            </div>
            <input type="range" id="stripes-count" min="5" max="30" value="10" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="stripes-pattern">Dashes Frequency</label>
              <span id="stripes-pattern-val" class="text-purple-400">12</span>
            </div>
            <input type="range" id="stripes-pattern" min="2" max="40" value="12" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="stripes-angle">Dash Angle (deg)</label>
              <span id="stripes-angle-val" class="text-purple-400">30°</span>
            </div>
            <input type="range" id="stripes-angle" min="0" max="90" value="30" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs font-bold text-slate-300">
              <label for="stripes-thickness">Line Thickness (px)</label>
              <span id="stripes-thickness-val" class="text-purple-400">3px</span>
            </div>
            <input type="range" id="stripes-thickness" min="1" max="5" value="3" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-500" />
          </div>

          <div class="grid grid-cols-2 gap-4 pt-2">
            <div class="space-y-1">
              <label for="stripes-lineColor" class="text-[11px] font-bold text-slate-400 block">Line Color</label>
              <input type="color" id="stripes-lineColor" value="#ec4899" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
            <div class="space-y-1">
              <label for="stripes-bg" class="text-[11px] font-bold text-slate-400 block">Background Color</label>
              <input type="color" id="stripes-bg" value="#0f172a" class="w-full h-10 bg-transparent border border-slate-850 rounded cursor-pointer" />
            </div>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <input type="checkbox" id="stripes-alternating" checked class="h-4 w-4 rounded border-slate-800 text-purple-600 focus:ring-purple-500 bg-slate-950" />
            <label for="stripes-alternating" class="text-xs font-bold text-slate-300">Alternating Dash Direction (creates tilt)</label>
          </div>
        </div>

      </div>

      <!-- Right Panel: Live SVG Preview (lg:col-span-7) -->
      <div class="lg:col-span-7 flex flex-col items-center justify-center space-y-6">
        
        <!-- Live Preview Canvas -->
        <div id="preview-canvas-wrapper" class="w-full max-w-[400px] aspect-square relative bg-slate-950 rounded-3xl border border-indigo-500/20 p-2 shadow-2xl flex items-center justify-center">
          <svg id="generator-svg" width="100%" height="100%" viewBox="0 0 400 400" class="w-full h-full bg-slate-950 rounded-2xl overflow-visible">
            <!-- Dynamically populated via JS -->
          </svg>
        </div>

        <!-- Actions -->
        <div class="flex flex-wrap gap-3 w-full justify-center">
          <button id="download-png-btn" class="rounded-xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 px-5 py-3 text-xs font-black text-white shadow-lg flex items-center gap-1.5 hover:scale-102 transition-transform">
            📥 Download PNG
          </button>
          <button id="share-link-btn" class="rounded-xl border border-indigo-500/20 bg-slate-900/60 hover:bg-slate-800 px-5 py-3 text-xs font-bold text-slate-200 hover:text-white flex items-center gap-1.5 transition-colors">
            🔗 Share Creation
          </button>
          <button id="reset-btn" class="rounded-xl border border-slate-850 bg-slate-950 hover:bg-slate-900 px-5 py-3 text-xs font-bold text-slate-400 hover:text-slate-350 flex items-center gap-1.5 transition-colors">
            🔄 Reset Defaults
          </button>
        </div>

      </div>

    </div>

  </section>

  <!-- Gallery Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto border-t border-slate-800">
    <div class="text-center space-y-2 mb-12">
      <h3 class="font-display text-3xl font-bold text-white">Community Creations</h3>
      <p class="text-slate-450 text-sm max-w-md mx-auto">Load one of these verified optical illusion presets directly into the generator.</p>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      
      <!-- Preset 1 -->
      <button class="preset-card bg-slate-900/40 border border-slate-800 hover:border-purple-500/30 hover:bg-slate-900 p-4 rounded-2xl text-center space-y-3 flex flex-col justify-between transition-all group" data-preset="classic-cafe">
        <div class="w-full aspect-square bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center p-1 border border-slate-850">
          <svg viewBox="0 0 100 100" class="w-full h-full opacity-60 group-hover:opacity-100 transition-opacity">
            <rect x="0" y="0" width="100" height="100" fill="#808080" />
            <rect x="5" y="10" width="20" height="20" fill="#000" />
            <rect x="25" y="10" width="20" height="20" fill="#fff" />
            <rect x="45" y="10" width="20" height="20" fill="#000" />
            <rect x="65" y="10" width="20" height="20" fill="#fff" />
            <rect x="15" y="40" width="20" height="20" fill="#000" />
            <rect x="35" y="40" width="20" height="20" fill="#fff" />
            <rect x="55" y="40" width="20" height="20" fill="#000" />
            <rect x="75" y="40" width="20" height="20" fill="#fff" />
          </svg>
        </div>
        <span class="text-xs font-bold text-white block">The Classic Café</span>
      </button>

      <!-- Preset 2 -->
      <button class="preset-card bg-slate-900/40 border border-slate-800 hover:border-purple-500/30 hover:bg-slate-900 p-4 rounded-2xl text-center space-y-3 flex flex-col justify-between transition-all group" data-preset="ghost-grid">
        <div class="w-full aspect-square bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center p-1 border border-slate-850">
          <svg viewBox="0 0 100 100" class="w-full h-full opacity-60 group-hover:opacity-100 transition-opacity">
            <rect x="0" y="0" width="100" height="100" fill="#fff" />
            <rect x="10" y="10" width="20" height="20" fill="#000" />
            <rect x="40" y="10" width="20" height="20" fill="#000" />
            <rect x="70" y="10" width="20" height="20" fill="#000" />
            <rect x="10" y="40" width="20" height="20" fill="#000" />
            <rect x="40" y="40" width="20" height="20" fill="#000" />
            <rect x="70" y="40" width="20" height="20" fill="#000" />
          </svg>
        </div>
        <span class="text-xs font-bold text-white block">Ghost Intersection</span>
      </button>

      <!-- Preset 3 -->
      <button class="preset-card bg-slate-900/40 border border-slate-800 hover:border-purple-500/30 hover:bg-slate-900 p-4 rounded-2xl text-center space-y-3 flex flex-col justify-between transition-all group" data-preset="subtle-spin">
        <div class="w-full aspect-square bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center p-1 border border-slate-850">
          <svg viewBox="0 0 100 100" class="w-full h-full opacity-60 group-hover:opacity-100 transition-opacity">
            <circle cx="50" cy="50" r="40" stroke="#eab308" stroke-width="4" stroke-dasharray="4,4" fill="none" />
            <circle cx="50" cy="50" r="25" stroke="#06b6d4" stroke-width="4" stroke-dasharray="4,4" fill="none" />
          </svg>
        </div>
        <span class="text-xs font-bold text-white block">Subtle Spin</span>
      </button>

      <!-- Preset 4 -->
      <button class="preset-card bg-slate-900/40 border border-slate-800 hover:border-purple-500/30 hover:bg-slate-900 p-4 rounded-2xl text-center space-y-3 flex flex-col justify-between transition-all group" data-preset="zoellner-maze">
        <div class="w-full aspect-square bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center p-1 border border-slate-850">
          <svg viewBox="0 0 100 100" class="w-full h-full opacity-60 group-hover:opacity-100 transition-opacity" fill="none" stroke="#ec4899">
            <line x1="10" y1="20" x2="90" y2="20" stroke-width="2" />
            <line x1="10" y1="50" x2="90" y2="50" stroke-width="2" />
            <!-- dashes -->
            <line x1="30" y1="10" x2="40" y2="30" stroke-width="1.5" />
            <line x1="60" y1="10" x2="70" y2="30" stroke-width="1.5" />
            <line x1="30" y1="60" x2="20" y2="40" stroke-width="1.5" />
            <line x1="60" y1="60" x2="50" y2="40" stroke-width="1.5" />
          </svg>
        </div>
        <span class="text-xs font-bold text-white block">Zöllner&apos;s Maze</span>
      </button>

      <!-- Preset 5 -->
      <button class="preset-card bg-slate-900/40 border border-slate-800 hover:border-purple-500/30 hover:bg-slate-900 p-4 rounded-2xl text-center space-y-3 flex flex-col justify-between transition-all group" data-preset="rainbow-grid">
        <div class="w-full aspect-square bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center p-1 border border-slate-850">
          <svg viewBox="0 0 100 100" class="w-full h-full opacity-60 group-hover:opacity-100 transition-opacity">
            <rect x="10" y="10" width="20" height="20" fill="#f87171" />
            <rect x="40" y="10" width="20" height="20" fill="#facc15" />
            <rect x="70" y="10" width="20" height="20" fill="#60a5fa" />
            <rect x="10" y="40" width="20" height="20" fill="#c084fc" />
            <rect x="40" y="40" width="20" height="20" fill="#fb923c" />
            <rect x="70" y="40" width="20" height="20" fill="#4ade80" />
          </svg>
        </div>
        <span class="text-xs font-bold text-white block">Rainbow Grid</span>
      </button>

      <!-- Preset 6 -->
      <button class="preset-card bg-slate-900/40 border border-slate-800 hover:border-purple-500/30 hover:bg-slate-900 p-4 rounded-2xl text-center space-y-3 flex flex-col justify-between transition-all group" data-preset="max-confusion">
        <div class="w-full aspect-square bg-slate-950 rounded-xl overflow-hidden flex items-center justify-center p-1 border border-slate-850">
          <svg viewBox="0 0 100 100" class="w-full h-full opacity-60 group-hover:opacity-100 transition-opacity">
            <circle cx="50" cy="50" r="42" stroke="#a855f7" stroke-width="4" stroke-dasharray="2,2" fill="none" />
            <circle cx="50" cy="50" r="32" stroke="#10b981" stroke-width="4" stroke-dasharray="2,2" fill="none" />
            <circle cx="50" cy="50" r="22" stroke="#a855f7" stroke-width="4" stroke-dasharray="2,2" fill="none" />
          </svg>
        </div>
        <span class="text-xs font-bold text-white block">Max Confusion</span>
      </button>

    </div>
