  <!-- Keyframe and Helper Animations -->
  <style>
    :root {
      --card-speed: 1.0;
      --card-play-state: running;
    }

    @keyframes spin-clockwise {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes spin-counter {
      0% { transform: rotate(360deg); }
      100% { transform: rotate(0deg); }
    }

    @keyframes pulse-dot {
      0%, 100% { transform: scale(1); opacity: 0.3; }
      50% { transform: scale(1.6); opacity: 1; }
    }

    @keyframes scroll-down {
      0% { transform: translateY(-40px); }
      100% { transform: translateY(0); }
    }

    @keyframes expand-hole {
      0%, 100% { transform: scale(0.8); opacity: 0.9; filter: blur(4px); }
      50% { transform: scale(1.35); opacity: 1; filter: blur(0px); }
    }

    @keyframes slant-lines {
      0%, 100% { transform: skewX(-5deg); }
      50% { transform: skewX(5deg); }
    }

    @keyframes oscillate-circle {
      0%, 100% { transform: translate(-3px, -3px); }
      50% { transform: translate(3px, 3px); }
    }

    @keyframes enigma-flow {
      0% { filter: hue-rotate(0deg) saturate(1); }
      100% { filter: hue-rotate(360deg) saturate(1.2); }
    }

    @keyframes float-bg {
      0%, 100% { transform: translate(-10px, -5px) skewX(-2deg); }
      50% { transform: translate(10px, 5px) skewX(2deg); }
    }

    @keyframes float-ball {
      0%, 100% { transform: translateY(-5px); }
      50% { transform: translateY(15px); }
    }
  </style>

  <!-- Script for Card Interactivity -->
  <script>
    // ----------------------------------------------------
    // CARD LEVEL PLAY/PAUSE AND SPEED CONTROLS
    // ----------------------------------------------------
    const cards = document.querySelectorAll('.illusion-card');
    cards.forEach(card => {
      const playPauseBtn = card.querySelector('.play-pause-btn');
      const playPauseText = playPauseBtn?.querySelector('span');
      const speedSlider = card.querySelector('.speed-slider') as HTMLInputElement;
      const speedValBadge = card.querySelector('.speed-val');
      const shareBtn = card.querySelector('.share-btn');

      let isPlaying = true;

      // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation
      card.querySelectorAll('button, input, select, details, summary, label, a').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
  

      // Play/Pause toggle
      playPauseBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        isPlaying = !isPlaying;
        (card as HTMLElement).style.setProperty('--card-play-state', isPlaying ? 'running' : 'paused');
        if (playPauseText) {
          playPauseText.textContent = isPlaying ? 'Pause' : 'Play';
        }
        if (playPauseBtn) {
          if (isPlaying) {
            playPauseBtn.classList.remove('bg-emerald-600', 'hover:bg-emerald-500');
            playPauseBtn.classList.add('bg-purple-600', 'hover:bg-purple-500');
          } else {
            playPauseBtn.classList.remove('bg-purple-600', 'hover:bg-purple-500');
            playPauseBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-500');
          }
        }
      });

      // Speed Slider adjustment
      speedSlider?.addEventListener('input', (e) => {
        e.stopPropagation();
        const val = (e.target as HTMLInputElement).value;
        (card as HTMLElement).style.setProperty('--card-speed', val);
        if (speedValBadge) {
          speedValBadge.textContent = `${parseFloat(val).toFixed(1)}x`;
        }
      });

      // Share button clipboard functionality
      shareBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        e.preventDefault();
        const cardId = card.id;
        const shareUrl = `${window.location.origin}${window.location.pathname}#${cardId}`;
        navigator.clipboard.writeText(shareUrl).then(() => {
          const toast = shareBtn.querySelector('.share-toast');
          if (toast) {
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            setTimeout(() => {
              toast.classList.remove('opacity-100');
              toast.classList.add('opacity-0');
            }, 2000);
          }
        });
      });
    });
  </script>

