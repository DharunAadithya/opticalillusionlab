  <style>
    :root {
      --card-speed: 1.0;
      --card-play-state: running;
    }

    @keyframes spin-clockwise {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @keyframes spin-counter {
      0% { transform: rotate(360deg); }
      100% { transform: rotate(0deg); }
    }

    @keyframes pulse-dot {
      0%, 100% { transform: scale(1); opacity: 0.3; }
      50% { transform: scale(1.6); opacity: 1; }
    }

    @keyframes scroll-down {
      0% { transform: translateY(-40px); }
      100% { transform: translateY(0); }
    }

    @keyframes expand-hole {
      0%, 100% { transform: scale(0.8); opacity: 0.9; filter: blur(4px); }
      50% { transform: scale(1.35); opacity: 1; filter: blur(0px); }
    }

    @keyframes slant-lines {
      0%, 100% { transform: skewX(-5deg); }
      50% { transform: skewX(5deg); }
    }

    @keyframes oscillate-circle {
      0%, 100% { transform: translate(-3px, -3px); }
