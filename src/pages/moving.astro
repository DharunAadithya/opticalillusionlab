// src/pages/moving.astro
import Layout from '../layouts/Layout.astro';

// Math Helper: draws an SVG wedge from (cx, cy) out to radius r
function getWedgePath(cx: number, cy: number, r: number, startAngle: number, endAngle: number) {
  const rad = Math.PI / 180;
  const x1 = cx + r * Math.cos(startAngle * rad);
  const y1 = cy + r * Math.sin(startAngle * rad);
  const x2 = cx + r * Math.cos(endAngle * rad);
  const y2 = cy + r * Math.sin(endAngle * rad);
  const largeArcFlag = endAngle - startAngle <= 180 ? 0 : 1;
  return `M ${cx},${cy} L ${x1},${y1} A ${r},${r} 0 ${largeArcFlag},1 ${x2},${y2} Z`;
}

// Generate concentric ring sectors for Moving Snakes & Peripheral Drift
function generateRingSectors(cx: number, cy: number, r: number, count: number, reversed: boolean) {
  const sectors = [];
  const colors = [
    'fill-slate-950 dark:fill-slate-900',          // Black
    'fill-indigo-600 dark:fill-indigo-500',       // Blue
    'fill-white dark:fill-slate-100',              // White
    'fill-yellow-400 dark:fill-yellow-300'         // Yellow
  ];
  if (reversed) {
    colors.reverse();
  }
  for (let i = 0; i < count; i++) {
    const baseAngle = (i * 360) / count;
    const step = 360 / count / 4;
    for (let c = 0; c < 4; c++) {
      sectors.push({
        path: getWedgePath(cx, cy, r, baseAngle + c * step, baseAngle + (c + 1) * step),
        color: colors[c]
      });
    }
  }
  return sectors;
}

// Helper to generate Archimedean Spiral coordinates for Motion Aftereffect
function getSpiralPath(cx: number, cy: number, turns: number, maxR: number) {
  const points = [];
  const steps = 200;
  for (let i = 0; i <= steps; i++) {
    const theta = (i / steps) * turns * 2 * Math.PI;
    const r = (i / steps) * maxR;
    const x = cx + r * Math.cos(theta);
    const y = cy + r * Math.sin(theta);
    points.push(`${i === 0 ? 'M' : 'L'} ${x.toFixed(1)},${y.toFixed(1)}`);
  }
  return points.join(' ');
}

const spiralPath = getSpiralPath(100, 100, 6, 80);

// Pre-render sectors for Peripheral Drift Wheels
const driftOuter = generateRingSectors(100, 100, 90, 24, false);
const driftInner = generateRingSectors(100, 100, 55, 16, true);

// Pre-render grid coordinates for Pulsing Grid
const gridSize = 5;
const gridCoords: number[] = [];
for (let i = 0; i < gridSize; i++) {
  gridCoords.push(30 + i * 35);
}

// Pre-render radiating ray coordinates for Enigma
const enigmaRays = [];
const rayCount = 72;
for (let i = 0; i < rayCount; i++) {
  const angle = (i * 360) / rayCount;
  const rad = Math.PI / 180;
  const x2 = 100 + 120 * Math.cos(angle * rad);
  const y2 = 100 + 120 * Math.sin(angle * rad);
  enigmaRays.push(`M 100,100 L ${x2.toFixed(1)},${y2.toFixed(1)}`);
}
