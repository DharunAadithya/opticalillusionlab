  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Handle Global Speed Mult
    const checkSpeed = () => {
      const level = localStorage.getItem('speed-multiplier-level') || '5';
      let multiplier = 1.0;
      const parsed = parseInt(level);
      if (parsed <= 5) {
        multiplier = 0.2 + (parsed - 1) * 0.2;
      } else {
        multiplier = 1.0 + (parsed - 5) * 0.4;
      }
      document.documentElement.style.setProperty('--speed-multiplier', multiplier.toString());
    };
    checkSpeed();
    window.addEventListener('storage', checkSpeed);

    // Prevent propagation on inner interactive controllers so we don't trigger parent clicks (if wrapped)
    const innerControls = document.querySelectorAll('.interactive-demo-card button, .interactive-demo-card input, .interactive-demo-card select');
    innerControls.forEach(ctrl => {
      ctrl.addEventListener('click', (e) => e.stopPropagation());
    });

    // Local script logic from original file
    // Share Page Link copying
    

    // Custom CSS animations variable bindings
    
    
    // Embed specific illusion script logic
    
      const cafeContainer = document.getElementById('cafe-illusion');
      const cafeSlider = cafeContainer?.querySelector('.cafe-slider') as HTMLInputElement;
      const cafeShiftVal = cafeContainer?.querySelector('.cafe-shift-val');
      const cafeRows = cafeContainer?.querySelectorAll('.cafe-row');
      const groutCheckbox = cafeContainer?.querySelector('.cafe-grout-checkbox') as HTMLInputElement;

      const updateCafeWall = () => {
        const shift = cafeSlider?.value || '12';
        const showGrout = groutCheckbox ? groutCheckbox.checked : true;
        if (cafeShiftVal) cafeShiftVal.textContent = `${shift}px`;
        
        cafeRows?.forEach(row => {
          const isEven = row.getAttribute('data-even') === 'true';
          (row as HTMLElement).style.transform = `translateX(${isEven ? shift : 0}px)`;
          if (showGrout) {
            row.classList.remove('border-transparent');
            row.classList.add('border-slate-500/80');
          } else {
            row.classList.remove('border-slate-500/80');
            row.classList.add('border-transparent');
          }
        });
      };

      cafeSlider?.addEventListener('input', updateCafeWall);
      groutCheckbox?.addEventListener('change', updateCafeWall);
      updateCafeWall();
  </script>
