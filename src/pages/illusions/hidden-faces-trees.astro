---
// src/pages/illusions/hidden-faces-trees.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="6 Hidden Faces in the Trees — Interactive Ambiguous Optical Illusion | Optical Illusion Lab" 
  description="Stare at the tree branches: can you find the 6 hidden human profiles? Test your fusiform face area and pareidolia in this interactive sketch."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/hidden" class="hover:text-white transition-colors">Hidden & Ambiguous</a>
      <span>/</span>
      <span class="text-purple-400">6 Hidden Faces in the Trees</span>
    </nav>

    <!-- Hero Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Type 3: Ambiguous Figures</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-rose-500/10 text-rose-455 border border-rose-500/20 uppercase tracking-wider">🔴 Hard</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          6 Hidden Faces in the Trees
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          A botanical sketch that exploits the brain's face detection centers. Trunks and negative spaces create human silhouettes.
        </p>
      </div>

      <!-- Share Button -->
      <button 
        id="share-illusion-page-btn"
        class="relative shrink-0 flex items-center space-x-2 rounded-2xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 hover:scale-105 text-white font-black text-sm px-6 py-3.5 transition-all shadow-lg shadow-purple-500/10"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
        <span>Share Page</span>
        <span id="page-share-toast" class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-655 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
      </button>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-4">
        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Scan the branches and negative spaces. Can you find all 6 hidden faces? Tap the face contours directly in the drawing to highlight them, or click "Reveal All" below.
          </div>
        </div>

        <div id="trees-illusion" class="relative flex flex-col items-center justify-center h-[400px] w-full bg-slate-950 rounded-xl overflow-hidden border border-indigo-500/10 p-6">
          <svg class="w-64 h-64 select-none" viewBox="0 0 200 200" id="svg-trees-detail">
            <!-- Base trunk & branches -->
            <path d="M 30,190 Q 50,130 50,80 Q 30,40 20,20 Q 50,40 60,70 L 60,190" fill="none" stroke="#e2e8f0" stroke-width="2.5" />
            <path d="M 170,190 Q 150,120 150,70 Q 170,30 180,10 Q 150,30 140,60 L 140,190" fill="none" stroke="#e2e8f0" stroke-width="2.5" />
            
            <!-- Face 1 target (young profile on left trunk branch) -->
            <path d="M 50,80 Q 42,75 42,70 Q 45,66 48,68 Q 45,60 50,55" fill="none" stroke="transparent" stroke-width="8" class="face-target cursor-pointer" data-idx="1" />
            <path id="highlight-detail-1" d="M 50,80 Q 42,75 42,70 Q 45,66 48,68 Q 45,60 50,55" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity" />
            
            <!-- Face 2 target (old profile on right trunk branch) -->
            <path d="M 150,70 Q 158,65 158,60 Q 155,56 152,58 Q 155,50 150,45" fill="none" stroke="transparent" stroke-width="8" class="face-target cursor-pointer" data-idx="2" />
            <path id="highlight-detail-2" d="M 150,70 Q 158,65 158,60 Q 155,56 152,58 Q 155,50 150,45" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity" />

            <!-- Face 3 target (lower branches left) -->
            <path d="M 60,130 Q 52,125 52,120 Q 55,116 58,118 Q 55,110 60,105" fill="none" stroke="transparent" stroke-width="8" class="face-target cursor-pointer" data-idx="3" />
            <path id="highlight-detail-3" d="M 60,130 Q 52,125 52,120 Q 55,116 58,118 Q 55,110 60,105" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity" />

            <!-- Face 4 target (lower branches right) -->
            <path d="M 140,130 Q 148,125 148,120 Q 145,116 142,118 Q 145,110 140,105" fill="none" stroke="transparent" stroke-width="8" class="face-target cursor-pointer" data-idx="4" />
            <path id="highlight-detail-4" d="M 140,130 Q 148,125 148,120 Q 145,116 142,118 Q 145,110 140,105" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity" />

            <!-- Face 5 target (ground root left) -->
            <path d="M 60,170 Q 50,165 50,160 M 50,160 Q 55,155 60,152" fill="none" stroke="transparent" stroke-width="8" class="face-target cursor-pointer" data-idx="5" />
            <path id="highlight-detail-5" d="M 60,170 Q 50,165 50,160 M 50,160 Q 55,155 60,152" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity" />

            <!-- Face 6 target (ground root right) -->
            <path d="M 140,170 Q 150,165 150,160 M 150,160 Q 145,155 140,152" fill="none" stroke="transparent" stroke-width="8" class="face-target cursor-pointer" data-idx="6" />
            <path id="highlight-detail-6" d="M 140,170 Q 150,165 150,160 M 150,160 Q 145,155 140,152" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity" />
          </svg>

          <!-- Control bar inside demo -->
          <div class="absolute bottom-4 flex items-center justify-between w-11/12 px-4 py-2 bg-slate-900/90 border border-white/10 rounded-xl z-10 text-xs">
            <div class="font-bold text-slate-300">Faces Found: <span id="faces-found-count" class="text-green-400 font-mono text-sm">0</span>/6</div>
            <div class="flex space-x-2">
              <button id="reveal-all-btn" class="text-xs font-bold px-2.5 py-1 rounded-lg bg-indigo-950 text-slate-350 hover:bg-slate-800 transition-all">Reveal All</button>
              <button id="reset-faces-btn" class="text-xs font-bold px-2.5 py-1 rounded-lg bg-indigo-950 text-slate-350 hover:bg-slate-800 transition-all">Reset</button>
            </div>
          </div>
          <p id="success-banner" class="absolute top-4 hidden text-xs font-bold text-green-400 uppercase tracking-widest bg-slate-900/95 border border-green-500/25 px-4 py-2 rounded-xl">🎉 You found all 6 faces!</p>
        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      
      <!-- Left 2-Columns: Science and Prompt -->
      <div class="lg:col-span-2 space-y-10">
        <!-- EXPERIENCE IT FIRST prompt -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🎮</span>
            <span>EXPERIENCE IT FIRST</span>
          </h2>
          <div class="bg-indigo-950/20 border-2 border-indigo-500/15 rounded-3xl p-6 text-slate-700 dark:text-slate-300">
            <p class="font-bold text-sm sm:text-base text-slate-200">Challenge your visual pareidolia:</p>
            <ul class="list-disc pl-5 mt-3 space-y-2 text-xs sm:text-sm font-medium">
              <li>Scan the image starting from the root trunk (Face 5 and 6) and move upward. Does finding one face make it easier to see the adjacent ones?</li>
              <li>Observe how the curves of the branches represent forehead profiles, nose bridges, lips, and chins.</li>
              <li>Notice how you can alternate between seeing a simple botanical drawing of a tree and a series of human profiles.</li>
            </ul>
          </div>
        </section>

        <!-- THE SCIENCE (400 words) -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed space-y-4 text-xs sm:text-sm font-semibold text-justify">
            <p>
              The 6 Hidden Faces in the Trees is a classic example of pareidolia and high-level face categorization in the human visual system. Pareidolia is the psychological phenomenon where the brain perceives a highly structured stimulus (like a human face or body) in a random or abstract configuration of lines and shapes. 
            </p>
            <p>
              From an evolutionary standpoint, recognizing faces instantly was crucial for human survival. The brain developed dedicated structures to detect faces, notably the Fusiform Face Area (FFA) located in the fusiform gyrus of the temporal lobe. The FFA is so sensitive that it actively scans all incoming visual signals for face templates—two eyes, a nose, and a mouth, or even a side profile showing the curve of a nose and chin.
            </p>
            <p>
              In this illusion, the artist has carefully crafted the curves of the branches so that the negative spaces (the white background) and the bark contours map to human profiles. When your eyes scan the trees, your primary visual cortex (V1) extracts the lines and orientations of the branches. 
            </p>
            <p>
              As these orientation signals are sent to the ventral object processing stream, the FFA registers the profile layouts. Once a face is detected, the brain applies a top-down semantic template, allowing you to clearly see the profile. However, if you shift your focus to the branches themselves, the brain groups the contours back into a tree structure, demonstrating the dynamic nature of Gestalt grouping and top-down cognitive categorization.
            </p>
          </div>
        </section>
      </div>

      <!-- Right Column: Fun Facts and Try This -->
      <div class="space-y-8">
        <!-- FUN FACTS -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">💡</span>
            <span>FUN FACTS</span>
          </h3>
          <ul class="space-y-4 text-xs sm:text-sm text-slate-650 dark:text-slate-300 font-semibold">
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>This belongs to the class of ambiguous drawings where positive and negative spaces share boundaries.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Neuroimaging studies show that when people experience pareidolia, the FFA activates just as strongly as when looking at a real face.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Hidden-face art has been used by psychologists to test visual thresholds and cognitive flexibility.</span>
            </li>
          </ul>
        </section>

        <!-- TRY THIS AT HOME -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧪</span>
            <span>TRY THIS AT HOME</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold">
            Look at clouds in the sky or details on a wooden wall. Try to count how many faces or animal profiles your brain can construct out of the textures.
          </p>
        </section>

        <!-- DISCOVERER -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>DISCOVERER</span>
          </h3>
          <div class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold space-y-2">
            <p><strong>Creator:</strong> Graphic Artists (19th Century)</p>
            <p>This drawing is part of a series of popular Victorian puzzles where animals and faces were hidden in trees to entertain families before television and radio.</p>
          </div>
        </section>
      </div>

    </div>

  </div>

  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Face Clicking and Highlights
    const targets = document.querySelectorAll('.face-target');
    const foundCountEl = document.getElementById('faces-found-count');
    const successBanner = document.getElementById('success-banner');
    const revealAllBtn = document.getElementById('reveal-all-btn');
    const resetFacesBtn = document.getElementById('reset-faces-btn');
    const foundSet = new Set<string>();

    targets.forEach(target => {
      target.addEventListener('click', () => {
        const idx = (target as SVGPathElement).dataset.idx;
        if (!idx) return;
        foundSet.add(idx);
        const hl = document.getElementById(`highlight-detail-${idx}`);
        if (hl) hl.style.opacity = '1';
        if (foundCountEl) foundCountEl.textContent = foundSet.size.toString();
        
        if (foundSet.size === 6 && successBanner) {
          successBanner.classList.remove('hidden');
        }
      });
    });

    revealAllBtn?.addEventListener('click', () => {
      for (let i = 1; i <= 6; i++) {
        foundSet.add(i.toString());
        const hl = document.getElementById(`highlight-detail-${i}`);
        if (hl) hl.style.opacity = '1';
      }
      if (foundCountEl) foundCountEl.textContent = foundSet.size.toString();
      if (successBanner) successBanner.classList.remove('hidden');
    });

    resetFacesBtn?.addEventListener('click', () => {
      foundSet.clear();
      for (let i = 1; i <= 6; i++) {
        const hl = document.getElementById(`highlight-detail-${i}`);
        if (hl) hl.style.opacity = '0';
      }
      if (foundCountEl) foundCountEl.textContent = '0';
      if (successBanner) successBanner.classList.add('hidden');
    });
  </script>
</Layout>
