            <button id="btn-reset-ishihara" class="bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold text-sm px-4 py-2.5 rounded-xl border border-slate-700 transition-colors">Reset</button>
          </div>

          <!-- Feedback Panel -->
          <div id="ishihara-feedback-panel" class="w-full max-w-[380px] text-left text-xs bg-slate-950/90 p-4 rounded-xl border border-slate-800 hidden space-y-3">
            <h4 class="font-extrabold text-purple-400 text-sm border-b border-slate-800 pb-1.5 flex items-center justify-between">
              <span>Test Results</span>
              <span id="ishihara-score-text" class="font-mono text-yellow-400">0/4 Correct</span>
            </h4>
            <div id="ishihara-breakdown" class="space-y-1.5 font-mono text-slate-350">
              <!-- Dynamically populated per-plate breakdown -->
            </div>
            <p id="ishihara-explain-text" class="text-slate-400 font-medium leading-relaxed mt-2"></p>
