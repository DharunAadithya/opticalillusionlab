              <button id="btn-copy-ishihara" class="flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2 rounded-lg text-xs shadow transition-all active:scale-95">Copy Result to Share</button>
              <button id="btn-try-again-ishihara" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold py-2 rounded-lg text-xs border border-slate-700 shadow transition-all active:scale-95">Try Again</button>
