---
// src/pages/illusions/afterimage-lightbulb.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Afterimage Light Bulb — Interactive Optical Illusion | Optical Illusion Lab" 
  description="Stare at the black light bulb for 30 seconds. Look at the white screen to see a glowing yellow afterimage floating in your vision."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <span class="text-purple-400">Afterimage Light Bulb</span>
    </nav>

    <!-- Hero Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 uppercase tracking-wider">Physiological</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wider">🟢 Easy</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Afterimage Light Bulb
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          Exhaust your photoreceptors by staring at a high-contrast bulb. When it disappears, your eyes generate a complementary, glowing afterimage.
        </p>
      </div>

      <!-- Share Button -->
      <button 
        id="share-illusion-page-btn"
        class="relative shrink-0 flex items-center space-x-2 rounded-2xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 hover:scale-105 text-white font-black text-sm px-6 py-3.5 transition-all shadow-lg shadow-purple-500/10"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
        <span>Share Page</span>
        <span id="page-share-toast" class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-650 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
      </button>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-4">
        <div id="bulb-illusion-container" class="relative flex flex-col items-center justify-center h-96 w-full bg-white border border-slate-200 rounded-xl overflow-hidden p-8">
          
          <!-- Light bulb SVG -->
          <svg id="svg-afterimage-bulb" class="w-48 h-48 select-none" viewBox="0 0 100 100">
            <!-- Light bulb silhouette -->
            <path d="M 50,15 C 33,15 25,27 25,45 C 25,58 35,68 40,75 L 40,85 L 60,85 L 60,75 C 65,68 75,58 75,45 C 75,27 67,15 50,15 Z" fill="#000000" />
            <!-- Metal screw threads -->
            <rect x="42.5" y="86" width="15" height="3" fill="#64748b" rx="0.5" />
            <rect x="44" y="90" width="12" height="3" fill="#64748b" rx="0.5" />
            <ellipse cx="50" cy="94" rx="4" ry="1.5" fill="#475569" />
            <!-- Center red staring point -->
            <circle cx="50" cy="45" r="3.5" fill="#ff0000" />
          </svg>

          <!-- White screen overlay -->
          <div id="afterimage-screen" class="absolute inset-0 bg-white flex flex-col items-center justify-center hidden p-8 border-4 border-dashed border-red-500 transition-colors animate-pulse text-center">
            <!-- Staring dot for afterimage anchoring -->
            <div class="w-2.5 h-2.5 bg-black rounded-full mb-3"></div>
            <span class="text-slate-900 font-black text-2xl tracking-wider uppercase">Look Here! 💡</span>
            <p class="text-sm text-slate-500 font-bold max-w-sm mt-2">Stare at the black dot and blink. Do you see a glowing yellow light bulb floating in your vision?</p>
          </div>

          <div class="absolute bottom-4 flex flex-col items-center space-y-2 bg-slate-950/80 px-5 py-3 rounded-2xl border border-white/10 text-center w-11/12 max-w-xs">
            <!-- Progress Bar -->
            <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden mb-1 hidden" id="bulb-progress-bar-container">
              <div id="bulb-progress-fill" class="bg-emerald-500 h-full w-full transition-all duration-100"></div>
            </div>
            <div class="flex items-center justify-between w-full">
              <button id="btn-start-bulb" class="text-xs font-black px-4 py-2 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white transition-all shadow-md">Start Staring (30s)</button>
              <span id="bulb-timer-text" class="font-mono text-xs text-emerald-400 font-black">30.0s</span>
            </div>
          </div>
        </div>

        <!-- Experience Feedback Panel (hidden by default) -->
        <div id="experience-feedback-panel" class="hidden w-full p-6 bg-slate-900/90 border border-white/10 rounded-2xl text-left space-y-4 shadow-xl">
          <h4 class="text-xs font-black uppercase text-emerald-400 font-display">Stare Experience Verdict</h4>
          
          <div class="text-xs space-y-4">
            <div class="space-y-2">
              <p class="text-sm font-bold text-slate-200">What did you perceive?</p>
              <div class="p-4 bg-emerald-500/5 border border-emerald-500/20 rounded-xl text-xs text-slate-350 font-medium leading-relaxed">
                <span class="text-emerald-450 font-bold block mb-1">✓ Neurological Reality Check:</span>
                If you saw a glowing yellow light bulb floating on the white screen, <strong>that happened entirely inside your desensitized photoreceptors and visual cortex!</strong> The screen simply displays a plain white background with a black anchor dot.
              </div>
            </div>
            
            <div class="p-4 bg-slate-950/60 border border-slate-800 rounded-xl text-xs space-y-2 leading-relaxed">
              <strong class="text-slate-200 font-display">Troubleshooting (If you did not see the effect):</strong>
              <ul class="list-disc pl-4 space-y-1 text-slate-400 font-medium">
                <li>Keep your gaze locked strictly on the red center dot of the light bulb during the 30-second stare period.</li>
                <li>Do not blink or move your eyes at all while the timer runs—even tiny micro-movements refresh the retinal image and prevent desensitization.</li>
                <li>Once the white screen appears, blink rapidly to help refresh and isolate the afterimage against the white background.</li>
                <li>Ensure your screen brightness is sufficiently high (at least 60%) and you are in a moderately lit room.</li>
              </ul>
            </div>
            
            <button id="btn-reset-experience" class="w-full border border-emerald-500/30 text-emerald-400 hover:bg-emerald-500/10 font-bold text-xs py-2 rounded-xl transition-all">Try Again 🔄</button>
          </div>
        </div>

        <div class="text-center text-xs text-slate-500 dark:text-slate-400 italic">
          This illusion uses a fixed high-contrast display for best effect.
        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      
      <!-- Left 2-Columns -->
      <div class="lg:col-span-2 space-y-10">
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-emerald-500">🎮</span>
            <span>EXPERIENCE IT FIRST</span>
          </h2>
          <div class="bg-indigo-950/20 border-2 border-indigo-500/15 rounded-3xl p-6 text-slate-700 dark:text-slate-300">
            <p class="font-bold text-sm sm:text-base text-slate-200">Stare directly at the red center dot inside the black light bulb silhouette. Keep your eyes perfectly still for 30 seconds:</p>
            <ul class="list-disc pl-5 mt-3 space-y-2 text-xs sm:text-sm font-medium">
              <li>Try not to blink while the countdown timer runs.</li>
              <li>When the timer hits 0s, the bulb will vanish and a plain white screen with a target black dot will appear.</li>
              <li>Stare at the black target dot on the white screen. You will see a glowing, brightly illuminated light bulb float in your vision.</li>
              <li>If the afterimage begins to fade, blink rapidly—this will refresh the visual signal.</li>
            </ul>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-emerald-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed space-y-4 text-xs sm:text-sm font-semibold text-justify">
            <p>The Afterimage Light Bulb is a classic physiological illusion based on <strong>photoreceptor adaptation</strong> and the <strong>opponent-process theory of color vision</strong>. When you stare at a dark object like the black light bulb, your retina's photoreceptors (specifically the rods and cones) receive constant, intense stimulation. The cells processing the black outline send minimal signal, while the surrounding cells processing the bright white background become highly active.</p>
            
            <p>Over 30 seconds, the photoreceptors processing the bright white background become fatigued or desensitized. The photoreceptors in the center, which were shielded by the black bulb silhouette, remain fully rested. When you look at the uniform white screen, the fatigued receptors respond weakly, while the rested receptors respond strongly. Because yellow and blue are opponent colors (as are green-red), the rested receptors trigger the perception of the complementary color, making the black silhouette appear as a bright, glowing yellow light bulb.</p>
          </div>
        </section>
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-emerald-500">💡</span>
            <span>FUN FACTS</span>
          </h3>
          <ul class="space-y-4 text-xs sm:text-sm text-slate-600 dark:text-slate-350 font-semibold">
            <li class="flex items-start space-x-2">
              <span class="text-emerald-500 font-black">•</span>
              <span>Afterimages are classified as "negative" when the colors are reversed (like this one) and "positive" when the original colors persist.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-emerald-500 font-black">•</span>
              <span>Opponent-process theory, proposed by Ewald Hering in 1878, explains why we see cyan after red, green after pink, and yellow after black.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-emerald-500 font-black">•</span>
              <span>Blinking helps you see afterimages because it briefly cuts off incoming light, allowing the retina's neural adaptation signals to be processed cleanly.</span>
            </li>
          </ul>
        </section>

        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-emerald-500">📜</span>
            <span>HISTORY</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-655 dark:text-slate-350 leading-relaxed font-semibold">
            Physiological afterimages have been documented since Aristotle. However, the systematic science of visual exhaustion and retinal persistence was mapped in the 19th century, laying the groundwork for early cinematography and visual psychology.
          </p>
        </section>
      </div>
    </div>
  </div>

  <script>
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Interactive Bulb Logic
    const startBtn = document.getElementById('btn-start-bulb') as HTMLButtonElement;
    const timerText = document.getElementById('bulb-timer-text') as HTMLElement;
    const progressFill = document.getElementById('bulb-progress-fill') as HTMLElement;
    const progressContainer = document.getElementById('bulb-progress-bar-container');
    const screen = document.getElementById('afterimage-screen');
    const svgBulb = document.getElementById('svg-afterimage-bulb');

    const feedbackPanel = document.getElementById('experience-feedback-panel');
    const resetExpBtn = document.getElementById('btn-reset-experience');

    let secondsLeft = 30.0;
    let timerId: any = null;
    let staringActive = false;

    const hideFeedback = () => {
      feedbackPanel?.classList.add('hidden');
    };

    const stopBulb = () => {
      clearInterval(timerId);
      staringActive = false;
      secondsLeft = 30.0;
      timerText.textContent = '30.0s';
      progressContainer?.classList.add('hidden');
      screen?.classList.add('hidden');
      svgBulb?.classList.remove('hidden');
      startBtn.textContent = 'Start Staring (30s)';
      hideFeedback();
    };

    startBtn?.addEventListener('click', () => {
      if (staringActive) {
        stopBulb();
      } else {
        staringActive = true;
        secondsLeft = 30.0;
        timerText.textContent = '30.0s';
        progressContainer?.classList.remove('hidden');
        screen?.classList.add('hidden');
        svgBulb?.classList.remove('hidden');
        startBtn.textContent = 'Reset Stare 🔄';
        hideFeedback();

        const startTime = Date.now();
        timerId = setInterval(() => {
          const elapsed = (Date.now() - startTime) / 1000;
          secondsLeft = 30.0 - elapsed;
          if (secondsLeft <= 0) {
            secondsLeft = 0;
            clearInterval(timerId);
            timerText.textContent = '0.0s';
            progressContainer?.classList.add('hidden');
            svgBulb?.classList.add('hidden');
            screen?.classList.remove('hidden');
            startBtn.textContent = 'Try Stare Again 🔄';
            staringActive = false;
            
            // Show feedback panel
            feedbackPanel?.classList.remove('hidden');
          }
          if (timerText) timerText.textContent = `${secondsLeft.toFixed(1)}s`;
          if (progressFill) progressFill.style.width = `${(secondsLeft / 30.0) * 100}%`;
        }, 100);
      }
    });

    resetExpBtn?.addEventListener('click', () => {
      stopBulb();
    });
  </script>
</Layout>
