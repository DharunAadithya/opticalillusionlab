---
// src/pages/illusions/the-dress.astro
import Layout from '../../layouts/Layout.astro';

// Math Helper: draws an SVG wedge from (cx, cy) out to radius r
function getWedgePath(cx: number, cy: number, r: number, startAngle: number, endAngle: number) {
  const rad = Math.PI / 180;
  const x1 = cx + r * Math.cos(startAngle * rad);
  const y1 = cy + r * Math.sin(startAngle * rad);
  const x2 = cx + r * Math.cos(endAngle * rad);
  const y2 = cy + r * Math.sin(endAngle * rad);
  const largeArcFlag = endAngle - startAngle <= 180 ? 0 : 1;
  return `M ${cx},${cy} L ${x1},${y1} A ${r},${r} 0 ${largeArcFlag},1 ${x2},${y2} Z`;
}
