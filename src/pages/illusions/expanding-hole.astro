  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Handle Global Speed Mult
    const checkSpeed = () => {
      const level = localStorage.getItem('speed-multiplier-level') || '5';
      let multiplier = 1.0;
      const parsed = parseInt(level);
      if (parsed <= 5) {
        multiplier = 0.2 + (parsed - 1) * 0.2;
      } else {
        multiplier = 1.0 + (parsed - 5) * 0.4;
      }
      document.documentElement.style.setProperty('--speed-multiplier', multiplier.toString());
    };
    checkSpeed();
    window.addEventListener('storage', checkSpeed);

    // Prevent propagation on inner interactive controllers so we don't trigger parent clicks (if wrapped)
    const innerControls = document.querySelectorAll('.interactive-demo-card button, .interactive-demo-card input, .interactive-demo-card select');
    innerControls.forEach(ctrl => {
      ctrl.addEventListener('click', (e) => e.stopPropagation());
    });

    // Local script logic from original file
    const container = document.getElementById('hole-illusion');
      const btn = container?.querySelector('.toggle-static');
      btn?.addEventListener('click', () => {
        alert("Nothing changed, because this image is already 100% static! The expanding motion is completely fabricated inside your brain.");
      });
  </script>
</Layout>
