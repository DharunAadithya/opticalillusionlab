                    {r5.map(sect => (
                      <path d={sect.path} fill={sect.color} />
                    ))}
                  </g>
                  <!-- Ring 6 (CCW) -->
                  <g class="snake-ring ring-ccw ring-6 origin-center" style="transform-origin: 100px 100px;">
                    {r6.map(sect => (
                      <path d={sect.path} fill={sect.color} />
                    ))}
                  </g>
                  
                  <!-- Stare Challenge Center Dot -->
                  <circle cx="100" cy="100" r="5" fill="#f43f5e" stroke="#ffffff" stroke-width="1.5" />
                </svg>
              )
            })}
