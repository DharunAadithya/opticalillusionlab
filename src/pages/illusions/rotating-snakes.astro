        <div id="snakes-illusion" class="relative flex flex-col items-center justify-center min-h-[440px] py-8 w-full bg-slate-900 rounded-xl overflow-hidden border border-indigo-500/10">
          <div class="grid grid-cols-2 gap-8 md:gap-16 max-w-[340px] md:max-w-[400px]">
