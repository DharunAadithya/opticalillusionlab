              return (
                <svg 
                  class="snake-wheel w-36 h-36 origin-center select-none overflow-visible" 
                  viewBox="0 0 200 200"
                >
                  <!-- Ring 1 (CW) -->
                  <g class="snake-ring ring-cw ring-1 origin-center" style="transform-origin: 100px 100px;">
                    {r1.map(sect => (
                      <path d={sect.path} fill={sect.color} />
                    ))}
                  </g>
                  <!-- Ring 2 (CCW) -->
                  <g class="snake-ring ring-ccw ring-2 origin-center" style="transform-origin: 100px 100px;">
                    {r2.map(sect => (
                      <path d={sect.path} fill={sect.color} />
                    ))}
                  </g>
                  <!-- Ring 3 (CW) -->
                  <g class="snake-ring ring-cw ring-3 origin-center" style="transform-origin: 100px 100px;">
                    {r3.map(sect => (
                      <path d={sect.path} fill={sect.color} />
                    ))}
                  </g>
                  <!-- Ring 4 (CCW) -->
                  <g class="snake-ring ring-ccw ring-4 origin-center" style="transform-origin: 100px 100px;">
                    {r4.map(sect => (
