---
// src/pages/illusions/coffer-illusion.astro
import Layout from '../../layouts/Layout.astro';
import CofferDemo from '../../components/illusions/CofferDemo.astro';
---

<Layout 
  title="Coffer Illusion — Interactive Optical Illusion | Optical Illusion Lab" 
  description="Stare at a grid of rectangular panels. Can you find the 16 circles hidden in plain sight? Explore the science of visual grouping and edge detection."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/famous" class="hover:text-white transition-colors">Famous Illusions</a>
      <span>/</span>
      <span class="text-purple-400">Coffer Illusion</span>
    </nav>

    <!-- Hero Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Geometric</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-rose-500/10 text-rose-400 border border-rose-500/20 uppercase tracking-wider">🔴 Hard</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Coffer Illusion
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          A grid of rectangular panels that conceals 16 perfectly round circles. Can you train your eyes to see them?
        </p>
      </div>

      <!-- Share Button -->
      <button 
        id="share-illusion-page-btn"
        class="relative shrink-0 flex items-center space-x-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-sm px-6 py-3.5 transition-colors shadow-lg cursor-pointer border-none"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
        <span>Share Page</span>
        <span id="page-share-toast" class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-650 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
      </button>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-6">
        <CofferDemo isCard={false} />

        <!-- Overhauled feedback panel for Coffer -->
        <div id="coffer-feedback-panel" class="hidden w-full text-left text-xs bg-slate-950/90 p-4 rounded-xl border border-slate-800 space-y-3 mt-4">
          <h4 class="font-extrabold text-purple-400 text-sm border-b border-slate-800 pb-1.5 flex items-center justify-between">
            <span>Result Validation</span>
            <span id="coffer-feedback-status" class="font-bold text-rose-500 font-mono">Incorrect ✗</span>
          </h4>
          <p class="text-slate-350 text-xs">
            Correct answer: <strong class="text-white">16</strong>. You found: <strong id="coffer-user-guess" class="text-white">0</strong>.
          </p>
          <p class="text-slate-400 font-medium leading-relaxed">
            <strong>Why:</strong> The Coffer Illusion features 16 circles disguised by beveled line segments that form the 3D-like coffers. The brain groups the straight line segments first (Gestalt principles of continuity and closure) and suppresses the circular curves until your focus shifts specifically to the intersections.
          </p>
          <button id="coffer-try-again-btn" class="w-full bg-slate-800 hover:bg-slate-700 text-slate-300 font-bold py-2 rounded-lg text-xs border border-slate-700 shadow transition-all active:scale-95">Try Again</button>
        </div>

        <div class="text-center text-xs text-slate-500 dark:text-slate-400 italic">
          Try typing in your guess, or use "Highlight Circles" and "Hide Grid Lines" to reveal the geometry.
        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      
      <!-- Left 2-Columns -->
      <div class="lg:col-span-2 space-y-10">
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🎮</span>
            <span>EXPERIENCE IT FIRST</span>
          </h2>
          <div class="bg-indigo-950/20 border-2 border-indigo-500/15 rounded-3xl p-6 text-slate-700 dark:text-slate-350">
            <p class="font-bold text-sm sm:text-base text-slate-200">Test your optical grouping abilities with these visual steps:</p>
            <ul class="list-disc pl-5 mt-3 space-y-2 text-xs sm:text-sm font-medium">
              <li>Stare at the center of the image. At first glance, you will see a pattern of wooden-style coffers or rectangular panels with beveled borders.</li>
              <li>Try to locate circular lines. If you struggle, type your guess in the input box or click <strong>Highlight Circles</strong>.</li>
              <li>Once you see the circles highlighted in gold, click <strong>Hide Grid Lines</strong>. You will notice the square frames disappear completely, leaving only the 16 circles.</li>
              <li>When you toggle the grid back on, try to keep your focus on the circular lines. You will find your brain continually trying to pull your attention back to the straight frames!</li>
            </ul>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed space-y-4 text-xs sm:text-sm font-semibold text-justify">
            <p>
              The <strong>Coffer Illusion</strong> is a highly famous geometric illusion that demonstrates the competition between different levels of visual processing in the human brain. The visual stimulus is composed of a series of light and dark line segments arranged on a grey background. Because the lines form intersecting corners, the brain immediately groups them into a series of sunken square panels, or "coffers," which resemble classic architectural door panels.
            </p>
            
            <p>
              Why are the circles so difficult to see? The answer lies in how the brain's <strong>visual cortex</strong> (specifically areas V1 and V2) processes visual inputs. Neurons in these early stages are highly sensitive to orientation and contrast, functioning as edge detectors. The sharp corners, right angles, and parallel lines of the coffers represent a highly structured, coherent, and dominant set of signals. In cognitive psychology, this is known as <strong>Gestalt grouping</strong>. The brain groups the straight line segments first, prioritizing the rectangular structure and actively suppressing alternative groupings, such as the circular segments.
            </p>
            
            <p>
              Furthermore, the circles themselves are not drawn with continuous curves; rather, their boundaries are suggested by the segment arrangements at the intersections. Because the diagonal line segments imply a 3D bevel (which gives the boxes their sunken, realistic appearance), the brain prioritizes a 3D scene interpretation. Once your visual focus shifts to the center of the crosses or the intersection diagonals, the circular grouping is finally assembled in your higher-level visual areas (such as the <strong>lateral occipital complex</strong>). When the circular shape is recognized, it pops into consciousness, and you can suddenly perceive all 16 circles.
            </p>

            <p>
              This visual rivalry demonstrates that perception is an active, top-down reconstruction. The brain does not simply display the raw image captured by the retina; instead, it generates the most likely interpretation based on familiar structures (like right angles and 3D shapes). Even after you know the circles are present, the straight grid continues to compete for dominance, meaning the illusion remains active even after it has been "solved."
            </p>
          </div>
        </section>
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">💡</span>
            <span>FUN FACTS</span>
          </h3>
          <ul class="space-y-4 text-xs sm:text-sm text-slate-600 dark:text-slate-350 font-semibold">
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>The illusion was created by Anthony Norcia, a visual scientist at the Smith-Kettlewell Eye Research Institute in San Francisco, California.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>It won a finalist spot in the 2006 Best Illusion of the Year Contest, quickly becoming one of the most shared illusions on the internet.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>The term "coffer" refers to a decorative sunken panel in a ceiling, vault, or dome, which is why the illusion has a distinctly architectural feel.</span>
            </li>
          </ul>
        </section>

        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>CREATOR</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-355 leading-relaxed font-semibold">
            Anthony Norcia's research focuses on the development of the human visual system, binocular vision, and spatial awareness. The Coffer Illusion was created during studies on how visual elements are segmented and integrated into coherent objects.
          </p>
        </section>
      </div>
    </div>
  </div>

  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Handle Global Speed Mult
    const checkSpeed = () => {
      const level = localStorage.getItem('speed-multiplier-level') || '5';
      let multiplier = 1.0;
      const parsed = parseInt(level);
      if (parsed <= 5) {
        multiplier = 0.2 + (parsed - 1) * 0.2;
      } else {
        multiplier = 1.0 + (parsed - 5) * 0.4;
      }
      document.documentElement.style.setProperty('--speed-multiplier', multiplier.toString());
    };
    checkSpeed();
    window.addEventListener('storage', checkSpeed);
  </script>
</Layout>
