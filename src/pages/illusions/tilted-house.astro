---
// src/pages/illusions/tilted-house.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Tilted House Illusion — Interactive Optical Illusion | Optical Illusion Lab" 
  description="Watch the stationary house appear to wobble and tilt as the vertical guidelines in the background slant back and forth."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/moving" class="hover:text-white transition-colors">Moving Illusions</a>
      <span>/</span>
      <span class="text-purple-400">Tilted House</span>
    </nav>

    <!-- Hero Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Reference Frames</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Tilted House
        </h1>
        <p class="text-slate-600 dark:text-slate-300 text-base max-w-2xl font-medium">
          The house remains static, but skewing background vertical lines make the house wobble and tilt.
        </p>
      </div>

      <!-- Share Button -->
      <button 
        id="share-illusion-page-btn"
        class="relative shrink-0 flex items-center space-x-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-sm px-6 py-3.5 transition-colors shadow-lg cursor-pointer border-none"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
        <span>Share Page</span>
        <span id="page-share-toast" class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-650 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
      </button>
    </div>

    <!-- LARGE INTERACTIVE DEMO (Centered) -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[500px] mx-auto space-y-6 container-tilted-house">
        <div class="relative flex flex-col items-center justify-center bg-slate-900 rounded-2xl border border-slate-800 shadow-xl min-h-[380px] p-6 pb-20">
          
          <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 200 200">
            <style>
              @keyframes slant-lines-page {
                0%, 100% { transform: skewX(0deg); }
                25% { transform: skewX(-12deg); }
                75% { transform: skewX(12deg); }
              }
            </style>
            <!-- Background slanting lines group -->
            <g class="origin-center slanting-lines-group" style="transform-origin: 100px 100px; animation: slant-lines-page 8s ease-in-out infinite;">
              {Array.from({ length: 9 }).map((_, i) => (
                <line x1={20 + i * 20} y1="10" x2={20 + i * 20} y2="190" stroke="#334155" stroke-dasharray="3,3" stroke-width="1.5" />
              ))}
            </g>
            <!-- Static foreground house drawing -->
            <g stroke="#ffffff" stroke-width="3.5" fill="none" stroke-linejoin="round">
              <line x1="30" y1="150" x2="170" y2="150" />
              <rect x="50" y="90" width="100" height="60" />
              <polygon points="50,90 100,50 150,90" />
              <rect x="88" y="115" width="24" height="35" />
              <rect x="65" y="105" width="16" height="16" />
              <rect x="119" y="105" width="16" height="16" />
            </g>
          </svg>

          <!-- Controls Panel -->
          <div class="absolute bottom-3 left-4 right-4 flex items-center justify-between gap-4 bg-slate-950/90 p-2.5 rounded-xl border border-slate-800 shadow-sm z-20">
            <button class="btn-play-pause text-xs font-bold px-4 py-2 rounded-lg border-none bg-[#7C3AED] hover:bg-[#6D28D9] text-white shadow-sm transition-all cursor-pointer">
              Pause
            </button>
            <div class="flex items-center space-x-3 flex-1 justify-end max-w-xs">
              <span class="text-[10px] text-slate-400 font-bold uppercase shrink-0">Speed: <span class="speed-val text-purple-400 font-mono">1.0x</span></span>
              <input type="range" min="0.5" max="3" step="0.1" value="1.0" class="speed-slider w-32 h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-600 focus:outline-none" />
            </div>
          </div>
        </div>

        <div class="text-center text-xs text-slate-500 dark:text-slate-400 italic">
          Use the controllers inside the display card to adjust speed or pause animation.
        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      
      <!-- Left 2-Columns: Science and Prompt -->
      <div class="lg:col-span-2 space-y-10">
        <!-- EXPERIENCE IT FIRST prompt -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🎮</span>
            <span>EXPERIENCE IT FIRST</span>
          </h2>
          <div class="bg-indigo-950/20 border-2 border-indigo-500/15 rounded-3xl p-6 text-slate-700 dark:text-slate-300">
            <p class="font-bold text-sm sm:text-base text-slate-200">Before reading the neuroscience explanation below, take a moment to interact with the demo above:</p>
            <ul class="list-disc pl-5 mt-3 space-y-2 text-xs sm:text-sm font-medium">
              <li>How does the visual change when you move your eyes or look at different parts of the screen?</li>
              <li>Stare at the door of the house. Notice if the house appears to tilt in the opposite direction of the slanting lines.</li>
              <li>Try slowing down the speed or pausing the animation. Does the tilt disappear when the background lines are frozen?</li>
            </ul>
          </div>
        </section>

        <!-- THE SCIENCE -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed space-y-4 text-xs sm:text-sm font-semibold text-justify">
            <p>The Tilted House illusion exploits visual reference frames and gravity cues. The house drawing remains stationary, but the vertical guidelines and background lines slant back and forth. The brain uses the surrounding lines as a frame of reference to determine what is 'straight' or vertical.</p>
            <p>When the grid tilts, the visual system attempts to align the house with this skewed reference frame, making the house appear to lean in the opposite direction. This highlights the top-down cognitive integration of spatial orientation, showing how our perception of verticality is highly dependent on visual context.</p>
          </div>
        </section>
      </div>

      <!-- Right Column: Fun Facts and Try This -->
      <div class="space-y-8">
        <!-- FUN FACTS -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">💡</span>
            <span>FUN FACTS</span>
          </h3>
          <ul class="space-y-4 text-xs sm:text-sm text-slate-650 dark:text-slate-300 font-semibold">
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Related to the Zöllner illusion and the rod-and-frame illusion.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Our brain constructs a subjective vertical using visual cues, the vestibular system (inner ear), and proprioception.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>If you tilt your head at the same angle as the background lines, the house tilt effect is diminished.</span>
            </li>
          </ul>
        </section>

        <!-- WHO DISCOVERED IT -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>WHO DISCOVERED IT</span>
          </h3>
          <div class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold space-y-2">
            <p><strong>Discoverer:</strong> Experimental Psychologists (mid-20th century)</p>
            <p>Stemming from Witkin's 1948 "Rod and Frame" experiments on field dependence, this animated variant demonstrates that dynamic reference changes continuously skew the subjective visual vertical mapped in the parietal cortex.</p>
          </div>
        </section>
      </div>

    </div>

  </div>

  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Control Logic
    const initPageControls = () => {
      const container = document.querySelector('.container-tilted-house');
      if (!container) return;

      const linesGroup = container.querySelector('.slanting-lines-group') as SVGElement;
      const btnPlayPause = container.querySelector('.btn-play-pause') as HTMLButtonElement;
      const speedSlider = container.querySelector('.speed-slider') as HTMLInputElement;
      const speedVal = container.querySelector('.speed-val') as HTMLElement;

      let isPaused = false;

      btnPlayPause?.addEventListener('click', () => {
        isPaused = !isPaused;
        btnPlayPause.textContent = isPaused ? 'Play' : 'Pause';
        if (linesGroup) {
          linesGroup.style.animationPlayState = isPaused ? 'paused' : 'running';
        }
      });

      speedSlider?.addEventListener('input', () => {
        const val = parseFloat(speedSlider.value);
        if (speedVal) speedVal.textContent = val.toFixed(1) + 'x';
        if (linesGroup) {
          linesGroup.style.animationDuration = `${8 / val}s`;
        }
      });
    };

    initPageControls();
    document.addEventListener('astro:page-load', initPageControls);
  </script>
</Layout>
