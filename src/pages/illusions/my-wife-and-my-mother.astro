---
// src/pages/illusions/my-wife-and-my-mother.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="My Wife and My Mother-in-Law — Ambiguous Optical Illusion | Optical Illusion Lab" 
  description="W.E. Hill's famous ambiguous figure. Spot the young woman looking away or the old woman looking down. Test your spatial reasoning."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/hidden" class="hover:text-white transition-colors">Hidden & Ambiguous</a>
      <span>/</span>
      <span class="text-purple-400">My Wife and My Mother-in-Law</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Ambiguous</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-yellow-500/10 text-yellow-600 dark:text-yellow-450 border border-yellow-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          My Wife and My Mother-in-Law
        </h1>
        <p class="text-slate-600 dark:text-slate-355 text-base max-w-2xl font-medium">
          W.E. Hill (1915). A classic bistable portrait where the same contours define either a young wife looking away or a mother-in-law looking down.
        </p>
      </div>
      <button 
        id="share-illusion-page-btn"
        class="shrink-0 flex items-center space-x-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-sm px-6 py-3.5 transition-colors shadow-lg cursor-pointer border-none"
      >
        <span>Share Page</span>
      </button>
    </div>

    <!-- MAIN GRID CONTAINER -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <!-- Demo / SVG Column -->
      <div class="lg:col-span-2 space-y-6">
        <div id="illusion-card" class="relative flex flex-col items-center justify-center bg-white rounded-3xl border border-slate-200 p-8 min-h-[420px] shadow-sm select-none">
          
          <svg class="w-full max-w-[280px] h-auto aspect-[350/400] select-none" viewBox="0 0 350 400" id="svg-wife-mother" style="background: #808080; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.35);">
            <!-- Background scarf (dark charcoal) -->
            <path d="M 60,80 C 120,30 230,30 290,80 C 340,140 310,240 270,290 C 230,330 150,330 110,290 C 70,240 50,140 60,80 Z" fill="#1e293b" stroke="#0f172a" stroke-width="3" />
            <!-- Face silhouette (light gray) -->
            <path d="M 120,110 C 180,80 240,80 260,110 C 280,140 270,210 250,240 C 220,270 170,270 140,240 C 115,200 110,140 120,110 Z" fill="#cbd5e1" stroke="#0f172a" stroke-width="2" />
            <!-- Hair/fur collar (medium-dark gray) -->
            <path d="M 100,270 C 160,290 220,290 260,270 C 280,240 290,200 295,170 L 255,170 C 240,210 210,240 160,230 C 120,220 105,240 100,270 Z" fill="#475569" stroke="#0f172a" stroke-width="2" />
            <!-- Nose (Old woman nose / young woman cheek) -->
            <path d="M 160,170 C 125,185 130,205 145,215 C 160,225 165,215 155,205 C 170,195 175,180 160,170 Z" fill="#94a3b8" stroke="#0f172a" stroke-width="2.5" />
            <!-- Neckband / Mouth (Young necklace / old mouth) -->
            <path d="M 160,240 Q 185,245 210,240" fill="none" stroke="#ef4444" stroke-width="5" stroke-linecap="round" />
            <!-- Ear / Eye (Young ear / old eye) -->
            <path d="M 205,180 C 200,175 195,180 196,186 C 198,190 205,188 205,180 Z" fill="#f8fafc" stroke="#0f172a" stroke-width="2" />
            <!-- Eyelash / Wrinkle -->
            <path d="M 152,175 Q 148,180 142,185" fill="none" stroke="#0f172a" stroke-width="2" />
            <!-- Feather (white accent) -->
            <path d="M 210,80 Q 230,20 210,5 Q 190,20 210,80 Z" fill="#f1f5f9" stroke="#0f172a" stroke-width="1.5" />

            <!-- Young Woman highlights overlay (Blue #3B82F6) -->
            <g id="young-highlights" class="opacity-0 transition-opacity duration-300" fill="none" stroke="#3B82F6" stroke-width="5" stroke-linecap="round">
              <path class="reveal-path" d="M 152,175 Q 162,205 168,230" /> <!-- chin/jaw -->
              <path class="reveal-path" d="M 205,180 C 200,175 195,180 196,186 C 198,190 205,188 205,180 Z" /> <!-- ear -->
              <path class="reveal-path" d="M 160,240 Q 185,245 210,240" /> <!-- necklace -->
              <text x="210" y="270" fill="#3B82F6" font-size="12" font-weight="900" stroke="none">Necklace</text>
              <text x="220" y="170" fill="#3B82F6" font-size="12" font-weight="900" stroke="none">Ear</text>
              <text x="175" y="215" fill="#3B82F6" font-size="12" font-weight="900" stroke="none">Chin</text>
            </g>

            <!-- Old Woman highlights overlay (Orange #F97316) -->
            <g id="old-highlights" class="opacity-0 transition-opacity duration-300" fill="none" stroke="#F97316" stroke-width="5" stroke-linecap="round">
              <path class="reveal-path" d="M 160,170 C 125,185 130,205 145,215 C 160,225 165,215 155,205 C 170,195 175,180 160,170 Z" /> <!-- nose -->
              <path class="reveal-path" d="M 205,180 C 200,175 195,180 196,186 C 198,190 205,188 205,180 Z" /> <!-- eye -->
              <path class="reveal-path" d="M 160,240 Q 185,245 210,240" /> <!-- mouth -->
              <text x="210" y="270" fill="#F97316" font-size="12" font-weight="900" stroke="none">Mouth</text>
              <text x="220" y="170" fill="#F97316" font-size="12" font-weight="900" stroke="none">Eye</text>
              <text x="100" y="195" fill="#F97316" font-size="12" font-weight="900" stroke="none">Nose</text>
            </g>
          </svg>

          <!-- Interactive controls at bottom -->
          <div class="w-full max-w-sm mt-6 space-y-4">
            <!-- Timer container -->
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200 text-xs">
              <span class="font-bold text-slate-500 uppercase">Find the Hidden Figure</span>
              <span id="countdown-timer" class="font-mono font-bold text-slate-700">30.0s</span>
            </div>

            <!-- Reveal & Hide Buttons -->
            <div class="flex gap-2 w-full">
              <button id="btn-reveal" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow">
                Reveal
              </button>
              <button id="btn-hide" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow hidden">
                Hide Answer
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Science / Explanation Column -->
      <div class="space-y-8">
        <section id="science-section" class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>
              <strong>Bistable Imagery & Border Ownership:</strong> This famous portrait shows how a single contour is mapped differently based on top-down mental models. 
            </p>
            <p>
              The young woman's cheek and jawline become the old woman's nose. The young woman's ear is the old woman's eye, and the young woman's neckband represents the old woman's mouth. The brain cannot hold both schemas in focus simultaneously. Once you recognize one face, it is easier to trigger it again, illustrating how neural networks consolidate templates and filter raw inputs.
            </p>
          </div>
        </section>

        <!-- RELATED LINKS -->
        <section class="border-t border-indigo-500/10 pt-6 space-y-3">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white">Related Illusions</h3>
          <div class="grid grid-cols-1 gap-3">
            <a href="/illusions/rubin-vase" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Rubin's Vase &rarr;
            </a>
            <a href="/illusions/duck-rabbit" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Duck-Rabbit Illusion &rarr;
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>

  <style>
    /* 1.5s stroke dashoffset animation */
    .reveal-path {
      stroke-dasharray: 1000;
      stroke-dashoffset: 1000;
    }
  </style>

  <script>
    function initWifeMother() {
      const timerText = document.getElementById('countdown-timer');
      const btnReveal = document.getElementById('btn-reveal') as HTMLButtonElement;
      const btnHide = document.getElementById('btn-hide') as HTMLButtonElement;
      
      const youngG = document.getElementById('young-highlights');
      const oldG = document.getElementById('old-highlights');

      let secondsLeft = 30.0;
      let timerActive = true;
      let isRevealed = false;

      const startTime = Date.now();
      const intervalId = setInterval(() => {
        if (!timerActive) {
          clearInterval(intervalId);
          return;
        }
        const elapsed = (Date.now() - startTime) / 1000;
        secondsLeft = Math.max(30.0 - elapsed, 0.0);
        if (timerText) timerText.textContent = `${secondsLeft.toFixed(1)}s`;

        if (secondsLeft <= 0) {
          clearInterval(intervalId);
          triggerReveal();
        }
      }, 100);

      const triggerReveal = () => {
        isRevealed = true;
        timerActive = false;
        if (timerText) timerText.textContent = '0.0s';
        
        btnReveal?.classList.add('hidden');
        btnHide?.classList.remove('hidden');

        // Draw animated outlines
        if (youngG && oldG) {
          youngG.classList.remove('opacity-0');
          oldG.classList.remove('opacity-0');

          youngG.querySelectorAll('.reveal-path').forEach(p => {
            const path = p as SVGPathElement;
            path.style.strokeDasharray = '1000';
            path.style.strokeDashoffset = '1000';
            path.getBoundingClientRect();
            path.style.transition = 'stroke-dashoffset 1.5s ease-in-out';
            path.style.strokeDashoffset = '0';
          });

          oldG.querySelectorAll('.reveal-path').forEach(p => {
            const path = p as SVGPathElement;
            path.style.strokeDasharray = '1000';
            path.style.strokeDashoffset = '1000';
            path.getBoundingClientRect();
            path.style.transition = 'stroke-dashoffset 1.5s ease-in-out';
            path.style.strokeDashoffset = '0';
          });
        }
      };

      const triggerHide = () => {
        isRevealed = false;
        btnReveal?.classList.remove('hidden');
        btnHide?.classList.add('hidden');

        if (youngG && oldG) {
          youngG.classList.add('opacity-0');
          oldG.classList.add('opacity-0');
          
          youngG.querySelectorAll('.reveal-path').forEach(p => {
            (p as SVGPathElement).style.strokeDasharray = '1000';
            (p as SVGPathElement).style.strokeDashoffset = '1000';
          });

          oldG.querySelectorAll('.reveal-path').forEach(p => {
            (p as SVGPathElement).style.strokeDasharray = '1000';
            (p as SVGPathElement).style.strokeDashoffset = '1000';
          });
        }
      };

      btnReveal?.addEventListener('click', triggerReveal);
      btnHide?.addEventListener('click', triggerHide);
    }

    initWifeMother();
    document.addEventListener('astro:page-load', initWifeMother);
  </script>
</Layout>
