    const container = document.getElementById('pinna-illusion');
      const ring1 = container?.querySelector('.pinna-ring-1') as SVGElement;
      const ring2 = container?.querySelector('.pinna-ring-2') as SVGElement;
      const btn = container?.querySelector('.toggle-pinna-spin');
      let spinning = false;

      btn?.addEventListener('click', () => {
        spinning = !spinning;
        if (ring1 && ring2) {
          if (spinning) {
            ring1.style.animation = 'spin-clockwise calc(20s / var(--speed-multiplier, 1)) linear infinite';
            ring2.style.animation = 'spin-counter calc(25s / var(--speed-multiplier, 1)) linear infinite';
            if (btn) btn.textContent = 'Stop Spin';
          } else {
            ring1.style.animation = '';
            ring2.style.animation = '';
            if (btn) btn.textContent = 'Start Spin (Prove static is same)';
          }
        }
      });
  </script>
</Layout>
