---
// src/pages/illusions/all-is-vanity.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="All is Vanity — Optical Illusion Lab" 
  description="Explore the science, history, and visual parameters of the All is Vanity optical illusion."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <span class="text-purple-400">All is Vanity</span>
    </nav>

    <!-- Hero Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Ambiguous</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          All is Vanity
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          Discover how the brain interprets this fascinating ambiguous visual puzzle.
        </p>
      </div>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-6">
        <div class="relative flex flex-col items-center justify-center min-h-[460px] w-full bg-slate-100 dark:bg-slate-950/40 rounded-3xl overflow-hidden border border-indigo-500/10 p-6">
          
          <svg id="svg-vanity" class="select-none bg-slate-900 rounded-xl p-4 shadow-2xl" viewBox="0 0 200 200" width="300" height="300">
            <!-- Vanity mirror (Skull head outline) -->
            <circle cx="100" cy="80" r="50" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-200" />
            <!-- Eye sockets (Woman's head and its reflection) -->
            <circle cx="85" cy="85" r="14" fill="none" stroke="#64748b" stroke-width="1.5" />
            <circle cx="115" cy="85" r="14" fill="none" stroke="#64748b" stroke-width="1.5" />
            <path d="M 80,85 C 80,75 90,75 90,85" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-200" />
            <path d="M 110,85 C 110,75 120,75 120,85" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-200" />
            <!-- Table / Jaw line -->
            <path d="M 40,140 L 160,140 L 150,175 L 50,175 Z" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-200" />
            <!-- Perfume bottles (Teeth) -->
            <g stroke="currentColor" stroke-width="1.5" class="text-slate-200">
              <line x1="85" y1="140" x2="85" y2="152" />
              <line x1="92" y1="140" x2="92" y2="152" />
              <line x1="100" y1="140" x2="100" y2="152" />
              <line x1="108" y1="140" x2="108" y2="152" />
              <line x1="115" y1="140" x2="115" y2="152" />
            </g>
            
            <!-- Skull Overlay -->
            <g id="vanity-overlay-skull" class="opacity-0 transition-opacity duration-300 pointer-events-none">
              <circle cx="100" cy="80" r="50" fill="none" stroke="#ef4444" stroke-width="3" />
              <path d="M 75,130 L 125,130 L 115,160 L 85,160 Z" fill="none" stroke="#ef4444" stroke-width="3" />
              <text x="100" y="25" fill="#ef4444" font-size="11" font-weight="900" text-anchor="middle">Skull Shape</text>
            </g>
            <!-- Woman Overlay -->
            <g id="vanity-overlay-woman" class="opacity-0 transition-opacity duration-300 pointer-events-none">
              <circle cx="85" cy="85" r="16" fill="none" stroke="#3b82f6" stroke-width="2.5" />
              <circle cx="115" cy="85" r="16" fill="none" stroke="#3b82f6" stroke-width="2.5" />
              <text x="100" y="62" fill="#60a5fa" font-size="10" font-weight="900" text-anchor="middle">Woman & Reflection</text>
            </g>
          </svg>

          <!-- Interactive Vote Panel -->
          <div class="mt-6 flex flex-col items-center gap-3 bg-slate-900/90 border border-white/5 p-4 rounded-2xl w-full max-w-sm">
            <div class="flex items-center justify-between w-full text-xs font-bold text-slate-350">
              <span>Which did you see first?</span>
            </div>
            
            <div class="flex w-full gap-2">
              <button id="btn-vote-woman" class="flex-1 bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 rounded-xl transition-all active:scale-95 shadow">A Woman 👩</button>
              <button id="btn-vote-skull" class="flex-1 bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 rounded-xl transition-all active:scale-95 shadow">A Skull 💀</button>
            </div>
            
            <div id="vote-feedback" class="hidden w-full text-left space-y-2 border-t border-slate-800 pt-2 text-xs">
              <p class="text-[10px] text-purple-400 font-bold">Your selection: <span id="user-selection" class="text-white"></span></p>
              <div class="flex justify-between font-bold text-slate-300 text-[10px]">
                <span>👩 Woman: <span id="pct-woman">45%</span></span>
                <span>💀 Skull: <span id="pct-skull">55%</span></span>
              </div>
              <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden flex">
                <div id="bar-woman" class="bg-purple-500 h-full" style="width: 45%;"></div>
                <div id="bar-skull" class="bg-indigo-400 h-full" style="width: 55%;"></div>
              </div>
            </div>

            <div class="flex w-full gap-2 mt-1">
              <button id="btn-toggle-woman" class="flex-1 border border-blue-500/30 text-blue-400 hover:bg-blue-500/10 font-bold text-[10px] py-2 rounded-xl transition-all">Show Woman 👩</button>
              <button id="btn-toggle-skull" class="flex-1 border border-rose-500/30 text-rose-400 hover:bg-rose-500/10 font-bold text-[10px] py-2 rounded-xl transition-all">Show Skull 💀</button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      <!-- Left 2-Columns -->
      <div class="lg:col-span-2 space-y-10">
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>All is Vanity is a classic ambiguous composite drawing created by American illustrator Charles Allan Gilbert in 1892. It depicts a young woman sitting at a vanity mirror, looking at her reflection. However, when viewed from a distance, the entire scene blends to form the shape of a human skull. The round vanity mirror forms the dome of the skull, the woman's head and its reflection form the dark eye sockets, and the perfume bottles and cosmetics on the table form the row of teeth along the jaw. This illusion demonstrates how the visual system groups high-frequency detail (the woman and cosmetics) and low-frequency structures (the skull) differently based on viewing distance and focus.</p>
          </div>
        </section>
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>HISTORY</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-355 leading-relaxed font-semibold">
            First described by Charles Allan Gilbert (1892). It remains a fundamental demonstration of perceptual processing and cognitive framing.
          </p>
        </section>
      </div>
    </div>
  </div>

  <script>
    const btnVoteWoman = document.getElementById('btn-vote-woman');
    const btnVoteSkull = document.getElementById('btn-vote-skull');
    const voteFeedback = document.getElementById('vote-feedback');
    const userSelection = document.getElementById('user-selection');
    const pctWoman = document.getElementById('pct-woman');
    const pctSkull = document.getElementById('pct-skull');
    const barWoman = document.getElementById('bar-woman');
    const barSkull = document.getElementById('bar-skull');

    const btnToggleWoman = document.getElementById('btn-toggle-woman');
    const btnToggleSkull = document.getElementById('btn-toggle-skull');

    const overlayWoman = document.getElementById('vanity-overlay-woman');
    const overlaySkull = document.getElementById('vanity-overlay-skull');

    const handleVote = (choice) => {
      if (userSelection) userSelection.textContent = choice === 'woman' ? "A Woman 👩" : "A Skull 💀";
      if (voteFeedback) voteFeedback.classList.remove('hidden');
      
      let wVal = 48;
      let sVal = 52;
      if (choice === 'woman') {
        wVal = 51;
        sVal = 49;
      } else {
        wVal = 46;
        sVal = 54;
      }
      if (pctWoman) pctWoman.textContent = wVal + '%';
      if (pctSkull) pctSkull.textContent = sVal + '%';
      if (barWoman) barWoman.style.width = wVal + '%';
      if (barSkull) barSkull.style.width = sVal + '%';
    };

    btnVoteWoman?.addEventListener('click', () => handleVote('woman'));
    btnVoteSkull?.addEventListener('click', () => handleVote('skull'));

    btnToggleWoman?.addEventListener('click', () => {
      const shown = overlayWoman?.classList.contains('opacity-100');
      if (shown) {
        overlayWoman?.classList.replace('opacity-100', 'opacity-0');
        if (btnToggleWoman) btnToggleWoman.textContent = "Show Woman 👩";
      } else {
        overlayWoman?.classList.replace('opacity-0', 'opacity-100');
        if (btnToggleWoman) btnToggleWoman.textContent = "Hide Woman 👩";
      }
    });

    btnToggleSkull?.addEventListener('click', () => {
      const shown = overlaySkull?.classList.contains('opacity-100');
      if (shown) {
        overlaySkull?.classList.replace('opacity-100', 'opacity-0');
        if (btnToggleSkull) btnToggleSkull.textContent = "Show Skull 💀";
      } else {
        overlaySkull?.classList.replace('opacity-0', 'opacity-100');
        if (btnToggleSkull) btnToggleSkull.textContent = "Hide Skull 💀";
      }
    });
  </script>
</Layout>
