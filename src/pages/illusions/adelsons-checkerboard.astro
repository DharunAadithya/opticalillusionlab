---
// src/pages/illusions/adelsons-checkerboard.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Adelson Checkerboard — Interactive Optical Illusion | Optical Illusion Lab" 
  description="Tile A in the light and Tile B in the cylinder shadow are identical gray colors, though your brain insists B is much lighter."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    
    <!-- Breadcrumb back navigation to Section -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/color" class="hover:text-white transition-colors">Color Perceptual</a>
      <span>/</span>
      <span class="text-purple-400">Adelson Checkerboard</span>
    </nav>

    <!-- Hero Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Color Constancy</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Adelson Checkerboard
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          Tile A in the light and Tile B in the cylinder shadow are identical gray colors, though your brain insists B is much lighter.
        </p>
      </div>

      <!-- Share Button -->
      <button 
        id="share-illusion-page-btn"
        class="relative shrink-0 flex items-center space-x-2 rounded-2xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 hover:scale-105 text-white font-black text-sm px-6 py-3.5 transition-all shadow-lg shadow-purple-500/10"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
        <span>Share Page</span>
        <span id="page-share-toast" class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-650 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
      </button>
    </div>

    <!-- LARGE INTERACTIVE DEMO (Fixed dark display for accuracy) -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-4">
        
        <!-- Instruction Text Box required by Section G -->
        <div class="bg-indigo-950/40 border border-indigo-500/25 rounded-2xl p-4 text-slate-300 text-xs sm:text-sm font-semibold">
          👁️ WHAT TO LOOK FOR: Tile A is in light. Tile B is in shadow. Tile B looks lighter, but they\'re the exact same gray. Click \'Reveal Truth\' if you don\'t believe it.
        </div>

        <div id="adelson-illusion-container" class="relative flex flex-col items-center justify-center h-96 w-full bg-slate-900 rounded-xl overflow-hidden border border-indigo-500/10 p-4">
          
          <!-- Wrapper for Board + cylinder + labels to keep geometry absolute -->
          <div class="relative w-[320px] h-[320px] select-none rounded shadow-inner">
            
            <!-- 8x8 Checkerboard Grid -->
            <div class="grid grid-cols-8 grid-rows-8 w-[320px] h-[320px]">
              {Array.from({ length: 64 }).map((_, index) => {
                const row = Math.floor(index / 8);
                const col = index % 8;
                const isDark = (row + col) % 2 === 0;
                // #c8c8c8 for light, #888888 for dark (adjusted so Tile A renders as #888888 outside the shadow)
                const bgColor = isDark ? '#888888' : '#c8c8c8';
                return (
                  <div 
                    style={`background-color: ${bgColor};`} 
                    class="w-10 h-10 transition-colors duration-300"
                  />
                );
              })}
            </div>

            <!-- Shadow Overlay SVG (z-index 10) -->
            <svg class="absolute inset-0 w-[320px] h-[320px] pointer-events-none" style="z-index: 10;">
              <polygon 
                id="adelson-shadow"
                points="230,135 295,145 160,320 40,200" 
                fill="rgba(0,0,0,0.32)" 
                class="transition-opacity duration-300"
              />
            </svg>

            <!-- Reveal Bridge SVG (z-index 20) -->
            <svg class="absolute inset-0 w-[320px] h-[320px] pointer-events-none" style="z-index: 20;">
              <line 
                id="adelson-bridge" 
                x1="100" y1="100" 
                x2="180" y2="220" 
                stroke="#888888" 
                stroke-width="16" 
                class="opacity-0 transition-opacity duration-300"
              />
            </svg>

            <!-- Green Cylinder (60x140px, rounded bottom, top cap for 3D gradient effect, z-index 15) -->
            <div class="absolute w-[60px] h-[140px] rounded-b-[20px] bg-gradient-to-r from-green-600 via-green-400 to-green-800 border border-green-700 shadow-lg" style="left: 230px; top: 10px; z-index: 15;">
              <!-- Cylinder top cap for 3D effect -->
              <div class="absolute top-0 left-0 w-full h-[20px] rounded-full bg-green-300 border border-green-400"></div>
            </div>

            <!-- Label A: white circle, black letter, z-index above everything (z-index 25), centered exactly on Tile A (Row 2, Col 2) -->
            <div class="absolute w-6 h-6 rounded-full bg-white text-black flex items-center justify-center font-bold text-xs shadow-md select-none border border-black/10" style="left: 88px; top: 88px; z-index: 25;">A</div>

            <!-- Label B: white circle, black letter, z-index above shadow (z-index 25), centered exactly on Tile B (Row 5, Col 4) -->
            <div class="absolute w-6 h-6 rounded-full bg-white text-black flex items-center justify-center font-bold text-xs shadow-md select-none border border-black/10" style="left: 168px; top: 208px; z-index: 25;">B</div>

          </div>

          <!-- Controls inside the display card -->
          <div class="absolute bottom-4 flex space-x-2 bg-slate-950/90 border border-white/10 rounded-xl p-1 z-30">
            <button id="btn-toggle-bridge" class="text-xs font-bold px-3 py-1.5 rounded-lg text-slate-400 hover:text-white transition-all">Reveal Truth</button>
            <button id="btn-toggle-shadow" class="text-xs font-bold px-3 py-1.5 rounded-lg text-slate-400 hover:text-white transition-all">Remove Shadow</button>
          </div>
        </div>
    
        <div class="text-center text-xs text-slate-500 dark:text-slate-400 italic">
          This illusion uses a fixed display for accuracy.
        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      
      <!-- Left 2-Columns: Science and Prompt -->
      <div class="lg:col-span-2 space-y-10">
        <!-- EXPERIENCE IT FIRST prompt -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🎮</span>
            <span>EXPERIENCE IT FIRST</span>
          </h2>
          <div class="bg-indigo-950/20 border-2 border-indigo-500/15 rounded-3xl p-6 text-slate-700 dark:text-slate-300">
            <p class="font-bold text-sm sm:text-base text-slate-200">Before reading the neuroscience explanation below, take a moment to interact with the demo above:</p>
            <ul class="list-disc pl-5 mt-3 space-y-2 text-xs sm:text-sm font-medium">
              <li>How does the visual change when you move your eyes or look at different parts of the screen?</li>
              <li>Use the buttons below the board to toggle the shadow or connect the squares with a gray bridge. Did it match what your eyes predicted?</li>
              <li>Pay attention to whether you can consciously force your brain to see them as the same shade when the shadow is present.</li>
            </ul>
          </div>
        </section>

        <!-- THE SCIENCE (400 words) -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed space-y-4 text-xs sm:text-sm font-semibold text-justify">
            <p>Adelson\'s Checker Shadow illusion demonstrates the neural mechanics of color constancy and lightness perception. Our visual system is not built to act as a physical light meter (photometer). When light hits the retina, it stimulates photoreceptors in proportion to the raw luminance. However, if our brain relied solely on this raw sensory input, an object\'s color would appear to change constantly as light and shadows shifted, rendering object identification impossible.</p>
            
            <p>To solve this, the visual cortex (specifically areas V1, V2, and V4) performs complex contextual calculations. The brain identifies that a green cylinder is casting a diagonal shadow. It understands that shadows decrease the amount of light reflecting off a surface. Therefore, the brain automatically and unconsciously scales up the perceived brightness of Tile B (a light tile in shadow) to compensate, while leaving Tile A (a dark tile in direct light) unadjusted. Opponent process pathways and lateral inhibition networks in the lateral geniculate nucleus (LGN) reinforce these boundary differences. When a solid gray bridge is drawn to connect A and B, the local contrast cues are bypassed, forcing the brain to see that both tiles reflect the exact same wavelength and intensity of light.</p>
          </div>
        </section>
      </div>

      <!-- Right Column: Fun Facts and Try This -->
      <div class="space-y-8">
        <!-- FUN FACTS -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">💡</span>
            <span>FUN FACTS</span>
          </h3>
          <ul class="space-y-4 text-xs sm:text-sm text-slate-650 dark:text-slate-300 font-semibold">
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Edward Adelson created the checkerboard diagram in 1995 to illustrate that visual systems calculate relative reflectance rather than absolute luminance.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Our eyes are incapable of judging absolute HSL values; we perceive color solely by comparing neighboring wavelengths.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>The illusion is so powerful that it persists even when you know the tiles are identical, proving it operates in early visual processing channels.</span>
            </li>
          </ul>
        </section>

        <!-- TRY THIS AT HOME -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧪</span>
            <span>TRY THIS AT HOME</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold">
            Print the checkerboard image on standard paper. Take a scissors and cut out squares A and B. Hold them side-by-side in direct light, and watch them instantly transform into the exact same shade of gray!
          </p>
        </section>

        <!-- WHO DISCOVERED IT -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>WHO DISCOVERED IT</span>
          </h3>
          <div class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold space-y-2">
            <p><strong>Discoverer:</strong> Edward H. Adelson (1995)</p>
            <p>Edward Adelson, a professor of Vision Science at MIT, designed this checkerboard digitally to prove that shadow cues are processed automatically by the visual cortex to determine physical surface properties.</p>
          </div>
        </section>
      </div>

    </div>

    <!-- SEO content: 300 words naturally written -->
    <section class="border-t border-indigo-500/10 pt-12 space-y-4 max-w-4xl mx-auto">
      <h3 class="font-display text-lg font-black text-white uppercase tracking-wider text-center">Educational Resources & History</h3>
      <p class="text-xs sm:text-sm text-slate-350 leading-relaxed text-justify font-semibold">
        Adelson Checkerboard optical illusion explanation and science. Discover how color constancy and visual cortex processing in V1 and V4 override raw retinal luminance, making identical gray tiles appear completely different. Learn about Edward Adelson\'s famous 1995 checker shadow experiment and test it yourself with our interactive SVG checkerboard widget.
      </p>
    </section>

    <!-- RELATED ILLUSIONS -->
    <section class="border-t border-indigo-500/10 pt-12 space-y-6">
      <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white text-center">Related Illusions</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a 
          href="/illusions/simultaneous-contrast" 
          class="group rounded-xl border border-indigo-950/20 bg-white dark:bg-slate-900/60 p-5 shadow-lg hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-purple-500/10 transition-all duration-300"
        >
          <div class="text-[10px] font-bold text-purple-400 uppercase tracking-wide">Related Illusion</div>
          <h4 class="font-display text-base font-bold text-slate-900 dark:text-white mt-1 group-hover:text-purple-400 transition-colors">
            Simultaneous Contrast &rarr;
          </h4>
        </a>
        <a 
          href="/illusions/wertheimer-koffka" 
          class="group rounded-xl border border-indigo-950/20 bg-white dark:bg-slate-900/60 p-5 shadow-lg hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-purple-500/10 transition-all duration-300"
        >
          <div class="text-[10px] font-bold text-purple-400 uppercase tracking-wide">Related Illusion</div>
          <h4 class="font-display text-base font-bold text-slate-900 dark:text-white mt-1 group-hover:text-purple-400 transition-colors">
            Wertheimer Koffka &rarr;
          </h4>
        </a>
        <a 
          href="/illusions/color-spheres" 
          class="group rounded-xl border border-indigo-950/20 bg-white dark:bg-slate-900/60 p-5 shadow-lg hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-purple-500/10 transition-all duration-300"
        >
          <div class="text-[10px] font-bold text-purple-400 uppercase tracking-wide">Related Illusion</div>
          <h4 class="font-display text-base font-bold text-slate-900 dark:text-white mt-1 group-hover:text-purple-400 transition-colors">
            Color Spheres &rarr;
          </h4>
        </a>
      </div>
    </section>

  </div>

  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Control selectors
    const shadowPolygon = document.getElementById('adelson-shadow');
    const bridgeLine = document.getElementById('adelson-bridge');
    const toggleBridgeBtn = document.getElementById('btn-toggle-bridge');
    const toggleShadowBtn = document.getElementById('btn-toggle-shadow');

    let shadowVisible = true;
    let bridgeVisible = false;

    toggleBridgeBtn?.addEventListener('click', () => {
      bridgeVisible = !bridgeVisible;
      if (bridgeLine) {
        bridgeLine.style.opacity = bridgeVisible ? '1' : '0';
      }
      if (toggleBridgeBtn) {
        toggleBridgeBtn.textContent = bridgeVisible ? 'Hide Bridge' : 'Reveal Truth';
        if (bridgeVisible) {
          toggleBridgeBtn.classList.add('bg-purple-600', 'text-white');
          toggleBridgeBtn.classList.remove('text-slate-400');
        } else {
          toggleBridgeBtn.classList.remove('bg-purple-600', 'text-white');
          toggleBridgeBtn.classList.add('text-slate-400');
        }
      }
    });

    toggleShadowBtn?.addEventListener('click', () => {
      shadowVisible = !shadowVisible;
      if (shadowPolygon) {
        shadowPolygon.style.opacity = shadowVisible ? '1' : '0';
      }
      if (toggleShadowBtn) {
        toggleShadowBtn.textContent = shadowVisible ? 'Remove Shadow' : 'Restore Shadow';
        if (!shadowVisible) {
          toggleShadowBtn.classList.add('bg-purple-600', 'text-white');
          toggleShadowBtn.classList.remove('text-slate-400');
        } else {
          toggleShadowBtn.classList.remove('bg-purple-600', 'text-white');
          toggleShadowBtn.classList.add('text-slate-400');
        }
      }
    });
  </script>
</Layout>
