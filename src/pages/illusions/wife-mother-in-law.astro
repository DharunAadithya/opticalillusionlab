---
// src/pages/illusions/wife-mother-in-law.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="My Wife and My Mother-in-Law — Optical Illusion Lab" 
  description="Explore the science, history, and visual parameters of the My Wife and My Mother-in-Law optical illusion."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <span class="text-purple-400">My Wife and My Mother-in-Law</span>
    </nav>

    <!-- Hero Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Ambiguous</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          My Wife and My Mother-in-Law
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          Discover how the brain interprets this fascinating ambiguous visual puzzle.
        </p>
      </div>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-6">
        <div class="relative flex flex-col items-center justify-center min-h-[460px] w-full bg-slate-100 dark:bg-slate-950/40 rounded-3xl overflow-hidden border border-indigo-500/10 p-6">
          
          <svg class="select-none" viewBox="0 0 350 400" width="300" height="342" style="background: #808080; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.35);">
            <!-- Background scarf (dark charcoal) -->
            <path d="M 60,80 C 120,30 230,30 290,80 C 340,140 310,240 270,290 C 230,330 150,330 110,290 C 70,240 50,140 60,80 Z" fill="#1e293b" stroke="#0f172a" stroke-width="3" />
            <!-- Face silhouette (light gray) -->
            <path d="M 120,110 C 180,80 240,80 260,110 C 280,140 270,210 250,240 C 220,270 170,270 140,240 C 115,200 110,140 120,110 Z" fill="#cbd5e1" stroke="#0f172a" stroke-width="2" />
            <!-- Hair/fur collar (medium-dark gray) -->
            <path d="M 100,270 C 160,290 220,290 260,270 C 280,240 290,200 295,170 L 255,170 C 240,210 210,240 160,230 C 120,220 105,240 100,270 Z" fill="#475569" stroke="#0f172a" stroke-width="2" />
            <!-- Nose (Old woman nose / young woman cheek) -->
            <path d="M 160,170 C 125,185 130,205 145,215 C 160,225 165,215 155,205 C 170,195 175,180 160,170 Z" fill="#94a3b8" stroke="#0f172a" stroke-width="2.5" />
            <!-- Neckband / Mouth (Young necklace / old mouth) -->
            <path d="M 160,240 Q 185,245 210,240" fill="none" stroke="#ef4444" stroke-width="5" stroke-linecap="round" />
            <!-- Ear / Eye (Young ear / old eye) -->
            <path d="M 205,180 C 200,175 195,180 196,186 C 198,190 205,188 205,180 Z" fill="#f8fafc" stroke="#0f172a" stroke-width="2" />
            <!-- Eyelash / Wrinkle -->
            <path d="M 152,175 Q 148,180 142,185" fill="none" stroke="#0f172a" stroke-width="2" />
            <!-- Feather (white accent) -->
            <path d="M 210,80 Q 230,20 210,5 Q 190,20 210,80 Z" fill="#f1f5f9" stroke="#0f172a" stroke-width="1.5" />
            
            <!-- Young Woman highlights overlay -->
            <g id="overlay-young" class="opacity-0 transition-opacity duration-300 pointer-events-none">
              <circle cx="205" cy="180" r="10" stroke="#3b82f6" stroke-width="3" fill="none" />
              <path d="M 160,240 Q 185,245 210,240" stroke="#3b82f6" stroke-width="4.5" fill="none" />
              <text x="225" y="180" fill="#3b82f6" font-size="12" font-weight="900">Young Ear</text>
              <text x="225" y="250" fill="#3b82f6" font-size="12" font-weight="900">Choker Necklace</text>
            </g>

            <!-- Old Woman highlights overlay -->
            <g id="overlay-old" class="opacity-0 transition-opacity duration-300 pointer-events-none">
              <path d="M 160,170 C 125,185 130,205 145,215" stroke="#ef4444" stroke-width="4.5" fill="none" />
              <circle cx="205" cy="180" r="5" fill="#ef4444" />
              <text x="50" y="170" fill="#ef4444" font-size="12" font-weight="900">Old Nose</text>
              <text x="225" y="200" fill="#ef4444" font-size="12" font-weight="900">Old Eye</text>
            </g>
          </svg>

          <!-- Interactive Vote Panel -->
          <div class="mt-4 flex flex-col items-center gap-3 bg-slate-900/90 border border-white/5 p-4 rounded-2xl w-full max-w-sm">
            <div class="flex items-center justify-between w-full text-xs font-bold text-slate-350">
              <span>Which did you see first?</span>
            </div>
            
            <div class="flex w-full gap-2">
              <button id="btn-vote-young" class="flex-1 bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 rounded-xl transition-all active:scale-95 shadow">👱‍♀️ Young Woman</button>
              <button id="btn-vote-old" class="flex-1 bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 rounded-xl transition-all active:scale-95 shadow">👵 Old Woman</button>
            </div>
            
            <div id="vote-feedback" class="hidden w-full text-left space-y-2 border-t border-slate-800 pt-2 text-xs">
              <p class="text-[10px] text-purple-400 font-bold">Your selection: <span id="user-selection" class="text-white"></span></p>
              <div class="flex justify-between font-bold text-slate-300 text-[10px]">
                <span>👱‍♀️ Young: <span id="pct-young">52%</span></span>
                <span>👵 Old: <span id="pct-old">48%</span></span>
              </div>
              <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden flex">
                <div id="bar-young" class="bg-purple-500 h-full" style="width: 52%;"></div>
                <div id="bar-old" class="bg-indigo-400 h-full" style="width: 48%;"></div>
              </div>
            </div>

            <div class="flex w-full gap-2 mt-1">
              <button id="btn-toggle-young" class="flex-1 border border-blue-500/30 text-blue-400 hover:bg-blue-500/10 font-bold text-[10px] py-2 rounded-xl transition-all">Show Young 👱‍♀️</button>
              <button id="btn-toggle-old" class="flex-1 border border-rose-500/30 text-rose-400 hover:bg-rose-500/10 font-bold text-[10px] py-2 rounded-xl transition-all">Show Old 👵</button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      <!-- Left 2-Columns -->
      <div class="lg:col-span-2 space-y-10">
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>My Wife and My Mother-in-Law is one of the most famous bistable ambiguous figures. Popularized by cartoonist W. E. Hill in 1915, the drawing contains both a young woman facing away into the background and an old woman looking downward in profile. The visual cortex experiences a rivalry between the two interpretations because the same line segments represent different facial features in each version: the young woman's chin functions as the old woman's nose, the young woman's ear acts as the old woman's eye, and the young woman's necklace is perceived as the old woman's mouth. This demonstrates that object recognition is a top-down prediction process.</p>
          </div>
        </section>
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>HISTORY</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-355 leading-relaxed font-semibold">
            First described by W. E. Hill (1915). It remains a fundamental demonstration of perceptual processing and cognitive framing.
          </p>
        </section>
      </div>
    </div>
  </div>

  <script>
    const btnVoteYoung = document.getElementById('btn-vote-young');
    const btnVoteOld = document.getElementById('btn-vote-old');
    const voteFeedback = document.getElementById('vote-feedback');
    const userSelection = document.getElementById('user-selection');
    const pctYoung = document.getElementById('pct-young');
    const pctOld = document.getElementById('pct-old');
    const barYoung = document.getElementById('bar-young');
    const barOld = document.getElementById('bar-old');

    const btnToggleYoung = document.getElementById('btn-toggle-young');
    const btnToggleOld = document.getElementById('btn-toggle-old');

    const overlayYoung = document.getElementById('overlay-young');
    const overlayOld = document.getElementById('overlay-old');

    const handleVote = (choice) => {
      if (userSelection) userSelection.textContent = choice === 'young' ? "Young Woman first 👱‍♀️" : "Old Woman first 👵";
      if (voteFeedback) voteFeedback.classList.remove('hidden');
      
      let yVal = 52;
      let oVal = 48;
      if (choice === 'young') {
        yVal = 53;
        oVal = 47;
      } else {
        yVal = 51;
        oVal = 49;
      }
      if (pctYoung) pctYoung.textContent = yVal + '%';
      if (pctOld) pctOld.textContent = oVal + '%';
      if (barYoung) barYoung.style.width = yVal + '%';
      if (barOld) barOld.style.width = oVal + '%';
    };

    btnVoteYoung?.addEventListener('click', () => handleVote('young'));
    btnVoteOld?.addEventListener('click', () => handleVote('old'));

    btnToggleYoung?.addEventListener('click', () => {
      const shown = overlayYoung?.classList.contains('opacity-100');
      if (shown) {
        overlayYoung?.classList.replace('opacity-100', 'opacity-0');
        if (btnToggleYoung) btnToggleYoung.textContent = "Show Young 👱‍♀️";
      } else {
        overlayYoung?.classList.replace('opacity-0', 'opacity-100');
        if (btnToggleYoung) btnToggleYoung.textContent = "Hide Young 👱‍♀️";
      }
    });

    btnToggleOld?.addEventListener('click', () => {
      const shown = overlayOld?.classList.contains('opacity-100');
      if (shown) {
        overlayOld?.classList.replace('opacity-100', 'opacity-0');
        if (btnToggleOld) btnToggleOld.textContent = "Show Old 👵";
      } else {
        overlayOld?.classList.replace('opacity-0', 'opacity-100');
        if (btnToggleOld) btnToggleOld.textContent = "Hide Old 👵";
      }
    });
  </script>
</Layout>
