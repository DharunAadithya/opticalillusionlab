      let ebbinghausTruth = false;

      toggleEbbinghausBtn?.addEventListener('click', () => {
        ebbinghausTruth = !ebbinghausTruth;
        ebbinghausSurrounds?.forEach(surround => {
          (surround as SVGElement).style.opacity = ebbinghausTruth ? '0.1' : '1.0';
