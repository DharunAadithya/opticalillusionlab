        });
        ebbinghausAlignLines?.forEach(line => {
          if (ebbinghausTruth) {
            line.classList.remove('opacity-0');
            line.classList.add('opacity-100');
          } else {
            line.classList.remove('opacity-100');
            line.classList.add('opacity-0');
          }
        });
        if (toggleEbbinghausBtn) {
