      const ebbinghausContainer = document.getElementById('ebbinghaus-illusion');
      const toggleEbbinghausBtn = ebbinghausContainer?.querySelector('.toggle-ebbinghaus');
      const ebbinghausSurrounds = ebbinghausContainer?.querySelectorAll('.ebbinghaus-surround');
