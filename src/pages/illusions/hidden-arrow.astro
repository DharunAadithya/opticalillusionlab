---
// src/pages/illusions/hidden-arrow.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Hidden Arrow — Figure-Ground Optical Illusion | Optical Illusion Lab" 
  description="Spot the arrow hidden in the negative space between bold letters. Test your visual figure-ground separation with a 30s timer."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/hidden" class="hover:text-white transition-colors">Hidden & Ambiguous</a>
      <span>/</span>
      <span class="text-purple-400">Hidden Arrow</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Figure-Ground</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-yellow-500/10 text-yellow-600 dark:text-yellow-450 border border-yellow-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Hidden Arrow
        </h1>
        <p class="text-slate-600 dark:text-slate-355 text-base max-w-2xl font-medium">
          A clever geometric figure-ground design where the empty white negative space between bold letterforms forms a perfect horizontal arrow pointing right.
        </p>
      </div>
      <button 
        id="share-illusion-page-btn"
        class="shrink-0 flex items-center space-x-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-sm px-6 py-3.5 transition-colors shadow-lg cursor-pointer border-none"
      >
        <span>Share Page</span>
      </button>
    </div>

    <!-- MAIN GRID CONTAINER -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <!-- Demo / SVG Column -->
      <div class="lg:col-span-2 space-y-6">
        <div id="illusion-card" class="relative flex flex-col items-center justify-center bg-white rounded-3xl border border-slate-200 p-8 min-h-[420px] shadow-sm select-none">
          
          <!-- SVG Area (Exactly 300x300 px) -->
          <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 300 300">
            <!-- Background white canvas -->
            <rect width="300" height="300" fill="#FFFFFF" rx="16" />
            
            <!-- Left Bold Letter Shape: 'E' in site purple (#7C3AED) -->
            <path 
              d="M 20,70 L 140,70 L 140,110 L 60,110 L 60,130 L 140,130 L 140,170 L 60,170 L 60,190 L 140,190 L 140,230 L 20,230 Z" 
              fill="#7C3AED" 
            />
            
            <!-- Right Bold Letter Shape: 'x' in Indigo (#4F46E5) -->
            <path 
              d="M 140,110 L 170,70 L 210,70 L 230,110 L 270,70 L 290,110 L 250,150 L 290,190 L 270,230 L 230,190 L 210,230 L 170,230 L 140,190 L 190,150 Z" 
              fill="#4F46E5" 
            />

            <!-- Hidden Arrow (filled with Gold #FFD700 on Reveal) -->
            <path 
              id="path-arrow" 
              class="reveal-path fill-none stroke-[#FFD700] stroke-[3] stroke-linecap-round stroke-linejoin-round opacity-0" 
              d="M 60,130 L 140,130 L 140,110 L 190,150 L 140,190 L 140,170 L 60,170 Z" 
            />
          </svg>

          <!-- Interactive controls at bottom -->
          <div class="w-full max-w-sm mt-6 space-y-4">
            <!-- Timer container -->
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200 text-xs">
              <span class="font-bold text-slate-500 uppercase">Find the Hidden Figure</span>
              <span id="countdown-timer" class="font-mono font-bold text-slate-700">30.0s</span>
            </div>

            <!-- Reveal & Hide Buttons -->
            <div class="flex gap-2 w-full">
              <button id="btn-reveal" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow">
                Reveal
              </button>
              <button id="btn-hide" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow hidden">
                Hide Answer
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Science / Explanation Column -->
      <div class="space-y-8">
        <section id="science-section" class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-350 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>
              <strong>Figure-Ground Segregation:</strong> In visual perception, the brain must separate objects of interest ("figure") from their surrounding canvas ("ground"). High-contrast colors like Purple and Indigo automatically attract attention, causing them to be categorized as solid figures.
            </p>
            <p>
              Because the white space between the blocks is interpreted as background (ground), the brain suppresses its shape details. This is why most people do not notice the arrow immediately. The arrow is hidden in the negative space. Toggling the highlight forces your brain to assign "figure" status to the white space, instantly resolving the arrow contour and filling it with gold.
            </p>
          </div>
        </section>

        <!-- RELATED LINKS -->
        <section class="border-t border-indigo-500/10 pt-6 space-y-3">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white">Related Illusions</h3>
          <div class="grid grid-cols-1 gap-3">
            <a href="/illusions/rubin-vase" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Rubin's Vase &rarr;
            </a>
            <a href="/illusions/hidden-face-pattern" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Hidden Face in Pattern &rarr;
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>

  <style>
    /* 1.5s stroke dashoffset animation */
    .reveal-path {
      stroke-dasharray: 1000;
      stroke-dashoffset: 1000;
    }
  </style>

  <script>
    function initHiddenArrow() {
      const timerText = document.getElementById('countdown-timer');
      const btnReveal = document.getElementById('btn-reveal') as HTMLButtonElement;
      const btnHide = document.getElementById('btn-hide') as HTMLButtonElement;
      const pathArrow = document.getElementById('path-arrow') as SVGPathElement;

      let secondsLeft = 30.0;
      let timerActive = true;
      let isRevealed = false;

      const startTime = Date.now();
      const intervalId = setInterval(() => {
        if (!timerActive) {
          clearInterval(intervalId);
          return;
        }
        const elapsed = (Date.now() - startTime) / 1000;
        secondsLeft = Math.max(30.0 - elapsed, 0.0);
        if (timerText) timerText.textContent = `${secondsLeft.toFixed(1)}s`;

        if (secondsLeft <= 0) {
          clearInterval(intervalId);
          triggerReveal();
        }
      }, 100);

      const triggerReveal = () => {
        isRevealed = true;
        timerActive = false;
        if (timerText) timerText.textContent = '0.0s';
        
        btnReveal?.classList.add('hidden');
        btnHide?.classList.remove('hidden');

        if (pathArrow) {
          pathArrow.classList.remove('opacity-0');
          pathArrow.style.fill = 'none';
          pathArrow.style.strokeDasharray = '1000';
          pathArrow.style.strokeDashoffset = '1000';
          pathArrow.getBoundingClientRect();
          pathArrow.style.transition = 'stroke-dashoffset 1.5s ease-in-out, fill 0.3s ease-in-out';
          pathArrow.style.strokeDashoffset = '0';

          // Fill with gold after drawing outline is complete
          setTimeout(() => {
            if (isRevealed) {
              pathArrow.style.fill = '#FFD700';
            }
          }, 1500);
        }
      };

      const triggerHide = () => {
        isRevealed = false;
        btnReveal?.classList.remove('hidden');
        btnHide?.classList.add('hidden');

        if (pathArrow) {
          pathArrow.classList.add('opacity-0');
          pathArrow.style.fill = 'none';
          pathArrow.style.strokeDasharray = '1000';
          pathArrow.style.strokeDashoffset = '1000';
        }
      };

      btnReveal?.addEventListener('click', triggerReveal);
      btnHide?.addEventListener('click', triggerHide);
    }

    initHiddenArrow();
    document.addEventListener('astro:page-load', initHiddenArrow);
  </script>
</Layout>
