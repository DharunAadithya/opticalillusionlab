---
// src/pages/illusions/duck-rabbit.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Duck-Rabbit Illusion — Optical Illusion Lab" 
  description="Explore the science, history, and seasonal cognitive bias of the Duck-Rabbit Illusion optical illusion."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <span class="text-purple-400">Duck-Rabbit Illusion</span>
    </nav>

    <!-- Hero Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Ambiguous</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-purple-500/10 text-purple-400 border border-purple-500/20 uppercase tracking-wider">🟢 Easy</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Duck-Rabbit Illusion
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          Discover how the brain interprets this fascinating ambiguous visual puzzle.
        </p>
      </div>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-6">
        <div class="relative flex flex-col items-center justify-center min-h-[460px] w-full bg-slate-100 dark:bg-slate-950/40 rounded-3xl overflow-hidden border border-indigo-500/10 p-6">
          
          <svg id="svg-duck-rabbit" class="select-none" viewBox="0 0 300 200" width="300" height="200" xmlns="http://www.w3.org/2000/svg" style="background: #0f172a; border-radius: 12px; padding: 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.35);">
            <ellipse cx="160" cy="110" rx="75" ry="55" fill="#ffffff" />
            <ellipse cx="95" cy="100" rx="40" ry="35" fill="#ffffff" />
            <path d="M 58,82 Q 25,72 10,90 Q 18,103 58,100 Z" fill="#ffffff" />
            <path d="M 58,100 Q 25,103 12,120 Q 20,133 58,117 Z" fill="#ffffff" />
            <circle cx="82" cy="86" r="6" fill="#0f172a" />
            <circle cx="82" cy="86" r="3" fill="#ffffff" />
            <path d="M 95,120 Q 90,110 95,100" stroke="#0f172a" stroke-width="2.5" fill="none" />
            
            <!-- Duck Highlight Overlay -->
            <g id="overlay-duck" class="opacity-0 transition-opacity duration-300 pointer-events-none">
              <path d="M 58,82 Q 25,72 10,90 Q 18,103 58,100 Z" stroke="#3b82f6" stroke-width="3.5" fill="none" />
              <path d="M 58,100 Q 25,103 12,120 Q 20,133 58,117 Z" stroke="#3b82f6" stroke-width="3.5" fill="none" />
              <text x="15" y="65" fill="#60a5fa" font-size="11" font-weight="900">Duck Bill</text>
            </g>

            <!-- Rabbit Highlight Overlay -->
            <g id="overlay-rabbit" class="opacity-0 transition-opacity duration-300 pointer-events-none">
              <path d="M 58,82 Q 25,72 10,90 Q 18,103 58,100 Z" stroke="#ef4444" stroke-width="3.5" fill="none" />
              <path d="M 58,100 Q 25,103 12,120 Q 20,133 58,117 Z" stroke="#ef4444" stroke-width="3.5" fill="none" />
              <text x="15" y="145" fill="#f87171" font-size="11" font-weight="900">Rabbit Ears</text>
            </g>
          </svg>

          <!-- Interactive Vote Panel -->
          <div class="mt-4 flex flex-col items-center gap-3 bg-slate-900/90 border border-white/5 p-4 rounded-2xl w-full max-w-sm">
            <div class="flex items-center justify-between w-full text-xs font-bold text-slate-350">
              <span>Which did you see first?</span>
            </div>
            
            <div class="flex w-full gap-2">
              <button id="btn-vote-duck" class="flex-1 bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 rounded-xl transition-all active:scale-95 shadow">🦆 Duck</button>
              <button id="btn-vote-rabbit" class="flex-1 bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 rounded-xl transition-all active:scale-95 shadow">🐇 Rabbit</button>
            </div>
            
            <div id="vote-feedback" class="hidden w-full text-left space-y-2 border-t border-slate-800 pt-2 text-xs">
              <p class="text-[10px] text-purple-400 font-bold">Your selection: <span id="user-selection" class="text-white"></span></p>
              <div class="flex justify-between font-bold text-slate-300 text-[10px]">
                <span>🦆 Duck: <span id="pct-duck">50%</span></span>
                <span>🐇 Rabbit: <span id="pct-rabbit">50%</span></span>
              </div>
              <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden flex">
                <div id="bar-duck" class="bg-purple-500 h-full" style="width: 50%;"></div>
                <div id="bar-rabbit" class="bg-indigo-400 h-full" style="width: 50%;"></div>
              </div>
            </div>

            <div class="flex w-full gap-2 mt-1">
              <button id="btn-toggle-duck" class="flex-1 border border-blue-500/30 text-blue-400 hover:bg-blue-500/10 font-bold text-[10px] py-2 rounded-xl transition-all">Show Duck 🦆</button>
              <button id="btn-toggle-rabbit" class="flex-1 border border-rose-500/30 text-rose-400 hover:bg-rose-500/10 font-bold text-[10px] py-2 rounded-xl transition-all">Show Rabbit 🐇</button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      <!-- Left 2-Columns -->
      <div class="lg:col-span-2 space-y-10">
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>The Duck-Rabbit Illusion is a classic ambiguous figure popularized by psychologist Joseph Jastrow in 1899. The silhouette is bistable: it can be seen as a duck facing to the left (where the protrusions are its bill) or a rabbit facing to the right (where the same protrusions are its ears). The visual system cannot hold both interpretations in conscious awareness simultaneously, forcing a perceptual toggle. Jastrow used the illusion to demonstrate that perception is not a passive recording of sensory data, but an active, cognitive interpretation that is heavily influenced by mental focus, context, and semantic priming.</p>
          </div>
        </section>
      </div>

      <!-- Right Column -->
      <div class="space-y-8">
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>HISTORY</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-355 leading-relaxed font-semibold">
            First described by Joseph Jastrow (1899). It remains a fundamental demonstration of perceptual processing and cognitive framing.
          </p>
        </section>
      </div>
    </div>
  </div>

  <script>
    const btnVoteDuck = document.getElementById('btn-vote-duck');
    const btnVoteRabbit = document.getElementById('btn-vote-rabbit');
    const voteFeedback = document.getElementById('vote-feedback');
    const userSelection = document.getElementById('user-selection');
    const pctDuck = document.getElementById('pct-duck');
    const pctRabbit = document.getElementById('pct-rabbit');
    const barDuck = document.getElementById('bar-duck');
    const barRabbit = document.getElementById('bar-rabbit');

    const btnToggleDuck = document.getElementById('btn-toggle-duck');
    const btnToggleRabbit = document.getElementById('btn-toggle-rabbit');

    const overlayDuck = document.getElementById('overlay-duck');
    const overlayRabbit = document.getElementById('overlay-rabbit');

    const handleVote = (choice) => {
      if (userSelection) userSelection.textContent = choice === 'duck' ? "Duck 🦆" : "Rabbit 🐇";
      if (voteFeedback) voteFeedback.classList.remove('hidden');
      
      let dVal = 50;
      let rVal = 50;
      if (choice === 'duck') {
        dVal = 52;
        rVal = 48;
      } else {
        dVal = 47;
        rVal = 53;
      }
      if (pctDuck) pctDuck.textContent = dVal + '%';
      if (pctRabbit) pctRabbit.textContent = rVal + '%';
      if (barDuck) barDuck.style.width = dVal + '%';
      if (barRabbit) barRabbit.style.width = rVal + '%';
    };

    btnVoteDuck?.addEventListener('click', () => handleVote('duck'));
    btnVoteRabbit?.addEventListener('click', () => handleVote('rabbit'));

    btnToggleDuck?.addEventListener('click', () => {
      const shown = overlayDuck?.classList.contains('opacity-100');
      if (shown) {
        overlayDuck?.classList.replace('opacity-100', 'opacity-0');
        if (btnToggleDuck) btnToggleDuck.textContent = "Show Duck 🦆";
      } else {
        overlayDuck?.classList.replace('opacity-0', 'opacity-100');
        if (btnToggleDuck) btnToggleDuck.textContent = "Hide Duck 🦆";
      }
    });

    btnToggleRabbit?.addEventListener('click', () => {
      const shown = overlayRabbit?.classList.contains('opacity-100');
      if (shown) {
        overlayRabbit?.classList.replace('opacity-100', 'opacity-0');
        if (btnToggleRabbit) btnToggleRabbit.textContent = "Show Rabbit 🐇";
      } else {
        overlayRabbit?.classList.replace('opacity-0', 'opacity-100');
        if (btnToggleRabbit) btnToggleRabbit.textContent = "Hide Rabbit 🐇";
      }
    });
  </script>
</Layout>
