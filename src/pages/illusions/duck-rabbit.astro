---
// src/pages/illusions/duck-rabbit.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Duck-Rabbit — Ambiguous Optical Illusion | Optical Illusion Lab" 
  description="Explore the classic Jastrow Duck-Rabbit figure. See a duck looking left or a rabbit looking right. Face the 30-second timer challenge."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/hidden" class="hover:text-white transition-colors">Hidden & Ambiguous</a>
      <span>/</span>
      <span class="text-purple-400">Duck-Rabbit</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Ambiguous</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-green-500/10 text-green-400 border border-green-500/20 uppercase tracking-wider">🟢 Easy</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Duck-Rabbit
        </h1>
        <p class="text-slate-600 dark:text-slate-355 text-base max-w-2xl font-medium">
          Joseph Jastrow (1899). A classic ambiguous illustration where a single contour represents either a duck's beak or a rabbit's ears.
        </p>
      </div>
      <button 
        id="share-illusion-page-btn"
        class="shrink-0 flex items-center space-x-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-sm px-6 py-3.5 transition-colors shadow-lg cursor-pointer border-none"
      >
        <span>Share Page</span>
      </button>
    </div>

    <!-- MAIN GRID CONTAINER -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <!-- Demo / SVG Column -->
      <div class="lg:col-span-2 space-y-6">
        <div id="illusion-card" class="relative flex flex-col items-center justify-center bg-white rounded-3xl border border-slate-200 p-8 min-h-[420px] shadow-sm select-none">
          
          <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 300 300">
            <!-- Background white canvas -->
            <rect width="300" height="300" fill="#FFFFFF" />

            <!-- Duck-Rabbit Classic Silhouette (White with black outline) -->
            <path d="M 220,110 C 260,110 290,135 290,170 C 290,205 260,230 220,230 C 210,210 205,190 200,175 L 100,195 C 90,195 85,185 95,180 C 120,165 150,160 180,155 C 180,150 180,140 180,135 C 150,130 120,125 95,110 C 85,105 90,95 100,95 L 200,110 C 205,105 210,110 220,110 Z" fill="#F8FAFC" stroke="#1e293b" stroke-width="4.5" />
            <!-- Eye -->
            <circle cx="215" cy="140" r="5" fill="#1e293b" />
            <!-- Mouth crease -->
            <path d="M 220,165 Q 215,170 210,175" fill="none" stroke="#1e293b" stroke-width="2.5" />

            <!-- Duck highlight: outlines the beak and eye (Blue #3B82F6) + Arrow + "Bill" label -->
            <g id="duck-highlights" class="opacity-0 transition-opacity duration-300" fill="none" stroke="#3B82F6" stroke-width="3">
              <path class="reveal-path" d="M 180,155 L 100,195 C 90,195 85,185 95,180 C 120,165 150,160 180,155 Z" />
              <path class="reveal-path" d="M 180,135 C 150,130 120,125 95,110 C 85,105 90,95 100,95 L 180,135" />
              <!-- Blue Arrow pointing to Bill -->
              <path d="M 90,150 L 60,150 M 70,143 L 60,150 L 70,157" stroke-linecap="round" stroke-linejoin="round" />
              <!-- Bill Text label -->
              <text x="50" y="135" fill="#3B82F6" font-size="12" font-weight="900" stroke="none">Bill</text>
            </g>

            <!-- Rabbit highlight: outlines the ears and nose (Orange #F97316) + Arrow + "Ears" label -->
            <g id="rabbit-highlights" class="opacity-0 transition-opacity duration-300" fill="none" stroke="#F97316" stroke-width="3">
              <!-- Ears -->
              <path class="reveal-path" d="M 180,155 L 100,195 M 180,135 L 100,95" />
              <!-- Rabbit Nose/Mouth (right side curve) -->
              <path class="reveal-path" d="M 260,150 C 275,170 280,185 270,200" />
              <!-- Orange Arrow pointing to Ears -->
              <path d="M 130,70 L 105,85 M 115,70 L 105,85 L 110,95" stroke-linecap="round" stroke-linejoin="round" />
              <!-- Ears Text label -->
              <text x="135" y="65" fill="#F97316" font-size="12" font-weight="900" stroke="none">Ears</text>
            </g>
          </svg>

          <!-- Interactive controls at bottom -->
          <div class="w-full max-w-sm mt-6 space-y-4">
            <!-- Timer container -->
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-200 text-xs">
              <span class="font-bold text-slate-500 uppercase">Find the Hidden Figure</span>
              <span id="countdown-timer" class="font-mono font-bold text-slate-700">30.0s</span>
            </div>

            <!-- Reveal & Hide Buttons -->
            <div class="flex gap-2 w-full">
              <button id="btn-reveal" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow">
                Reveal
              </button>
              <button id="btn-hide" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow hidden">
                Hide Answer
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Science / Explanation Column -->
      <div class="space-y-8">
        <section id="science-section" class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>
              <strong>Bistable Perception & Priming:</strong> The Jastrow Duck-Rabbit is a classic example of cognitive bistability. The visual stimulus remains exactly the same, but your mental model fluctuates between two animal shapes. 
            </p>
            <p>
              Interestingly, researchers have found that people are heavily influenced by context and semantic priming. If tested near Easter, participants are much more likely to see the rabbit first. If tested on a rainy autumn day, they tend to see the duck. It proves that top-down mental context overrides bottom-up sensory data.
            </p>
          </div>
        </section>

        <!-- RELATED LINKS -->
        <section class="border-t border-indigo-500/10 pt-6 space-y-3">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white">Related Illusions</h3>
          <div class="grid grid-cols-1 gap-3">
            <a href="/illusions/rubin-vase" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Rubin's Vase &rarr;
            </a>
            <a href="/illusions/my-wife-and-my-mother" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              My Wife and My Mother-in-Law &rarr;
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>

  <style>
    /* 1.5s stroke dashoffset animation */
    .reveal-path {
      stroke-dasharray: 1000;
      stroke-dashoffset: 1000;
    }
  </style>

  <script>
    function initDuckRabbit() {
      const timerText = document.getElementById('countdown-timer');
      const btnReveal = document.getElementById('btn-reveal') as HTMLButtonElement;
      const btnHide = document.getElementById('btn-hide') as HTMLButtonElement;
      
      const duckG = document.getElementById('duck-highlights');
      const rabbitG = document.getElementById('rabbit-highlights');

      let secondsLeft = 30.0;
      let timerActive = true;
      let isRevealed = false;

      const startTime = Date.now();
      const intervalId = setInterval(() => {
        if (!timerActive) {
          clearInterval(intervalId);
          return;
        }
        const elapsed = (Date.now() - startTime) / 1000;
        secondsLeft = Math.max(30.0 - elapsed, 0.0);
        if (timerText) timerText.textContent = `${secondsLeft.toFixed(1)}s`;

        if (secondsLeft <= 0) {
          clearInterval(intervalId);
          triggerReveal();
        }
      }, 100);

      const triggerReveal = () => {
        isRevealed = true;
        timerActive = false;
        if (timerText) timerText.textContent = '0.0s';
        
        btnReveal?.classList.add('hidden');
        btnHide?.classList.remove('hidden');

        // Draw animated outlines
        if (duckG && rabbitG) {
          duckG.classList.remove('opacity-0');
          rabbitG.classList.remove('opacity-0');

          duckG.querySelectorAll('.reveal-path').forEach(p => {
            const path = p as SVGPathElement;
            path.style.strokeDasharray = '1000';
            path.style.strokeDashoffset = '1000';
            path.getBoundingClientRect();
            path.style.transition = 'stroke-dashoffset 1.5s ease-in-out';
            path.style.strokeDashoffset = '0';
          });

          rabbitG.querySelectorAll('.reveal-path').forEach(p => {
            const path = p as SVGPathElement;
            path.style.strokeDasharray = '1000';
            path.style.strokeDashoffset = '1000';
            path.getBoundingClientRect();
            path.style.transition = 'stroke-dashoffset 1.5s ease-in-out';
            path.style.strokeDashoffset = '0';
          });
        }
      };

      const triggerHide = () => {
        isRevealed = false;
        btnReveal?.classList.remove('hidden');
        btnHide?.classList.add('hidden');

        if (duckG && rabbitG) {
          duckG.classList.add('opacity-0');
          rabbitG.classList.add('opacity-0');
          
          duckG.querySelectorAll('.reveal-path').forEach(p => {
            (p as SVGPathElement).style.strokeDasharray = '1000';
            (p as SVGPathElement).style.strokeDashoffset = '1000';
          });

          rabbitG.querySelectorAll('.reveal-path').forEach(p => {
            (p as SVGPathElement).style.strokeDasharray = '1000';
            (p as SVGPathElement).style.strokeDashoffset = '1000';
          });
        }
      };

      btnReveal?.addEventListener('click', triggerReveal);
      btnHide?.addEventListener('click', triggerHide);
    }

    initDuckRabbit();
    document.addEventListener('astro:page-load', initDuckRabbit);
  </script>
</Layout>
