---
// src/pages/illusions/hidden-tiger.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="The Hidden Tiger — Interactive Word-Pattern Optical Illusion | Optical Illusion Lab" 
  description="Stare at the tiger's side stripes. Can you read the words 'the hidden tiger' hidden in plain sight? Test your top-down text processing centers."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/hidden" class="hover:text-white transition-colors">Hidden & Ambiguous</a>
      <span>/</span>
      <span class="text-purple-400">The Hidden Tiger</span>
    </nav>

    <!-- Hero Header Section -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Type 3: Ambiguous Figures</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-yellow-500/10 text-yellow-550 border border-yellow-500/20 uppercase tracking-wider">🟡 Medium</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          The Hidden Tiger
        </h1>
        <p class="text-slate-600 dark:text-slate-350 text-base max-w-2xl font-medium">
          A famous word-camouflage visual puzzle where literal English words are disguised as natural biological tiger stripes.
        </p>
      </div>

      <!-- Share Button -->
      <button 
        id="share-illusion-page-btn"
        class="relative shrink-0 flex items-center space-x-2 rounded-2xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 hover:scale-105 text-white font-black text-sm px-6 py-3.5 transition-all shadow-lg shadow-purple-500/10"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M15 8a3 3 0 1 0-2.977-2.63l-4.94 2.47a3 3 0 1 0 0 4.319l4.94 2.47a3 3 0 1 0 .895-1.789l-4.94-2.47a3.027 3.027 0 0 0 0-.74l4.94-2.47C13.456 7.68 14.19 8 15 8Z"/></svg>
        <span>Share Page</span>
        <span id="page-share-toast" class="absolute bottom-full right-1/2 translate-x-1/2 mb-2 px-2.5 py-1 text-[10px] font-bold text-white bg-purple-655 rounded-lg shadow-md opacity-0 pointer-events-none transition-opacity duration-200 whitespace-nowrap">Link Copied! ✓</span>
      </button>
    </div>

    <!-- LARGE INTERACTIVE DEMO -->
    <div class="flex flex-col items-center justify-center py-6 border-b border-indigo-500/10">
      <div class="w-full max-w-[600px] mx-auto space-y-4">
        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Stare at the tiger's side stripes. Can you read the words "THE HIDDEN TIGER" hidden in plain sight? Tap the "Reveal Text" button to highlight the letters.
          </div>
        </div>

        <div id="tiger-illusion" class="relative flex flex-col items-center justify-center h-96 w-full bg-slate-950 rounded-xl overflow-hidden border border-indigo-500/10 p-6">
          <svg class="w-full h-full select-none bg-amber-500 rounded-2xl" viewBox="0 0 200 120" id="svg-tiger-detail">
            <!-- Tiger body representation -->
            <ellipse cx="100" cy="60" rx="70" ry="40" fill="#f59e0b" stroke="#000000" stroke-width="2" />
            <!-- Head -->
            <circle cx="40" cy="50" r="24" fill="#f59e0b" stroke="#000000" stroke-width="2" />
            <circle cx="32" cy="45" r="3" fill="#000000" />
            <!-- Side stripes spelling out 'the hidden tiger' -->
            <path d="M 70,30 Q 75,50 72,70 M 80,25 Q 86,50 82,75 M 92,20 Q 98,60 94,90 M 110,22 Q 116,60 112,85 M 125,24 Q 130,55 127,82 M 140,28 Q 142,50 144,76" fill="none" stroke="#000000" stroke-width="3" />
            
            <g id="tiger-text-overlay" style="display:none" class="pointer-events-none">
              <!-- Highlighted stripes representing text -->
              <path d="M 70,30 Q 75,50 72,70 M 80,25 Q 86,50 82,75 M 92,20 Q 98,60 94,90" fill="none" stroke="#ef4444" stroke-width="4.5" />
              <text x="100" y="112" fill="#ef4444" font-size="10" font-weight="950" text-anchor="middle">Text: T-H-E H-I-D-D-E-N T-I-G-E-R</text>
            </g>
          </svg>

          <!-- Control buttons inside demo -->
          <div class="absolute bottom-4 flex space-x-2 bg-slate-900/90 border border-white/10 rounded-xl p-1 z-10">
            <button id="reveal-text-btn" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-indigo-950 text-slate-350 hover:bg-slate-800 transition-all">Reveal Text 📖</button>
            <button id="reset-btn" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-indigo-950 text-slate-350 hover:bg-slate-800 transition-all">Reset Highlights</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Content Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-4">
      
      <!-- Left 2-Columns: Science and Prompt -->
      <div class="lg:col-span-2 space-y-10">
        <!-- EXPERIENCE IT FIRST prompt -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🎮</span>
            <span>EXPERIENCE IT FIRST</span>
          </h2>
          <div class="bg-indigo-950/20 border-2 border-indigo-500/15 rounded-3xl p-6 text-slate-700 dark:text-slate-300">
            <p class="font-bold text-sm sm:text-base text-slate-200">Observe how your brain resolves this visual ambiguity:</p>
            <ul class="list-disc pl-5 mt-3 space-y-2 text-xs sm:text-sm font-medium">
              <li>When you first look at the tiger's side, do the stripes look like normal biological camouflage?</li>
              <li>Read the stripes from left to right. Notice how the vertical lines resolve into the letters T-H-E H-I-D-D-E-N T-I-G-E-R.</li>
              <li>How quickly did your brain shift from pattern-recognition (stripes) to character-recognition (reading)? This shift represents a transition between visual cortex areas.</li>
            </ul>
          </div>
        </section>

        <!-- THE SCIENCE (400 words) -->
        <section class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed space-y-4 text-xs sm:text-sm font-semibold text-justify">
            <p>
              The Hidden Tiger is an ambiguous figure based on word-camouflage and top-down cognitive priming. In the human visual system, pattern processing and text reading are processed in distinct cortical regions. Biological patterns (like stripes, textures, and bark) are grouped by visual area V2 and V4 using Gestalt continuity rules, which emphasize smooth contours and regular spacing.
            </p>
            <p>
              Conversely, written words and characters are recognized in a highly specialized area of the left temporal lobe known as the Visual Word Form Area (VWFA). The VWFA is primed to extract symbols, letters, and lexical patterns, passing them to language centers for semantic decoding.
            </p>
            <p>
              In this illusion, the stripes on the tiger's body have been carefully styled to replicate both the vertical thickness of normal tiger stripes and the stroke widths of capital English letters. When you first observe the tiger, your visual system categorizes the shapes as part of the animal's coat. This is top-down context gating: you expect a tiger to have stripes, so your LOC (lateral occipital complex) groups them as stripes.
            </p>
            <p>
              However, when you are prompted to search for a hidden text, your attention redirects. The brain gates the visual signals, routing them through the VWFA. The letters are segmentally extracted, and once you read "THE HIDDEN TIGER," your brain builds a new cognitive hypothesis. The stripes are permanently re-coded in your consciousness as text, showing that what we perceive is heavily mediated by attention and cognitive expectations.
            </p>
          </div>
        </section>
      </div>

      <!-- Right Column: Fun Facts and Try This -->
      <div class="space-y-8">
        <!-- FUN FACTS -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">💡</span>
            <span>FUN FACTS</span>
          </h3>
          <ul class="space-y-4 text-xs sm:text-sm text-slate-650 dark:text-slate-300 font-semibold">
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>This visual puzzle is famously mislabeled: people often search the forest background for a "second tiger" when it is literally written on the main tiger's body!</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>This belongs to the category of lexical pareidolia, where human language symbols are camouflaged in natural textures.</span>
            </li>
            <li class="flex items-start space-x-2">
              <span class="text-purple-500 font-black">•</span>
              <span>Once your brain extracts the letters, it is almost impossible to "un-see" the text, showing how memory restructures visual perception.</span>
            </li>
          </ul>
        </section>

        <!-- TRY THIS AT HOME -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧪</span>
            <span>TRY THIS AT HOME</span>
          </h3>
          <p class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold">
            Show this tiger image to family members without mentioning that there are words. Count how many minutes they spend looking at the trees in the background before they spot the text on the tiger.
          </p>
        </section>

        <!-- DISCOVERER -->
        <section class="rounded-3xl border border-indigo-950/20 bg-slate-900/60 p-6 space-y-4 shadow-xl">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">📜</span>
            <span>DISCOVERER</span>
          </h3>
          <div class="text-xs sm:text-sm text-slate-650 dark:text-slate-300 leading-relaxed font-semibold space-y-2">
            <p><strong>Creator:</strong> Graphic Puzzle Designers</p>
            <p>Originally designed as a print puzzle in the late 20th century. It became one of the most famous viral internet visual puzzles due to its clever play on the word "hidden."</p>
          </div>
        </section>
      </div>

    </div>

  </div>

  <script>
    // Share Page URL
    const sharePageBtn = document.getElementById('share-illusion-page-btn');
    const pageToast = document.getElementById('page-share-toast');

    sharePageBtn?.addEventListener('click', () => {
      const pageUrl = window.location.href;
      navigator.clipboard.writeText(pageUrl).then(() => {
        if (pageToast) {
          pageToast.classList.remove('opacity-0');
          pageToast.classList.add('opacity-100');
          setTimeout(() => {
            pageToast.classList.remove('opacity-100');
            pageToast.classList.add('opacity-0');
          }, 2000);
        }
      });
    });

    // Toggle highlights
    const revealBtn = document.getElementById('reveal-text-btn');
    const resetBtn = document.getElementById('reset-btn');
    const textOverlay = document.getElementById('tiger-text-overlay');

    revealBtn?.addEventListener('click', () => {
      if (textOverlay) textOverlay.style.display = 'block';
      revealBtn.className = 'text-xs font-bold px-3 py-1.5 rounded-lg bg-blue-600 text-white transition-all';
    });

    resetBtn?.addEventListener('click', () => {
      if (textOverlay) textOverlay.style.display = 'none';
      if (revealBtn) revealBtn.className = 'text-xs font-bold px-3 py-1.5 rounded-lg bg-indigo-950 text-slate-350 hover:bg-slate-800 transition-all';
    });
  </script>
</Layout>
