---
// src/pages/illusions/hidden-tiger.astro
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="The Hidden Tiger — Camouflage Optical Illusion | Optical Illusion Lab" 
  description="Spot the tiger hidden in the vertical bamboo forest. Take the 30-second timer challenge and learn the science."
>
  <div class="py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-12">
    <!-- Breadcrumb back navigation -->
    <nav class="flex text-xs font-black uppercase tracking-wider text-slate-400 space-x-2 pb-2 border-b border-indigo-500/10">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/hidden" class="hover:text-white transition-colors">Hidden & Ambiguous</a>
      <span>/</span>
      <span class="text-purple-400">The Hidden Tiger</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 pb-6">
      <div class="space-y-3">
        <div class="flex items-center space-x-2">
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 uppercase tracking-wider">Camouflage</span>
          <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-red-550/10 text-red-500 border border-red-500/20 uppercase tracking-wider">🔴 Hard</span>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
          Tiger in the Bamboo
        </h1>
        <p class="text-slate-600 dark:text-slate-355 text-base max-w-2xl font-medium">
          A classic camouflage optical illusion where the vertical stripes of a tiger blend seamlessly with the vertical stalks of a bamboo forest.
        </p>
      </div>
      <button 
        id="share-illusion-page-btn"
        class="shrink-0 flex items-center space-x-2 rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-sm px-6 py-3.5 transition-colors shadow-lg cursor-pointer border-none"
      >
        <span>Share Page</span>
      </button>
    </div>

    <!-- MAIN GRID CONTAINER -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <!-- Demo / SVG Column -->
      <div class="lg:col-span-2 space-y-6">
        <div id="illusion-card" class="relative flex flex-col items-center justify-center bg-[#132a13] rounded-3xl border border-slate-800 p-8 min-h-[420px] shadow-sm select-none">
          
          <svg class="w-full max-w-[320px] h-auto aspect-[4/3] select-none overflow-visible" viewBox="0 0 400 300" id="svg-hidden-tiger">
            <!-- Background: Deep jungle green -->
            <rect width="400" height="300" fill="#132a13" rx="16" />

            <!-- Background Bamboo Stalks (10 stalks, dark forest green) -->
            <g stroke="#061e06" stroke-width="12" stroke-linecap="round">
              <line x1="25" y1="10" x2="25" y2="290" />
              <line x1="65" y1="10" x2="65" y2="290" />
              <line x1="105" y1="10" x2="105" y2="290" />
              <line x1="145" y1="10" x2="145" y2="290" />
              <line x1="185" y1="10" x2="185" y2="290" />
              <line x1="225" y1="10" x2="225" y2="290" />
              <line x1="265" y1="10" x2="265" y2="290" />
              <line x1="305" y1="10" x2="305" y2="290" />
              <line x1="345" y1="10" x2="345" y2="290" />
              <line x1="385" y1="10" x2="385" y2="290" />
            </g>

            <!-- Tiger Group (Orange body + vertical black stripes aligning with bamboo) -->
            <g id="tiger-body-group">
              <!-- Tiger Base Shape (Orange, slightly detailed body contour) -->
              <!-- Facing left, crouching slightly -->
              <path 
                d="M 80,180 C 70,175 60,170 55,160 C 50,150 45,130 50,120 C 55,110 70,100 85,100 C 100,100 115,95 130,85 C 145,75 160,80 180,85 C 200,90 230,90 260,85 C 290,80 320,90 330,110 C 340,120 345,140 340,155 C 335,165 315,185 295,190 C 275,195 240,195 210,190 C 180,185 140,190 120,195 C 100,195 90,190 80,180 Z" 
                fill="#EA580C" 
              />
              
              <!-- Tiger Head & Ears detail -->
              <path d="M 60,120 L 45,115 L 48,125 Z" fill="#EA580C" />
              <circle cx="58" cy="132" r="2.5" fill="#FEF08A" /> <!-- eye -->

              <!-- Tiger Vertical Black Stripes (aligning perfectly with stalks at x=105, 145, 185, 225, 265, 305) -->
              <g stroke="#061e06" stroke-width="12" stroke-linecap="butt">
                <!-- Stripe 1 (intersecting body at x=105) -->
                <line x1="105" y1="100" x2="105" y2="195" />
                <!-- Stripe 2 (x=145) -->
                <line x1="145" y1="83" x2="145" y2="192" />
                <!-- Stripe 3 (x=185) -->
                <line x1="185" y1="86" x2="185" y2="190" />
                <!-- Stripe 4 (x=225) -->
                <line x1="225" y1="88" x2="225" y2="191" />
                <!-- Stripe 5 (x=265) -->
                <line x1="265" y1="84" x2="265" y2="192" />
                <!-- Stripe 6 (x=305) -->
                <line x1="305" y1="95" x2="305" y2="182" />
              </g>
            </g>

            <!-- Foreground Bamboo overlay (to complete the sandwich and enhance camouflage) -->
            <g stroke="#061e06" stroke-width="12" stroke-linecap="round">
              <line x1="105" y1="10" x2="105" y2="90" />
              <line x1="105" y1="200" x2="105" y2="290" />
              
              <line x1="145" y1="10" x2="145" y2="70" />
              <line x1="145" y1="200" x2="145" y2="290" />

              <line x1="185" y1="10" x2="185" y2="75" />
              <line x1="185" y1="200" x2="185" y2="290" />

              <line x1="225" y1="10" x2="225" y2="75" />
              <line x1="225" y1="200" x2="225" y2="290" />

              <line x1="265" y1="10" x2="265" y2="70" />
              <line x1="265" y1="200" x2="265" y2="290" />

              <line x1="305" y1="10" x2="305" y2="85" />
              <line x1="305" y1="190" x2="305" y2="290" />
            </g>

            <!-- Reveal Outline overlay: traces the complete tiger shape in bright orange (#F97316) -->
            <path 
              id="path-tiger-reveal" 
              class="reveal-path stroke-[#F97316] fill-none stroke-[3.5] stroke-linecap-round stroke-linejoin-round opacity-0" 
              d="M 80,180 C 70,175 60,170 55,160 C 50,150 45,130 50,120 C 55,110 70,100 85,100 C 100,100 115,95 130,85 C 145,75 160,80 180,85 C 200,90 230,90 260,85 C 290,80 320,90 330,110 C 340,120 345,140 340,155 C 335,165 315,185 295,190 C 275,195 240,195 210,190 C 180,185 140,190 120,195 C 100,195 90,190 80,180 Z" 
            />
          </svg>

          <!-- Interactive controls at bottom -->
          <div class="w-full max-w-sm mt-6 space-y-4">
            <!-- Timer container -->
            <div class="flex items-center justify-between p-3 bg-slate-900 rounded-xl border border-slate-800 text-xs text-white">
              <span class="font-bold text-slate-400 uppercase">Find the Hidden Figure</span>
              <span id="countdown-timer" class="font-mono font-bold text-slate-300">30.0s</span>
            </div>

            <!-- Reveal & Hide Buttons -->
            <div class="flex gap-2 w-full">
              <button id="btn-reveal" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow">
                Reveal
              </button>
              <button id="btn-hide" class="flex-1 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs py-2.5 rounded-lg border-none transition-colors cursor-pointer shadow hidden">
                Hide Answer
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Science / Explanation Column -->
      <div class="space-y-8">
        <section id="science-section" class="space-y-4">
          <h2 class="font-display text-2xl font-black text-slate-900 dark:text-white flex items-center space-x-2">
            <span class="text-purple-500">🧠</span>
            <span>THE SCIENCE</span>
          </h2>
          <div class="prose prose-indigo dark:prose-invert text-slate-700 dark:text-slate-300 leading-relaxed text-xs sm:text-sm font-semibold text-justify">
            <p>
              <strong>Visual Camouflage & Disruption:</strong> Camouflage relies on breaking up the silhouette of an object so that its boundaries cannot be easily segmented from the background by the visual cortex.
            </p>
            <p>
              By aligning the tiger's vertical black stripes exactly with the dark green bamboo stalks in the background and foreground, the brain's visual area V1 groups the tiger's stripes together with the stalks based on parallel alignment (Gestalt grouping of good continuation). Consequently, the brain parses the image as a single uniform field of vertical lines, effectively hiding the contour of the tiger until a color contrast or motion cue reveals it.
            </p>
          </div>
        </section>

        <!-- RELATED LINKS -->
        <section class="border-t border-indigo-500/10 pt-6 space-y-3">
          <h3 class="font-display text-lg font-black text-slate-900 dark:text-white">Related Illusions</h3>
          <div class="grid grid-cols-1 gap-3">
            <a href="/illusions/faces-in-tree" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Faces in the Tree &rarr;
            </a>
            <a href="/illusions/dalmatian-dog" class="rounded-xl border border-slate-200 bg-white dark:bg-slate-900/60 p-4 hover:border-purple-500/40 hover:-translate-y-0.5 transition-all text-xs font-bold text-slate-900 dark:text-white">
              Camouflaged Dalmatian &rarr;
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>

  <style>
    /* 1.5s stroke dashoffset animation */
    .reveal-path {
      stroke-dasharray: 1000;
      stroke-dashoffset: 1000;
    }
  </style>

  <script>
    function initHiddenTiger() {
      const timerText = document.getElementById('countdown-timer');
      const btnReveal = document.getElementById('btn-reveal') as HTMLButtonElement;
      const btnHide = document.getElementById('btn-hide') as HTMLButtonElement;
      const pathTiger = document.getElementById('path-tiger-reveal') as SVGPathElement;

      let secondsLeft = 30.0;
      let timerActive = true;
      let isRevealed = false;

      const startTime = Date.now();
      const intervalId = setInterval(() => {
        if (!timerActive) {
          clearInterval(intervalId);
          return;
        }
        const elapsed = (Date.now() - startTime) / 1000;
        secondsLeft = Math.max(30.0 - elapsed, 0.0);
        if (timerText) timerText.textContent = `${secondsLeft.toFixed(1)}s`;

        if (secondsLeft <= 0) {
          clearInterval(intervalId);
          triggerReveal();
        }
      }, 100);

      const triggerReveal = () => {
        isRevealed = true;
        timerActive = false;
        if (timerText) timerText.textContent = '0.0s';
        
        btnReveal?.classList.add('hidden');
        btnHide?.classList.remove('hidden');

        if (pathTiger) {
          pathTiger.classList.remove('opacity-0');
          pathTiger.style.strokeDasharray = '1000';
          pathTiger.style.strokeDashoffset = '1000';
          pathTiger.getBoundingClientRect();
          pathTiger.style.transition = 'stroke-dashoffset 1.5s ease-in-out';
          pathTiger.style.strokeDashoffset = '0';
        }
      };

      const triggerHide = () => {
        isRevealed = false;
        btnReveal?.classList.remove('hidden');
        btnHide?.classList.add('hidden');

        if (pathTiger) {
          pathTiger.classList.add('opacity-0');
          pathTiger.style.strokeDasharray = '1000';
          pathTiger.style.strokeDashoffset = '1000';
        }
      };

      btnReveal?.addEventListener('click', triggerReveal);
      btnHide?.addEventListener('click', triggerHide);
    }

    initHiddenTiger();
    document.addEventListener('astro:page-load', initHiddenTiger);
  </script>
</Layout>
