---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="404 Page Not Found — Optical Illusion Lab" 
  description="Oops! The optical illusion you are looking for has vanished or was never physically constructed in this dimension."
>
  <div class="py-24 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto space-y-12 text-center">
    <div class="space-y-4">
      <div class="inline-flex items-center space-x-2 rounded-full border border-purple-500/30 bg-purple-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-purple-300">
        🌀 Lost in Perception
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
        404: Page Not Found
      </h1>
      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-xl mx-auto leading-relaxed">
        The coordinates you requested do not exist in this Euclidean plane. Or perhaps your brain is just misinterpreting the URL?
      </p>
    </div>

    <!-- The Scintillating Grid Interactive Container -->
    <div id="scintillating-404" class="max-w-md mx-auto rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/40 p-6 shadow-sm space-y-6">
      <div class="relative flex flex-col items-center justify-center h-64 w-full bg-slate-950 rounded-xl overflow-hidden border border-purple-500/15 p-4 select-none">
        
        <!-- Scintillating Grid SVG -->
        <svg id="grid-svg" viewBox="0 0 320 200" class="w-full h-full overflow-visible">
          <!-- Background -->
          <rect width="320" height="200" fill="#020617" />
          
          <!-- Grid Lines Group -->
          <g id="grid-lines" class="transition-opacity duration-500 ease-in-out">
            <!-- Vertical Lines -->
            <line x1="40" y1="0" x2="40" y2="200" stroke="#475569" stroke-width="4.5" />
            <line x1="80" y1="0" x2="80" y2="200" stroke="#475569" stroke-width="4.5" />
            <line x1="120" y1="0" x2="120" y2="200" stroke="#475569" stroke-width="4.5" />
            <line x1="160" y1="0" x2="160" y2="200" stroke="#475569" stroke-width="4.5" />
            <line x1="200" y1="0" x2="200" y2="200" stroke="#475569" stroke-width="4.5" />
            <line x1="240" y1="0" x2="240" y2="200" stroke="#475569" stroke-width="4.5" />
            <line x1="280" y1="0" x2="280" y2="200" stroke="#475569" stroke-width="4.5" />
            
            <!-- Horizontal Lines -->
            <line x1="0" y1="40" x2="320" y2="40" stroke="#475569" stroke-width="4.5" />
            <line x1="0" y1="80" x2="320" y2="80" stroke="#475569" stroke-width="4.5" />
            <line x1="0" y1="120" x2="320" y2="120" stroke="#475569" stroke-width="4.5" />
            <line x1="0" y1="160" x2="320" y2="160" stroke="#475569" stroke-width="4.5" />
          </g>
          
          <!-- Intersections (White Dots) -->
          <!-- We place dots at x=40,80,120,160,200,240,280 and y=40,80,120,160 -->
          <g id="grid-dots">
            <!-- Row 1 -->
            <circle cx="40" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="80" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="120" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="160" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="200" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="240" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="280" cy="40" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />

            <!-- Row 2 -->
            <circle cx="40" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="80" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="120" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="160" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="200" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="240" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="280" cy="80" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />

            <!-- Row 3 -->
            <circle cx="40" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="80" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="120" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="160" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="200" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="240" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="280" cy="120" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />

            <!-- Row 4 -->
            <circle cx="40" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="80" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="120" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="160" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="200" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="240" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
            <circle cx="280" cy="160" r="5.5" fill="#ffffff" stroke="#020617" stroke-width="1" />
          </g>
        </svg>

        <!-- Dynamic Overlay Message -->
        <div class="absolute inset-x-0 bottom-3 text-center pointer-events-none">
          <p class="text-[10px] text-slate-500 font-medium">Tip: Scan your eyes across the grid to see phantom dark dots appear.</p>
        </div>
      </div>

      <!-- Controls -->
      <div class="flex flex-col sm:flex-row gap-3">
        <button id="toggle-grid" class="flex-1 rounded-xl bg-purple-600 hover:bg-purple-500 text-white font-bold text-sm px-4 py-2.5 shadow-sm hover:shadow active:scale-98 transition-all">
          Prove Equality (Hide Grid)
        </button>
        <button id="change-colors" class="flex-1 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 hover:bg-slate-50 dark:hover:bg-slate-900 text-slate-700 dark:text-slate-200 font-bold text-sm px-4 py-2.5 active:scale-98 transition-all">
          Invert Dots
        </button>
      </div>
    </div>

    <!-- Educational explanation -->
    <div class="max-w-md mx-auto text-left text-xs text-slate-500 dark:text-slate-400 space-y-2">
      <p>
        <strong>How it works:</strong> The <em>Scintillating Grid Illusion</em> tricks your brain's lateral inhibition. When light stimulates the photoreceptors in your retina, it inhibits neighboring receptors. At the intersections, there is more surrounding light, causing the brain to reduce the perceived brightness at those junctions, creating the illusion of grey/black spots.
      </p>
    </div>

    <div class="pt-6 border-t border-slate-200 dark:border-slate-800">
      <a href="/" class="inline-flex items-center space-x-2 rounded-xl bg-purple-600 hover:bg-purple-500 px-6 py-3 text-sm font-semibold text-white shadow-md hover:shadow-lg transition-all duration-200">
        Return to Homepage
      </a>
    </div>
  </div>

  <script is:inline>
    // Handles the interactive elements on the 404 page
    (function() {
      const container = document.getElementById('scintillating-404');
      if (!container) return;

      const toggleGridBtn = container.querySelector('#toggle-grid');
      const changeColorsBtn = container.querySelector('#change-colors');
      const gridLines = container.querySelector('#grid-lines');
      const dotsGroup = container.querySelector('#grid-dots');
      const dots = dotsGroup.querySelectorAll('circle');

      let linesVisible = true;
      let dotsInverted = false;

      toggleGridBtn.addEventListener('click', () => {
        linesVisible = !linesVisible;
        if (linesVisible) {
          gridLines.style.opacity = '1';
          toggleGridBtn.textContent = 'Prove Equality (Hide Grid)';
        } else {
          gridLines.style.opacity = '0';
          toggleGridBtn.textContent = 'Show Grid';
        }
      });

      changeColorsBtn.addEventListener('click', () => {
        dotsInverted = !dotsInverted;
        dots.forEach(dot => {
          if (dotsInverted) {
            dot.setAttribute('fill', '#020617');
            dot.setAttribute('stroke', '#ffffff');
          } else {
            dot.setAttribute('fill', '#ffffff');
            dot.setAttribute('stroke', '#020617');
          }
        });
        changeColorsBtn.textContent = dotsInverted ? 'Reset Dots' : 'Invert Dots';
      });
    })();
  </script>
</Layout>
