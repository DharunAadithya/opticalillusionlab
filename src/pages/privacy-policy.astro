---
// src/pages/privacy-policy.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Privacy Policy — Optical Illusion Lab" 
  description="Read the privacy policy for Optical Illusion Lab. Details on data collection, ad-serving networks, cookies, and passive income policies."
>
  <div class="py-24 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto text-center space-y-6">
    <div class="inline-flex items-center space-x-2 rounded-full border border-indigo-500/30 bg-indigo-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-indigo-300">
      🚧 Section Under Construction
    </div>
    <h1 class="font-display text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 dark:text-white">
      Privacy Policy
    </h1>
    <p class="text-slate-600 dark:text-slate-400 max-w-md mx-auto text-sm sm:text-base">
      We are currently building this section of the Optical Illusion Lab. Check back soon for mind-bending interactive illusions and visual puzzles!
    </p>
    <div class="pt-4">
      <a href="/" class="inline-flex items-center space-x-2 rounded-xl bg-gradient-to-r from-purple-600 to-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-purple-500/20 hover:scale-102 hover:shadow-purple-500/30 active:scale-98 transition-all duration-200">
        Return to Homepage
      </a>
    </div>
  </div>
</Layout>
