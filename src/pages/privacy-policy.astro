---
// src/pages/privacy-policy.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Privacy Policy — Optical Illusion Lab" 
  description="Privacy guidelines, tracking cookie notices, and data handling practices at Optical Illusion Lab."
>
  <div class="py-24 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto space-y-12">
    <div class="space-y-4 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
        Privacy Policy
      </h1>
      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-md mx-auto leading-relaxed">
        Understand how we gather and protect your laboratory preferences and anonymous analytics data.
      </p>
      <div class="mx-auto h-1 w-20 rounded-full bg-purple-600"></div>
    </div>

    <div class="prose prose-indigo dark:prose-invert max-w-none space-y-8 text-slate-700 dark:text-slate-300 leading-relaxed">
      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">1. Information We Collect</h2>
        <p>
          We do not collect any personally identifiable information (PII) on the Optical Illusion Lab unless you explicitly submit a feedback message via our contact form. The contact details you provide (name and email) are used solely to reply to your research and feedback inquiries.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">2. Cookies and Local Storage</h2>
        <p>
          We use local browser storage to save your visual laboratory preferences (such as light/dark mode theme preferences and global speed multiplier levels). This data remains on your local machine and is never sent to our servers.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">3. Third-Party Web Analytics</h2>
        <p>
          We implement standard Google Analytics (using async script tags) to track overall site traffic, page performance, and geographic distributions. This data is fully aggregated and anonymized, helping us optimize the rendering performance of our interactive SVG canvas nodes for different devices.
        </p>
      </div>
    </div>

    <div class="pt-6 text-center border-t border-slate-200 dark:border-slate-800">
      <a href="/" class="inline-flex items-center space-x-2 rounded-xl bg-purple-600 hover:bg-purple-500 px-6 py-3 text-sm font-semibold text-white shadow-md hover:shadow-lg transition-all duration-200">
        Return to Homepage
      </a>
    </div>
  </div>
</Layout>
