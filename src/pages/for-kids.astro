---
// src/pages/for-kids.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Optical Illusions for Kids — 8 Amazing Brain Tricks | Optical Illusion Lab" 
  description="Explore the best interactive optical illusions for kids. Play with 8 awesome visual tricks, test your brain with a fun quiz, and learn how to draw illusions!"
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-950 via-indigo-950 to-slate-950 text-white border-b border-indigo-500/20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(236,72,153,0.15),transparent_50%)]"></div>
    
    <div class="relative mx-auto max-w-4xl text-center space-y-6">
      <div class="inline-flex items-center space-x-2 rounded-full border border-pink-500/30 bg-pink-500/15 px-4 py-1.5 text-sm font-black uppercase tracking-wider text-pink-300 backdrop-blur-sm animate-pulse">
        🎈 Brain Magic Playground 🎈
      </div>
      <h1 class="font-display text-4xl sm:text-6xl font-black tracking-tight bg-gradient-to-r from-pink-400 via-yellow-300 to-cyan-400 bg-clip-text text-transparent filter drop-shadow-[0_2px_8px_rgba(0,0,0,0.5)]">
        Optical Illusions For Kids! 🧠⭐
      </h1>
      
      <!-- Section 1: "WARM UP YOUR BRAIN! 🧠" -->
      <div class="bg-slate-900/60 border-2 border-indigo-500/30 p-6 sm:p-8 rounded-3xl max-w-2xl mx-auto shadow-2xl space-y-4 backdrop-blur-md">
        <h2 class="text-xl sm:text-2xl font-black text-yellow-300 tracking-wide uppercase">
          WARM UP YOUR BRAIN! 🧠🔥
        </h2>
        <p class="text-base sm:text-lg text-slate-100 font-bold leading-relaxed">
          Your brain is the <span class="bg-gradient-to-r from-pink-400 to-yellow-300 bg-clip-text text-transparent font-black">BEST</span> magician in the world.<br/>
          It creates tricks so good that even YOU get fooled!<br/>
          Let's explore 8 mind-bending illusions together... 🚀
        </p>
      </div>

      <div class="flex justify-center space-x-4 pt-4">
        <a href="#kids-gallery" class="rounded-2xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 px-6 py-3.5 text-base font-bold text-white shadow-lg hover:scale-105 transition-all">
          Play the Tricks! 🎮
        </a>
        <a href="#kids-draw" class="rounded-2xl bg-gradient-to-r from-cyan-500 to-blue-600 px-6 py-3.5 text-base font-bold text-white shadow-lg hover:scale-105 transition-all">
          Learn to Draw ✏️
        </a>
        <a href="#kids-quiz" class="rounded-2xl border-2 border-white/20 bg-white/5 hover:bg-white/10 px-6 py-3.5 text-base font-bold text-slate-200 hover:text-white transition-all">
          Quiz Time! 🏆
        </a>
      </div>
    </div>
  </section>

  <!-- Section 2: 8 Kid-Friendly Illusions -->
  <section id="kids-gallery" class="py-16 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto space-y-12">
    
    <!-- Illusion 1: Kanizsa Triangle -->
    <a href="/illusions/kanizsa-triangle" class="kids-card bg-slate-900/80 border-2 border-pink-500/30 rounded-3xl p-6 sm:p-8 shadow-2xl relative overflow-hidden transition-all duration-300 block hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(236,72,153,0.4)] hover:border-pink-500/50 cursor-pointer group" data-id="kanizsa">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="space-y-4"><div class="flex items-center space-x-2">
            <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-pink-500/20 text-pink-400 border border-pink-500/30">🟢 EASY</span>
            <span class="text-xs font-bold text-cyan-400 uppercase tracking-wider">Shape Magic ✨</span>
          </div>
          <h2 class="font-display text-2xl sm:text-3xl font-black text-white">1. KANIZSA TRIANGLE 🔺</h2>
          <p class="text-lg sm:text-xl text-slate-200 font-semibold leading-relaxed">
            Do you see a white triangle? THERE IS NO TRIANGLE! Your brain drew it in! 🤯
          </p>
          <div class="bg-indigo-950/40 p-4 rounded-2xl border border-indigo-500/10 text-sm text-indigo-300">
            💡 <strong>Fun Fact:</strong> Your brain does this to help you see whole shapes faster!
          </div>
          <button class="kids-action-btn bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-base px-6 py-3.5 rounded-lg shadow-xl transition-all border-none cursor-pointer">
            Make it disappear! 🪄
          </button>
          <div class="pt-4 flex items-center justify-between border-t border-slate-700/30 mt-2">
            <span class="text-xs font-black uppercase text-pink-400">Step Inside the Lab</span>
            <span class="text-sm font-black text-pink-400 group-hover:text-pink-300 transition-colors">Explore &rarr;</span>
          </div>
        </div>
        <div class="flex flex-col items-center justify-center bg-slate-950/60 rounded-2xl p-6 border-2 border-slate-800">
          <div class="w-full max-w-[400px] h-[400px] flex items-center justify-center relative overflow-hidden bg-slate-950 rounded-xl">
            <svg id="svg-kanizsa-kids" class="w-[300px] h-[300px] select-none overflow-visible rounded-lg" viewBox="0 0 200 200" style="background: #F8F8F8;">
              <rect x="0" y="0" width="200" height="200" fill="#F8F8F8" />
              <!-- Pac-Man 1 - TOP: center (100, 40), radius 25px -->
              <g class="pacman-t transition-transform duration-700 origin-center" style="transform-origin: 100px 40px;">
                <path d="M 100 40 L 112.5 61.65 A 25 25 0 1 1 87.5 61.65 Z" fill="#ec4899" />
              </g>
              <!-- Pac-Man 2 - BOTTOM LEFT: center (53.5, 142.5), radius 25px -->
              <g class="pacman-l transition-transform duration-700 origin-center" style="transform-origin: 53.5px 142.5px;">
                <path d="M 53.5 142.5 L 60.4 118.5 A 25 25 0 1 1 77.8 136.45 Z" fill="#ec4899" />
              </g>
              <!-- Pac-Man 3 - BOTTOM RIGHT: center (146.5, 142.5), radius 25px -->
              <g class="pacman-r transition-transform duration-700 origin-center" style="transform-origin: 146.5px 142.5px;">
                <path d="M 146.5 142.5 L 122.2 136.45 A 25 25 0 1 1 139.6 118.5 Z" fill="#ec4899" />
              </g>
            </svg>
            <div class="kids-wow-badge absolute inset-0 flex items-center justify-center bg-slate-950/80 hidden select-none">
              <div class="text-center animate-bounce space-y-2">
                <span class="block text-4xl">🌟</span>
                <span class="block text-pink-400 font-black text-2xl tracking-widest">WOW! AMAZING! 💥</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </a>
    <!-- Illusion 2: Wertheimer Ring -->
    <a href="/illusions/wertheimer-koffka" class="kids-card bg-slate-900/80 border-2 border-yellow-500/30 rounded-3xl p-6 sm:p-8 shadow-2xl relative overflow-hidden transition-all duration-300 /50 block hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(234,179,8,0.4)] hover:border-yellow-500/50 cursor-pointer transition-all duration-300 group" data-id="ring">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="space-y-4"><div class="flex items-center space-x-2">
            <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-yellow-500/20 text-yellow-400 border border-yellow-500/30">🟢 EASY</span>
            <span class="text-xs font-bold text-cyan-400 uppercase tracking-wider">Color Thief 🎨</span>
          </div>
          <h2 class="font-display text-2xl sm:text-3xl font-black text-white">2. WERTHEIMER-KOFFKA RING 🎨</h2>
          <p class="text-lg sm:text-xl text-slate-200 font-semibold leading-relaxed">
            Are these two halves different colors? NOPE! They're exactly the same! Your eyes are LYING to you! 😂
          </p>
          
          <div class="space-y-2 pt-2">
            <label for="ring-slider" class="block text-xs font-black text-slate-300 uppercase tracking-wider">Slide to merge the ring halves! 👇</label>
            <input type="range" id="ring-slider" min="0" max="100" value="0" class="w-full h-3 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-yellow-400 border border-yellow-500/20" />
          </div>

          <div class="flex items-center space-x-4">
            <button class="kids-action-btn bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-base px-6 py-3.5 rounded-lg shadow-xl transition-all border-none cursor-pointer">
              Prove it! 🔎
            </button>
          </div>
          <div class="pt-4 flex items-center justify-between border-t border-slate-700/30 mt-2">
            <span class="text-xs font-black uppercase text-yellow-400">Step Inside the Lab</span>
            <span class="text-sm font-black text-yellow-400 group-hover:text-yellow-300 transition-colors">Explore &rarr;</span>
          </div>
        </div>
        <div class="flex flex-col items-center justify-center bg-slate-950/60 rounded-2xl p-6 border-2 border-slate-800 relative min-h-[340px]">
          <div class="w-full max-w-[320px] h-[280px] rounded-xl flex overflow-hidden relative border-2 border-slate-850">
            <!-- Split backgrounds -->
            <div class="w-1/2 h-full bg-white transition-all duration-300" id="bg-half-left"></div>
            <div class="w-1/2 h-full bg-slate-950 transition-all duration-300" id="bg-half-right"></div>
            
            <!-- SVG Overlaid -->
            <div class="absolute inset-0 flex items-center justify-center">
              <svg id="svg-ring-kids" class="w-48 h-48 select-none overflow-visible" viewBox="0 0 200 200">
                <path class="ring-left fill-[#888888] transition-transform duration-300" d="M 100,50 A 50,50 0 0,0 100,150 L 100,130 A 30,30 0 0,1 100,70 Z" />
                <path class="ring-right fill-[#888888] transition-transform duration-300" d="M 100,50 A 50,50 0 0,1 100,150 L 100,130 A 30,30 0 0,0 100,70 Z" />
                
                <!-- Red connector divider -->
                <line class="ring-divider stroke-rose-500 stroke-[4] transition-opacity duration-300" x1="100" y1="20" x2="100" y2="180" />
              </svg>
            </div>
            
            <div class="kids-wow-badge absolute inset-0 flex items-center justify-center bg-slate-950/80 hidden select-none">
              <div class="text-center animate-bounce space-y-2">
                <span class="block text-4xl">🎨</span>
                <span class="block text-yellow-400 font-black text-2xl tracking-widest">WOW! AMAZING! 🌟</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </a>
    <!-- Illusion 3: Café Wall -->
    <a href="/illusions/cafe-wall" class="kids-card bg-slate-900/80 border-2 border-cyan-500/30 rounded-3xl p-6 sm:p-8 shadow-2xl relative overflow-hidden transition-all duration-300 /50 block hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(6,182,212,0.4)] hover:border-cyan-500/50 cursor-pointer transition-all duration-300 group" data-id="wobbly">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="space-y-4"><div class="flex items-center space-x-2">
            <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-cyan-500/20 text-cyan-400 border border-cyan-500/30">🟡 MEDIUM</span>
            <span class="text-xs font-bold text-pink-400 uppercase tracking-wider">Line Illusion 〰️</span>
          </div>
          <h2 class="font-display text-2xl sm:text-3xl font-black text-white">3. CAFÉ WALL 〰️</h2>
          <p class="text-lg sm:text-xl text-slate-200 font-semibold leading-relaxed">
            Are these lines straight or tilted?
          </p>
          <div class="flex space-x-4 kids-poll-buttons">
            <button class="poll-btn-tilted bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-base px-6 py-3 rounded-lg flex-1 shadow-md transition-all border-none cursor-pointer">
              Tilted! 📈
            </button>
            <button class="poll-btn-straight bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-base px-6 py-3 rounded-lg flex-1 shadow-md transition-all border-none cursor-pointer">
              Straight! 📏
            </button>
          </div>
          <div class="pt-4 flex items-center justify-between border-t border-slate-700/30 mt-2">
            <span class="text-xs font-black uppercase text-cyan-400">Step Inside the Lab</span>
            <span class="text-sm font-black text-cyan-400 group-hover:text-cyan-300 transition-colors">Explore &rarr;</span>
          </div>
        </div>
        <div class="flex flex-col items-center justify-center bg-slate-950/60 rounded-2xl p-6 border-2 border-slate-800 relative">
          <div class="relative w-full max-w-[280px] border-4 border-slate-700 overflow-hidden bg-slate-950 p-2 rounded-xl">
            <div class="cafe-grid-kids flex flex-col w-full relative space-y-1">
              <!-- Grid lines are implemented in relative positions -->
              {Array.from({ length: 5 }).map((_, rIndex) => {
                const shift = rIndex % 2 === 0 ? '8px' : '-8px';
                return (
                  <div class="flex w-[320px] transition-transform duration-700 cafe-row-kids" style={{ transform: `translateX(${shift})` }}>
                    {Array.from({ length: 10 }).map((_, sIndex) => (
                      <div class={`w-8 h-8 shrink-0 ${sIndex % 2 === 0 ? 'bg-cyan-400' : 'bg-pink-500'} border-r-2 border-l-2 border-slate-950`}></div>
                    ))}
                  </div>
                )
              })}
              
              <!-- Divider straight lines overlay -->
              <div class="absolute inset-x-0 top-[35px] h-[3px] bg-slate-400 transition-colors duration-500 align-guideline"></div>
              <div class="absolute inset-x-0 top-[73px] h-[3px] bg-slate-400 transition-colors duration-500 align-guideline"></div>
              <div class="absolute inset-x-0 top-[111px] h-[3px] bg-slate-400 transition-colors duration-500 align-guideline"></div>
              <div class="absolute inset-x-0 top-[149px] h-[3px] bg-slate-400 transition-colors duration-500 align-guideline"></div>
            </div>
            
            <div class="kids-wow-badge absolute inset-0 flex items-center justify-center bg-slate-950/90 hidden select-none">
              <div class="text-center animate-bounce space-y-2 p-4">
                <span class="block text-4xl">📏</span>
                <span class="block text-cyan-400 font-black text-xl tracking-wider">STRAIGHT! 💥</span>
                <p class="text-xs text-slate-200 font-bold max-w-[220px]">
                  Every single line is perfectly straight. The colored boxes trick your brain into seeing a tilt!
                </p>
                <button class="retry-btn mt-3 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs px-3 py-1.5 rounded-lg border-none cursor-pointer">See Illusion Again</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </a>
    <!-- Illusion 4: Hermann Grid -->
    <a href="/illusions/hermann-grid" class="kids-card bg-slate-900/80 border-2 border-purple-500/30 rounded-3xl p-6 sm:p-8 shadow-2xl relative overflow-hidden transition-all duration-300 /50 block hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(168,85,247,0.4)] hover:border-purple-500/50 cursor-pointer transition-all duration-300 group" data-id="ghosts">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="space-y-4"><div class="flex items-center space-x-2">
            <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-green-500/20 text-green-400 border border-green-500/30">🟢 EASY</span>
            <span class="text-xs font-bold text-yellow-400 uppercase tracking-wider">Ghost Hunt 👻</span>
          </div>
          <h2 class="font-display text-2xl sm:text-3xl font-black text-white">4. HERMANN GRID 👻</h2>
          <p class="text-lg sm:text-xl text-slate-200 font-semibold leading-relaxed">
            Count the black dots at the corners! How many do you see? Type your answer:
          </p>
          <div class="flex space-x-3 pt-2">
            <input type="text" id="kids-dots-input" placeholder="Enter number..." class="w-full max-w-[150px] bg-slate-950 border-2 border-slate-800 focus:border-purple-500 text-white font-black text-center text-lg rounded-2xl px-4 py-3 focus:outline-none transition-colors" />
            <button class="kids-submit-dots bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-base px-6 py-3 rounded-lg shadow-lg transition-transform border-none cursor-pointer">
              Submit
            </button>
          </div>
          <div class="kids-dots-feedback hidden p-3 rounded-xl font-bold text-sm"></div>
          <div class="pt-4 flex items-center justify-between border-t border-slate-700/30 mt-2">
            <span class="text-xs font-black uppercase text-purple-400">Step Inside the Lab</span>
            <span class="text-sm font-black text-purple-400 group-hover:text-purple-300 transition-colors">Explore &rarr;</span>
          </div>
        </div>
        <div class="flex flex-col items-center justify-center bg-slate-950/60 rounded-2xl p-6 border-2 border-slate-800 relative">
          <div class="w-full max-w-[280px] h-[280px] bg-slate-950 border-2 border-slate-800 p-4 rounded-xl flex items-center justify-center">
            <!-- Precise Hermann Grid with high-contrast black boxes on white lines -->
            <svg class="w-56 h-56 select-none bg-slate-950" viewBox="0 0 200 200">
              <!-- Dark slate background blocks -->
              <rect x="0" y="0" width="40" height="40" fill="#030712" />
              <rect x="50" y="0" width="40" height="40" fill="#030712" />
              <rect x="100" y="0" width="40" height="40" fill="#030712" />
              <rect x="150" y="0" width="40" height="40" fill="#030712" />

              <rect x="0" y="50" width="40" height="40" fill="#030712" />
              <rect x="50" y="50" width="40" height="40" fill="#030712" />
              <rect x="100" y="50" width="40" height="40" fill="#030712" />
              <rect x="150" y="50" width="40" height="40" fill="#030712" />

              <rect x="0" y="100" width="40" height="40" fill="#030712" />
              <rect x="50" y="100" width="40" height="40" fill="#030712" />
              <rect x="100" y="100" width="40" height="40" fill="#030712" />
              <rect x="150" y="100" width="40" height="40" fill="#030712" />

              <rect x="0" y="150" width="40" height="40" fill="#030712" />
              <rect x="50" y="150" width="40" height="40" fill="#030712" />
              <rect x="100" y="150" width="40" height="40" fill="#030712" />
              <rect x="150" y="150" width="40" height="40" fill="#030712" />

              <!-- Yellow-White Grid Lines -->
              <g stroke="#ffffff" stroke-width="10" opacity="0.95">
                <line x1="45" y1="0" x2="45" y2="200" />
                <line x1="95" y1="0" x2="95" y2="200" />
                <line x1="145" y1="0" x2="145" y2="200" />

                <line x1="0" y1="45" x2="200" y2="45" />
                <line x1="0" y1="95" x2="200" y2="95" />
                <line x1="0" y1="145" x2="200" y2="145" />
              </g>
            </svg>
          </div>
          
          <div class="kids-wow-badge absolute inset-0 flex items-center justify-center bg-slate-950/90 hidden select-none">
            <div class="text-center animate-bounce space-y-2 p-6">
              <span class="block text-4xl">👻</span>
              <span class="block text-purple-400 font-black text-xl tracking-wider">ZERO! AMAZING!</span>
              <p class="text-xs text-slate-200 font-bold max-w-[220px]">
                ZERO! There are NO black dots! Your brain made them up! Ghosts aren't real — but your brain ghost dots are! 👻
              </p>
              <button class="retry-btn mt-3 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs px-3 py-1.5 rounded-lg border-none cursor-pointer">Try Again</button>
            </div>
          </div>
        </div>
      </div>
    </a>
    <!-- Illusion 5: Breathing Square -->
    <a href="/illusions/breathing-square" class="kids-card bg-slate-900/80 border-2 border-pink-500/30 rounded-3xl p-6 sm:p-8 shadow-2xl relative overflow-hidden transition-all duration-300 /50 block hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(236,72,153,0.4)] hover:border-pink-500/50 cursor-pointer transition-all duration-300 group" data-id="breathing">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="space-y-4"><div class="flex items-center space-x-2">
            <span class="text-xs font-black px-2.5 py-0.5 rounded-full bg-pink-500/20 text-pink-400 border border-pink-500/30">🟡 MEDIUM</span>
            <span class="text-xs font-bold text-cyan-400 uppercase tracking-wider">Motion Trick 💨</span>
          </div>
          <h2 class="font-display text-2xl sm:text-3xl font-black text-white">5. THE BREATHING SQUARE 💨</h2>
          <p class="text-lg sm:text-xl text-slate-200 font-semibold leading-relaxed">
            Watch the square breathe... NOW — is it actually getting bigger?
          </p>
          <button class="kids-action-btn bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-black text-base px-6 py-3.5 rounded-lg shadow-xl transition-all border-none cursor-pointer">
            Freeze it! 🧊
          </button>
          <div class="pt-4 flex items-center justify-between border-t border-slate-700/30 mt-2">
            <span class="text-xs font-black uppercase text-pink-400">Step Inside the Lab</span>
            <span class="text-sm font-black text-pink-400 group-hover:text-pink-300 transition-colors">Explore &rarr;</span>
          </div>
        </div>
        <div class="flex flex-col items-center justify-center bg-slate-950/60 rounded-2xl p-6 border-2 border-slate-800 relative">
          <div class="w-full max-w-[280px] h-[280px] bg-slate-950 rounded-xl flex items-center justify-center relative overflow-hidden">
            <svg class="w-48 h-48 select-none overflow-visible" viewBox="0 0 200 200">
              <!-- Rotating blue square -->
              <rect class="kids-blue-square fill-cyan-400 origin-center" x="65" y="65" width="70" height="70" style="transform-origin: 100px 100px; animation: spin-clockwise 4s linear infinite;" />
              <!-- Yellow-pink Occluders in corners -->
              <g class="kids-occluders fill-pink-500">
                <rect x="0" y="0" width="55" height="55" />
                <rect x="145" y="0" width="55" height="55" />
                <rect x="0" y="145" width="55" height="55" />
                <rect x="145" y="145" width="55" height="55" />
              </g>
              <!-- Guide ruler frame -->
              <rect class="kids-ruler-frame stroke-yellow-400 stroke-[3] fill-none opacity-0 transition-opacity duration-300" x="65" y="65" width="70" height="70" />
            </svg>
          </div>
          
          <div class="kids-wow-badge absolute inset-0 flex items-center justify-center bg-slate-950/90 hidden select-none">
            <div class="text-center animate-bounce space-y-2 p-6">
              <span class="block text-4xl">🧊</span>
              <span class="block text-pink-400 font-black text-xl tracking-wider">AMAZING!</span>
              <p class="text-xs text-slate-200 font-bold max-w-[220px]">
                It was just SPINNING the whole time! Sneaky square! 😄
              </p>
              <button class="retry-btn mt-3 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-xs px-3 py-1.5 rounded-lg border-none cursor-pointer">Spin Again</button>
            </div>
          </div>
