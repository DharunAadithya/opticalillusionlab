      100% { transform: rotate(360deg); }
    }
  </style>

  <script>
    // ----------------------------------------------------
    // 8 ILLUSIONS INTERACTIVITY SCRIPTS
    // ----------------------------------------------------

    // Helper to setup retry hooks
    const setupRetry = (card: HTMLElement, resetCallback: () => void) => {
      const retryBtn = card.querySelector('.retry-btn');
      retryBtn?.addEventListener('click', () => {
        const wowBadge = card.querySelector('.kids-wow-badge');
        wowBadge?.classList.add('hidden');
        resetCallback();
      });
    };

    // 1. THE IMPOSSIBLE SQUARE
    const kanizsaCard = document.querySelector('[data-id="kanizsa"]') as HTMLElement;
    if (kanizsaCard) {
      const disappearBtn = kanizsaCard.querySelector('.kids-action-btn') as HTMLButtonElement;
      const pacmen = kanizsaCard.querySelectorAll('#svg-kanizsa-kids g');
      const kanizsaWow = kanizsaCard.querySelector('.kids-wow-badge');
      let rotated = false;

      disappearBtn?.addEventListener('click', () => {
        rotated = !rotated;
        pacmen.forEach((pac, idx) => {
          let rotationAngle = 0;
          if (rotated) {
            // rotate out of alignment so they don't form a square
            rotationAngle = idx % 2 === 0 ? 180 : -180;
          }
          (pac as HTMLElement).style.transform = `rotate(${rotationAngle}deg)`;
        });
        
        disappearBtn.textContent = rotated ? "Bring it back! 🪄" : "Make it disappear! 🪄";
        
        if (rotated) {
          setTimeout(() => {
            kanizsaWow?.classList.remove('hidden');
            const wowText = kanizsaWow?.querySelector('.kids-wow-badge span:last-child');
            if (wowText) wowText.textContent = "WOW! IT DISAPPEARED! 💥";
          }, 700);
        } else {
          kanizsaWow?.classList.add('hidden');
        }
      });

      setupRetry(kanizsaCard, () => {
        rotated = false;
        pacmen.forEach(pac => {
          (pac as HTMLElement).style.transform = `rotate(0deg)`;
        });
        if (disappearBtn) disappearBtn.textContent = "Make it disappear! 🪄";
      });
    }

    // 2. THE COLOR THIEF
    const ringCard = document.querySelector('[data-id="ring"]') as HTMLElement;
    if (ringCard) {
      const proveBtn = ringCard.querySelector('.kids-action-btn') as HTMLButtonElement;
      const ringLeft = ringCard.querySelector('.ring-left') as SVGElement;
      const ringRight = ringCard.querySelector('.ring-right') as SVGElement;
      const divider = ringCard.querySelector('.ring-divider') as SVGElement;
      const ringWow = ringCard.querySelector('.kids-wow-badge');
      const ringSlider = ringCard.querySelector('#ring-slider') as HTMLInputElement;

      const updateRingDisplacement = (val: number) => {
        // val ranges from 0 (split, separated by 30px) to 100 (merged, together)
        // At 0: translate left half by -20px, right half by 20px
        // At 100: translate both to 0px
        const maxOffset = 25; // px
        const offset = maxOffset - (val / 100) * maxOffset;
        
        ringLeft.style.transform = `translateX(-${offset}px)`;
        ringRight.style.transform = `translateX(${offset}px)`;
        
        // fade divider as we merge
        divider.style.opacity = (1 - (val / 100)).toString();

        if (val === 100) {
          ringWow?.classList.remove('hidden');
        } else {
          ringWow?.classList.add('hidden');
        }
      };

      // Set initial state
      updateRingDisplacement(0);

      ringSlider?.addEventListener('input', (e) => {
        const val = parseInt((e.target as HTMLInputElement).value);
        updateRingDisplacement(val);
      });

      proveBtn?.addEventListener('click', () => {
        // Animate the slider to 100
        let currentVal = parseInt(ringSlider.value);
        const interval = setInterval(() => {
          if (currentVal >= 100) {
            clearInterval(interval);
          } else {
            currentVal += 5;
            if (currentVal > 100) currentVal = 100;
            ringSlider.value = currentVal.toString();
            updateRingDisplacement(currentVal);
          }
        }, 16);
      });

      setupRetry(ringCard, () => {
        ringSlider.value = "0";
        updateRingDisplacement(0);
      });
    }

    // 3. THE WOBBLY LINES
    const wobblyCard = document.querySelector('[data-id="wobbly"]') as HTMLElement;
    if (wobblyCard) {
      const pollButtons = wobblyCard.querySelectorAll('.kids-poll-buttons button');
      const wobblyWow = wobblyCard.querySelector('.kids-wow-badge');
      const cafeRows = wobblyCard.querySelectorAll('.cafe-row-kids');
      const guidelines = wobblyCard.querySelectorAll('.align-guideline');

      pollButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Realign the wobbly rows and light up straight red guidelines
          cafeRows.forEach(row => {
            (row as HTMLElement).style.transform = 'translateX(0px)';
          });
          
          guidelines.forEach(line => {
            (line as HTMLElement).style.backgroundColor = '#ef4444'; // Red straight lines
          });

          wobblyWow?.classList.remove('hidden');
          pollButtons.forEach(b => b.setAttribute('disabled', 'true'));
        });
      });

      setupRetry(wobblyCard, () => {
        cafeRows.forEach((row, rIndex) => {
          const shift = rIndex % 2 === 0 ? '8px' : '-8px';
          (row as HTMLElement).style.transform = `translateX(${shift})`;
        });
        guidelines.forEach(line => {
          (line as HTMLElement).style.backgroundColor = '#94a3b8'; // gray
        });
        pollButtons.forEach(b => b.removeAttribute('disabled'));
      });
    }

    // 4. THE GHOST DOTS
    const ghostsCard = document.querySelector('[data-id="ghosts"]') as HTMLElement;
    if (ghostsCard) {
      const dotsInput = ghostsCard.querySelector('#kids-dots-input') as HTMLInputElement;
      const submitDotsBtn = ghostsCard.querySelector('.kids-submit-dots') as HTMLButtonElement;
      const dotsFeedback = ghostsCard.querySelector('.kids-dots-feedback') as HTMLElement;
      const ghostWow = ghostsCard.querySelector('.kids-wow-badge');

      submitDotsBtn?.addEventListener('click', () => {
        const val = dotsInput?.value.trim();
        if (dotsFeedback) {
          dotsFeedback.classList.remove('hidden');
          if (val === '0' || val.toLowerCase() === 'zero') {
            dotsFeedback.textContent = "🎉 CORRECT! Your brain ignores spots when you stare directly at them! 👻";
            dotsFeedback.className = "kids-dots-feedback p-3 rounded-xl font-bold text-sm bg-green-500/20 text-green-400 border border-green-500/30";
            
            setTimeout(() => {
              ghostWow?.classList.remove('hidden');
            }, 600);
          } else {
            dotsFeedback.textContent = "❌ Not quite! Stare directly at one intersection. Does the dark spot vanish? Try typing 0!";
            dotsFeedback.className = "kids-dots-feedback p-3 rounded-xl font-bold text-sm bg-red-500/20 text-red-400 border border-red-500/30";
          }
        }
      });

      setupRetry(ghostsCard, () => {
        if (dotsInput) dotsInput.value = "";
        dotsFeedback?.classList.add('hidden');
      });
    }

    // 5. THE BREATHING SQUARE
    const breathingCard = document.querySelector('[data-id="breathing"]') as HTMLElement;
    if (breathingCard) {
      const freezeBtn = breathingCard.querySelector('.kids-action-btn') as HTMLButtonElement;
      const blueSquare = breathingCard.querySelector('.kids-blue-square') as SVGElement;
      const rulerFrame = breathingCard.querySelector('.kids-ruler-frame') as SVGElement;
      const breathingWow = breathingCard.querySelector('.kids-wow-badge');
      let frozen = false;

      freezeBtn?.addEventListener('click', () => {
        frozen = !frozen;
        if (blueSquare && rulerFrame) {
          blueSquare.style.animationPlayState = frozen ? 'paused' : 'running';
          rulerFrame.style.opacity = frozen ? '1' : '0';
        }
        
        freezeBtn.textContent = frozen ? "Spin Again! 🔄" : "Freeze it! 🧊";
        
        if (frozen) {
          setTimeout(() => {
            breathingWow?.classList.remove('hidden');
          }, 600);
        }
      });

      setupRetry(breathingCard, () => {
        frozen = false;
        if (blueSquare && rulerFrame) {
          blueSquare.style.animationPlayState = 'running';
          rulerFrame.style.opacity = '0';
        }
        if (freezeBtn) freezeBtn.textContent = "Freeze it! 🧊";
      });
    }

    // 6. THE COPYCAT COLORS
    const ebbinghausCard = document.querySelector('[data-id="ebbinghaus"]') as HTMLElement;
    if (ebbinghausCard) {
      const ebbinghausBtns = ebbinghausCard.querySelectorAll('.kids-ebbinghaus-buttons button');
      const ebbinghausWow = ebbinghausCard.querySelector('.kids-wow-badge');
      const ebbinghausRuler = ebbinghausCard.querySelectorAll('.ebbinghaus-ruler');
      const surroundBig = ebbinghausCard.querySelector('.surround-big') as SVGElement;
      const surroundSmall = ebbinghausCard.querySelector('.surround-small') as SVGElement;
      const centerLeftGroup = ebbinghausCard.querySelector('.center-left-group') as SVGElement;
      const centerRightGroup = ebbinghausCard.querySelector('.center-right-group') as SVGElement;

      ebbinghausBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // 1. Fade out surrounding circles
          if (surroundBig) surroundBig.style.opacity = '0.05';
          if (surroundSmall) surroundSmall.style.opacity = '0.05';

          // 2. Slide center circles closer to the middle to line them up side-by-side!
          // Middle of the 320 width is 160.
          // Left circle starts at cx=80. Translate it right by 50px (so it sits at 130).
          // Right circle starts at cx=240. Translate it left by 50px (so it sits at 190).
          if (centerLeftGroup) centerLeftGroup.style.transform = 'translateX(50px)';
          if (centerRightGroup) centerRightGroup.style.transform = 'translateX(-50px)';

          // 3. Show alignment rulers
          ebbinghausRuler?.forEach(line => {
            (line as SVGElement).style.opacity = '1';
          });

          setTimeout(() => {
            ebbinghausWow?.classList.remove('hidden');
          }, 800);

          ebbinghausBtns.forEach(b => b.setAttribute('disabled', 'true'));
        });
      });

      setupRetry(ebbinghausCard, () => {
        if (surroundBig) surroundBig.style.opacity = '1';
        if (surroundSmall) surroundSmall.style.opacity = '1';
        if (centerLeftGroup) centerLeftGroup.style.transform = '';
        if (centerRightGroup) centerRightGroup.style.transform = '';
        ebbinghausRuler?.forEach(line => {
          (line as SVGElement).style.opacity = '0';
        });
        ebbinghausBtns.forEach(b => b.removeAttribute('disabled'));
      });
    }

    // 7. THE DIZZY DOTS
    const troxlerCard = document.querySelector('[data-id="troxler"]') as HTMLElement;
    if (troxlerCard) {
      const startTroxlerBtn = troxlerCard.querySelector('.kids-start-troxler') as HTMLButtonElement;
      const troxlerCountdown = troxlerCard.querySelector('.kids-countdown-badge') as HTMLElement;
      const troxlerWow = troxlerCard.querySelector('.kids-wow-badge');
      
      let countdownInterval: any = null;
      let secondsLeft = 15;
      let staringActive = false;

      startTroxlerBtn?.addEventListener('click', () => {
        if (staringActive) return;
        staringActive = true;
        secondsLeft = 15;
        
        if (troxlerCountdown) {
          troxlerCountdown.classList.remove('hidden');
          troxlerCountdown.textContent = `${secondsLeft}s`;
        }
        if (startTroxlerBtn) {
          startTroxlerBtn.setAttribute('disabled', 'true');
        }

        const duration = 15000; // 15 seconds
        const startTime = Date.now();
        countdownInterval = setInterval(() => {
          const elapsed = Date.now() - startTime;
          const remaining = Math.max(0, duration - elapsed);
          const secondsLeft = (remaining / 1000).toFixed(1);
          if (troxlerCountdown) {
            troxlerCountdown.textContent = `${secondsLeft}s`;
          }
          
          if (remaining <= 0) {
            clearInterval(countdownInterval);
            troxlerCountdown.classList.add('hidden');
            staringActive = false;
            
            setTimeout(() => {
              troxlerWow?.classList.remove('hidden');
            }, 300);

            if (startTroxlerBtn) {
              startTroxlerBtn.removeAttribute('disabled');
              startTroxlerBtn.textContent = 'Restart';
            }
          }
        }, 100);
      });

      setupRetry(troxlerCard, () => {
        clearInterval(countdownInterval);
        staringActive = false;
        if (troxlerCountdown) troxlerCountdown.classList.add('hidden');
        if (startTroxlerBtn) {
          startTroxlerBtn.removeAttribute('disabled');
          startTroxlerBtn.textContent = 'Start Staring! ⏱️';
        }
      });
    }

    // 8. THE FAKER LINES
    const mullerCard = document.querySelector('[data-id="muller"]') as HTMLElement;
    if (mullerCard) {
      const mullerBtns = mullerCard.querySelectorAll('.kids-muller-buttons button');
      const rulerGroup = mullerCard.querySelector('.ruler-group') as SVGElement;
      const mullerWow = mullerCard.querySelector('.kids-wow-badge');

      mullerBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          // Slide in the measuring ruler overlay
          if (rulerGroup) {
            rulerGroup.style.transform = 'translateY(0px)';
          }

          setTimeout(() => {
            mullerWow?.classList.remove('hidden');
          }, 800);

          mullerBtns.forEach(b => b.setAttribute('disabled', 'true'));
        });
      });

      setupRetry(mullerCard, () => {
        if (rulerGroup) {
          rulerGroup.style.transform = 'translateY(-160px)';
        }
        mullerBtns.forEach(b => b.removeAttribute('disabled'));
      });
    }

    // 9. THE RING SQUEEZER (Delboeuf)
    const delboeufCard = document.querySelector('[data-id="delboeuf"]') as HTMLElement;
    if (delboeufCard) {
      const delboeufBtns = delboeufCard.querySelectorAll('.kids-delboeuf-buttons button');
      const delboeufRulers = delboeufCard.querySelectorAll('.delboeuf-ruler');
      const delboeufWow = delboeufCard.querySelector('.kids-wow-badge');

      delboeufBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          delboeufRulers.forEach(r => r.classList.remove('opacity-0'));
          delboeufRulers.forEach(r => r.classList.add('opacity-100'));

          setTimeout(() => {
            delboeufWow?.classList.remove('hidden');
          }, 800);

          delboeufBtns.forEach(b => b.setAttribute('disabled', 'true'));
        });
      });

      setupRetry(delboeufCard, () => {
        delboeufRulers.forEach(r => r.classList.remove('opacity-100'));
        delboeufRulers.forEach(r => r.classList.add('opacity-0'));
        delboeufBtns.forEach(b => b.removeAttribute('disabled'));
      });
    }


    // ----------------------------------------------------
    // KIDS HOME EXPERIMENTS INTERACTIVITY
    // ----------------------------------------------------
    // 1. Thaumatrope Bird in a Cage
    const thaumatropeCard = document.querySelector('[data-experiment="thaumatrope"]') as HTMLElement;
    if (thaumatropeCard) {
      const btnSpin = document.getElementById('btn-spin-thaumatrope') as HTMLButtonElement;
      const btnFlip = document.getElementById('btn-flip-thaumatrope') as HTMLButtonElement;
      const disc = document.getElementById('thaumatrope-disc') as SVGElement;
      const bird = document.getElementById('thaumatrope-bird') as SVGElement;
      const cage = document.getElementById('thaumatrope-cage') as SVGElement;
      const wow = document.getElementById('thaumatrope-wow') as HTMLElement;
      
      let isSpinning = false;
      let currentSide = 'cage'; // cage or bird
      
      btnFlip?.addEventListener('click', () => {
        if (isSpinning) return;
        currentSide = currentSide === 'cage' ? 'bird' : 'cage';
        if (currentSide === 'cage') {
          cage.style.opacity = '1';
          bird.style.opacity = '0';
        } else {
          cage.style.opacity = '0';
          bird.style.opacity = '1';
        }
      });
      
      btnSpin?.addEventListener('click', () => {
        if (isSpinning) {
          // Stop spinning
          isSpinning = false;
          disc.style.animation = 'none';
          cage.style.opacity = currentSide === 'cage' ? '1' : '0';
          bird.style.opacity = currentSide === 'bird' ? '1' : '0';
          wow?.classList.add('hidden');
          btnSpin.textContent = 'Spin Disc! 🔄';
          btnFlip.removeAttribute('disabled');
        } else {
          // Start spinning
          isSpinning = true;
          disc.style.animation = 'spin-clockwise 0.15s linear infinite';
          cage.style.opacity = '0.7';
          bird.style.opacity = '0.7';
          wow?.classList.remove('hidden');
          btnSpin.textContent = 'Stop Spinning 🛑';
          btnFlip.setAttribute('disabled', 'true');
        }
      });
    }

    // 2. Impossible 3D Builder
    const perspectiveCard = document.querySelector('[data-experiment="perspective"]') as HTMLElement;
    if (perspectiveCard) {
      const slider = document.getElementById('perspective-slider') as HTMLInputElement;
      const angleText = document.getElementById('perspective-angle-text') as HTMLElement;
      const bar3 = document.getElementById('perspective-bar-3') as SVGElement;
      const wow = document.getElementById('perspective-wow') as HTMLElement;
      
      slider?.addEventListener('input', (e) => {
        const val = parseInt((e.target as HTMLInputElement).value);
        if (angleText) angleText.textContent = `${val}°`;
        
        // Translate bar 3 based on slider value. At 0, offset is (0,0)
        // At other values, offset is (val * 1px, val * -0.6px)
        const xOffset = val * 0.8;
        const yOffset = val * -0.5;
        if (bar3) {
          bar3.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
        }
        
        if (val === 0) {
          wow?.classList.remove('hidden');
        } else {
          wow?.classList.add('hidden');
        }
      });
    }

    // 3. Rainbow Star Stare
    const afterimageKidsCard = document.querySelector('[data-experiment="afterimage"]') as HTMLElement;
    if (afterimageKidsCard) {
      const btnStare = document.getElementById('btn-stare-afterimage') as HTMLButtonElement;
      const timerBadge = document.getElementById('afterimage-kids-timer') as HTMLElement;
      const screen = document.getElementById('kids-afterimage-screen') as HTMLElement;
      const svgStar = document.getElementById('svg-afterimage-kids') as SVGElement;
      
      let timerVal = 20;
      let intervalId: any = null;
      let isStaring = false;
      
      btnStare?.addEventListener('click', () => {
        if (isStaring) {
          // Reset
          clearInterval(intervalId);
          isStaring = false;
          timerVal = 20;
          timerBadge.classList.add('hidden');
          screen.classList.add('hidden');
          svgStar.style.opacity = '1';
          btnStare.textContent = 'Stare Challenge (20s) ⏱️';
        } else {
          isStaring = true;
          timerVal = 20;
          timerBadge.classList.remove('hidden');
          timerBadge.textContent = `${timerVal}s`;
          screen.classList.add('hidden');
          svgStar.style.opacity = '1';
          btnStare.textContent = 'Reset Stare 🔄';
          
          const duration = 20000; // 20 seconds
          const startTime = Date.now();
          intervalId = setInterval(() => {
            const elapsed = Date.now() - startTime;
            const remaining = Math.max(0, duration - elapsed);
            const secondsLeft = (remaining / 1000).toFixed(1);
            timerBadge.textContent = `${secondsLeft}s`;
            
            if (remaining <= 0) {
              clearInterval(intervalId);
              timerBadge.classList.add('hidden');
              svgStar.style.opacity = '0';
              screen.classList.remove('hidden');
              btnStare.textContent = 'Try Stare Again 🔄';
              isStaring = false;
            }
          }, 100);
        }
      });
    }


    // ----------------------------------------------------
    // QUIZ TIME! LOGIC
    // ----------------------------------------------------
    const quizQuestions = document.querySelectorAll('.quiz-question');
    const quizResults = document.getElementById('quiz-results');
    const quizScoreText = document.getElementById('quiz-score-text');
    const quizMessageText = document.getElementById('quiz-message-text');
    const restartQuizBtn = document.getElementById('restart-quiz-btn');

    let currentQuestionIdx = 0;
    let quizScore = 0;

    const initQuizOptions = () => {
      quizQuestions.forEach((q, qIdx) => {
        const optionBtns = q.querySelectorAll('.quiz-option-btn');
        optionBtns.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const isCorrect = (e.currentTarget as HTMLElement).getAttribute('data-correct') === 'true';
            if (isCorrect) {
              quizScore++;
            }
            
            // Go to next question
            q.classList.add('hidden');
            currentQuestionIdx++;
            
            if (currentQuestionIdx < quizQuestions.length) {
              quizQuestions[currentQuestionIdx].classList.remove('hidden');
            } else {
              // Quiz Finished!
              if (quizResults && quizScoreText && quizMessageText) {
                quizResults.classList.remove('hidden');
                quizScoreText.textContent = `Score: ${quizScore}/5`;
                
                if (quizScore === 5) {
                  quizMessageText.textContent = "🏆 5/5 — You are a BRAIN MASTER! 🧠👑";
                } else if (quizScore >= 3) {
                  quizMessageText.textContent = "🌟 3-4/5 — Great job! Your brain is super smart! 🌟";
                } else {
                  quizMessageText.textContent = "😄 1-2/5 — Keep practicing! Illusions fool everyone! 😄";
                }
              }
            }
          });
        });
      });
    };

    initQuizOptions();

    restartQuizBtn?.addEventListener('click', () => {
      quizScore = 0;
      currentQuestionIdx = 0;
      quizResults?.classList.add('hidden');
      quizQuestions.forEach((q, idx) => {
        if (idx === 0) {
          q.classList.remove('hidden');
        } else {
          q.classList.add('hidden');
        }
      });
    });

  
    // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation
    const kidsCards = document.querySelectorAll('.kids-card');
    kidsCards.forEach(card => {
      card.querySelectorAll('button, input, select, details, summary, label, a, .kids-action-btn, .poll-btn-tilted, .poll-btn-straight').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
    });
    
  </script>
</Layout>
