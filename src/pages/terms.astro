---
// src/pages/terms.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Terms of Service — Optical Illusion Lab" 
  description="Terms of Service and use guidelines for the interactive scientific and entertainment assets at Optical Illusion Lab."
>
  <div class="py-24 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto space-y-12">
    <div class="space-y-4 text-center">
      <h1 class="font-display text-4xl sm:text-5xl font-black tracking-tight text-slate-900 dark:text-white">
        Terms of Service
      </h1>
      <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 max-w-md mx-auto leading-relaxed">
        Please read these guidelines carefully before using our interactive visual laboratory.
      </p>
      <div class="mx-auto h-1 w-20 rounded-full bg-purple-600"></div>
    </div>

    <div class="prose prose-indigo dark:prose-invert max-w-none space-y-8 text-slate-700 dark:text-slate-300 leading-relaxed">
      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">1. Acceptance of Terms</h2>
        <p>
          By accessing or using the Optical Illusion Lab website, you agree to comply with and be bound by these Terms of Service. If you do not agree, please do not access or use our services.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">2. Sensory Warning & Use Disclaimer</h2>
        <p>
          Some interactive animations and visual experiments contain high-contrast geometric patterns, rapid movement variations, and peripheral drift triggers. While completely safe for general viewers, these visual patterns may cause temporary eye fatigue, headaches, or mild disorientation. If you experience discomfort or are sensitive to high-contrast visual stimuli, please discontinue use immediately.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">3. Intellectual Property</h2>
        <p>
          All mathematics, code, styles, and custom vector graphics (SVGs) featured in the interactive demonstrations are the intellectual property of Optical Illusion Lab. You may reference, study, or link to these demos for educational, research, or non-commercial purposes, provided appropriate attribution is given.
        </p>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900 dark:text-white mb-3">4. Limitation of Liability</h2>
        <p>
          The materials and interactive demos are provided on an "as is" basis. Optical Illusion Lab makes no warranties, expressed or implied, and hereby disclaims all other warranties, including without limitation, implied warranties of merchantability or fitness for a particular purpose.
        </p>
      </div>
    </div>

    <div class="pt-6 text-center border-t border-slate-200 dark:border-slate-800">
      <a href="/" class="inline-flex items-center space-x-2 rounded-xl bg-purple-600 hover:bg-purple-500 px-6 py-3 text-sm font-semibold text-white shadow-md hover:shadow-lg transition-all duration-200">
        Return to Homepage
      </a>
    </div>
  </div>
</Layout>
