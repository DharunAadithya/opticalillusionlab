    }
    .wdys-science-card:hover { border-color: rgba(139,92,246,0.35); transform: translateY(-3px); }
    .wdys-sci-icon { font-size: 2rem; margin-bottom: 0.6rem; }
    .wdys-science-card h3 { font-weight: 700; color: #c4b5fd; margin-bottom: 0.5rem; font-size: 1rem; }
    .wdys-science-card p { font-size: 0.82rem; color: #94a3b8; line-height: 1.65; }

    /* ===================== FAQ ===================== */
    .wdys-faq-section { padding: 5rem 1.5rem; background: #0f172a; }
    .wdys-faq-inner { max-width: 800px; margin: 0 auto; }
    .wdys-faq-title { font-family: 'Outfit',sans-serif; font-size: 2rem; font-weight: 800; color: #f1f5f9; margin-bottom: 2rem; text-align: center; }
    .wdys-faq-list { display: flex; flex-direction: column; gap: 0.75rem; }
    .wdys-faq-item {
      border-radius: 12px;
      border: 1px solid rgba(99,102,241,0.15);
      background: rgba(15,23,42,0.7);
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .wdys-faq-item[open] { border-color: rgba(139,92,246,0.35); }
    .wdys-faq-q {
      padding: 1rem 1.25rem; font-weight: 700; font-size: 0.9rem; color: #c4b5fd;
      cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;
    }
    .wdys-faq-q::after { content: '+'; font-size: 1.2rem; color: #6366f1; transition: transform 0.2s; }
    .wdys-faq-item[open] .wdys-faq-q::after { transform: rotate(45deg); }
    .wdys-faq-a { padding: 0 1.25rem 1rem; font-size: 0.83rem; color: #94a3b8; line-height: 1.7; }
  </style>

  <script is:inline>
  // ============================================================
  //  VOTE STATE  (localStorage per-session)
  // ============================================================
  const STORAGE_KEY = 'wdys_votes_v2';
  const VISITORS_KEY = 'wdys_visitors_v1';

  function loadVotes() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); }
    catch { return {}; }
  }
  function saveVotes(v) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(v)); } catch {}
  }

  // Simulated global vote pool (seeded so results look real from day 1)
  const SEED = {
    '1': { a:1423, b:987 },
    '2': { a:1102, b:1340 },
    '3': { a:1688, b:954 },
    '4': { a:873, b:612 },
    '5': { a:1240, b:1080 },
    '6': { a:998, b:1205 },
    '7': { a:1450, b:882 },
    '8': { a:936, b:1104 },
    '9': { a:1288, b:1022 },
    '10':{ a:654, b:488, c:1210 },
    '11':{ a:1050, b:1190 },
    '12':{ a:1380, b:810 },
  };

  // ============================================================
  //  VISITOR COUNTER
  // ============================================================
  function initVisitorCounter() {
    const BASE = 24187;
    let stored = parseInt(localStorage.getItem(VISITORS_KEY) || '0');
    if (!stored) {
      stored = BASE + Math.floor(Math.random() * 800);
      localStorage.setItem(VISITORS_KEY, stored);
    }
    // Increment on each visit
    const visits = stored + 1;
    localStorage.setItem(VISITORS_KEY, visits);
    document.getElementById('visit-counter-text').textContent =
      `Today, ${visits.toLocaleString()} people have taken this test`;
  }

  // ============================================================
  //  PROGRESS TRACKER
  // ============================================================
  let answeredCount = 0;
  const TOTAL = 12;

  function updateProgress() {
    const pct = Math.round((answeredCount / TOTAL) * 100);
    document.getElementById('progress-bar').style.width = pct + '%';
    document.getElementById('progress-label').textContent = answeredCount + ' / ' + TOTAL + ' answered';
    if (answeredCount === TOTAL) {
      setTimeout(showResults, 600);
    }
  }

  // ============================================================
  //  VOTE HANDLER
  // ============================================================
  function getPct(card, choice) {
    const pool = SEED[String(card)] || {};
    const votes = loadVotes();
    const myVote = votes[String(card)];
    // add my vote to pool copy
    const counts = Object.assign({}, pool);
    if (myVote) counts[myVote] = (counts[myVote] || 0) + 1;
    const total = Object.values(counts).reduce((s, v) => s + v, 0);
    if (!total) return 0;
    return Math.round(((counts[choice] || 0) / total) * 100);
  }

  function revealBars(cardIndex) {
    const reveal = document.getElementById('reveal-' + cardIndex);
    if (!reveal) return;
    reveal.style.display = 'flex';
    reveal.style.flexDirection = 'column';
    reveal.style.gap = '0.5rem';

    const card = String(cardIndex);
    const choices = cardIndex === 10 ? ['a','b','c'] : ['a','b'];
    choices.forEach(ch => {
      const bar = document.getElementById('bar-' + cardIndex + '-' + ch);
      const pct = document.getElementById('pct-' + cardIndex + '-' + ch);
      if (!bar || !pct) return;
      const p = getPct(cardIndex, ch);
      setTimeout(() => { bar.style.width = p + '%'; }, 100);
      pct.textContent = p + '%';
    });
  }

  function handleVote(e) {
    const btn = e.currentTarget;
    const card = parseInt(btn.dataset.card);
    const choice = btn.dataset.choice;
    const votes = loadVotes();

    if (votes[String(card)]) return; // already voted

    votes[String(card)] = choice;
    saveVotes(votes);

    // Highlight selected button
    const siblings = btn.closest('.wdys-vote-buttons').querySelectorAll('.wdys-vote-btn');
    siblings.forEach(b => { b.disabled = true; b.classList.remove('selected-a','selected-b','selected-c'); });
    btn.classList.add('selected-' + choice);

    // Increment answeredCount only first time
    if (!window.__wdysAnswered) window.__wdysAnswered = {};
    if (!window.__wdysAnswered[card]) {
      window.__wdysAnswered[card] = true;
      answeredCount++;
      updateProgress();
    }

    // Mark card as voted
    document.getElementById('card-' + card)?.classList.add('voted');

    revealBars(card);
    updateProgress();
  }

  // ============================================================
  //  RESULTS
  // ============================================================
  function showResults() {
    const section = document.getElementById('results-section');
    section.style.display = 'block';
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });

    const votes = loadVotes();
    // Tally "a" vs "b" choices — "a" = first/creative, "b" = second/analytical
    let aCount = 0, bCount = 0;
    for (let i = 1; i <= 12; i++) {
      const v = votes[String(i)];
      if (v === 'a') aCount++;
      else if (v === 'b' || v === 'c') bCount++;
    }

    const icon = document.getElementById('brain-icon');
    const label = document.getElementById('brain-type-label');
    const desc = document.getElementById('brain-desc');

    if (aCount >= 9) {
      icon.textContent = '🎨';
      label.textContent = 'Right-Brain Creative Tendency';
      desc.textContent = 'You consistently gravitate toward the first, often more visually intuitive interpretation. Your visual cortex shows strong top-down creative priming — you tend to see the "big picture" before the details. Artists, musicians, and lateral thinkers share this pattern.';
    } else if (bCount >= 9) {
      icon.textContent = '🔬';
      label.textContent = 'Left-Brain Analytical Tendency';
      desc.textContent = 'You consistently select the second interpretation — often the more contextual, detail-oriented reading. Your visual system excels at bottom-up feature analysis before pattern completion. Scientists, engineers, and systematic thinkers share this perceptual style.';
    } else if (Math.abs(aCount - bCount) <= 3) {
      icon.textContent = '⚖️';
      label.textContent = 'Whole-Brain Integrative Thinker';
      desc.textContent = 'Your first impressions are beautifully balanced — you switch fluidly between creative and analytical interpretations. Neuroscience calls this high perceptual flexibility. You can train yourself to see both versions of any ambiguous figure with ease.';
    } else if (aCount > bCount) {
      icon.textContent = '🌟';
      label.textContent = 'Creative-Leaning Whole Thinker';
      desc.textContent = 'You lean creative but retain strong analytical depth. Your perceptual system is flexible and primed for novel interpretations first, but you can shift to systematic analysis when needed. A hallmark of innovative problem-solvers.';
    } else {
      icon.textContent = '🧩';
      label.textContent = 'Analytical-Leaning Whole Thinker';
      desc.textContent = 'You lean analytical but remain open to creative jumps. Your brain prefers to confirm structures before jumping to holistic conclusions. This makes you excellent at quality control, debugging, and spotting inconsistencies others miss.';
    }

    document.getElementById('score-breakdown').innerHTML =
      `<span>🎨 First-choice: ${aCount}</span><span>🔬 Second/Third-choice: ${bCount}</span><span>Total answered: ${aCount + bCount} / 12</span>`;
  }

  function shareResult() {
    try {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const el = document.getElementById('share-confirm');
        el.style.display = 'block';
        setTimeout(() => { el.style.display = 'none'; }, 2500);
      });
    } catch {
      document.getElementById('share-confirm').textContent = '📋 Copy this URL: ' + window.location.href;
      document.getElementById('share-confirm').style.display = 'block';
    }
  }

  // ============================================================
  //  ARROW REVEAL (card 1)
  // ============================================================
  function toggleArrows(showId, hideId, btn) {
    document.getElementById(showId).style.display = 'block';
    document.getElementById(hideId).style.display = 'none';
    btn.closest('.wdys-reveal-actions').querySelectorAll('.wdys-reveal-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }

  // ============================================================
  //  RUBIN HIGHLIGHT (card 3)
  // ============================================================
  function rubinHighlight(which) {
    const left = document.getElementById('rubin-left');
    const right = document.getElementById('rubin-right');
    const vase = document.getElementById('rubin-vase-hl');
    if (which === 'faces') {
      left.style.fill = '#7c3aed';
      right.style.fill = '#7c3aed';
      vase.style.fill = 'rgba(250,204,21,0)';
    } else {
      left.style.fill = '#1e1b4b';
      right.style.fill = '#1e1b4b';
      vase.style.fill = 'rgba(250,204,21,0.5)';
    }
  }

  // ============================================================
  //  NECKER CUBE FLIP (card 9)
  // ============================================================
  let neckerFlipped = false;
  function neckerFlip() {
    neckerFlipped = !neckerFlipped;
    const front = document.getElementById('necker-front');
    const back = document.getElementById('necker-back');
    if (neckerFlipped) {
      front.style.stroke = '#6366f1';
      front.style.strokeDasharray = '6,4';
      back.style.stroke = '#e2e8f0';
      back.style.strokeDasharray = 'none';
    } else {
      front.style.stroke = '#e2e8f0';
      front.style.strokeDasharray = 'none';
      back.style.stroke = '#6366f1';
      back.style.strokeDasharray = '6,4';
    }
  }
  // Auto-flip timer
  setInterval(() => {
    const votes = loadVotes();
    if (!votes['9']) return; // only animate after voting
    neckerFlip();
  }, 4200);

  // ============================================================
  //  SPINNING DANCER (card 8)
  // ============================================================
  function initDancer() {
    const svg = document.getElementById('dancer-svg');
    const speedSlider = document.getElementById('dancer-speed');
    const beltCheck = document.getElementById('dancer-belt');
    if (!svg || !speedSlider) return;

    speedSlider.addEventListener('input', () => {
      const dur = (6 - parseInt(speedSlider.value)) * 0.8 + 0.4;
      svg.style.animationDuration = dur + 's';
    });

    beltCheck.addEventListener('change', () => {
      const body = svg.querySelector('ellipse[fill="#c084fc"]');
      if (body) {
        body.setAttribute('fill', beltCheck.checked ? '#f97316' : '#c084fc');
      }
    });
  }

  // ============================================================
  //  DOTS CANVAS (card 10)
  // ============================================================
  function initDots() {
    const canvas = document.getElementById('dots-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    let t = 0;
    const R = 55;
    const cx = W / 2, cy = H / 2;

    function draw() {
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = '#0f172a';
      ctx.fillRect(0, 0, W, H);

      // Dot A — moves in a circle
      const ax = cx - R + R * Math.cos(t);
      const ay = cy + R * Math.sin(t);
      ctx.beginPath();
      ctx.arc(ax, ay, 16, 0, Math.PI * 2);
      ctx.fillStyle = '#818cf8';
      ctx.shadowColor = '#6366f1';
      ctx.shadowBlur = 20;
      ctx.fill();

      // Dot B — moves in opposite phase circle
      const bx = cx + R + R * Math.cos(t + Math.PI);
      const by = cy + R * Math.sin(t + Math.PI);
      ctx.beginPath();
      ctx.arc(bx, by, 16, 0, Math.PI * 2);
      ctx.fillStyle = '#f472b6';
      ctx.shadowColor = '#ec4899';
      ctx.shadowBlur = 20;
      ctx.fill();
      ctx.shadowBlur = 0;

      // Path trace
      ctx.strokeStyle = 'rgba(129,140,248,0.12)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(cx - R, cy, R, 0, Math.PI * 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.arc(cx + R, cy, R, 0, Math.PI * 2);
      ctx.stroke();

      t += 0.032;
      requestAnimationFrame(draw);
    }
    draw();

    // Cover slider
    const coverSlider = document.getElementById('dots-cover');
    const stage = document.getElementById('dots-stage');
    if (coverSlider && stage) {
      coverSlider.addEventListener('input', () => {
        const pct = parseInt(coverSlider.value);
        // Darken right side of canvas using overlay positioned over canvas
        canvas.style.maskImage = pct > 0
          ? `linear-gradient(to right, black ${100-pct}%, transparent ${100-pct}%)`
          : 'none';
        canvas.style.webkitMaskImage = canvas.style.maskImage;
      });
    }
  }

  // ============================================================
  //  SEASONAL DUCK/RABBIT (card 11)
  // ============================================================
  function initSeasonal() {
    const month = new Date().getMonth(); // 0=Jan
    const label = document.getElementById('seasonal-label');
    const duckHint = document.getElementById('duck-hint');
    const rabbitHint = document.getElementById('rabbit-hint');
    const science = document.getElementById('seasonal-science');

    const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const isDuckSeason = month >= 2 && month <= 8; // March–September

    if (label) label.textContent = '📅 ' + monthNames[month] + (isDuckSeason ? ' — Duck Season 🦆' : ' — Rabbit Season 🐇');

    if (isDuckSeason && duckHint) {
      duckHint.style.opacity = '0.7';
    } else if (rabbitHint) {
      rabbitHint.style.opacity = '0.7';
    }

    if (science) {
      science.textContent = isDuckSeason
        ? `It's ${monthNames[month]}! Jastrow's research found people are primed by seasonal animal imagery. Spring/Summer months → duck features feel more salient. Does the bill look more prominent to you?`
        : `It's ${monthNames[month]}! Autumn/Winter months prime people for rabbit imagery. The long ears may jump out more readily right now. This is a real example of top-down perceptual priming from cultural calendar context.`;
    }
  }

  // ============================================================
  //  INIT ALL
  // ============================================================
  document.addEventListener('DOMContentLoaded', () => {
    initVisitorCounter();
    updateProgress();
    initDancer();
    initDots();
    initSeasonal();

    // Restore any prior votes from this session
    const votes = loadVotes();
    Object.entries(votes).forEach(([card, choice]) => {
      const btns = document.querySelectorAll(`[data-card="${card}"]`);
      btns.forEach(b => {
        b.disabled = true;
        if (b.dataset.choice === choice) b.classList.add('selected-' + choice);
      });
      revealBars(parseInt(card));
      if (!window.__wdysAnswered) window.__wdysAnswered = {};
      if (!window.__wdysAnswered[card]) {
        window.__wdysAnswered[card] = true;
        answeredCount++;
      }
      document.getElementById('card-' + card)?.classList.add('voted');
    });
    updateProgress();

    // Show results if all 12 answered from a previous session
    if (answeredCount === TOTAL) {
      document.getElementById('results-section').style.display = 'block';
      showResults();
    }

    // Attach vote listeners
    document.querySelectorAll('.wdys-vote-btn').forEach(btn => {
      btn.addEventListener('click', handleVote);
    });
  });
  </script>

</Layout>
