---
// src/pages/what-do-you-see.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="What Do You See First? 10 Ambiguous Illusions | Optical Illusion Lab"
  description="These images have two completely valid interpretations. Which one your brain picks first reveals something fascinating about you. Take the 10-illusion perception test and discover your Brain Type."
>

  <!-- Hero Section -->
  <section class="wdys-hero relative overflow-hidden py-20 px-4 sm:px-6 lg:px-8 text-white border-b border-indigo-500/10">
    <div class="wdys-hero-bg-radial"></div>
    <div class="wdys-hero-orb wdys-orb-1"></div>
    <div class="wdys-hero-orb wdys-orb-2"></div>

    <div class="relative mx-auto max-w-5xl text-center space-y-6">
      <nav class="flex justify-center text-xs font-semibold text-indigo-300 space-x-2" aria-label="Breadcrumb">
        <a href="/" class="hover:underline hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-400">What Do You See First?</span>
      </nav>

      <div class="wdys-badge">
        👁️ PERCEPTION TEST
      </div>

      <h1 class="font-display text-5xl sm:text-7xl font-extrabold tracking-tight wdys-title-gradient">
        What Do You See First?
      </h1>
      <p class="mx-auto max-w-2xl text-base sm:text-xl text-slate-300 leading-relaxed">
        These images have <strong class="text-white">TWO completely valid interpretations.</strong>
        Which one your brain picks first reveals something fascinating about you.
      </p>

      <!-- Live Visit Counter -->
      <div class="wdys-counter-pill" id="visit-counter-pill">
        <span class="wdys-counter-dot"></span>
        <span id="visit-counter-text">Loading visitors...</span>
      </div>

      <!-- Progress tracker -->
      <div class="wdys-progress-bar-outer" id="progress-wrapper">
        <div class="wdys-progress-track">
          <div class="wdys-progress-fill" id="progress-bar" style="width:0%"></div>
        </div>
        <span class="wdys-progress-label" id="progress-label">0 / 10 answered</span>
      </div>
    </div>
  </section>

  <!-- Cards Grid -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
    <div class="wdys-grid" id="illusions-grid">

      <!-- ===== CARD 1: OLD WOMAN / YOUNG WOMAN ===== -->
      <div class="wdys-card border-l-4 border-l-yellow-500" id="card-1" data-index="1">
        <div class="wdys-card-header">
          <div class="wdys-tags"><span class="wdys-tag-medium">🟡 Medium</span><span class="wdys-tag-type">Bistable Portrait</span></div>
          <h2 class="wdys-card-title">1. Old Woman / Young Woman</h2>
          <p class="wdys-card-desc">The same drawing contains two complete people. The young woman's chin is the old woman's nose. Her choker is the old woman's mouth.</p>
        </div>

        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Observe the profile line. Can you see a young lady looking away, or an old woman looking downwards in profile?
          </div>
        </div>
<div class="wdys-demo-area">
          <!-- SVG Old Woman / Young Woman -->
          <svg id="svg-ow-yw" class="wdys-svg" viewBox="0 0 240 280" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <marker id="arr-blue-1" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M0 1L10 5L0 9z" fill="#60a5fa"/></marker>
              <marker id="arr-rose-1" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M0 1L10 5L0 9z" fill="#fb7185"/></marker>
            </defs>
            <!-- Main figure outline -->
            <path class="wdys-path-main" d="M 100,30 Q 140,18 165,40 Q 185,60 175,95 Q 165,130 155,145 Q 150,155 148,165 Q 145,175 130,185 Q 110,195 90,188 Q 70,178 65,162 Q 55,145 60,125 Q 52,108 55,90 Q 58,65 70,48 Z"/>
            <!-- Hair / bonnet top -->
            <path class="wdys-path-detail" d="M 95,28 Q 120,15 148,32 Q 165,42 168,58" stroke-width="3"/>
            <!-- Face profile - left side (young jaw / old nose+chin) -->
            <path class="wdys-path-main" d="M 70,68 Q 58,90 57,108 Q 53,130 62,148 Q 68,162 75,168"/>
            <!-- Nose (young) / protrusion (old) -->
            <path class="wdys-path-main" d="M 75,100 Q 63,108 62,118 Q 65,126 78,120"/>
            <!-- Mouth / choker -->
            <path class="wdys-path-main" d="M 80,160 Q 95,168 110,162" stroke-linecap="round"/>
            <!-- Eye (young, small) / Ear (old) -->
            <path class="wdys-path-detail" d="M 90,78 Q 86,82 87,87 Q 91,90 96,87 Q 98,82 95,78 Z" stroke-width="1.5"/>
            <!-- Ear (young) -->
            <path class="wdys-path-detail" d="M 148,88 Q 155,93 154,102 Q 150,108 143,104" stroke-width="1.5"/>
            <!-- Eyelashes / wrinkle lines (old) -->
            <path class="wdys-path-faint" d="M 72,95 Q 80,92 90,93"/>
            <path class="wdys-path-faint" d="M 68,120 Q 74,118 80,120"/>
            <!-- Neckband / scarf -->
            <path class="wdys-path-detail" d="M 75,170 Q 100,182 125,172 Q 135,168 140,162" stroke-width="2"/>
            <!-- Fur trim / collar -->
            <path class="wdys-path-faint" d="M 65,185 Q 90,200 115,195 Q 135,190 148,178"/>

            <!-- Young-woman annotation arrows (hidden by default) -->
            <g id="ow-yw-young-arrows" style="display:none">
              <line x1="170" y1="80" x2="128" y2="83" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#arr-blue-1)"/>
              <text x="175" y="78" fill="#60a5fa" font-size="9" font-weight="bold">Eye</text>
              <line x1="170" y1="155" x2="105" y2="162" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#arr-blue-1)"/>
              <text x="175" y="153" fill="#60a5fa" font-size="9" font-weight="bold">Choker</text>
              <line x1="170" y1="115" x2="135" y2="108" stroke="#60a5fa" stroke-width="1.5" marker-end="url(#arr-blue-1)"/>
              <text x="175" y="113" fill="#60a5fa" font-size="9" font-weight="bold">Ear</text>
            </g>
            <!-- Old-woman annotation arrows (hidden by default) -->
            <g id="ow-yw-old-arrows" style="display:none">
              <line x1="20" y1="113" x2="58" y2="116" stroke="#fb7185" stroke-width="1.5" marker-end="url(#arr-rose-1)"/>
              <text x="3" y="111" fill="#fb7185" font-size="9" font-weight="bold">Nose</text>
              <line x1="20" y1="163" x2="68" y2="163" stroke="#fb7185" stroke-width="1.5" marker-end="url(#arr-rose-1)"/>
              <text x="1" y="161" fill="#fb7185" font-size="9" font-weight="bold">Mouth</text>
              <line x1="20" y1="85" x2="83" y2="85" stroke="#fb7185" stroke-width="1.5" marker-end="url(#arr-rose-1)"/>
              <text x="4" y="83" fill="#fb7185" font-size="9" font-weight="bold">Ear</text>
            </g>
          </svg>
        </div>

        <div class="wdys-vote-section">
          <p class="wdys-vote-prompt">Which do you see first?</p>
          <div class="wdys-vote-buttons">
            <button class="wdys-vote-btn" data-card="1" data-choice="a">👱‍♀️ Young Woman</button>
            <button class="wdys-vote-btn" data-card="1" data-choice="b">👵 Old Woman</button>
          </div>
          <div class="wdys-reveal-bar" id="reveal-1" style="display:none">
            <div class="wdys-result-bar-row">
              <span class="wdys-result-label">👱‍♀️ Young</span>
              <div class="wdys-bar-track"><div class="wdys-bar-fill wdys-bar-a" id="bar-1-a" style="width:0%"></div></div>
              <span class="wdys-pct" id="pct-1-a">—</span>
            </div>
            <div class="wdys-result-bar-row">
              <span class="wdys-result-label">👵 Old</span>
              <div class="wdys-bar-track"><div class="wdys-bar-fill wdys-bar-b" id="bar-1-b" style="width:0%"></div></div>
              <span class="wdys-pct" id="pct-1-b">—</span>
            </div>
            <div class="wdys-reveal-actions">
              <button class="wdys-reveal-btn active" onclick="toggleArrows('ow-yw-young-arrows','ow-yw-old-arrows',this)">Show Young Woman ↗</button>
              <button class="wdys-reveal-btn" onclick="toggleArrows('ow-yw-old-arrows','ow-yw-young-arrows',this)">Show Old Woman ↗</button>
            </div>
          </div>
        </div>
      
        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            The Old Woman / Young Woman portrait is a classic bistable ambiguous figure. The young woman's cheek and chin double as the old woman's nose, her ear represents the old woman's eye, and her neckband is perceived as the old woman's mouth. The brain cannot resolve both interpretations simultaneously, toggling its attention between them.
          </p>
        </details>

        <!-- Explore Link -->
        <div class="w-full mt-4 pt-4 border-t border-slate-500/10 flex justify-between items-center text-xs font-black text-indigo-400 hover:text-indigo-300 transition-colors">
          <span>Explore Science & Facts</span>
          <a href="/illusions/old-woman-young-woman" class="hover:underline">Explore &rarr;</a>
        </div>
</div>

      <!-- ===== CARD 2: DUCK OR RABBIT ===== -->
      <div class="wdys-card border-l-4 border-l-emerald-500" id="card-2" data-index="2">
        <div class="wdys-card-header">
          <div class="wdys-tags"><span class="wdys-tag-easy">🟢 Easy</span><span class="wdys-tag-type">Classic Bistable</span></div>
          <h2 class="wdys-card-title">2. Duck or Rabbit?</h2>
          <p class="wdys-card-desc">Jastrow's 1899 classic. The duck's bill becomes the rabbit's ears depending on which way your brain points the animal.</p>
        </div>

        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Observe the protrusions on the left. Do you see them as a duck's open bill facing left, or a rabbit's ears facing right?
          </div>
        </div>
<div class="wdys-demo-area">
          <svg id="svg-duck-rabbit" class="wdys-svg bg-slate-900 rounded-xl p-2" viewBox="0 0 300 200" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="160" cy="110" rx="75" ry="55" fill="#ffffff" />
            <ellipse cx="95" cy="100" rx="40" ry="35" fill="#ffffff" />
            <path d="M 58,82 Q 25,72 10,90 Q 18,103 58,100 Z" fill="#ffffff" />
            <path d="M 58,100 Q 25,103 12,120 Q 20,133 58,117 Z" fill="#ffffff" />
            <circle cx="82" cy="86" r="6" fill="#0f172a" />
            <circle cx="82" cy="86" r="3" fill="#ffffff" />
            <path d="M 95,120 Q 90,110 95,100" stroke="#0f172a" stroke-width="2.5" fill="none" />

            <!-- Duck Highlight Overlay -->
            <g id="dr-duck-overlay" style="display:none" class="pointer-events-none">
              <path d="M 58,82 Q 25,72 10,90 Q 18,103 58,100 Z" stroke="#3b82f6" stroke-width="3.5" fill="none" />
              <path d="M 58,100 Q 25,103 12,120 Q 20,133 58,117 Z" stroke="#3b82f6" stroke-width="3.5" fill="none" />
              <text x="15" y="65" fill="#60a5fa" font-size="11" font-weight="900">Duck Bill</text>
            </g>
            <!-- Rabbit Highlight Overlay -->
            <g id="dr-rabbit-overlay" style="display:none" class="pointer-events-none">
              <path d="M 58,82 Q 25,72 10,90 Q 18,103 58,100 Z" stroke="#ef4444" stroke-width="3.5" fill="none" />
              <path d="M 58,100 Q 25,103 12,120 Q 20,133 58,117 Z" stroke="#ef4444" stroke-width="3.5" fill="none" />
              <text x="15" y="145" fill="#f87171" font-size="11" font-weight="900">Rabbit Ears</text>
            </g>
          </svg>
          <p class="wdys-fun-fact">🌱 Fun fact: People born in spring tend to see the rabbit first!</p>
        </div>

        <div class="wdys-vote-section">
          <p class="wdys-vote-prompt">Which do you see first?</p>
          <div class="wdys-vote-buttons">
            <button class="wdys-vote-btn" data-card="2" data-choice="a">🦆 Duck</button>
            <button class="wdys-vote-btn" data-card="2" data-choice="b">🐇 Rabbit</button>
          </div>
          <div class="wdys-reveal-bar" id="reveal-2" style="display:none">
            <div class="wdys-result-bar-row">
              <span class="wdys-result-label">🦆 Duck</span>
              <div class="wdys-bar-track"><div class="wdys-bar-fill wdys-bar-a" id="bar-2-a" style="width:0%"></div></div>
              <span class="wdys-pct" id="pct-2-a">—</span>
            </div>
            <div class="wdys-result-bar-row">
              <span class="wdys-result-label">🐇 Rabbit</span>
              <div class="wdys-bar-track"><div class="wdys-bar-fill wdys-bar-b" id="bar-2-b" style="width:0%"></div></div>
              <span class="wdys-pct" id="pct-2-b">—</span>
            </div>
            <div class="wdys-reveal-actions">
              <button class="wdys-reveal-btn active" onclick="toggleArrows('dr-duck-overlay','dr-rabbit-overlay',this)">Show Duck 🦆</button>
              <button class="wdys-reveal-btn" onclick="toggleArrows('dr-rabbit-overlay','dr-duck-overlay',this)">Show Rabbit 🐇</button>
            </div>
            <p class="wdys-insight">Tip: Tilt your head right → duck. Left → rabbit. The ambiguity is in the horizontal orientation of the "bill/ears".</p>
          </div>
        </div>
      
        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            The Duck-Rabbit is a classic bistable figure. The horizontal protrusions function as either a duck's bill or a rabbit's ears. The brain alternates between these interpretations based on top-down semantic priming and gaze orientation.
          </p>
        </details>

        <!-- Explore Link -->
        <div class="w-full mt-4 pt-4 border-t border-slate-500/10 flex justify-between items-center text-xs font-black text-indigo-400 hover:text-indigo-300 transition-colors">
          <span>Explore Science & Facts</span>
          <a href="/illusions/duck-rabbit" class="hover:underline">Explore &rarr;</a>
        </div>
</div>

      <!-- ===== CARD 3: FACE OR VASE (RUBIN) ===== -->
      <div class="wdys-card border-l-4 border-l-emerald-500" id="card-3" data-index="3">
        <div class="wdys-card-header">
          <div class="wdys-tags"><span class="wdys-tag-easy">🟢 Easy</span><span class="wdys-tag-type">Figure-Ground</span></div>
          <h2 class="wdys-card-title">3. Face or Vase?</h2>
          <p class="wdys-card-desc">Edgar Rubin's 1915 masterpiece of figure-ground perception. Your brain can only hold one interpretation at a time.</p>
        </div>

        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Stare at the center. Do you see a yellow vase, or two dark profiles facing each other?
          </div>
        </div>
<div class="wdys-demo-area">
          <svg id="svg-rubin" class="wdys-svg" viewBox="0 0 240 260" xmlns="http://www.w3.org/2000/svg">
            <rect width="240" height="260" fill="#1e1b4b" rx="8"/>
            <!-- Left face profile -->
            <path id="rubin-left" fill="#e2e8f0"
              d="M 0,0 L 80,0
                 Q 85,40 80,55
                 Q 72,75 65,88
                 Q 55,102 58,118
                 Q 60,130 52,145
                 Q 48,158 55,170
                 Q 62,182 70,192
                 Q 80,205 80,260
                 L 0,260 Z"/>
            <!-- Right face profile (mirror) -->
            <path id="rubin-right" fill="#e2e8f0"
              d="M 240,0 L 160,0
                 Q 155,40 160,55
                 Q 168,75 175,88
                 Q 185,102 182,118
                 Q 180,130 188,145
                 Q 192,158 185,170
                 Q 178,182 170,192
                 Q 160,205 160,260
                 L 240,260 Z"/>
            <!-- Vase highlight overlay (initially hidden) -->
            <path id="rubin-vase-hl" fill="rgba(250,204,21,0)"
              d="M 80,0 Q 90,30 95,55 Q 105,88 120,103 Q 105,118 95,145 Q 88,165 85,192 Q 90,220 100,250 L 140,250 Q 150,220 155,192 Q 152,165 145,145 Q 135,118 120,103 Q 135,88 145,55 Q 150,30 160,0 Z"/>
            <!-- Vase (center white space) — made of invisible path for clarity -->
          </svg>
          <p class="wdys-fun-fact" id="rubin-hint">Hover to see the vase highlighted in gold ✨</p>
        </div>

        <div class="wdys-vote-section">
          <p class="wdys-vote-prompt">What did you see first?</p>
          <div class="wdys-vote-buttons">
            <button class="wdys-vote-btn" data-card="3" data-choice="a">👤 Two Faces</button>
            <button class="wdys-vote-btn" data-card="3" data-choice="b">🏺 A Vase</button>
          </div>
          <div class="wdys-reveal-bar" id="reveal-3" style="display:none">
            <div class="wdys-result-bar-row">
              <span class="wdys-result-label">👤 Faces</span>
              <div class="wdys-bar-track"><div class="wdys-bar-fill wdys-bar-a" id="bar-3-a" style="width:0%"></div></div>
              <span class="wdys-pct" id="pct-3-a">—</span>
            </div>
            <div class="wdys-result-bar-row">
              <span class="wdys-result-label">🏺 Vase</span>
              <div class="wdys-bar-track"><div class="wdys-bar-fill wdys-bar-b" id="bar-3-b" style="width:0%"></div></div>
              <span class="wdys-pct" id="pct-3-b">—</span>
            </div>
            <div class="wdys-reveal-actions">
              <button class="wdys-reveal-btn active" onclick="rubinHighlight('faces', this)">Highlight Faces 👤</button>
              <button class="wdys-reveal-btn" onclick="rubinHighlight('vase', this)">Highlight Vase 🏺</button>
            </div>
          </div>
        </div>
      
        <!-- Collapsible Explanation -->
        <details class="w-full mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none text-left">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            Rubin's Vase is a classic figure-ground illusion. The visual cortex must decide whether to assign the central contour to the foreground (creating a vase) or the background (creating two profiles facing each other).
          </p>
        </details>

        <!-- Explore Link -->
        <div class="w-full mt-4 pt-4 border-t border-slate-500/10 flex justify-between items-center text-xs font-black text-indigo-400 hover:text-indigo-300 transition-colors">
          <span>Explore Science & Facts</span>
          <a href="/illusions/rubins-vase" class="hover:underline">Explore &rarr;</a>
        </div>
</div>

      <!-- ===== CARD 4: DUCK OR SQUIRREL ===== -->
      <div class="wdys-card border-l-4 border-l-rose-500" id="card-4" data-index="4">
        <div class="wdys-card-header">
          <div class="wdys-tags"><span class="wdys-tag-hard">🔴 Hard</span><span class="wdys-tag-type">Bistable Animal</span></div>
          <h2 class="wdys-card-title">4. Duck or Squirrel?</h2>
          <p class="wdys-card-desc">The duck's bill sweeps into the squirrel's bushy tail. Fewer than 40% of viewers see both animals without a hint.</p>
        </div>

        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350 text-left">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Observe the main figure shape. Is it a duck looking to the left, or a squirrel holding a nut facing right?
          </div>
        </div>
<div class="wdys-demo-area">
          <svg id="svg-duck-squirrel" class="wdys-svg" viewBox="0 0 260 220" xmlns="http://www.w3.org/2000/svg">
            <!-- Body shared -->
            <ellipse class="wdys-fill-primary" cx="125" cy="125" rx="58" ry="42"/>
            <!-- Head -->
            <ellipse class="wdys-fill-primary" cx="80" cy="100" rx="30" ry="26"/>
            <!-- Duck bill / Squirrel face snout -->
            <path class="wdys-fill-secondary" d="M 52,90 Q 30,82 18,98 Q 28,113 52,108 Z"/>
            <!-- Squirrel bushy tail / Duck wing -->
            <path class="wdys-fill-secondary" d="M 170,75 Q 210,55 228,82 Q 240,100 225,122 Q 205,145 175,138 Q 155,128 165,110 Q 172,95 170,75 Z"/>
            <!-- Squirrel ear / Duck head feather -->
            <path class="wdys-fill-primary" d="M 72,75 Q 70,55 82,52 Q 92,52 90,72 Z"/>
            <!-- Eye -->
            <circle cx="68" cy="92" r="5" fill="white"/>
            <circle cx="68" cy="92" r="2.5" fill="#1e293b"/>
            <circle cx="69" cy="91" r="1" fill="white"/>
            <!-- Legs / feet -->
            <path class="wdys-fill-secondary" d="M 108,165 Q 112,180 122,183 Q 130,178 128,165 Z"/>
            <path class="wdys-fill-secondary" d="M 128,165 Q 132,180 142,182 Q 150,176 148,165 Z"/>

            <!-- Duck Overlay -->
            <g id="ds-duck-overlay" style="display:none" class="pointer-events-none">
              <path d="M 52,90 Q 30,82 18,98 Q 28,113 52,108 Z" fill="none" stroke="#3b82f6" stroke-width="2.5" />
              <path d="M 170,75 Q 210,55 228,82 Q 240,100 225,122 Q 205,145 175,138 Q 155,128 165,110 Q 172,95 170,75 Z" fill="none" stroke="#3b82f6" stroke-width="2.5" />
              <text x="125" y="45" fill="#60a5fa" font-size="10" font-weight="900" text-anchor="middle">Duck Wing & Beak</text>
            </g>
            <!-- Squirrel Overlay -->
            <g id="ds-squirrel-overlay" style="display:none" class="pointer-events-none">
              <path d="M 170,75 Q 210,55 228,82 Q 240,100 225,122 Q 205,145 175,138 Q 155,128 165,110 Q 172,95 170,75 Z" fill="none" stroke="#ef4444" stroke-width="2.5" />
              <path d="M 72,75 Q 70,55 82,52 Q 92,52 90,72 Z" fill="none" stroke="#ef4444" stroke-width="2.5" />
