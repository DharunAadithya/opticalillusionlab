  <style>
    /* Continuous rotating animation for Spinning Dancer */
    @keyframes spin-dancer-scale {
      0% { transform: scaleX(1); }
      50% { transform: scaleX(-1); }
      100% { transform: scaleX(1); }
    }
  </style>

  <script>
    function initHiddenLabs() {
      const cards = document.querySelectorAll('.illusion-container');
      
      cards.forEach(card => {
        const id = card.getAttribute('data-id');
        const timerText = card.querySelector('.countdown-timer') as HTMLElement;
        const btnGiveUp = card.querySelector('.btn-give-up') as HTMLButtonElement;
        const explanation = card.querySelector('.science-explanation') as HTMLElement;
        
        let secondsLeft = 30.0;
        let isRevealed = false;
        
        const startTime = Date.now();
        const intervalId = setInterval(() => {
          if (isRevealed) {
            clearInterval(intervalId);
            return;
          }
          
          const elapsed = (Date.now() - startTime) / 1000;
          secondsLeft = Math.max(30.0 - elapsed, 0.0);
          
          if (timerText) timerText.textContent = `${secondsLeft.toFixed(1)}s`;
          
          if (secondsLeft <= 0) {
            clearInterval(intervalId);
            triggerReveal();
          }
        }, 100);
        
        const triggerReveal = () => {
          if (isRevealed) return;
          isRevealed = true;
          clearInterval(intervalId);
          if (timerText) timerText.textContent = '0.0s';
          
          card.classList.add('revealed-active');
          if (explanation) explanation.classList.remove('hidden');
          if (btnGiveUp) {
            btnGiveUp.textContent = 'Revealed ✓';
            btnGiveUp.disabled = true;
          }

          if (id === 'impossible-trident') {
            const btnTrace = card.querySelector('.btn-trace-trident') as HTMLButtonElement;
            if (btnTrace) btnTrace.click();
          } else if (id === 'spinning-dancer') {
            const dancerBelt = card.querySelector('#dancer-belt-toggle') as HTMLInputElement;
            if (dancerBelt) {
              dancerBelt.checked = true;
              dancerBelt.dispatchEvent(new Event('change'));
            }
          } else if (id === 'hermann-grid') {
            const checkBtn = card.querySelector('#submit-dots-btn') as HTMLButtonElement;
            const checkInput = card.querySelector('#dots-count-input') as HTMLInputElement;
            if (checkInput) checkInput.value = '0';
            if (checkBtn) checkBtn.click();
          }
        };
        
        btnGiveUp?.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          triggerReveal();
        });

        if (id === 'spinning-dancer') {
          const beltToggle = card.querySelector('#dancer-belt-toggle') as HTMLInputElement;
          const leftLimb = card.querySelector('.dancer-left-limb');
          const rightLimb = card.querySelector('.dancer-right-limb');
          beltToggle?.addEventListener('change', (e) => {
            const checked = (e.target as HTMLInputElement).checked;
            if (leftLimb && rightLimb) {
              if (checked) {
                leftLimb.setAttribute('fill', '#ef4444');  // Red
                rightLimb.setAttribute('fill', '#3b82f6'); // Blue
              } else {
                leftLimb.setAttribute('fill', 'currentColor');
                rightLimb.setAttribute('fill', 'currentColor');
              }
            }
          });
        }
      });
    }

    initHiddenLabs();
    document.addEventListener('astro:page-load', initHiddenLabs);
  </script>
