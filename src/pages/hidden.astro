          } else {
            overlayS?.classList.replace('opacity-0', 'opacity-100');
            if (btnToggleS) btnToggleS.textContent = "Hide Skull 💀";
          }
        });
      }
      // 3. Duck-Rabbit Seasonal Hint
      const seasonalHintBox = document.getElementById('seasonal-hint-box');
      if (seasonalHintBox) {
        const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
        const currentMonth = months[new Date().getMonth()];
        let hint = "";
        if (currentMonth === 'April') {
          hint = `🐰 <strong>Easter (April) Hint:</strong> 75% of users report seeing the Rabbit first due to recent holiday bias!`;
        } else if (currentMonth === 'November' || currentMonth === 'December') {
          hint = `🦆 <strong>Fall Hint:</strong> 80% of users report seeing the Duck first as wild ducks migrate!`;
        } else {
          hint = `📅 <strong>Seasonal Fact:</strong> Currently it is ${currentMonth}. Duck/Rabbit perception changes seasonally based on ambient exposure!`;
        }
        seasonalHintBox.innerHTML = hint;
      }

      // 5. Hidden Faces Trees
      const treeCard = document.querySelector('[data-id="hidden-faces-trees"]') as HTMLElement;
      if (treeCard) {
        const targets = treeCard.querySelectorAll('.face-target');
        const countText = treeCard.querySelector('.faces-count');
        const resetBtn = treeCard.querySelector('.reset-faces-btn');
        const spotBtn = treeCard.querySelector('.btn-spot');
        const faceMsg = treeCard.querySelector('.face-message');
        const timeEl = treeCard.querySelector('.spot-time');
        
        let foundSet = new Set();
        
        targets.forEach(target => {
          target.addEventListener('click', (e) => {
            e.stopPropagation();
            const idx = target.getAttribute('data-idx');
            if (idx && !foundSet.has(idx)) {
              foundSet.add(idx);
              const highlight = document.getElementById(`highlight-${idx}`);
              if (highlight) highlight.classList.replace('opacity-0', 'opacity-100');
              
              if (countText) countText.textContent = foundSet.size.toString();
              
              if (foundSet.size === 6) {
                faceMsg?.classList.remove('hidden');
                // Auto trigger spot button click
                btnSpotTrigger(treeCard);
              }
            }
          });
        });

        resetBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          foundSet.clear();
          if (countText) countText.textContent = "0";
          faceMsg?.classList.add('hidden');
          if (timeEl) timeEl.classList.remove('stopped', 'text-green-500');
          treeCard.querySelectorAll('[id^="highlight-"]').forEach(hl => {
            hl.classList.replace('opacity-100', 'opacity-0');
          });
        });
      }

      // 7. Hermann Grid Dots Input
      const hermannCard = document.querySelector('[data-id="hermann-grid"]') as HTMLElement;
      const dotsInput = document.getElementById('dots-count-input') as HTMLInputElement;
      const submitDotsBtn = document.getElementById('submit-dots-btn');
      const dotsFeedback = document.getElementById('dots-feedback-panel');
      const dotsFeedbackStatus = document.getElementById('dots-feedback-status');
      const dotsUserGuess = document.getElementById('dots-user-guess');
      const dotsTryAgainBtn = document.getElementById('dots-try-again-btn');

      submitDotsBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        const guess = parseInt(dotsInput.value || '0');
        if (dotsUserGuess) dotsUserGuess.textContent = guess.toString();
        
        if (dotsFeedback) dotsFeedback.classList.remove('hidden');
        
        if (guess === 0) {
          if (dotsFeedbackStatus) {
            dotsFeedbackStatus.textContent = "Correct ✓";
            dotsFeedbackStatus.className = "font-bold text-emerald-450 font-mono text-sm";
          }
          btnSpotTrigger(hermannCard);
        } else {
          if (dotsFeedbackStatus) {
            dotsFeedbackStatus.textContent = "Incorrect ✗";
            dotsFeedbackStatus.className = "font-bold text-rose-500 font-mono text-sm";
          }
        }
      });

      dotsTryAgainBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (dotsInput) dotsInput.value = "0";
        if (dotsFeedback) dotsFeedback.classList.add('hidden');
      });

      // 8. Spinning Dancer Color Guide Toggle
      const beltToggle = document.getElementById('dancer-belt-toggle') as HTMLInputElement;
      const dancerCard = document.querySelector('[data-id="spinning-dancer"]') as HTMLElement;
      const leftLimb = dancerCard?.querySelector('.dancer-left-limb');
      const rightLimb = dancerCard?.querySelector('.dancer-right-limb');
      beltToggle?.addEventListener('change', (e) => {
        const checked = (e.target as HTMLInputElement).checked;
        if (leftLimb && rightLimb) {
          if (checked) {
            leftLimb.setAttribute('fill', '#ef4444');  // Red
            rightLimb.setAttribute('fill', '#3b82f6'); // Blue
          } else {
            leftLimb.setAttribute('fill', 'currentColor');
            rightLimb.setAttribute('fill', 'currentColor');
          }
        }
      });

      // 10. Impossible Elephant
      const elephantCard = document.querySelector('[data-id="impossible-elephant"]') as HTMLElement;
      const btnElephant4 = document.getElementById('btn-elephant-4');
      const btnElephant5 = document.getElementById('btn-elephant-5');
      const btnElephantReveal = document.getElementById('btn-elephant-reveal');
      const elephantFeedback = document.getElementById('elephant-feedback-panel');
      const elephantUserGuess = document.getElementById('elephant-user-guess');
      const elephantTryAgain = document.getElementById('elephant-try-again-btn');
      const elephantOverlay = elephantCard?.querySelector('.diagram-overlay');

      const handleElephantGuess = (guessStr: string) => {
        if (elephantUserGuess) elephantUserGuess.textContent = guessStr;
        if (elephantFeedback) elephantFeedback.classList.remove('hidden');
        if (elephantOverlay) {
          elephantOverlay.classList.remove('opacity-0');
          elephantOverlay.classList.add('opacity-100');
        }
        btnSpotTrigger(elephantCard);
      };

      btnElephant4?.addEventListener('click', (e) => {
        e.stopPropagation();
        handleElephantGuess("4 Legs");
      });

      btnElephant5?.addEventListener('click', (e) => {
        e.stopPropagation();
        handleElephantGuess("5 Legs");
      });

      btnElephantReveal?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (elephantOverlay) {
          const shown = elephantOverlay.classList.contains('opacity-100');
          if (shown) {
            elephantOverlay.classList.remove('opacity-100');
            elephantOverlay.classList.add('opacity-0');
            if (btnElephantReveal) btnElephantReveal.textContent = "Reveal Highlights";
          } else {
            elephantOverlay.classList.remove('opacity-0');
            elephantOverlay.classList.add('opacity-100');
            if (btnElephantReveal) btnElephantReveal.textContent = "Hide Highlights";
          }
        }
      });

      elephantTryAgain?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (elephantFeedback) elephantFeedback.classList.add('hidden');
        if (elephantOverlay) {
          elephantOverlay.classList.remove('opacity-100');
          elephantOverlay.classList.add('opacity-0');
        }
        if (btnElephantReveal) btnElephantReveal.textContent = "Reveal Highlights";
      });

      // 11. Impossible Trident
      const tridentCard = document.querySelector('[data-id="impossible-trident"]') as HTMLElement;
      const btnToggleTrident = tridentCard?.querySelector('.btn-toggle-trident');
      const tridentOverlay = tridentCard?.querySelector('.trident-overlay');
      btnToggleTrident?.addEventListener('click', (e) => {
        e.stopPropagation();
        if (tridentOverlay) {
          const shown = tridentOverlay.classList.contains('opacity-100');
          if (shown) {
            tridentOverlay.classList.replace('opacity-100', 'opacity-0');
            if (btnToggleTrident) btnToggleTrident.textContent = "Reveal Highlights 👁️";
          } else {
            tridentOverlay.classList.replace('opacity-0', 'opacity-100');
            if (btnToggleTrident) btnToggleTrident.textContent = "Hide Highlights 👁️";
            btnSpotTrigger(tridentCard);
          }
        }
      });
    };

    const btnSpotTrigger = (card: HTMLElement) => {
      const btnSpot = card.querySelector('.btn-spot') as HTMLButtonElement;
      btnSpot?.click();
    };

    // Init share buttons
    const initShareButtons = () => {
      document.querySelectorAll('.share-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const name = btn.getAttribute('data-name') || "an illusion";
          const card = btn.closest('.illusion-container') as HTMLElement;
          const time = card?.querySelector('.spot-time')?.textContent || "0.0s";
          const text = `I spotted ${name} on the Optical Illusion Lab! Can you beat my time? Test here: ${window.location.href}`;
          navigator.clipboard.writeText(text).then(() => {
            const originalSvg = btn.innerHTML;
            btn.innerHTML = `<span class="text-[9px] font-bold text-green-500">Copied! ✓</span>`;
            setTimeout(() => {
              btn.innerHTML = originalSvg;
            }, 2000);
          });
        });
      });
    };

    // Make cards clickable
    const makeCardsClickable = () => {
      document.querySelectorAll('.illusion-container').forEach(card => {
        card.style.cursor = 'pointer';
        card.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('button, input, select, details, summary, a, svg, iframe')) {
            return;
          }
          const link = card.querySelector('a[href^="/illusions/"]');
          if (link) {
            const href = link.getAttribute('href');
            if (href) {
              window.location.href = href;
            }
          }
        });
      });
    };

    // Load scripts
    startGlobalTimer();
    loadPersonalBests();
    initSpotButtons();
    initVotingAndReveals();
    initSpecialDemos();
    initShareButtons();
    makeCardsClickable();
  </script>

</Layout>
