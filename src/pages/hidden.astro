---
// src/pages/hidden.astro
import Layout from '../layouts/Layout.astro';
import ImpossibleTridentDemo from '../components/illusions/ImpossibleTridentDemo.astro';
---

<Layout 
  title="Hidden & Ambiguous Optical Illusions | Optical Illusion Lab" 
  description="Explore interactive ambiguous figures, impossible objects, and hidden shapes. Challenge your visual processing under 30-second timers."
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-900 via-slate-950 to-slate-900 text-white border-b border-indigo-500/10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(147,51,234,0.08),transparent_50%)]"></div>
    <div class="absolute -top-40 -left-40 h-80 w-80 rounded-full bg-purple-600/10 blur-3xl"></div>
    
    <div class="relative mx-auto max-w-4xl text-center space-y-6">
      <nav class="flex justify-center text-xs font-semibold text-purple-400 space-x-2" aria-label="Breadcrumb">
        <a href="/" class="hover:underline hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-400">Hidden & Ambiguous Figures</span>
      </nav>
      
      <h1 class="font-display text-4xl sm:text-6xl font-black tracking-tight text-white">
        Hidden & Ambiguous
      </h1>
      <p class="mx-auto max-w-2xl text-base sm:text-lg text-slate-300 leading-relaxed font-medium">
        These aren't magic tricks. They're AMBIGUOUS FIGURES — images 
        your brain can interpret in multiple completely valid ways. Try our interactive visual labs or browse the hidden figures gallery to test your perception.
      </p>

      <div class="inline-flex items-center space-x-2 rounded-xl border border-purple-500/30 bg-purple-950/45 px-5 py-3 text-xs font-bold text-purple-300 shadow-lg shadow-purple-900/10 max-w-xl mx-auto backdrop-blur-sm">
        ⏱️ Visual Labs: Challenge your visual brain under 30-second countdown timers.
      </div>
    </div>
  </section>

  <main class="py-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto space-y-20">
    
    <!-- SECTION 1: INTERACTIVE VISUAL LABS (Trident, Dancer, Hermann Grid) -->
    <section class="space-y-10">
      <div class="text-center space-y-2">
        <h2 class="font-display text-3xl font-black text-slate-900 dark:text-white">Interactive Visual Labs 🧪</h2>
        <p class="text-xs text-slate-500 dark:text-slate-400">Control visual parameters directly in these live experimental models.</p>
        <div class="mx-auto h-1 w-20 rounded-full bg-gradient-to-r from-purple-500 to-indigo-500 mt-2"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">
        
        <!-- Lab Card 1: Impossible Trident -->
        <section class="illusion-container bg-white dark:bg-slate-900/60 rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-md flex flex-col justify-between relative overflow-hidden group" data-id="impossible-trident">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-red-500/10 text-red-550 border border-red-500/20">🔴 Hard</span>
              <span class="text-[10px] font-bold text-indigo-455 uppercase tracking-wider">Impossible</span>
            </div>
            <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2">Impossible Trident</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-6">A mind-bending geometric blivet where three cylinders at one end merge into two rectangular bars at the other.</p>
          </div>
          
          <div class="w-full flex items-center justify-center bg-slate-100 dark:bg-slate-950/40 rounded-2xl p-4 border border-slate-200 dark:border-slate-800 min-h-[260px] relative overflow-hidden">
            <ImpossibleTridentDemo isCard={true} />
          </div>

          <div class="w-full space-y-4 pt-4 flex flex-col items-center">
            <div class="w-full flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-950 rounded-xl border border-slate-200 dark:border-slate-800 text-xs">
              <button class="btn-give-up bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-4 py-2 rounded-lg border-none transition-colors cursor-pointer">Give Up / Reveal ⏱️</button>
              <span class="countdown-timer font-mono font-bold text-slate-700 dark:text-slate-350">30.0s</span>
            </div>

            <div class="science-explanation hidden w-full text-left text-xs bg-slate-950/90 p-4 rounded-xl border border-slate-800 space-y-2">
              <h4 class="font-extrabold text-purple-400 text-sm">Scientific Explanation</h4>
              <p class="text-slate-300 leading-relaxed font-normal">
                <strong>Figure-Ground Swap:</strong> The line borders representing background gaps between the two rectangles at the base are extended to become the contours of the middle cylinder prong, creating a figure-ground swap conflict.
              </p>
            </div>
          </div>
        </section>

        <!-- Lab Card 2: Spinning Dancer -->
        <section class="illusion-container bg-white dark:bg-slate-900/60 rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-md flex flex-col justify-between relative overflow-hidden group" data-id="spinning-dancer">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-red-500/10 text-red-550 border border-red-500/20">🔴 Hard</span>
              <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-wider">Ambiguous</span>
            </div>
            <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2">The Spinning Dancer</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-6">A rotating silhouette whose direction of spin (clockwise or counter-clockwise) is entirely decided by your mind.</p>
          </div>
          
          <div class="w-full flex items-center justify-center bg-slate-100 dark:bg-slate-950/40 rounded-2xl p-4 border border-slate-200 dark:border-slate-800 min-h-[260px] relative overflow-hidden">
            <div class="flex items-center justify-center w-full h-full" style="perspective: 600px;">
              <svg id="dancer-svg" class="dancer-svg w-28 h-40 text-slate-900 dark:text-slate-200" viewBox="0 0 200 200" style="transform-style: preserve-3d; animation: spin-dancer-scale 4s linear infinite;">
                <circle cx="100" cy="30" r="8" fill="currentColor" />
                <path d="M95,42 C92,60 92,80 96,95 L104,95 C108,80 108,60 105,42 Z" fill="currentColor" />
                <path class="dancer-left-limb" d="M96,44 Q65,42 40,35 Q65,48 96,49 Z M97,95 L97,165 C97,168 99,170 101,170 L101,95 Z" fill="currentColor" />
                <path class="dancer-right-limb" d="M104,44 Q135,42 160,35 Q135,48 104,49 Z M103,95 Q125,115 130,125 Q115,125 103,115 Z" fill="currentColor" />
                
                <!-- Helper colored belt -->
                <path id="dancer-belt" class="opacity-0 transition-opacity duration-300" d="M 96,94 L 104,94" stroke="#ec4899" stroke-width="4" stroke-linecap="round" />
              </svg>
            </div>
          </div>

          <div class="w-full space-y-4 pt-4 flex flex-col items-center">
            <div class="w-full flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-950 rounded-xl border border-slate-200 dark:border-slate-800 text-xs">
              <button class="btn-give-up bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-4 py-2 rounded-lg border-none transition-colors cursor-pointer">Give Up / Reveal ⏱️</button>
              <span class="countdown-timer font-mono font-bold text-slate-700 dark:text-slate-350">30.0s</span>
            </div>

            <div class="flex wrap items-center justify-between w-full p-2.5 bg-slate-900/60 border border-slate-800 rounded-xl text-xs gap-3">
              <label class="flex items-center space-x-2 cursor-pointer font-bold select-none text-slate-300">
                <input type="checkbox" id="dancer-belt-toggle" class="rounded border-slate-700 bg-slate-950 text-purple-600 accent-purple-600" />
                <span>Color Guide 🎨</span>
              </label>
              <div class="flex gap-1.5">
                <button class="btn-vote bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-2.5 py-1 rounded border-none cursor-pointer text-[10px]" data-vote="cw">CW ➡️</button>
                <button class="btn-vote bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-2.5 py-1 rounded border-none cursor-pointer text-[10px]" data-vote="ccw">CCW ⬅️</button>
              </div>
            </div>

            <div class="science-explanation hidden w-full text-left text-xs bg-slate-950/90 p-4 rounded-xl border border-slate-800 space-y-2">
              <h4 class="font-extrabold text-purple-400 text-sm">Scientific Explanation</h4>
              <p class="text-slate-300 leading-relaxed font-normal">
                <strong>Depth Cue Absence:</strong> Because the silhouette lacks volumetric cues, shadows, or texture shading, the brain cannot determine whether the dancer is spinning clockwise on her left leg or counter-clockwise on her right leg.
              </p>
            </div>
          </div>
        </section>

        <!-- Lab Card 3: Hermann Grid -->
        <section class="illusion-container bg-white dark:bg-slate-900/60 rounded-3xl border border-slate-200 dark:border-slate-800 p-6 shadow-md flex flex-col justify-between relative overflow-hidden group" data-id="hermann-grid">
          <div>
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-yellow-500/10 text-yellow-600 border border-yellow-500/20">🟡 Medium</span>
              <span class="text-[10px] font-bold text-indigo-400 uppercase tracking-wider">Physiological</span>
            </div>
            <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white mb-2">Hermann Grid Dots</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-6">A grid layout of black tiles with gray intersections. Ghostly dark dots appear in your periphery, disappearing when you look at them.</p>
          </div>
          
          <div class="w-full flex items-center justify-center bg-slate-100 dark:bg-slate-950/40 rounded-2xl p-4 border border-slate-200 dark:border-slate-800 min-h-[260px] relative overflow-hidden">
            <svg class="w-full max-w-[200px] h-auto aspect-square select-none rounded-lg" viewBox="0 0 200 200">
              <rect width="200" height="200" fill="#000000" />
              <g stroke="#ffffff" stroke-width="12">
                <line x1="40" y1="0" x2="40" y2="200" />
                <line x1="80" y1="0" x2="80" y2="200" />
                <line x1="120" y1="0" x2="120" y2="200" />
                <line x1="160" y1="0" x2="160" y2="200" />
                
                <line x1="0" y1="40" x2="200" y2="40" />
                <line x1="0" y1="80" x2="200" y2="80" />
                <line x1="0" y1="120" x2="200" y2="120" />
                <line x1="0" y1="160" x2="200" y2="160" />
              </g>
            </svg>
          </div>

          <div class="w-full space-y-4 pt-4 flex flex-col items-center">
            <div class="w-full flex items-center justify-between p-3 bg-slate-50 dark:bg-slate-950 rounded-xl border border-slate-200 dark:border-slate-800 text-xs">
              <button class="btn-give-up bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-4 py-2 rounded-lg border-none transition-colors cursor-pointer">Give Up / Reveal ⏱️</button>
              <span class="countdown-timer font-mono font-bold text-slate-700 dark:text-slate-355">30.0s</span>
            </div>

            <div class="flex items-center justify-between w-full p-2.5 bg-slate-900/60 border border-slate-800 rounded-xl text-xs gap-3">
              <div class="flex items-center space-x-1.5 w-full">
                <label for="dots-count-input" class="font-bold shrink-0 text-slate-300">How many dots? </label>
                <input type="number" id="dots-count-input" class="w-14 bg-slate-950 border border-slate-700 text-center font-bold text-white rounded p-1 text-xs" value="0" min="0" />
              </div>
              <button id="submit-dots-btn" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold px-3 py-1.5 rounded-lg shrink-0 border-none cursor-pointer transition-colors text-xs">Submit</button>
            </div>

            <div class="science-explanation hidden w-full text-left text-xs bg-slate-950/90 p-4 rounded-xl border border-slate-800 space-y-2">
              <h4 class="font-extrabold text-purple-400 text-sm">Scientific Explanation</h4>
              <p class="text-slate-300 leading-relaxed font-normal">
                <strong>Lateral Inhibition:</strong> Retinal receptive fields at intersections receive surround inhibition from white lines on four sides, whereas straight lines receive it on only two sides. This makes intersections look dimmer in your periphery.
              </p>
            </div>
          </div>
        </section>

      </div>
    </section>

    <!-- SECTION 2: HIDDEN FIGURES GALLERY (2-column Grid, 8 cards) -->
    <section class="space-y-10">
      <div class="text-center space-y-2">
        <h2 class="font-display text-3xl font-black text-slate-900 dark:text-white">Hidden Figures Gallery 🖼️</h2>
        <p class="text-xs text-slate-500 dark:text-slate-400">Click on any card to access its dedicated detail page, 30s timer, and outlines drawing.</p>
        <div class="mx-auto h-1 w-20 rounded-full bg-gradient-to-r from-purple-500 to-indigo-500 mt-2"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
        <!-- Card 1: Rubin's Vase -->
        <div class="group relative rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-[10px] font-bold">
              <span class="text-indigo-400 uppercase tracking-wider">Ambiguous</span>
              <span class="px-2 py-0.5 rounded bg-green-500/10 text-green-550 border border-green-500/20">🟢 Easy</span>
            </div>
            <div class="w-full h-36 bg-slate-100 dark:bg-slate-950/40 rounded-xl overflow-hidden mb-4 flex items-center justify-center border border-slate-200 dark:border-slate-800">
              <svg class="w-32 h-32 select-none" viewBox="0 0 300 300">
                <rect width="300" height="300" fill="#FFFFFF"/>
                <path d="M 0,0 L 110,0 C 130,40 140,50 120,70 C 105,85 110,100 135,110 C 150,115 150,125 130,130 C 110,135 115,150 130,170 C 145,190 120,240 100,250 L 100,300 L 0,300 Z" fill="#000000" />
                <path d="M 300,0 L 190,0 C 170,40 160,50 180,70 C 195,85 190,100 165,110 C 150,115 150,125 170,130 C 190,135 185,150 170,170 C 155,190 180,240 200,250 L 200,300 L 300,300 Z" fill="#000000" />
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold text-slate-900 dark:text-white">Rubin's Vase</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">
              Edgar Rubin (1915). Flip between seeing a white central vase or two black face profiles looking at each other.
            </p>
          </div>
          <a href="/illusions/rubin-vase" class="mt-4 block text-center rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-extrabold text-xs py-2.5 transition-colors">
            Explore Illusion &rarr;
          </a>
        </div>

        <!-- Card 2: Duck-Rabbit -->
        <div class="group relative rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-[10px] font-bold">
              <span class="text-indigo-400 uppercase tracking-wider">Ambiguous</span>
              <span class="px-2 py-0.5 rounded bg-green-500/10 text-green-550 border border-green-500/20">🟢 Easy</span>
            </div>
            <div class="w-full h-36 bg-slate-100 dark:bg-slate-950/40 rounded-xl overflow-hidden mb-4 flex items-center justify-center border border-slate-200 dark:border-slate-800">
              <svg class="w-32 h-32 select-none" viewBox="0 0 300 300">
                <rect width="300" height="300" fill="#FFFFFF"/>
                <path d="M 220,110 C 260,110 290,135 290,170 C 290,205 260,230 220,230 C 210,210 205,190 200,175 L 100,195 C 90,195 85,185 95,180 C 120,165 150,160 180,155 C 180,150 180,140 180,135 C 150,130 120,125 95,110 C 85,105 90,95 100,95 L 200,110 C 205,105 210,110 220,110 Z" fill="none" stroke="#000000" stroke-width="6" />
                <circle cx="215" cy="140" r="6" fill="#000000" />
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold text-slate-900 dark:text-white">Duck-Rabbit</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">
              Joseph Jastrow (1899). A classic outline drawing that instantly shifts from a duck to a rabbit depending on focus.
            </p>
          </div>
          <a href="/illusions/duck-rabbit" class="mt-4 block text-center rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-extrabold text-xs py-2.5 transition-colors">
            Explore Illusion &rarr;
          </a>
        </div>

        <!-- Card 3: My Wife and My Mother-in-Law -->
        <div class="group relative rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-[10px] font-bold">
              <span class="text-indigo-400 uppercase tracking-wider">Ambiguous</span>
              <span class="px-2 py-0.5 rounded bg-yellow-500/10 text-yellow-600 border border-yellow-500/20">🟡 Medium</span>
            </div>
            <div class="w-full h-36 bg-slate-100 dark:bg-slate-950/40 rounded-xl overflow-hidden mb-4 flex items-center justify-center border border-slate-200 dark:border-slate-800">
              <svg class="w-32 h-32 select-none" viewBox="0 0 350 400">
                <rect width="350" height="400" fill="#808080" />
                <path d="M 60,80 C 120,30 230,30 290,80 C 340,140 310,240 270,290 C 230,330 150,330 110,290 C 70,240 50,140 60,80 Z" fill="#1e293b" />
                <path d="M 120,110 C 180,80 240,80 260,110 C 280,140 270,210 250,240 C 220,270 170,270 140,240 C 115,200 110,140 120,110 Z" fill="#cbd5e1" />
                <path d="M 100,270 C 160,290 220,290 260,270 C 280,240 290,200 295,170 L 255,170 C 240,210 210,240 160,230 C 120,220 105,240 100,270 Z" fill="#475569" />
                <path d="M 160,170 C 125,185 130,205 145,215 C 160,225 165,215 155,205 C 170,195 175,180 160,170 Z" fill="#94a3b8" stroke="#0f172a" stroke-width="2" />
                <circle cx="205" cy="180" r="3" fill="#ffffff" stroke="#0f172a" stroke-width="1.5" />
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold text-slate-900 dark:text-white">My Wife and My Mother-in-Law</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">
              W.E. Hill (1915). A portrait where a young wife looking away shares contours with an old mother-in-law looking down.
            </p>
          </div>
          <a href="/illusions/my-wife-and-my-mother" class="mt-4 block text-center rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-extrabold text-xs py-2.5 transition-colors">
            Explore Illusion &rarr;
          </a>
        </div>

        <!-- Card 4: Tiger in the Bamboo -->
        <div class="group relative rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-[10px] font-bold">
              <span class="text-indigo-400 uppercase tracking-wider">Camouflage</span>
              <span class="px-2 py-0.5 rounded bg-red-550/10 text-red-500 border border-red-500/20">🔴 Hard</span>
            </div>
            <div class="w-full h-36 bg-slate-100 dark:bg-slate-950/40 rounded-xl overflow-hidden mb-4 flex items-center justify-center border border-slate-200 dark:border-slate-800">
              <svg class="w-32 h-32 select-none" viewBox="0 0 400 300">
                <rect width="400" height="300" fill="#132a13" />
                <g stroke="#061e06" stroke-width="15">
                  <line x1="40" y1="0" x2="40" y2="300" />
                  <line x1="120" y1="0" x2="120" y2="300" />
                  <line x1="200" y1="0" x2="200" y2="300" />
                  <line x1="280" y1="0" x2="280" y2="300" />
                  <line x1="360" y1="0" x2="360" y2="300" />
                </g>
                <path d="M 80,180 C 60,170 50,130 65,110 C 85,90 120,80 180,85 C 240,85 320,90 330,110 C 340,130 335,160 295,190 C 240,195 140,190 80,180 Z" fill="#EA580C" />
                <g stroke="#061e06" stroke-width="15">
                  <line x1="120" y1="80" x2="120" y2="190" />
                  <line x1="200" y1="80" x2="200" y2="190" />
                  <line x1="280" y1="80" x2="280" y2="190" />
                </g>
              </svg>
            </div>
            <h3 class="font-display text-lg font-bold text-slate-900 dark:text-white">Tiger in the Bamboo</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed">
              A camouflaged typographic forest scene where literal English text is styled directly into the tiger's side coat.
            </p>
          </div>
          <a href="/illusions/hidden-tiger" class="mt-4 block text-center rounded-lg bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-extrabold text-xs py-2.5 transition-colors">
            Explore Illusion &rarr;
          </a>
        </div>

        <!-- Card 5: Faces in the Tree -->
        <div class="group relative rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/60 p-6 flex flex-col justify-between shadow-sm hover:-translate-y-1 hover:shadow-lg transition-all duration-300">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-[10px] font-bold">
              <span class="text-indigo-400 uppercase tracking-wider">Negative Space</span>
              <span class="px-2 py-0.5 rounded bg-red-550/10 text-red-550 border border-red-500/20">🔴 Hard</span>
            </div>
            <div class="w-full h-36 bg-slate-100 dark:bg-slate-950/40 rounded-xl overflow-hidden mb-4 flex items-center justify-center border border-slate-200 dark:border-slate-800">
              <svg class="w-32 h-32 select-none" viewBox="0 0 400 360">
                <rect width="400" height="360" fill="#FFFFFF"/>
                <path d="M 20,330 Q 200,320 380,330 L 380,360 L 20,360 Z" fill="#000000" />
                <path d="M 150,330 C 140,300 135,270 145,250 C 155,230 148,220 152,215 C 155,210 142,200 146,192 C 150,185 140,175 145,160 C 130,150 115,130 110,100 C 125,105 135,100 142,80 C 150,60 170,45 200,30 C 230,45 250,60 258,80 C 265,100 275,105 290,100 C 285,130 270,150 255,160 C 260,175 250,185 254,192 C 258,200 245,210 248,215 C 252,220 245,230 255,250 C 265,270 260,300 250,330 Z" fill="#000000" />
                <path d="M 125,100 C 100,80 80,90 60,60" fill="none" stroke="#000000" stroke-width="12" />
