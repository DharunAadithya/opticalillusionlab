            spotTimeEl.classList.add('stopped', 'text-green-500');
            const spotTime = spotTimeEl.textContent || "0.0s";
            
            // Check PB
            const currentPb = localStorage.getItem(`pb-hidden-${id}`);
            if (!currentPb || spotTime < currentPb) {
