  <style>
    /* Repeating linear gradient for downward scrolling stripes */
    .waterfall-stripes {
      background: repeating-linear-gradient(to bottom, #020617, #020617 15px, #f1f5f9 15px, #f1f5f9 30px);
      background-size: 100% 30px;
      animation: move-stripes-down 1s linear infinite;
    }
    
    .waterfall-stripes.paused {
      animation-play-state: paused;
    }
    
    @keyframes move-stripes-down {
      0% { background-position-y: 0px; }
      100% { background-position-y: 30px; }
    }

    /* Spinning dancer CSS animation */
    @keyframes spin-scale-x {
      0% { transform: scaleX(1); }
      50% { transform: scaleX(-1); }
      100% { transform: scaleX(1); }
    }
    
    .dancer-silhouette {
      transform-origin: 100px 100px;
      animation: spin-scale-x calc(4s / var(--speed-multiplier, 1)) linear infinite;
    }
  </style>

  <script>
    // ----------------------------------------------------
    // STOPWATCH TIMER LOGIC FOR ALL 10 CARDS
    // ----------------------------------------------------
    const cards = document.querySelectorAll('.illusion-card');
    const cardStates: Record<string, {
      elapsed: number;
      interval: any;
      running: boolean;
    }> = {};

    cards.forEach(card => {
      const id = card.getAttribute('data-id');
      if (!id) return;

      // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation
      card.querySelectorAll('button, input, select, details, summary, label, a').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
  
      
      cardStates[id] = {
        elapsed: 0.0,
        interval: null,
        running: true
      };

      // Start timer automatically on page load
      const timerValEl = card.querySelector('.timer-val');
      cardStates[id].interval = setInterval(() => {
        if (cardStates[id].running) {
          cardStates[id].elapsed += 0.1;
          if (timerValEl) {
            timerValEl.textContent = cardStates[id].elapsed.toFixed(1);
          }
        }
      }, 100);

      // Load PB from localStorage
      const pb = localStorage.getItem(`hidden-illusion-pb-${id}`);
      const pbValEl = card.querySelector('.pb-val');
      const leaderboardValEl = document.getElementById(`pb-${id}`);
      if (pb) {
        if (pbValEl) pbValEl.textContent = `${parseFloat(pb).toFixed(1)}s`;
        if (leaderboardValEl) leaderboardValEl.textContent = `${parseFloat(pb).toFixed(1)}s`;
      }

      // Found It! / I See It! Button Handler
      const foundBtn = card.querySelector('.found-btn');
      foundBtn?.addEventListener('click', () => {
        if (!cardStates[id].running) return;
        cardStates[id].running = false;
        clearInterval(cardStates[id].interval);

        const score = cardStates[id].elapsed;
        const savedPb = localStorage.getItem(`hidden-illusion-pb-${id}`);
        if (!savedPb || score < parseFloat(savedPb)) {
          localStorage.setItem(`hidden-illusion-pb-${id}`, score.toString());
          if (pbValEl) pbValEl.textContent = `${score.toFixed(1)}s`;
          if (leaderboardValEl) leaderboardValEl.textContent = `${score.toFixed(1)}s`;
        }

        // Trigger reveal outlines
        const svg = card.querySelector('svg');
        const revealMarkers = card.querySelectorAll('.reveal-markers, .young-guides, .old-guides, .duck-beak-highlight, .rabbit-ears-highlight, .vase-highlight, .trident-trace, .jnd-bridge');
        revealMarkers.forEach(el => el.classList.remove('opacity-0'));
      });

      // Give Up / Reveal Button Handler
      const revealBtn = card.querySelector('.reveal-btn');
      revealBtn?.addEventListener('click', () => {
        cardStates[id].running = false;
        clearInterval(cardStates[id].interval);
        
        const revealMarkers = card.querySelectorAll('.reveal-markers, .young-guides, .old-guides, .duck-beak-highlight, .rabbit-ears-highlight, .vase-highlight, .trident-trace, .jnd-bridge, .tiger-text-stripes');
        revealMarkers.forEach(el => {
          el.classList.remove('opacity-0');
          // Tiger text stripe reveal transitions to magenta
          if (el.classList.contains('tiger-text-stripes')) {
            el.setAttribute('stroke', '#d946ef');
          }
        });
      });

      // Share Button Handler
      const shareBtn = card.querySelector('.share-btn');
      shareBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        const score = cardStates[id].elapsed;
        const title = card.querySelector('h3')?.textContent || 'Illusion';
        const shareText = `I spotted the ${title} in ${score.toFixed(1)}s on the Optical Illusion Lab! Can you beat me?`;
        
        navigator.clipboard.writeText(shareText).then(() => {
          const toast = shareBtn.querySelector('.share-toast');
          if (toast) {
            toast.classList.remove('opacity-0');
            toast.classList.add('opacity-100');
            setTimeout(() => {
              toast.classList.remove('opacity-100');
              toast.classList.add('opacity-0');
            }, 2000);
          }
        });
      });
    });

    // Reset Leaderboard Handler
    const resetBtn = document.getElementById('reset-leaderboard-btn');
    resetBtn?.addEventListener('click', () => {
      Object.keys(cardStates).forEach(id => {
        localStorage.removeItem(`hidden-illusion-pb-${id}`);
        const pbValEl = document.querySelector(`#card-${id} .pb-val`);
        if (pbValEl) pbValEl.textContent = `-`;
        const leaderboardValEl = document.getElementById(`pb-${id}`);
        if (leaderboardValEl) leaderboardValEl.textContent = `-`;
      });
    });


    // ----------------------------------------------------
    // CARD SPECIFIC CONTROLLER INTERACTIVITY
    // ----------------------------------------------------

    // 1. Old Woman / Young Woman
    const youngBtn = document.querySelector('.see-young-btn');
    const oldBtn = document.querySelector('.see-old-btn');
    const youngGuides = document.querySelector('.young-guides');
    const oldGuides = document.querySelector('.old-guides');

    youngBtn?.addEventListener('click', () => {
      youngGuides?.classList.remove('opacity-0');
      oldGuides?.classList.add('opacity-0');
      youngBtn.classList.add('bg-purple-600', 'text-white');
      oldBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    oldBtn?.addEventListener('click', () => {
      youngGuides?.classList.add('opacity-0');
      oldGuides?.classList.remove('opacity-0');
      oldBtn.classList.add('bg-purple-600', 'text-white');
      youngBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    // 2. Duck or Rabbit
    const duckBtn = document.querySelector('.highlight-duck');
    const rabbitBtn = document.querySelector('.highlight-rabbit');
    const duckHighlight = document.querySelector('.duck-beak-highlight');
    const rabbitHighlight = document.querySelector('.rabbit-ears-highlight');

    duckBtn?.addEventListener('click', () => {
      duckHighlight?.classList.remove('opacity-0');
      rabbitHighlight?.classList.add('opacity-0');
      duckBtn.classList.add('bg-purple-600', 'text-white');
      rabbitBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    rabbitBtn?.addEventListener('click', () => {
      duckHighlight?.classList.add('opacity-0');
      rabbitHighlight?.classList.remove('opacity-0');
      rabbitBtn.classList.add('bg-purple-600', 'text-white');
      duckBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    // Duck or Rabbit Voting
    const voteDuckBtn = document.querySelector('.vote-duck');
    const voteRabbitBtn = document.querySelector('.vote-rabbit');
    const statsPercentage = document.querySelector('.stat-percentage');

    const handleVotingStats = () => {
      if (statsPercentage) {
        statsPercentage.classList.remove('hidden');
      }
      voteDuckBtn?.setAttribute('disabled', 'true');
      voteRabbitBtn?.setAttribute('disabled', 'true');
    };

    voteDuckBtn?.addEventListener('click', () => {
      localStorage.setItem('voted-duck-rabbit', 'duck');
      handleVotingStats();
    });

    voteRabbitBtn?.addEventListener('click', () => {
      localStorage.setItem('voted-duck-rabbit', 'rabbit');
      handleVotingStats();
    });

    // Check if voted previously
    if (localStorage.getItem('voted-duck-rabbit') && statsPercentage) {
      statsPercentage.classList.remove('hidden');
    }

    // 3. Face or Vase
    const voteFacesBtn = document.querySelector('.vote-faces');
    const voteVaseBtn = document.querySelector('.vote-vase');
    const statsPercentageVase = document.querySelector('.stat-percentage-vase');

    const handleVotingStatsVase = () => {
      if (statsPercentageVase) {
        statsPercentageVase.classList.remove('hidden');
      }
      voteFacesBtn?.setAttribute('disabled', 'true');
      voteVaseBtn?.setAttribute('disabled', 'true');
    };

    voteFacesBtn?.addEventListener('click', () => {
      localStorage.setItem('voted-face-vase', 'faces');
      handleVotingStatsVase();
    });

    voteVaseBtn?.addEventListener('click', () => {
      localStorage.setItem('voted-face-vase', 'vase');
      handleVotingStatsVase();
    });

    if (localStorage.getItem('voted-face-vase') && statsPercentageVase) {
      statsPercentageVase.classList.remove('hidden');
    }

    // Face or Vase slow alternation animation
    const rubinFaceL = document.querySelector('.rubin-face-l');
    const rubinFaceR = document.querySelector('.rubin-face-r');
    const rubinCenterVase = document.querySelector('.rubin-center-vase');
    const vaseHighlight = document.querySelectorAll('.vase-highlight');

    let vaseActive = true;
    setInterval(() => {
      vaseActive = !vaseActive;
      if (vaseActive) {
        rubinCenterVase?.setAttribute('fill', '#e2e8f0');
        rubinFaceL?.setAttribute('fill', '#0f172a');
        rubinFaceR?.setAttribute('fill', '#0f172a');
        vaseHighlight.forEach(el => el.classList.remove('opacity-0'));
      } else {
        rubinCenterVase?.setAttribute('fill', '#020617');
        rubinFaceL?.setAttribute('fill', '#c084fc');
        rubinFaceR?.setAttribute('fill', '#c084fc');
        vaseHighlight.forEach(el => el.classList.add('opacity-0'));
      }
    }, 4000);

    // 4. Necker Cube
    const lockFrontBtn = document.querySelector('.lock-front-btn');
    const lockBackBtn = document.querySelector('.lock-back-btn');
    const releaseLockBtn = document.querySelector('.release-lock-btn');
    const shadeFront = document.querySelector('.necker-shade-front');
    const shadeBack = document.querySelector('.necker-shade-back');

    lockFrontBtn?.addEventListener('click', () => {
      shadeFront?.classList.remove('fill-indigo-500/0');
      shadeFront?.classList.add('fill-indigo-500/40');
      shadeBack?.classList.add('fill-emerald-500/0');
      shadeBack?.classList.remove('fill-emerald-500/40');
      lockFrontBtn.classList.add('bg-purple-600', 'text-white');
      lockBackBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    lockBackBtn?.addEventListener('click', () => {
      shadeBack?.classList.remove('fill-emerald-500/0');
      shadeBack?.classList.add('fill-emerald-500/40');
      shadeFront?.classList.add('fill-indigo-500/0');
      shadeFront?.classList.remove('fill-indigo-500/40');
      lockBackBtn.classList.add('bg-purple-600', 'text-white');
      lockFrontBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    releaseLockBtn?.addEventListener('click', () => {
      shadeFront?.classList.add('fill-indigo-500/0');
      shadeFront?.classList.remove('fill-indigo-500/40');
      shadeBack?.classList.add('fill-emerald-500/0');
      shadeBack?.classList.remove('fill-emerald-500/40');
      lockFrontBtn?.classList.remove('bg-purple-600', 'text-white');
      lockBackBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    // 5. Spinning Dancer
    const forceCwBtn = document.querySelector('.force-cw-btn');
    const forceCcwBtn = document.querySelector('.force-ccw-btn');
    const resetDancerBtn = document.querySelector('.reset-dancer-btn');
    const cwLines = document.querySelector('.cw-lines');
    const ccwLines = document.querySelector('.ccw-lines');
    const dancerSilhouette = document.querySelector('.dancer-silhouette');

    forceCwBtn?.addEventListener('click', () => {
      cwLines?.classList.remove('opacity-0');
      ccwLines?.classList.add('opacity-0');
      if (dancerSilhouette) {
        dancerSilhouette.classList.add('text-blue-500');
        dancerSilhouette.classList.remove('text-slate-100');
      }
      forceCwBtn.classList.add('bg-purple-600', 'text-white');
      forceCcwBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    forceCcwBtn?.addEventListener('click', () => {
      cwLines?.classList.add('opacity-0');
      ccwLines?.classList.remove('opacity-0');
      if (dancerSilhouette) {
        dancerSilhouette.classList.add('text-rose-500');
        dancerSilhouette.classList.remove('text-slate-100');
      }
      forceCcwBtn.classList.add('bg-purple-600', 'text-white');
      forceCwBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    resetDancerBtn?.addEventListener('click', () => {
      cwLines?.classList.add('opacity-0');
      ccwLines?.classList.add('opacity-0');
      if (dancerSilhouette) {
        dancerSilhouette.classList.remove('text-blue-500', 'text-rose-500');
        dancerSilhouette.classList.add('text-slate-100');
      }
      forceCwBtn?.classList.remove('bg-purple-600', 'text-white');
      forceCcwBtn?.classList.remove('bg-purple-600', 'text-white');
    });

    // Spinning Dancer Voting
    const voteCwBtn = document.querySelector('.vote-cw');
    const voteCcwBtn = document.querySelector('.vote-ccw');
    const statsPercentageDancer = document.querySelector('.stat-percentage-dancer');

    const handleVotingStatsDancer = () => {
      if (statsPercentageDancer) {
        statsPercentageDancer.classList.remove('hidden');
      }
      voteCwBtn?.setAttribute('disabled', 'true');
      voteCcwBtn?.setAttribute('disabled', 'true');
    };

    voteCwBtn?.addEventListener('click', () => {
      localStorage.setItem('voted-dancer-direction', 'cw');
      handleVotingStatsDancer();
    });

    voteCcwBtn?.addEventListener('click', () => {
      localStorage.setItem('voted-dancer-direction', 'ccw');
      handleVotingStatsDancer();
    });

    if (localStorage.getItem('voted-dancer-direction') && statsPercentageDancer) {
      statsPercentageDancer.classList.remove('hidden');
    }

    // 7. Impossible Trident
    const traceTridentBtn = document.querySelector('.trace-trident-btn');
    const tridentTrace = document.querySelector('.trident-trace');
    let traceActive = false;

    traceTridentBtn?.addEventListener('click', () => {
      traceActive = !traceActive;
      if (traceActive) {
        tridentTrace?.classList.remove('opacity-0');
        traceTridentBtn.classList.add('bg-purple-600', 'text-white');
      } else {
        tridentTrace?.classList.add('opacity-0');
        traceTridentBtn.classList.remove('bg-purple-600', 'text-white');
      }
    });

    // 8. Count the Black Dots
    const dotsGuessInput = document.getElementById('dots-guess') as HTMLInputElement;
    const submitGuessBtn = document.querySelector('.submit-guess-btn');
    const dotsFeedback = document.querySelector('.dots-feedback');

    submitGuessBtn?.addEventListener('click', () => {
      const guess = dotsGuessInput.value.trim();
      if (dotsFeedback) {
        dotsFeedback.classList.remove('hidden');
        if (guess === '0') {
          dotsFeedback.textContent = "🎉 Correct! The answer is 0. All intersections are purely white. Your brain generated the black dots in your peripheral vision due to lateral inhibition.";
          dotsFeedback.classList.remove('text-red-500');
          dotsFeedback.classList.add('text-purple-500');
          
          // Stop timer and solve puzzle
          const id = 'dots';
          if (cardStates[id] && cardStates[id].running) {
            cardStates[id].running = false;
            clearInterval(cardStates[id].interval);
            const score = cardStates[id].elapsed;
            const pbValEl = document.querySelector('#card-dots .pb-val');
            const leaderboardValEl = document.getElementById('pb-dots');
            const savedPb = localStorage.getItem(`hidden-illusion-pb-${id}`);
            if (!savedPb || score < parseFloat(savedPb)) {
              localStorage.setItem(`hidden-illusion-pb-${id}`, score.toString());
              if (pbValEl) pbValEl.textContent = `${score.toFixed(1)}s`;
              if (leaderboardValEl) leaderboardValEl.textContent = `${score.toFixed(1)}s`;
            }
          }
        } else {
          dotsFeedback.textContent = "❌ Incorrect count. Look directly at any of the black dots you see. Do they disappear? Enter your new guess.";
          dotsFeedback.classList.remove('text-purple-500');
          dotsFeedback.classList.add('text-red-500');
        }
      }
    });

    // 9. JND - Same or Different
    const jndYesBtn = document.querySelector('.jnd-yes-btn');
    const jndNoBtn = document.querySelector('.jnd-no-btn');
    const jndFeedback = document.querySelector('.jnd-feedback');
    const jndBridge = document.querySelector('.jnd-bridge');

    const handleJndReveal = (vote: string) => {
      jndBridge?.classList.remove('opacity-0');
      if (jndFeedback) {
        jndFeedback.classList.remove('hidden');
        jndFeedback.textContent = `You voted ${vote}. The connecting bridge shows both squares are the exact same hex color (#888888)!`;
      }
      
      const id = 'jnd';
      if (cardStates[id] && cardStates[id].running) {
        cardStates[id].running = false;
        clearInterval(cardStates[id].interval);
        const score = cardStates[id].elapsed;
        const pbValEl = document.querySelector('#card-jnd .pb-val');
        const leaderboardValEl = document.getElementById('pb-jnd');
        const savedPb = localStorage.getItem(`hidden-illusion-pb-${id}`);
        if (!savedPb || score < parseFloat(savedPb)) {
          localStorage.setItem(`hidden-illusion-pb-${id}`, score.toString());
          if (pbValEl) pbValEl.textContent = `${score.toFixed(1)}s`;
          if (leaderboardValEl) leaderboardValEl.textContent = `${score.toFixed(1)}s`;
        }
      }
    };

    jndYesBtn?.addEventListener('click', () => handleJndReveal('YES'));
    jndNoBtn?.addEventListener('click', () => handleJndReveal('NO'));

    // 10. Motion Aftereffect
    const startAftereffectBtn = document.querySelector('.start-aftereffect-btn');
    const stripes = document.querySelector('.waterfall-stripes');
    const timerLabel = document.querySelector('.aftereffect-timer-label');
    
    let stareTimer: any = null;
    let secondsRemaining = 20;
    let isStaringActive = false;

    startAftereffectBtn?.addEventListener('click', () => {
      if (isStaringActive) return;
      isStaringActive = true;
      secondsRemaining = 20;
      stripes?.classList.remove('paused');
      
      if (timerLabel) {
        timerLabel.textContent = `Stare at the red dot: 20s remaining`;
      }
      if (startAftereffectBtn) {
        startAftereffectBtn.setAttribute('disabled', 'true');
      }

      stareTimer = setInterval(() => {
        secondsRemaining--;
        if (timerLabel) {
          timerLabel.textContent = `Stare at the red dot: ${secondsRemaining}s remaining`;
        }
        
        if (secondsRemaining <= 0) {
          clearInterval(stareTimer);
          stripes?.classList.add('paused');
          isStaringActive = false;
          if (timerLabel) {
            timerLabel.textContent = `STOP! Experience motion aftereffect now!`;
          }
          if (startAftereffectBtn) {
            startAftereffectBtn.removeAttribute('disabled');
            startAftereffectBtn.textContent = 'Restart';
          }
          
          // Trigger I See It / solved state for timer pb
          const id = 'aftereffect';
          if (cardStates[id] && cardStates[id].running) {
            cardStates[id].running = false;
            clearInterval(cardStates[id].interval);
            const score = cardStates[id].elapsed;
            const pbValEl = document.querySelector('#card-aftereffect .pb-val');
            const leaderboardValEl = document.getElementById('pb-aftereffect');
            const savedPb = localStorage.getItem(`hidden-illusion-pb-${id}`);
            if (!savedPb || score < parseFloat(savedPb)) {
              localStorage.setItem(`hidden-illusion-pb-${id}`, score.toString());
              if (pbValEl) pbValEl.textContent = `${score.toFixed(1)}s`;
              if (leaderboardValEl) leaderboardValEl.textContent = `${score.toFixed(1)}s`;
            }
          }
        }
      }, 1000);
    });
  </script>
</Layout>
