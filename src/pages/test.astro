    <!-- Comparative stats panel -->
    <div class="bg-slate-900/60 border border-slate-850 p-6 rounded-2xl space-y-4">
      <h3 class="text-sm font-black text-white uppercase tracking-wider text-center">Global Brain Types distribution</h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="p-3 bg-slate-950/40 rounded-xl border border-slate-800 space-y-1">
          <span class="block text-xl">🎨</span>
          <span class="block text-xs font-black text-slate-400">Creative</span>
          <span class="block text-sm font-black text-pink-400">28%</span>
        </div>
        <div class="p-3 bg-slate-950/40 rounded-xl border border-slate-800 space-y-1">
          <span class="block text-xl">🔬</span>
          <span class="block text-xs font-black text-slate-400">Analyst</span>
          <span class="block text-sm font-black text-yellow-400">35%</span>
        </div>
        <div class="p-3 bg-slate-950/40 rounded-xl border border-slate-800 space-y-1">
          <span class="block text-xl">⚡</span>
          <span class="block text-xs font-black text-slate-400">Flexible</span>
          <span class="block text-sm font-black text-cyan-400">12%</span>
        </div>
        <div class="p-3 bg-slate-950/40 rounded-xl border border-slate-800 space-y-1">
          <span class="block text-xl">🌀</span>
          <span class="block text-xs font-black text-slate-400">Deep Proc.</span>
          <span class="block text-sm font-black text-purple-400">25%</span>
