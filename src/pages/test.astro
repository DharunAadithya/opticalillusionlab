    <!-- Legal disclaimer -->
    <div class="text-center text-[10px] text-slate-500 uppercase tracking-widest leading-relaxed max-w-md mx-auto">
      ⚠️ Disclaimer: This assessment is designed solely for entertainment and educational purposes. It does not constitute a clinical, medical, or psychological diagnosis.
    </div>

  </section>

  <style>
    /* Spinning dancer animation keyframe */
    @keyframes dancer-rotate {
      0% { transform: scaleX(1); }
      50% { transform: scaleX(-1); }
      100% { transform: scaleX(1); }
    }
    .animate-dancer {
      animation: dancer-rotate 2.8s ease-in-out infinite;
      transform-origin: 50px 75px;
    }
  </style>

  <script>
    // ----------------------------------------------------
    // TEST STATE MACHINE LOGIC
    // ----------------------------------------------------

    const startTestBtn = document.getElementById('start-test-btn');
    const testIntro = document.getElementById('test-intro');
    const testInterface = document.getElementById('test-interface');
    const testResultsPanel = document.getElementById('test-results-panel');
    const progressBar = document.getElementById('test-progress-bar');
    const progressPct = document.getElementById('progress-pct');
    const questionTracker = document.getElementById('question-tracker');
    const questions = document.querySelectorAll('.test-question');
    const retakeTestBtn = document.getElementById('retake-test-btn');
    const shareResultBtn = document.getElementById('share-result-btn');
    const shareToast = document.getElementById('share-toast');

    // Brain Type result fields
    const resultTypeName = document.getElementById('result-type-name');
    const resultTypePct = document.getElementById('result-type-percentage');
    const resultTypeDesc = document.getElementById('result-type-desc');

    let currentQIdx = 0;
    let scores = { C: 0, A: 0, F: 0, D: 0 };
    let currentShareMessage = "";

    // Brain Type Descriptions
    const brainTypeDescriptions: Record<string, { name: string; pct: string; desc: string; share: string }> = {
      C: {
        name: "🎨 THE CREATIVE",
        pct: "Only 28% of people got this result",
        share: "I'm a Creative Brain type! What's yours?",
        desc: `
          <p>
            <strong>Your dominant processing style is intuitive, synthesis-oriented, and holistic!</strong> You tend to see the forest before the trees, naturally looking for global shapes, patterns, and connections. In cognitive psychology, this is referred to as <strong>right-hemisphere integration</strong> or <strong>global precedence processing</strong>.
          </p>
          <p>
            When faced with visual ambiguity, your brain constructs the most emotionally resonant or anthropomorphic interpretation first (such as seeing faces and animals). You rely heavily on context and immediate visual impact, which fuels your creativity and allows you to make unique emotional connections in your work and life.
          </p>
          <p>
            You are highly visual, artistic, and adapt easily to artistic ambiguities. Your brain is gifted at lateral thinking, enabling you to find innovative solutions by connecting ideas that others might deem completely unrelated. You trust your instincts and thrive in environments that value open-ended brainstorming.
          </p>
        `
      },
      A: {
        name: "🔬 THE ANALYST",
        pct: "Only 35% of people got this result",
        share: "I'm an Analyst Brain type! What's yours?",
        desc: `
          <p>
            <strong>Your dominant processing style is logical, detail-oriented, and systematic!</strong> You tend to see the individual trees before the forest, focusing heavily on local components, edges, and coordinates. This correlates with strong <strong>left-hemisphere focal attention</strong> and systematic cognitive framing.
          </p>
          <p>
            Faced with ambiguous figures, your brain defaults to the most geometric or physically grounded structure (like structural vases, static lines, and direct coordinates). You naturally analyze the boundary details, checking alignment and scanning for logical inconsistencies before drawing a conclusion.
          </p>
          <p>
            This high-detail focal processing makes you excellent at logical analysis, coding, mathematics, and complex engineering. You are observant, structured, and notice factual discrepancies immediately. You prefer clear definitions, organized environments, and value evidence-based reasoning above immediate instinct.
          </p>
        `
      },
      F: {
        name: "⚡ THE FLEXIBLE THINKER",
        pct: "Only 12% of people got this result",
        share: "I'm a Flexible Thinker! Only 12% of people are. What's yours?",
        desc: `
          <p>
            <strong>Your dominant processing style is highly adaptable, bistable, and multi-perspective!</strong> You did not just latch onto one interpretation — you frequently reported seeing both or noted that the illusions kept switching in front of your eyes. This indicates a high degree of <strong>cognitive flexibility</strong> and rapid hemispheric alternation.
          </p>
          <p>
            Your visual cortex is highly sensitive to feedback loops, which prevents you from locking onto a single sensory explanation. Your V1/V2 brain regions actively swap hypotheses in real time, allowing you to hold two opposing realities in your head simultaneously.
          </p>
          <p>
            This rare flexibility translates into a strong ability to see other points of view. You are an excellent mediator, strategist, and highly adaptable problem solver. You don't get stuck in dogma and can easily shift your strategy when circumstances change, making you incredibly resilient in fast-paced fields.
          </p>
        `
      },
      D: {
        name: "🌀 THE DEEP PROCESSOR",
        pct: "Only 25% of people got this result",
        share: "I'm a Deep Processor! What's yours?",
        desc: `
          <p>
            <strong>Your dominant processing style is deep, contemplative, and highly independent!</strong> You frequently selected options that indicated unusual patterns or required careful study. This indicates a <strong>deep bottom-up sensory processing</strong> style, where your brain refuses to take shortcuts and studies every detail individually.
          </p>
          <p>
            Unlike the general population whose brains take fast shortcuts and jump to conclusions, your visual pathway is extra thorough. You process details independently of context, which makes you immune to certain common biases but means your brain takes longer to process complex visual scenes.
          </p>
          <p>
            You are highly contemplative, independent, and resistant to peer pressure or groupthink. You notice things that others completely skip, making you an excellent investigator, auditor, or deep researcher. You take your time to build solid, unshakeable foundations in everything you study.
          </p>
        `
      }
    };

    // Show/hide helper
    const showScreen = (showEl: HTMLElement, hideEls: HTMLElement[]) => {
      showEl.classList.remove('hidden');
      hideEls.forEach(el => el.classList.add('hidden'));
    };

    // Question Insights & Statistics Database
    const questionInsights = [
      {
        options: {
          "0": {
            choice: "Clockwise",
            text: "You perceive clockwise rotation, which indicates a strong reliance on the 'viewpoint-from-above' visual bias. Your brain defaults to looking down at the figure.",
            stats: [
              { label: "Clockwise (Default)", value: 52 },
              { label: "Counter-Clockwise", value: 38 },
              { label: "Both/Keeps switching", value: 10 }
            ]
          },
          "1": {
            choice: "Counter-Clockwise",
            text: "You perceive counter-clockwise rotation, indicating a more analytical focus on the bottom pivot points and silhouette edges.",
            stats: [
              { label: "Clockwise", value: 52 },
              { label: "Counter-Clockwise (Analytical)", value: 38 },
              { label: "Both/Keeps switching", value: 10 }
            ]
          },
          "2": {
            choice: "Both",
            text: "You see it switch in both directions! This shows high cognitive flexibility, where your visual cortex easily updates its depth hypotheses in real-time.",
            stats: [
              { label: "Clockwise", value: 52 },
              { label: "Counter-Clockwise", value: 38 },
              { label: "Both/Keeps switching", value: 10 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Young Woman",
            text: "Seeing the Young Woman first suggests high sensitivity to fine details (high-frequency contours) like eyelashes and cheeks. Statistically more common in younger viewers.",
            stats: [
              { label: "Young Woman", value: 52 },
              { label: "Old Woman", value: 48 }
            ]
          },
          "1": {
            choice: "Old Woman",
            text: "Seeing the Old Woman first suggests your visual system groups large contours and low-frequency structures first, identifying the large nose and jawline.",
            stats: [
              { label: "Young Woman", value: 52 },
              { label: "Old Woman", value: 48 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Duck",
            text: "Seeing the Duck first suggests a left-to-right scanning bias. It is also heavily influenced by cognitive priming and seasonal context (more common in autumn).",
            stats: [
              { label: "Duck", value: 50 },
              { label: "Rabbit", value: 50 }
            ]
          },
          "1": {
            choice: "Rabbit",
            text: "Seeing the Rabbit first suggests a right-to-left scanning bias. It is highly influenced by priming (more common during spring/Easter).",
            stats: [
              { label: "Duck", value: 50 },
              { label: "Rabbit", value: 50 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "A Vase",
            text: "Focusing on the Vase first indicates that your brain automatically groups the central positive space as the figure, relegating the outer dark space to the background.",
            stats: [
              { label: "A Vase", value: 45 },
              { label: "Two Faces", value: 55 }
            ]
          },
          "1": {
            choice: "Two Faces",
            text: "Focusing on the Faces first indicates that your brain processes the negative space as the active figure, showing highly integrated background processing.",
            stats: [
              { label: "A Vase", value: 45 },
              { label: "Two Faces", value: 55 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Triangle",
            text: "Grouping the dots as a Triangle demonstrates the Gestalt principle of closure. Your visual cortex automatically constructs boundaries between disparate elements.",
            stats: [
              { label: "Triangle", value: 65 },
              { label: "Line", value: 20 },
              { label: "Neither", value: 15 }
            ]
          },
          "1": {
            choice: "Line",
            text: "Seeing them as a Line indicates your brain groups elements sequentially or searches for linear direction rather than closed geometric forms.",
            stats: [
              { label: "Triangle", value: 65 },
              { label: "Line", value: 20 },
              { label: "Neither", value: 15 }
            ]
          },
          "2": {
            choice: "Neither",
            text: "Processing the dots as independent points with no grouping shows a highly literal bottom-up processing style that avoids premature structural assumptions.",
            stats: [
              { label: "Triangle", value: 65 },
              { label: "Line", value: 20 },
              { label: "Neither", value: 15 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Yes, same",
            text: "Correct! Both squares reflect the exact same shade of gray. You bypassed or recalled the color constancy illusion.",
            stats: [
              { label: "Yes, same", value: 15 },
              { label: "No, different", value: 85 }
            ]
          },
          "1": {
            choice: "No, different",
            text: "Incorrect, but completely normal! Your brain scales up the brightness of square B because it lies in a shadow, maintaining color constancy in daily life.",
            stats: [
              { label: "Yes, same", value: 15 },
              { label: "No, different", value: 85 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Yes, definitely",
            text: "Normal peripheral drift! The asymmetric contrast borders of the rings stimulate motion-sensitive neurons in your visual cortex even though the image is static.",
            stats: [
              { label: "Yes, definitely", value: 70 },
              { label: "No, static", value: 20 },
              { label: "I can't tell", value: 10 }
            ]
          },
          "1": {
            choice: "No, static",
            text: "You see it static. Your visual system has a strong focal fixation, or you are less sensitive to asymmetric contrast drift in the periphery.",
            stats: [
              { label: "Yes, definitely", value: 70 },
              { label: "No, static", value: 20 },
              { label: "I can't tell", value: 10 }
            ]
          },
          "2": {
            choice: "I can't tell",
            text: "Your brain is actively trying to resolve the conflict between the static focal center and the drifting peripheral signals.",
            stats: [
              { label: "Yes, definitely", value: 70 },
              { label: "No, static", value: 20 },
              { label: "I can't tell", value: 10 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Up",
            text: "Perceiving it pointing Up indicates that your brain interprets the perspective projection as an ascending folded structure.",
            stats: [
              { label: "Up", value: 48 },
              { label: "Down", value: 37 },
              { label: "Both/Switches", value: 15 }
            ]
          },
          "1": {
            choice: "Down",
            text: "Perceiving it pointing Down indicates that your brain interprets the perspective projection as a descending folded structure.",
            stats: [
              { label: "Up", value: 48 },
              { label: "Down", value: 37 },
              { label: "Both/Switches", value: 15 }
            ]
          },
          "2": {
            choice: "Both",
            text: "You experience bistable switching, which shows excellent hemispheric rivalry and rapid update of depth parameters.",
            stats: [
              { label: "Up", value: 48 },
              { label: "Down", value: 37 },
              { label: "Both/Switches", value: 15 }
            ]
          }
        }
      },
      {
        options: {
          "0": {
            choice: "Instantly",
            text: "Instantly detecting the face shows highly active pareidolia and rapid face recognition via the fusiform face area (FFA).",
            stats: [
              { label: "Instantly (<5s)", value: 30 },
              { label: "Quickly (5-15s)", value: 40 },
              { label: "Took a while", value: 20 },
              { label: "Needed hint", value: 10 }
            ]
          },
          "1": {
            choice: "Quickly",
            text: "Quickly detecting the face shows normal face pareidolia, where the brain rapidly scans forest trunks for organic patterns.",
            stats: [
              { label: "Instantly (<5s)", value: 30 },
              { label: "Quickly (5-15s)", value: 40 },
              { label: "Took a while", value: 20 },
              { label: "Needed hint", value: 10 }
            ]
          },
          "2": {
            choice: "Took a while",
            text: "Taking a while indicates a highly analytical processing style that prioritizes physical edges (like tree bark) over rapid organic facial grouping.",
            stats: [
              { label: "Instantly (<5s)", value: 30 },
              { label: "Quickly (5-15s)", value: 40 },
              { label: "Took a while", value: 20 },
              { label: "Needed hint", value: 10 }
            ]
          },
          "3": {
            choice: "Needed hint",
            text: "Needing a hint indicates that your visual cortex processed the image purely as a landscape, showing strong resistance to pareidolia.",
            stats: [
              { label: "Instantly (<5s)", value: 30 },
              { label: "Quickly (5-15s)", value: 40 },
              { label: "Took a while", value: 20 },
              { label: "Needed hint", value: 10 }
            ]
          }
        }
      }
    ];

    // Initialize test
    startTestBtn?.addEventListener('click', () => {
      if (testIntro && testInterface) {
        showScreen(testInterface, [testIntro]);
        currentQIdx = 0;
        scores = { C: 0, A: 0, F: 0, D: 0 };
        renderQuestion();
      }
    });

    const feedbackPanel = document.getElementById('question-feedback');
    const feedbackChoice = document.getElementById('q-feedback-choice');
    const feedbackText = document.getElementById('q-feedback-text');
    const feedbackStats = document.getElementById('q-feedback-stats');
    const btnNext = document.getElementById('btn-next-question');

    let isWaitingForNext = false;
    let selectedCategory = 'C';

    // Render current question
    const renderQuestion = () => {
      isWaitingForNext = false;
      feedbackPanel?.classList.add('hidden');

      questions.forEach((q, idx) => {
        if (idx === currentQIdx) {
          q.classList.remove('hidden');
          // Re-enable and reset option buttons
          q.querySelectorAll('.test-option-btn').forEach(btn => {
            (btn as HTMLButtonElement).disabled = false;
            btn.classList.remove('border-purple-500', 'bg-purple-500/10', 'opacity-50');
          });
        } else {
          q.classList.add('hidden');
        }
      });

      // Update tracker and progress bar
      if (questionTracker && progressPct && progressBar) {
        const qNum = currentQIdx + 1;
        const progress = Math.round((qNum / 9) * 100);
        
        questionTracker.textContent = `Question ${qNum} of 9`;
        progressPct.textContent = `${progress}% Complete`;
        progressBar.style.width = `${progress}%`;
      }
    };

    // Handle Option Clicks
    questions.forEach(q => {
      const optionBtns = q.querySelectorAll('.test-option-btn');
      const catMap = JSON.parse(q.getAttribute('data-cat-map') || '{}') as Record<string, string>;

      optionBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          if (isWaitingForNext) return;
          e.stopPropagation();

          const clickedBtn = e.currentTarget as HTMLButtonElement;
          const oIdx = clickedBtn.getAttribute('data-oidx') || '0';
          selectedCategory = catMap[oIdx] || 'C';
          
          // Disable all other buttons in this question and highlight selected
          optionBtns.forEach(b => {
            const button = b as HTMLButtonElement;
            button.disabled = true;
            if (button === clickedBtn) {
              button.classList.add('border-purple-500', 'bg-purple-500/10');
            } else {
              button.classList.add('opacity-50');
            }
          });

          // Show Per-Question feedback panel
          const insightData = questionInsights[currentQIdx]?.options[oIdx as keyof typeof questionInsights[number]['options']];
          if (insightData && feedbackPanel && feedbackChoice && feedbackText && feedbackStats) {
            feedbackChoice.textContent = `You selected: ${insightData.choice}`;
            feedbackText.textContent = insightData.text;

            // Generate statistics breakdown HTML
            let statsHtml = "";
            insightData.stats.forEach(stat => {
              const active = stat.label.includes(insightData.choice);
              statsHtml += `
                <div class="space-y-1">
                  <div class="flex justify-between font-bold ${active ? 'text-white' : 'text-slate-400'}">
                    <span>${stat.label}</span>
                    <span>${stat.value}%</span>
                  </div>
                  <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
                    <div class="${active ? 'bg-purple-500' : 'bg-slate-700'} h-full" style="width: ${stat.value}%"></div>
                  </div>
                </div>
              `;
            });
            feedbackStats.innerHTML = statsHtml;
            feedbackPanel.classList.remove('hidden');
          }

          isWaitingForNext = true;
        });
      });
    });

    btnNext?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!isWaitingForNext) return;

      // Increment category score
      if (selectedCategory in scores) {
        scores[selectedCategory as keyof typeof scores]++;
      }

      currentQIdx++;
      if (currentQIdx < 9) {
        renderQuestion();
      } else {
        // Test Finished! Calculate results
        calculateResults();
      }
    });

    // Calculate final Brain Type
    const calculateResults = () => {
      let maxCategory: keyof typeof scores = 'C';
      let maxScore = -1;

      // Find highest category score
      Object.keys(scores).forEach(cat => {
        const c = cat as keyof typeof scores;
        if (scores[c] > maxScore) {
          maxScore = scores[c];
          maxCategory = c;
        }
      });

      // Render results screen
      const res = brainTypeDescriptions[maxCategory] || brainTypeDescriptions.C;
      if (resultTypeName && resultTypePct && resultTypeDesc) {
        resultTypeName.textContent = res.name;
        resultTypePct.textContent = res.pct;
        resultTypeDesc.innerHTML = res.desc;
        currentShareMessage = res.share;
      }

      feedbackPanel?.classList.add('hidden');
      if (testInterface && testResultsPanel) {
        showScreen(testResultsPanel, [testInterface]);
      }
    };

    // Forest hint outline action
    const forestHintBtn = document.getElementById('forest-hint-btn');
    const forestOutline = document.getElementById('face-hint-outline');
    let hintShowing = false;

    forestHintBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      hintShowing = !hintShowing;
      if (forestOutline) {
        forestOutline.classList.toggle('opacity-0', !hintShowing);
      }
      if (forestHintBtn) {
        forestHintBtn.textContent = hintShowing ? "Hide Hint 💡" : "Show Hint 💡";
      }
    });

    // Retake Test
    retakeTestBtn?.addEventListener('click', () => {
      if (testIntro && testResultsPanel) {
        showScreen(testIntro, [testResultsPanel]);
        // Reset forest hint
        hintShowing = false;
        forestOutline?.classList.add('opacity-0');
        if (forestHintBtn) forestHintBtn.textContent = "Show Hint 💡";
        feedbackPanel?.classList.add('hidden');
      }
    });

    // Share result action
    shareResultBtn?.addEventListener('click', () => {
      const shareUrl = window.location.href;
      const fullMessage = `${currentShareMessage}\nTake the optical illusion personality test here to find your dominant brain type: ${shareUrl}`;
      
      navigator.clipboard.writeText(fullMessage).then(() => {
        if (shareToast) {
          shareToast.classList.remove('hidden');
          setTimeout(() => {
            shareToast.classList.add('hidden');
          }, 3000);
        }
      });
    });

  </script>
</Layout>
