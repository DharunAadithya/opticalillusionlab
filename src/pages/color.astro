    <h2 class="font-display text-2xl font-black text-white">COLOUR VS COLOR</h2>
    <p class="text-slate-350 text-sm max-w-2xl mx-auto leading-relaxed">
      Whether you spell it as <strong class="text-white">color optical illusions</strong> or <strong class="text-white">colour optical illusions</strong>, you are in the right place! We use both spelling variations across our website so that all visitors from the United Kingdom, Australia, Canada, and the United States find exactly the visual experiments and science they were looking for! Enjoy the magic of colour perception!
    </p>
  </section>

  <script>
    // ----------------------------------------------------
    // 1. THE AMBIGUOUS DRESS WIDGET
    // ----------------------------------------------------
    const dressSlider = document.getElementById('dress-light-slider') as HTMLInputElement;
    const dressFabric = document.querySelectorAll('.dress-fabric');
    const dressStripes = document.querySelectorAll('.dress-stripes');
    const dressOverlay = document.getElementById('dress-overlay');
    const dressVoteControls = document.getElementById('dress-vote-controls');
    const dressResults = document.getElementById('dress-results');
    const dressExplanation = document.getElementById('dress-explanation');
    const pctBlueText = document.getElementById('pct-blue');
    const pctWhiteText = document.getElementById('pct-white');
    const barBlue = document.getElementById('bar-blue');
    const barWhite = document.getElementById('bar-white');
    const voteCountLabel = document.getElementById('vote-count-label');

    // Formula to interpolate colors for the dress
    const updateDressStyle = (val: number) => {
      // val ranges from 0 (cool cast shadow) to 100 (warm sunlight)
      // At 0 (Blue Shadow assumption -> see White-Gold):
      //   Fabric is a very light blue/white. HSL = (210, 15%, 88%)
      //   Stripes are gold/brown. HSL = (42, 55%, 52%)
      // At 100 (Gold Sunlight assumption -> see Blue-Black):
      //   Fabric is a deep rich blue. HSL = (215, 65%, 28%)
      //   Stripes are dark black/brown. HSL = (35, 30%, 12%)
      
      const fabricH = 210 + (val / 100) * 5;     // 210 to 215
      const fabricS = 15 + (val / 100) * 50;     // 15% to 65%
      const fabricL = 88 - (val / 100) * 60;     // 88% to 28%

      const stripesH = 42 - (val / 100) * 7;     // 42 to 35
      const stripesS = 55 - (val / 100) * 25;    // 55% to 30%
      const stripesL = 52 - (val / 100) * 40;    // 52% to 12%

      const fabricColor = `hsl(${fabricH}, ${fabricS}%, ${fabricL}%)`;
      const stripesColor = `hsl(${stripesH}, ${stripesS}%, ${stripesL}%)`;

      dressFabric.forEach(el => {
        (el as HTMLElement).style.fill = fabricColor;
      });
      dressStripes.forEach(el => {
        (el as HTMLElement).style.fill = stripesColor;
      });

      // Ambient light overlay opacity
      if (dressOverlay) {
        if (val < 50) {
          // cool blue overlay
          const op = (50 - val) / 50 * 0.35;
          dressOverlay.setAttribute('fill', `rgba(59, 130, 246, ${op})`);
        } else {
          // warm gold overlay
          const op = (val - 50) / 50 * 0.35;
          dressOverlay.setAttribute('fill', `rgba(245, 158, 11, ${op})`);
        }
      }
    };

    // Set initial
    updateDressStyle(50);

    dressSlider?.addEventListener('input', (e) => {
      const val = parseInt((e.target as HTMLInputElement).value);
      updateDressStyle(val);
    });

    // Voting Logic
    const initVote = () => {
      let bVotes = parseInt(localStorage.getItem('dress_votes_blue') || '154');
      let wVotes = parseInt(localStorage.getItem('dress_votes_white') || '96');
      
      const refreshResults = () => {
        const total = bVotes + wVotes;
        const pBlue = Math.round((bVotes / total) * 100);
        const pWhite = 100 - pBlue;
        
        if (pctBlueText && pctWhiteText && barBlue && barWhite && voteCountLabel) {
          pctBlueText.textContent = `${pBlue}%`;
          pctWhiteText.textContent = `${pWhite}%`;
          barBlue.style.width = `${pBlue}%`;
          barWhite.style.width = `${pWhite}%`;
          voteCountLabel.textContent = `Total votes: ${total} (Simulated live feed)`;
        }
      };

      const hasVoted = localStorage.getItem('dress_has_voted') === 'true';
      if (hasVoted) {
        dressVoteControls?.classList.add('hidden');
        dressResults?.classList.remove('hidden');
        dressExplanation?.classList.remove('hidden');
        refreshResults();
      }

      const btns = dressVoteControls?.querySelectorAll('.vote-btn');
      btns?.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const choice = (e.currentTarget as HTMLElement).getAttribute('data-choice');
          if (choice === 'blue-black') {
            bVotes++;
            localStorage.setItem('dress_votes_blue', bVotes.toString());
            // Animate slider to 100 to show what the blue/black choice looks like
            dressSlider.value = "100";
            updateDressStyle(100);
          } else {
            wVotes++;
            localStorage.setItem('dress_votes_white', wVotes.toString());
            // Animate slider to 0 to show what the white/gold choice looks like
            dressSlider.value = "0";
            updateDressStyle(0);
          }
          
          localStorage.setItem('dress_has_voted', 'true');
          
          // Cross-fade UI
          dressVoteControls?.classList.add('hidden');
          dressResults?.classList.remove('hidden');
          dressExplanation?.classList.remove('hidden');
          refreshResults();
        });
      });
    };

    initVote();


    // ----------------------------------------------------
    // EXPERIMENTS SCRIPTS
    // ----------------------------------------------------

    // 1. SAME GRAY, DIFFERENT WORLD
    const cbCard = document.querySelector('[data-exp="checkerboard"]');
    const cbBtn = cbCard?.querySelector('.action-btn') as HTMLButtonElement;
    const cbBridge = cbCard?.querySelector('#checkers-bridge') as SVGElement;
    let cbRevealed = false;

    cbBtn?.addEventListener('click', () => {
      cbRevealed = !cbRevealed;
      if (cbBridge) {
        cbBridge.style.opacity = cbRevealed ? '1' : '0';
      }
      cbBtn.textContent = cbRevealed ? "Hide Bridge 🏁" : "Reveal Truth 🔎";
    });

    // 2. ALL GRAY CIRCLES
    const spheresCard = document.querySelector('[data-exp="spheres"]');
    const spheresBtn = spheresCard?.querySelector('.action-btn') as HTMLButtonElement;
    const assimilationLines = spheresCard?.querySelector('.assimilation-lines') as SVGElement;
    let spheresRevealed = false;

    spheresBtn?.addEventListener('click', () => {
      spheresRevealed = !spheresRevealed;
      if (assimilationLines) {
        assimilationLines.style.opacity = spheresRevealed ? '0.05' : '1';
      }
      spheresBtn.textContent = spheresRevealed ? "Show Colored Lines 🔵" : "Remove Colored Lines ⚡";
    });

    // 3. THE IMPOSSIBLE GRADIENT
    const cornsweetCard = document.querySelector('[data-exp="cornsweet"]');
    const cornsweetBtn = cornsweetCard?.querySelector('.action-btn') as HTMLButtonElement;
    const cornsweetGradients = cornsweetCard?.querySelectorAll('.cornsweet-gradient');
    const cornsweetCover = cornsweetCard?.querySelector('#cornsweet-divider-cover') as HTMLElement;
    const cornsweetContainer = cornsweetCard?.querySelector('#cornsweet-container');
    let cornsweetRevealed = false;

    const toggleCornsweet = (state: boolean) => {
      cornsweetRevealed = state;
      if (cornsweetCover) {
        cornsweetCover.style.opacity = cornsweetRevealed ? '1' : '0';
      }
      if (cornsweetGradients) {
        cornsweetGradients.forEach(el => {
          (el as HTMLElement).style.opacity = cornsweetRevealed ? '0' : '1';
        });
      }
      if (cornsweetBtn) {
        cornsweetBtn.textContent = cornsweetRevealed ? "Show Center Edge 🌓" : "Cover Center Edge 🪵";
      }
    };

    cornsweetBtn?.addEventListener('click', () => toggleCornsweet(!cornsweetRevealed));
    
    // Also toggle on hover over container
    cornsweetContainer?.addEventListener('mouseenter', () => toggleCornsweet(true));
    cornsweetContainer?.addEventListener('mouseleave', () => toggleCornsweet(false));

    // 4. WHITE'S ILLUSION
    const whitesCard = document.querySelector('[data-exp="whites"]');
    const whitesBtn = whitesCard?.querySelector('.action-btn') as HTMLButtonElement;
    const whitesStripes = whitesCard?.querySelector('.whites-stripes') as SVGElement;
    let whitesRevealed = false;

    whitesBtn?.addEventListener('click', () => {
      whitesRevealed = !whitesRevealed;
      if (whitesStripes) {
        whitesStripes.style.opacity = whitesRevealed ? '0.05' : '1';
      }
      whitesBtn.textContent = whitesRevealed ? "Show Background Stripes 🦓" : "Isolate Gray Bars 🦓";
    });

    // 5. COLOR FROM LINES
    const contoursCard = document.querySelector('[data-exp="contours"]');
    const contoursBtn = contoursCard?.querySelector('.action-btn') as HTMLButtonElement;
    const contourFills = contoursCard?.querySelector('.contour-fills') as SVGElement;
    let contoursRevealed = false;

    contoursBtn?.addEventListener('click', () => {
      contoursRevealed = !contoursRevealed;
      if (contourFills) {
        contourFills.style.opacity = contoursRevealed ? '0' : '0.8';
      }
      contoursBtn.textContent = contoursRevealed ? "Show Contours 🎨" : "Remove Contours 🎨";
    });

    // 6. SIMULTANEOUS CONTRAST
    const contrastCard = document.querySelector('[data-exp="contrast"]');
    const contrastSlider = contrastCard?.querySelector('#contrast-slider') as HTMLInputElement;
    const contrastBg = contrastCard?.querySelector('#contrast-bg') as HTMLElement;

    contrastSlider?.addEventListener('input', (e) => {
      const val = parseInt((e.target as HTMLInputElement).value);
      // Interpolate background color from bright blue (0%) to deep purple (50%) to bright red (100%)
      let bg = '';
      if (val < 50) {
        const factor = val / 50; // 0 to 1
        const r = Math.round(59 + factor * 69); // 59 to 128
        const g = Math.round(130 - factor * 80); // 130 to 50
        const b = Math.round(246 - factor * 118); // 246 to 128
        bg = `rgb(${r}, ${g}, ${b})`;
      } else {
        const factor = (val - 50) / 50; // 0 to 1
        const r = Math.round(128 + factor * 111); // 128 to 239
        const g = Math.round(50 - factor * 18); // 50 to 32
        const b = Math.round(128 - factor * 90); // 128 to 38
        bg = `rgb(${r}, ${g}, ${b})`;
      }
      if (contrastBg) {
        contrastBg.style.backgroundColor = bg;
      }
    });

    // 7. AFTERIMAGE — STARE AND SEE
    const afterimageCard = document.querySelector('[data-exp="afterimage"]');
    const afterimageBtn = afterimageCard?.querySelector('.action-btn') as HTMLButtonElement;
    const afterimageScreen = afterimageCard?.querySelector('#afterimage-screen') as HTMLElement;
    const afterimageCross = afterimageCard?.querySelector('#afterimage-cross') as SVGElement;
    const afterimageTarget = afterimageCard?.querySelector('#afterimage-white-target') as HTMLElement;
    const afterimageTimer = afterimageCard?.querySelector('#afterimage-timer') as HTMLElement;

    let staring = false;
    let timerVal = 30;
    let staringInterval: any = null;

    afterimageBtn?.addEventListener('click', () => {
      if (staring) return;
      staring = true;
      timerVal = 30;
      
      // Reset layout
      if (afterimageCross) afterimageCross.classList.remove('hidden');
      if (afterimageTarget) afterimageTarget.classList.add('hidden');
      if (afterimageScreen) afterimageScreen.style.backgroundColor = '';
      
      if (afterimageTimer) {
        afterimageTimer.classList.remove('hidden');
        afterimageTimer.textContent = `${timerVal}s`;
      }
      if (afterimageBtn) afterimageBtn.setAttribute('disabled', 'true');

      staringInterval = setInterval(() => {
        timerVal--;
        if (afterimageTimer) afterimageTimer.textContent = `${timerVal}s`;

        if (timerVal <= 0) {
          clearInterval(staringInterval);
          staring = false;
          if (afterimageTimer) afterimageTimer.classList.add('hidden');
          
          // Switch to blank white target with red text feedback
          if (afterimageCross) afterimageCross.classList.add('hidden');
          if (afterimageTarget) afterimageTarget.classList.remove('hidden');
          if (afterimageScreen) afterimageScreen.style.backgroundColor = '#ffffff';

          if (afterimageBtn) {
            afterimageBtn.removeAttribute('disabled');
            afterimageBtn.textContent = "Restart Stare (30s) ⏱️";
          }
        }
      }, 1000);
    });

  
    // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation
    const colorCards = document.querySelectorAll('[data-exp]');
    colorCards.forEach(card => {
      card.querySelectorAll('button, input, select, details, summary, label, a, .action-btn').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
    });
    
  </script>
</Layout>
