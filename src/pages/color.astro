---
// src/pages/color.astro
import Layout from '../layouts/Layout.astro';
import ColorSpheresDemo from '../components/illusions/ColorSpheresDemo.astro';
---

<Layout 
  title="Color & Colour Optical Illusions — 4 Visual Experiments | Optical Illusion Lab" 
  description="Explore interactive color optical illusions, play with simultaneous contrast, and try the afterimage experiment."
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-16 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-100 via-purple-50 to-white dark:from-slate-900 dark:via-purple-950 dark:to-slate-950 text-slate-900 dark:text-white border-b border-indigo-500/10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(168,85,247,0.15),transparent_50%)]"></div>
    
    <div class="relative mx-auto max-w-4xl text-center space-y-6">
      <div class="inline-flex items-center space-x-2 rounded-full border border-purple-500/30 bg-purple-500/15 px-4 py-1.5 text-xs font-black uppercase tracking-wider text-purple-350 backdrop-blur-sm">
        🎨 Perceptual Color Lab 🎨
      </div>
      <h1 class="font-display text-4xl sm:text-6xl font-black tracking-tight bg-gradient-to-r from-pink-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">
        Color & Colour Optical Illusions
      </h1>
      <p class="mx-auto max-w-2xl text-lg sm:text-xl text-slate-600 dark:text-slate-200 font-medium leading-relaxed">
        Your brain doesn't see colors — it <span class="text-pink-400 font-bold">guesses</span> them. And it's wrong more often than you think.
      </p>
      
      <div class="flex justify-center">
        <a href="#experiments-grid" class="rounded-2xl bg-gradient-to-r from-pink-500 via-purple-600 to-indigo-600 hover:scale-105 text-white px-8 py-4 text-sm font-bold shadow-lg transition-all">
          Explore Experiments 🔬
        </a>
      </div>
    </div>
  </section>



  <!-- SECTION 2: 4 COLOR ILLUSION EXPERIMENTS -->
  <section id="experiments-grid" class="py-16 px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto space-y-12">
    <div class="text-center space-y-2">
      <h2 class="font-display text-3xl sm:text-4xl font-black text-slate-900 dark:text-white">
        4 COLOR ILLUSION EXPERIMENTS 🧪
      </h2>
      <p class="text-slate-600 dark:text-slate-400 max-w-md mx-auto text-sm">Interact with each visual lab to test your perceptual color limits.</p>
      <div class="mx-auto h-1 w-24 rounded-full bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-500 mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      
      <!-- Experiment 1: All Gray Circles -->
      <a href="/illusions/color-spheres" class="bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col justify-between hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.35)] cursor-pointer transition-all duration-300 block group" data-exp="spheres">
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs font-bold text-purple-400 uppercase tracking-widest">1. Chromatic Assimilation</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-550/10 text-red-400 border border-red-500/20">🔴 HARD</span>
          </div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white">ALL GRAY CIRCLES 🔵🟢🔴</h3>
          <p class="text-slate-600 dark:text-slate-300 text-xs leading-relaxed">
            These circles appear red, blue, and green. But they are actually completely identical gray! Hover or toggle to remove the lines.
          </p>
        </div>
        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Observe the spheres. Click 'Remove Colored Lines' to see that they are all the same shade of gray.
          </div>
        </div>
        <ColorSpheresDemo isCard={true} />

        <!-- Collapsible Explanation -->
        <details class="mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            Chromatic assimilation (neon color spreading) causes local color signals from foreground lines to bleed into the adjacent gray circles in our visual cortex, tricking us into seeing red, blue, or green spheres.
          </p>
        </details>

        <div class="mt-5 flex items-center justify-between border-t border-slate-850 pt-4">
          <span class="text-xs font-black text-purple-400 group-hover:text-purple-300 transition-colors">Explore &rarr;</span>
        </div>
      </a>



      <!-- Experiment 2: White's Illusion -->
      <a href="/illusions/whites-illusion" class="bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col justify-between hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.35)] cursor-pointer transition-all duration-300 block group" data-exp="whites">
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs font-bold text-purple-400 uppercase tracking-widest">2. Lateral Inhibition</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-450 border border-yellow-500/20">🟡 MEDIUM</span>
          </div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white">WHITE'S ILLUSION 🦓</h3>
          <p class="text-slate-600 dark:text-slate-300 text-xs leading-relaxed">
            The gray bars look totally different depending on whether they sit on the black or white stripes. Isolate them to prove they match!
          </p>
        </div>
        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Examine the gray bars on white and black stripes. Click 'Isolate Gray Bars' to see they are identical.
          </div>
        </div>
        <div class="my-6 flex flex-col items-center justify-center bg-slate-950/40 rounded-xl p-4 border border-slate-800 relative min-h-[220px]">
          <svg id="svg-whites" class="w-full max-w-[280px] h-40 select-none border border-slate-800 rounded-lg" viewBox="0 0 200 120">
            <!-- White background -->
            <rect x="0" y="0" width="200" height="120" fill="#fff" />
            
            <!-- Horizontal black stripes -->
            <g class="whites-stripes">
              <rect x="0" y="15" width="200" height="15" fill="#000" />
              <rect x="0" y="45" width="200" height="15" fill="#000" />
              <rect x="0" y="75" width="200" height="15" fill="#000" />
              <rect x="0" y="105" width="200" height="15" fill="#000" />
            </g>
            
            <!-- Gray bars (both identical #7f7f7f) -->
            <!-- Left bar sits on white stripes, flanked by black stripes -->
            <rect x="50" y="20" width="20" height="65" fill="#7f7f7f" />
            <!-- Right bar sits on black stripes, flanked by white stripes -->
            <rect x="130" y="35" width="20" height="65" fill="#7f7f7f" />
          </svg>
        </div>

        <!-- Collapsible Explanation -->
        <details class="mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            Gestalt grouping rules prioritize horizontal line continuity. Because the gray bars are grouped with the stripes they break, they absorb different contrast weights, overriding retinal lateral inhibition.
          </p>
        </details>

        <div class="mt-5 flex items-center justify-between border-t border-slate-850 pt-4">
          <button class="action-btn bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 px-4 rounded-xl shadow transition-transform active:scale-98">
          Isolate Gray Bars 🦓
        </button>
          <span class="text-xs font-black text-purple-400 group-hover:text-purple-300 transition-colors">Explore &rarr;</span>
        </div>
      </a>



      <!-- Experiment 3: Simultaneous Contrast -->
      <a href="/illusions/simultaneous-contrast" class="bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col justify-between hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.35)] cursor-pointer transition-all duration-300 block group" data-exp="contrast">
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs font-bold text-purple-400 uppercase tracking-wider">3. Hue Contrast</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-green-500/15 text-green-400 border border-green-500/20">🟢 EASY</span>
          </div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white">SIMULTANEOUS CONTRAST 🟧</h3>
          <p class="text-slate-600 dark:text-slate-300 text-xs leading-relaxed">
            The orange square in the middle looks different on blue vs red backgrounds. Drag the slider to shift the background color!
          </p>
        </div>
        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Stare at the orange square. Drag the background slider and see how its color appears to change.
          </div>
        </div>
        <div class="my-6 flex flex-col items-center justify-center bg-slate-950/40 rounded-xl p-4 border border-slate-800 relative min-h-[220px]">
          <!-- Split screen or slider screen -->
          <div id="contrast-bg" class="w-full max-w-[280px] h-40 rounded-lg flex items-center justify-center border border-slate-800 transition-colors duration-200" style="background-color: #3b82f6;">
            <!-- Orange square -->
            <div class="w-10 h-10 bg-[#f97316] shadow-md rounded-md"></div>
          </div>
          
          <div class="w-full max-w-[280px] mt-4 space-y-1">
            <div class="flex justify-between text-[10px] font-bold text-slate-400 uppercase tracking-widest">
              <span>🔵 Blue BG</span>
              <span>🟣 Purple BG</span>
              <span>🔴 Red BG</span>
            </div>
            <input type="range" id="contrast-slider" min="0" max="100" value="0" class="w-full h-2 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-pink-500" />
          </div>
        </div>

        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider text-center">Drag slider to shift background color! 🎛️</div>
              <div class="mt-5 flex items-center justify-between border-t border-slate-850 pt-4">
          <span class="text-xs font-black text-purple-400 group-hover:text-purple-300 transition-colors">Explore &rarr;</span>
        </div>
      </a>

      <!-- Experiment 4: Afterimage - Stare and See -->
      <a href="/illusions/afterimage-stare" class="bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col justify-between hover:border-purple-500/40 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(168,85,247,0.35)] cursor-pointer transition-all duration-300 block group" data-exp="afterimage">
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <span class="text-xs font-bold text-purple-400 uppercase tracking-widest">4. Receptor Fatigue</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-550/10 text-red-400 border border-red-500/20">🔴 HARD</span>
          </div>
          <h3 class="font-display text-xl font-bold text-slate-900 dark:text-white">AFTERIMAGE — STARE AND SEE ⏱️</h3>
          <p class="text-slate-600 dark:text-slate-300 text-xs leading-relaxed">
            Stare at the center of the colored cross for 30 seconds. When the timer hits zero, a ghostly complementary afterimage will float on the white screen!
          </p>
        </div>
        
        <!-- Instruction Box -->
        <div class="my-3 flex items-start gap-2 rounded-xl border border-indigo-500/10 bg-indigo-500/5 p-3 text-xs text-slate-350">
          <span class="text-base leading-none">👁️</span>
          <div>
            <strong class="text-slate-200">👁️ WHAT TO LOOK FOR:</strong> Stare at the white center dot in the cyan cross for 30s. Look at the white box when the timer ends.
          </div>
        </div>
        <div class="my-6 flex flex-col items-center justify-center bg-slate-950/40 rounded-xl p-4 border border-slate-800 relative min-h-[220px]">
          <!-- Afterimage box -->
          <div id="afterimage-screen" class="relative w-full max-w-[280px] h-40 flex items-center justify-center border border-slate-800 rounded-lg transition-colors duration-500 bg-slate-950">
            <!-- Colored cross (Cyan-Red setup: Staring at Cyan creates a Red afterimage) -->
            <svg id="afterimage-cross" class="w-24 h-24 select-none overflow-visible" viewBox="0 0 100 100">
              <rect x="40" y="10" width="20" height="80" fill="#06b6d4" />
              <rect x="10" y="40" width="80" height="20" fill="#06b6d4" />
              <circle cx="50" cy="50" r="3" fill="#ffffff" />
            </svg>
            
            <div id="afterimage-white-target" class="hidden w-full h-full bg-white flex flex-col items-center justify-center space-y-2 text-slate-900 rounded-lg p-4 text-center">
              <div class="w-16 h-16 border-4 border-slate-300 relative flex items-center justify-center">
                <!-- Tiny target dot -->
                <div class="w-1.5 h-1.5 bg-slate-800 rounded-full"></div>
              </div>
              <p class="text-[10px] font-bold text-slate-600 uppercase tracking-wider">If you see a ghost image, it is generated by your retina — not drawn here.</p>
            </div>
            
            <!-- Countdown overlay -->
            <div id="afterimage-timer" class="absolute top-2 right-2 bg-slate-900/90 text-yellow-300 font-mono font-black text-xs px-2 py-1 rounded border border-white/10 hidden">30s</div>
          </div>
        </div>

        <!-- Collapsible Explanation -->
        <details class="mt-4 border-t border-slate-800/40 pt-3 text-xs text-slate-400 select-none">
          <summary class="font-bold cursor-pointer hover:text-purple-400">👁️ Reveal Answer & Science</summary>
          <p class="mt-2 font-normal leading-relaxed text-slate-400">
            Simultaneous contrast is caused by lateral inhibition in retina cells. A dark background causes adjacent cells processing the orange square to fire faster, enhancing its perceived brightness.
          </p>
        </details>


        <div class="mt-5 flex items-center justify-between border-t border-slate-850 pt-4">
          <button class="action-btn bg-purple-600 hover:bg-purple-500 text-white font-bold text-xs py-2.5 px-4 rounded-xl shadow transition-transform active:scale-98">
          Start Afterimage Stare (30s) ⏱️
        </button>
          <span class="text-xs font-black text-purple-400 group-hover:text-purple-300 transition-colors">Explore &rarr;</span>
        </div>
      </a>



    </div>
  </section>

  <!-- SECTION 3: COLOR SCIENCE -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-slate-900/40 border-t border-b border-indigo-500/10">
    <div class="mx-auto max-w-4xl space-y-10">
      <div class="text-center space-y-2">
        <h2 class="font-display text-3xl font-black text-white">How Your Brain Decides What Color Something Is 🧠🔬</h2>
        <p class="text-slate-400 text-xs uppercase tracking-wider">The neurology of human color perception</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <!-- SVG diagram column -->
        <div class="bg-slate-950/60 p-6 rounded-2xl border border-slate-800 flex items-center justify-center min-h-[260px]">
          <svg class="w-full max-w-[320px] h-48 select-none" viewBox="0 0 300 180">
            <!-- Light wave -->
            <path d="M 10,90 Q 25,60 40,90 T 70,90 T 100,90" fill="none" stroke="#f43f5e" stroke-width="2.5" class="animate-pulse" />
            
            <!-- Eye shape -->
            <path d="M 90,90 Q 120,50 150,90 Q 120,130 90,90 Z" fill="none" stroke="#818cf8" stroke-width="2.5" />
            <circle cx="125" cy="90" r="14" fill="none" stroke="#818cf8" stroke-width="2" />
            <circle cx="125" cy="90" r="6" fill="#818cf8" />
            
            <!-- Optic nerve pathway -->
            <path d="M 150,90 C 180,90 200,105 220,105 L 250,90 L 265,90" fill="none" stroke="#c084fc" stroke-width="3" stroke-dasharray="4,4" id="optic-nerve" />
            
            <!-- Brain visual cortex -->
            <path d="M 245,60 C 265,65 290,75 290,100 C 290,125 265,135 245,120 Z" fill="none" stroke="#22d3ee" stroke-width="2.5" />
            <text x="268" y="104" fill="#22d3ee" font-size="11" font-weight="black" font-family="sans-serif" text-anchor="middle">V1/V4</text>

            <!-- Flow indicators -->
            <circle cx="10" cy="90" r="4" fill="#ef4444">
              <animateMotion dur="2.5s" repeatCount="indefinite" path="M 10,90 Q 25,60 40,90 T 70,90 T 100,90 L 125,90" />
            </circle>
            <circle cx="150" cy="90" r="4" fill="#a855f7">
              <animateMotion dur="2.5s" repeatCount="indefinite" path="M 150,90 C 180,90 200,105 220,105 L 250,90 L 265,90" />
            </circle>
          </svg>
        </div>

        <!-- Explanation copy column -->
        <div class="space-y-4 text-slate-350 text-sm leading-relaxed">
          <p>
            Perceiving a color is a complex multi-step computation. When light hits your eye's retina, it stimulates three types of cone photoreceptors tuned to short (blue), medium (green), and long (red) wavelengths of light. But the raw signals sent along the optic nerve are highly ambiguous.
          </p>
          <p>
            These signals travel to the lateral geniculate nucleus (LGN) and arrive at the visual cortex at the back of the brain (specifically areas <strong>V1</strong> and <strong>V4</strong>). Here, the brain performs <strong>differential contrast calculations</strong>. Rather than calculating absolute values, it compares the wavelength of light coming from an object against the wavelengths of light coming from its surrounding environment.
          </p>
          <p>
            By assessing this ratio, the brain discounts the color of the ambient illumination (such as yellow sunlight or blue sky shadow) to keep the object's perceived color constant. This survival mechanism lets you identify a red apple under a blue-shaded tree or in golden sunset rays, though in special situations it results in the stunning optical illusions seen here!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: COLOUR vs COLOR -->
  <section class="py-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto text-center space-y-4">
    <div class="inline-flex items-center space-x-2 rounded-full border border-pink-500/20 bg-pink-500/5 px-4 py-1 text-xs font-bold text-pink-300">
      🇬🇧 UK / US Spelling Note 🇺🇸
    </div>
    <h2 class="font-display text-2xl font-black text-white">COLOUR VS COLOR</h2>
    <p class="text-slate-350 text-sm max-w-2xl mx-auto leading-relaxed">
      Whether you spell it as <strong class="text-white">color optical illusions</strong> or <strong class="text-white">colour optical illusions</strong>, you are in the right place! We use both spelling variations across our website so that all visitors from the United Kingdom, Australia, Canada, and the United States find exactly the visual experiments and science they were looking for! Enjoy the magic of colour perception!
    </p>
  </section>

  <script>
    // ----------------------------------------------------
    // EXPERIMENTS SCRIPTS
    // ----------------------------------------------------

    // 4. WHITE'S ILLUSION
    const whitesCard = document.querySelector('[data-exp="whites"]');
    const whitesBtn = whitesCard?.querySelector('.action-btn') as HTMLButtonElement;
    const whitesStripes = whitesCard?.querySelector('.whites-stripes') as SVGElement;
    let whitesRevealed = false;

    whitesBtn?.addEventListener('click', () => {
      whitesRevealed = !whitesRevealed;
      if (whitesStripes) {
        whitesStripes.style.opacity = whitesRevealed ? '0.05' : '1';
      }
      whitesBtn.textContent = whitesRevealed ? "Show Background Stripes 🦓" : "Isolate Gray Bars 🦓";
    });



    // 6. SIMULTANEOUS CONTRAST
    const contrastCard = document.querySelector('[data-exp="contrast"]');
    const contrastSlider = contrastCard?.querySelector('#contrast-slider') as HTMLInputElement;
    const contrastBg = contrastCard?.querySelector('#contrast-bg') as HTMLElement;

    contrastSlider?.addEventListener('input', (e) => {
      const val = parseInt((e.target as HTMLInputElement).value);
      // Interpolate background color from bright blue (0%) to deep purple (50%) to bright red (100%)
      let bg = '';
      if (val < 50) {
        const factor = val / 50; // 0 to 1
        const r = Math.round(59 + factor * 69); // 59 to 128
        const g = Math.round(130 - factor * 80); // 130 to 50
        const b = Math.round(246 - factor * 118); // 246 to 128
        bg = `rgb(${r}, ${g}, ${b})`;
      } else {
        const factor = (val - 50) / 50; // 0 to 1
        const r = Math.round(128 + factor * 111); // 128 to 239
        const g = Math.round(50 - factor * 18); // 50 to 32
        const b = Math.round(128 - factor * 90); // 128 to 38
        bg = `rgb(${r}, ${g}, ${b})`;
      }
      if (contrastBg) {
        contrastBg.style.backgroundColor = bg;
      }
    });

    // 7. AFTERIMAGE — STARE AND SEE
    const afterimageCard = document.querySelector('[data-exp="afterimage"]');
    const afterimageBtn = afterimageCard?.querySelector('.action-btn') as HTMLButtonElement;
    const afterimageScreen = afterimageCard?.querySelector('#afterimage-screen') as HTMLElement;
    const afterimageCross = afterimageCard?.querySelector('#afterimage-cross') as SVGElement;
    const afterimageTarget = afterimageCard?.querySelector('#afterimage-white-target') as HTMLElement;
    const afterimageTimer = afterimageCard?.querySelector('#afterimage-timer') as HTMLElement;

    let staring = false;
    let timerVal = 30;
    let staringInterval: any = null;

    afterimageBtn?.addEventListener('click', () => {
      if (staring) return;
      staring = true;
      timerVal = 30;
      
      // Reset layout
      if (afterimageCross) afterimageCross.classList.remove('hidden');
      if (afterimageTarget) afterimageTarget.classList.add('hidden');
      if (afterimageScreen) afterimageScreen.style.backgroundColor = '';
      
      if (afterimageTimer) {
        afterimageTimer.classList.remove('hidden');
        afterimageTimer.textContent = `${timerVal}s`;
      }
      if (afterimageBtn) afterimageBtn.setAttribute('disabled', 'true');

      staringInterval = setInterval(() => {
        timerVal--;
        if (afterimageTimer) afterimageTimer.textContent = `${timerVal}s`;

        if (timerVal <= 0) {
          clearInterval(staringInterval);
          staring = false;
          if (afterimageTimer) afterimageTimer.classList.add('hidden');
          
          // Switch to blank white target with red text feedback
          if (afterimageCross) afterimageCross.classList.add('hidden');
          if (afterimageTarget) afterimageTarget.classList.remove('hidden');
          if (afterimageScreen) afterimageScreen.style.backgroundColor = '#ffffff';

          if (afterimageBtn) {
            afterimageBtn.removeAttribute('disabled');
            afterimageBtn.textContent = "Restart Stare (30s) ⏱️";
          }
        }
      }, 1000);
    });

  
    // Stop event propagation on inner details, summary, buttons, and inputs to prevent navigation
    const colorCards = document.querySelectorAll('[data-exp]');
    colorCards.forEach(card => {
      card.querySelectorAll('button, input, select, details, summary, label, a, .action-btn').forEach(el => {
        el.addEventListener('click', (e) => e.stopPropagation());
        el.addEventListener('mousedown', (e) => e.stopPropagation());
        el.addEventListener('touchstart', (e) => e.stopPropagation());
      });
    });
    
  </script>
</Layout>
