---
// src/components/ImpossibleEye.astro

// Generate Fraser Spiral concentric dashes
const cx = 100;
const cy = 100;

function generateFraserDashes(r: number, count: number, tilt: number, length: number) {
  const dashes = [];
  const rad = Math.PI / 180;
  for (let i = 0; i < count; i++) {
    const angle = (i * 360) / count;
    const x1 = cx + r * Math.cos(angle * rad);
    const y1 = cy + r * Math.sin(angle * rad);
    const x2 = cx + (r - length) * Math.cos((angle + tilt) * rad);
    const y2 = cy + (r - length) * Math.sin((angle + tilt) * rad);
    
    dashes.push({
      d: `M ${x1},${y1} L ${x2},${y2}`,
      color: i % 2 === 0 ? 'stroke-slate-950 dark:stroke-slate-900' : 'stroke-white dark:stroke-slate-200'
    });
  }
  return dashes;
}

const ring1 = generateFraserDashes(36, 24, 25, 8);
const ring2 = generateFraserDashes(28, 18, -25, 6);
---

<div 
  id="impossible-eye-container" 
  class="group fixed z-[9999] select-none pointer-events-auto w-10 h-7 bottom-4 right-4 lg:w-[90px] lg:h-[60px] lg:bottom-24 lg:right-8"
>
  <!-- Interactive Area Wrapper -->
  <div class="relative w-full h-full flex items-center justify-center">
    
    <!-- Ghost Trail Outline 3 (Most delayed) -->
    <div id="ghost-trail-3" class="absolute inset-0 pointer-events-none opacity-10 hidden lg:block transition-opacity duration-300">
      <svg class="w-full h-full filter drop-shadow-[0_0_8px_rgba(168,85,247,0.3)]" viewBox="0 0 200 200">
        <path d="M 15,100 Q 100,35 185,100 Q 100,165 15,100 Z" fill="none" stroke="#a855f7" stroke-width="2.5" />
        <g stroke="#a855f7" stroke-width="2.5" fill="none" stroke-linecap="round">
          <path d="M 50,56 Q 35,38 22,34" />
          <path d="M 75,44 Q 68,18 60,11" />
          <path d="M 100,38 Q 100,10 100,0" />
          <path d="M 125,44 Q 132,18 140,11" />
          <path d="M 150,56 Q 165,38 178,34" />
        </g>
      </svg>
    </div>

    <!-- Ghost Trail Outline 2 -->
    <div id="ghost-trail-2" class="absolute inset-0 pointer-events-none opacity-20 hidden lg:block transition-opacity duration-300">
      <svg class="w-full h-full filter drop-shadow-[0_0_12px_rgba(168,85,247,0.5)]" viewBox="0 0 200 200">
        <path d="M 15,100 Q 100,35 185,100 Q 100,165 15,100 Z" fill="none" stroke="#a855f7" stroke-width="2.5" />
        <g stroke="#a855f7" stroke-width="2.5" fill="none" stroke-linecap="round">
          <path d="M 50,56 Q 35,38 22,34" />
          <path d="M 75,44 Q 68,18 60,11" />
          <path d="M 100,38 Q 100,10 100,0" />
          <path d="M 125,44 Q 132,18 140,11" />
          <path d="M 150,56 Q 165,38 178,34" />
        </g>
      </svg>
    </div>

    <!-- Ghost Trail Outline 1 (Least delayed) -->
    <div id="ghost-trail-1" class="absolute inset-0 pointer-events-none opacity-40 hidden lg:block transition-opacity duration-300">
      <svg class="w-full h-full filter drop-shadow-[0_0_15px_rgba(168,85,247,0.6)]" viewBox="0 0 200 200">
        <path d="M 15,100 Q 100,35 185,100 Q 100,165 15,100 Z" fill="none" stroke="#a855f7" stroke-width="2.5" />
        <g stroke="#a855f7" stroke-width="2.5" fill="none" stroke-linecap="round">
          <path d="M 50,56 Q 35,38 22,34" />
          <path d="M 75,44 Q 68,18 60,11" />
          <path d="M 100,38 Q 100,10 100,0" />
          <path d="M 125,44 Q 132,18 140,11" />
          <path d="M 150,56 Q 165,38 178,34" />
        </g>
      </svg>
    </div>

    <!-- Primary Interactive Eye -->
    <div id="primary-eye" class="eye-instance absolute inset-0 transition-all duration-75">
      <div class="eye-ball-wrapper w-full h-full flex items-center justify-center">
        
        <!-- Glowing Eyelashes & Eye SVG -->
        <svg 
          id="main-eye-svg"
          class="w-full h-full filter drop-shadow-[0_0_10px_rgba(139,92,246,0.7)]" 
          viewBox="0 0 200 200"
        >
          <defs>
            <!-- 3D Sclera Gradient with Purple/Lavender Tint -->
            <radialGradient id="sclera-grad-tint" cx="45%" cy="45%" r="50%" fx="35%" fy="35%">
              <stop offset="0%" stop-color="#ffffff" />
              <stop offset="65%" stop-color="#f5f0ff" />
              <stop offset="100%" stop-color="#d8cdff" />
            </radialGradient>
            
            <radialGradient id="iris-glow-purple" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#a855f7" stop-opacity="0.95" />
              <stop offset="75%" stop-color="#7c3aed" stop-opacity="0.95" />
              <stop offset="100%" stop-color="#4c1d95" stop-opacity="1" />
            </radialGradient>
          </defs>

          <!-- Top Glowing Eyelashes -->
          <g class="eye-lashes hidden lg:block stroke-purple-400 dark:stroke-purple-300 stroke-[2.5] fill-none" stroke-linecap="round">
            <path d="M 50,56 Q 35,38 22,34" />
            <path d="M 75,44 Q 68,18 60,11" />
            <path d="M 100,38 Q 100,10 100,0" />
            <path d="M 125,44 Q 132,18 140,11" />
            <path d="M 150,56 Q 165,38 178,34" />
          </g>

          <!-- Eyeball Content (blinks & winks) -->
          <g class="eye-content-g origin-center transition-transform duration-300">
            <!-- Sclera (White/Purple Tinted Eyeball) -->
            <path d="M 15,100 Q 100,35 185,100 Q 100,165 15,100 Z" fill="url(#sclera-grad-tint)" stroke="#4c1d95" stroke-width="2" />
            
            <!-- Iris Group -->
            <g class="iris-g origin-center">
              <circle cx="100" cy="100" r="44" fill="url(#iris-glow-purple)" stroke="#2e1065" stroke-width="1.5" />
              
              <!-- Fraser Spiral Iris Rotation: Accelerated to 20s rotation -->
              <g class="fraser-spiral-iris origin-center" style="animation: spin-iris 20s linear infinite;">
                {ring1.map((dash) => (
                  <path d={dash.d} class={dash.color} stroke-width="2.5" stroke-linecap="round" />
                ))}
                {ring2.map((dash) => (
                  <path d={dash.d} class={dash.color} stroke-width="2" stroke-linecap="round" />
                ))}
              </g>

              <!-- Pupil Group -->
              <g class="pupil-g origin-center transition-transform duration-75">
                <!-- Pupil Circle (Subject to clicking size changes) -->
                <circle class="pupil-circle origin-center" cx="100" cy="100" r="16" fill="#020617" />
                <circle cx="94" cy="94" r="5" fill="#ffffff" opacity="0.8" />
              </g>
            </g>
          </g>
        </svg>

      </div>
    </div>

    <!-- Small hover tooltip (desktop only) -->
    <div class="eye-tooltip absolute bottom-[115%] left-1/2 -translate-x-1/2 px-2.5 py-1 text-xs font-bold text-white bg-slate-950 border border-purple-500/30 rounded-lg shadow-lg opacity-0 scale-90 pointer-events-none transition-all duration-200 whitespace-nowrap z-[10000] hidden lg:block group-hover:opacity-100 group-hover:scale-100">
      I see you 👁️
    </div>

    <!-- Double Click "Nice try 😏" Toast Popup -->
    <div id="eye-wink-msg" class="absolute bottom-[115%] left-1/2 -translate-x-1/2 px-3 py-1 text-xs font-black text-purple-300 bg-slate-950 border border-purple-500 rounded-lg shadow-lg opacity-0 scale-90 pointer-events-none transition-all duration-300 whitespace-nowrap z-[10001]">
      Nice try 😏
    </div>

  </div>
</div>

<style>
  /* 3s Pulsing Glow/Scale Loop on Desktop */
  @media (min-width: 1024px) {
    #impossible-eye-container {
      animation: pulse-glow 3s ease-in-out infinite;
    }
  }

  @keyframes pulse-glow {
    0%, 100% {
      transform: scale(1.0);
      filter: drop-shadow(0 0 10px rgba(139, 92, 246, 0.7));
    }
    50% {
      transform: scale(1.05);
      filter: drop-shadow(0 0 25px rgba(139, 92, 246, 1.0));
    }
  }

  @keyframes spin-iris {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  /* Surprised Dilation Pupil Transition */
  .pupil-circle {
    transition: transform 0.12s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    transform-origin: 100px 100px;
  }
  .surprised-active .pupil-circle {
    transform: scale(0.4) !important;
  }

  /* Wink transition class */
  .eye-content-g {
    transition: transform 0.3s ease-in-out;
    transform-origin: center;
  }
  .wink-active .eye-content-g {
    transform: scaleY(0.01) !important;
  }

  /* Eye Socket depth layout border styling */
  #impossible-eye-container::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 9999px;
    box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.5), 0 0 12px rgba(139, 92, 246, 0.3);
    pointer-events: none;
    z-index: 10;
  }
</style>

<script>
  const container = document.getElementById('impossible-eye-container');
  const primaryEye = document.getElementById('primary-eye');
  const eyeGContents = document.querySelectorAll('.eye-content-g');
  const pupilGroups = document.querySelectorAll('.pupil-g');
  const winkMsg = document.getElementById('eye-wink-msg');

  // Ghosts
  const ghost1 = document.getElementById('ghost-trail-1');
  const ghost2 = document.getElementById('ghost-trail-2');
  const ghost3 = document.getElementById('ghost-trail-3');

  if (container && pupilGroups.length > 0) {
    let currentX = 0, currentY = 0;
    let targetX = 0, targetY = 0;
    
    // Magnetic Shift translation values
    let shiftX = 0, shiftY = 0;
    let targetShiftX = 0, targetShiftY = 0;
    
    // Ghost trail delayed coordinates
    let g1x = 0, g1y = 0;
    let g2x = 0, g2y = 0;
    let g3x = 0, g3y = 0;

    let lastMoveTime = Date.now();
    let isStationary = false;
    let blinkTimer: any = null;

    const MAX_PUPIL_OFFSET = 12;
    const MAX_SHIFT_OFFSET = 20; // Magnetic pull offset

    // Saccadic jerky updates: check target differences every 180ms
    setInterval(() => {
      // Bypass on mobile
      if (window.innerWidth < 1024) return;

      const dist = Math.hypot(targetX - currentX, targetY - currentY);
      if (dist > 1.5) {
        currentX = targetX;
        currentY = targetY;

        // Check if pupil dilates on stationary
        const timeDiff = Date.now() - lastMoveTime;
        let scale = 1.0;
        if (timeDiff > 2000) {
          isStationary = true;
          scale = 1.0 + Math.sin(Date.now() * 0.0035) * 0.25;
        }

        // Snap update to simulate saccades
        pupilGroups.forEach(pupil => {
          (pupil as HTMLElement).style.transform = `translate(${currentX}px, ${currentY}px) scale(${scale})`;
        });
      }
    }, 180);

    // Mouse listener for coordinate tracking
    window.addEventListener('mousemove', (e) => {
      lastMoveTime = Date.now();
      isStationary = false;

      // Skip tracking logic on mobile screen sizes
      if (window.innerWidth < 1024) return;

      const rect = container.getBoundingClientRect();
      const eyeCenterX = rect.left + rect.width / 2;
      const eyeCenterY = rect.top + rect.height / 2;

      const dx = e.clientX - eyeCenterX;
      const dy = e.clientY - eyeCenterY;
      const distance = Math.hypot(dx, dy);

      if (distance > 0) {
        const factor = Math.min(distance / 250, 1);
        
        // Pupil target offset
        targetX = (dx / distance) * MAX_PUPIL_OFFSET * factor;
        targetY = (dy / distance) * MAX_PUPIL_OFFSET * factor;

        // Magnetic shift target offset
        targetShiftX = (dx / distance) * MAX_SHIFT_OFFSET * factor;
        targetShiftY = (dy / distance) * MAX_SHIFT_OFFSET * factor;
      } else {
        targetX = 0;
        targetY = 0;
        targetShiftX = 0;
        targetShiftY = 0;
      }
    });

    // Main visual LERP loop for trails and eye positioning
    const frameUpdate = () => {
      if (window.innerWidth >= 1024) {
        // Shift main eye towards cursor
        shiftX += (targetShiftX - shiftX) * 0.2;
        shiftY += (targetShiftY - shiftY) * 0.2;
        
        if (primaryEye) {
          primaryEye.style.transform = `translate(${shiftX}px, ${shiftY}px)`;
        }

        // Lerp ghost trails behind the main eye
        g1x += (shiftX - g1x) * 0.22;
        g1y += (shiftY - g1y) * 0.22;
        
        g2x += (g1x - g2x) * 0.15;
        g2y += (g1y - g2y) * 0.15;

        g3x += (g2x - g3x) * 0.08;
        g3y += (g2y - g3y) * 0.08;

        if (ghost1) ghost1.style.transform = `translate(${g1x}px, ${g1y}px)`;
        if (ghost2) ghost2.style.transform = `translate(${g2x}px, ${g2y}px)`;
        if (ghost3) ghost3.style.transform = `translate(${g3x}px, ${g3y}px)`;
      } else {
        // Reset transforms on mobile screens
        if (primaryEye) primaryEye.style.transform = 'none';
        pupilGroups.forEach(p => ((p as HTMLElement).style.transform = 'none'));
      }
      
      requestAnimationFrame(frameUpdate);
    };
    requestAnimationFrame(frameUpdate);


    // ----------------------------------------------------
    // CLICK INTERACTION (Surprised Pupil Dilation)
    // ----------------------------------------------------
    container.addEventListener('click', () => {
      if (window.innerWidth < 1024) return;

      container.classList.add('surprised-active');
      
      // Return to normal size after 1 second
      setTimeout(() => {
        container.classList.remove('surprised-active');
      }, 1000);
    });


    // ----------------------------------------------------
    // DOUBLE CLICK INTERACTION (Slow Wink & message)
    // ----------------------------------------------------
    container.addEventListener('dblclick', (e) => {
      if (window.innerWidth < 1024) return;
      e.stopPropagation(); // Prevent duplicate click surprise triggers

      container.classList.add('wink-active');
      
      // Fade in toast message
      if (winkMsg) {
        winkMsg.classList.remove('opacity-0', 'scale-90');
        winkMsg.classList.add('opacity-100', 'scale-100');
      }

      // Restore wink eye after 1.2s and fade out message
      setTimeout(() => {
        container.classList.remove('wink-active');
        if (winkMsg) {
          winkMsg.classList.remove('opacity-100', 'scale-100');
          winkMsg.classList.add('opacity-0', 'scale-90');
        }
      }, 1200);
    });


    // ----------------------------------------------------
    // RANDOM BLINKING (Every 4 to 9 seconds)
    // ----------------------------------------------------
    const triggerBlink = () => {
      if (window.innerWidth >= 1024 && !container.classList.contains('wink-active')) {
        eyeGContents.forEach(g => {
          (g as SVGElement).style.transform = 'scaleY(0.01)';
        });

        setTimeout(() => {
          eyeGContents.forEach(g => {
            (g as SVGElement).style.transform = 'scaleY(1)';
          });
        }, 140);
      }

      const nextBlink = 4000 + Math.random() * 5000;
      blinkTimer = setTimeout(triggerBlink, nextBlink);
    };
    blinkTimer = setTimeout(triggerBlink, 5000);
  }
</script>
