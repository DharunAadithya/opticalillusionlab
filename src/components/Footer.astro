---
// src/components/Footer.astro
const today = new Date();
---

<footer class="w-full border-t border-slate-200/80 dark:border-slate-800 bg-white dark:bg-slate-950 text-slate-500 dark:text-slate-400 py-16 mt-20 transition-colors duration-300">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
      <!-- Brand & Info Column -->
      <div class="md:col-span-2 space-y-4">
        <div class="flex items-center space-x-3">
          <img
            src="/favicon-96x96.png"
            alt="Optical Illusion Lab Logo"
            class="h-12 w-12 rounded-xl shadow-[0_0_12px_rgba(147,51,234,0.4)]"
          />
          <span class="font-display text-xl font-black text-slate-900 dark:text-white tracking-tight">
            Optical Illusion Lab
          </span>
        </div>
        <p class="text-sm font-medium text-slate-700 dark:text-slate-300 italic">
          Where science meets perception.
        </p>
        <p class="text-xs text-slate-600 dark:text-slate-400 max-w-sm leading-relaxed">
          Unveiling the fascinating science of human visual perception. Explore interactive visual anomalies, dynamic illusions, and learn how your brain constructs reality.
        </p>
        <p class="text-[11px] text-slate-400 dark:text-slate-500 italic max-w-xs leading-normal">
          Disclaimer: Visual animations may cause temporary eye fatigue or mild disorientation. Take breaks if you experience discomfort.
        </p>
      </div>

      <!-- Categories Column -->
      <div>
        <h3 class="text-xs font-bold text-slate-900 dark:text-slate-200 uppercase tracking-wider mb-4">Illusion Types</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/famous" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Famous Illusions</a></li>
          <li><a href="/moving" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Moving Illusions</a></li>
          <li><a href="/hidden" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Hidden Details</a></li>
          <li><a href="/color" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Color & Contrast</a></li>
          <li><a href="/for-kids" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">For Kids</a></li>
        </ul>
      </div>

      <!-- Interactive Tools Column -->
      <div>
        <h3 class="text-xs font-bold text-slate-900 dark:text-slate-200 uppercase tracking-wider mb-4">Laboratory Tools</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/what-do-you-see" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">What Do You See?</a></li>
          <li><a href="/drawings" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Drawings Gallery</a></li>
          <li><a href="/generator" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Illusion Generator</a></li>
          <li><a href="/how-they-work" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Science & Theory</a></li>
          <li><a href="/test" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Illusion Test</a></li>
        </ul>
      </div>

      <!-- Legal / Contact Column -->
      <div>
        <h3 class="text-xs font-bold text-slate-900 dark:text-slate-200 uppercase tracking-wider mb-4">Information</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/about" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Contact</a></li>
          <li><a href="/privacy-policy" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-purple-600 dark:hover:text-purple-400 transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-slate-200 dark:border-slate-800 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between text-xs text-slate-400 dark:text-slate-500">
      <p>&copy; {today.getFullYear()} Optical Illusion Lab. All rights reserved.</p>
      <p class="mt-2 sm:mt-0">Built with 💜 for curious minds.</p>
    </div>
  </div>
</footer>
