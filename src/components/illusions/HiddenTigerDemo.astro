---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="hiddentiger-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-[#070A13] rounded-2xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[380px] p-4 pb-20">
    
    <!-- High-Fidelity Hidden Tiger typographic SVG -->
    <svg class="w-full max-w-[320px] h-auto aspect-[320/220] select-none overflow-visible" viewBox="0 0 320 220">
      <defs>
        <!-- Soft glow filter -->
        <filter id="glow-tiger" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="4" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
        <!-- Tiger skin gradient -->
        <linearGradient id="tiger-skin" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#EA580C" />
          <stop offset="40%" stop-color="#F97316" />
          <stop offset="60%" stop-color="#FB923C" />
          <stop offset="100%" stop-color="#EA580C" />
        </linearGradient>
      </defs>

      <!-- Tiger Body Silhouette (Drawn in rich tiger orange) -->
      <!-- A gorgeous, organic profile of a tiger lying down or standing -->
      <path 
        d="M 15,160 
           Q 25,120 45,115
           C 65,110 85,90 95,70
           C 105,50 120,40 135,40
           C 155,40 185,60 215,70
           C 235,75 270,75 295,95
           C 310,110 305,150 290,170
           C 270,185 240,185 210,180
           C 180,175 140,175 110,180
           C 70,185 45,185 15,160 Z" 
        fill="url(#tiger-skin)" 
        stroke="#7C2D12" 
        stroke-width="3" 
      />

      <!-- Tiger Face Silhouette Details on the left -->
      <path d="M 95,70 L 80,75 L 75,70 L 85,60 Z" fill="#070A13" /> <!-- Ear -->
      <circle cx="55" cy="122" r="2.5" fill="#FEF08A" /> <!-- Glowing eye -->

      <!-- TYPOGRAPHIC TIGER STRIPES forming "THE HIDDEN TIGER" -->
      <!-- Drawn as vertical, organic, wavy black paths (#070A13) -->
      <g fill="#070A13" stroke="none">
        
        <!-- ================= 'T' 'H' 'E' ================= -->
        <!-- 'T' stripe -->
        <path d="M 105,65 Q 112,65 112,69 H 98 Q 98,65 105,65 Z" />
        <path d="M 104.5,69 Q 106,100 103,130 C 101,150 107,150 106,155 Q 103,155 102.5,130 Z" />

        <!-- 'H' stripes -->
        <path d="M 112,68 Q 114,100 112,132 C 111,148 114,148 113,154 Q 110,154 110,132 Z" />
        <path d="M 121,68 Q 123,100 121,132 C 120,148 123,148 122,154 Q 119,154 119,132 Z" />
        <path d="M 112,105 H 121 V 109 H 112 Z" />

        <!-- 'E' stripes -->
        <path d="M 128,68 Q 130,100 128,132 C 127,148 130,148 129,154 Q 126,154 126,132 Z" />
        <path d="M 129,68 H 136 V 71 H 129 Z" />
        <path d="M 129,105 H 135 V 108 H 129 Z" />
        <path d="M 129,149 H 136 V 152 H 129 Z" />


        <!-- ================= 'H' 'I' 'D' 'D' 'E' 'N' ================= -->
        <!-- 'H' -->
        <path d="M 143,65 Q 145,100 143,135 C 142,150 145,150 144,156 Q 141,156 141,135 Z" />
        <path d="M 152,65 Q 154,100 152,135 C 151,150 154,150 153,156 Q 150,156 150,135 Z" />
        <path d="M 143,105 H 152 V 108 H 143 Z" />

        <!-- 'I' -->
        <path d="M 159,68 Q 161,100 159,135 C 158,150 161,150 160,155 Q 157,155 157,135 Z" />

        <!-- 'D' -->
        <path d="M 166,66 Q 168,100 166,135 C 165,150 168,150 167,156 Q 164,156 164,135 Z" />
        <path d="M 167,66 C 177,66 179,90 178,110 C 177,130 175,156 167,156 Q 165,156 165,153 C 172,153 174,130 174,110 C 174,90 172,69 167,69 Z" />

        <!-- 'D' -->
        <path d="M 183,66 Q 185,100 183,135 C 182,150 185,150 184,156 Q 181,156 181,135 Z" />
        <path d="M 184,66 C 194,66 196,90 195,110 C 194,130 192,156 184,156 Q 182,156 182,153 C 189,153 191,130 191,110 C 191,90 189,69 184,69 Z" />

        <!-- 'E' -->
        <path d="M 201,65 Q 203,100 201,135 C 200,150 203,150 202,156 Q 199,156 199,135 Z" />
        <path d="M 202,65 H 209 V 68 H 202 Z" />
        <path d="M 202,105 H 208 V 108 H 202 Z" />
        <path d="M 202,151 H 209 V 154 H 202 Z" />

        <!-- 'N' -->
        <path d="M 214,65 Q 216,100 214,135 C 213,150 216,150 215,156 Q 212,156 212,135 Z" />
        <path d="M 226,65 Q 228,100 226,135 C 225,150 228,150 227,156 Q 224,156 224,135 Z" />
        <path d="M 214,68 L 226,153 H 229 L 217,68 Z" />


        <!-- ================= 'T' 'I' 'G' 'E' 'R' ================= -->
        <!-- 'T' -->
        <path d="M 239,63 Q 246,63 246,67 H 232 Q 232,63 239,63 Z" />
        <path d="M 238.5,67 Q 240,100 238,135 C 237,150 240,150 239,155 Q 236,155 235.5,135 Z" />

        <!-- 'I' -->
        <path d="M 248,65 Q 250,100 248,135 C 247,150 250,150 249,155 Q 246,155 246,135 Z" />

        <!-- 'G' -->
        <path d="M 255,65 C 265,65 267,80 266,100 M 266,120 C 267,140 263,156 254,156 C 246,156 244,130 244,110 C 244,90 246,65 255,65 Z" fill="none" stroke="#070A13" stroke-width="3" />
        <path d="M 258,110 H 267 V 114 H 258 Z" />
        <path d="M 264,114 V 135 H 267 V 114 Z" />

        <!-- 'E' -->
        <path d="M 273,65 Q 275,100 273,135 C 272,150 275,150 274,156 Q 271,156 271,135 Z" />
        <path d="M 274,65 H 281 V 68 H 274 Z" />
        <path d="M 274,105 H 280 V 108 H 274 Z" />
        <path d="M 274,151 H 281 V 154 H 274 Z" />

        <!-- 'R' -->
        <path d="M 286,65 Q 288,100 286,135 C 285,150 288,150 287,156 Q 284,156 284,135 Z" />
        <path d="M 287,65 C 295,65 297,85 295,95 C 293,105 291,110 287,110 Z M 290,92 C 290,80 288,69 287,69 Z" />
        <path d="M 287,110 L 297,156 H 293 L 285,110 Z" />

      </g>

      <!-- Highlights Overlay: Glow on Typographic Stripes (Red) -->
      <g class="tiger-overlay-stripes opacity-0 transition-opacity duration-300 pointer-events-none" filter="url(#glow-tiger)">
        <!-- Highlight letters boundary box -->
        <rect x="94" y="58" width="206" height="104" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-dasharray="4,3" rx="6" />
        <text x="200" y="50" fill="#22C55E" font-size="10" font-weight="900" text-anchor="middle">"THE HIDDEN TIGER"</text>
      </g>
    </svg>

    <!-- Overlay Toggle Controls inside container -->
    <div class="absolute bottom-2 z-20">
      <button class="btn-toggle-tiger-stripes bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[9px] font-black px-4 py-2 rounded-lg border-none transition-colors cursor-pointer uppercase">Reveal Text Stripes 🐅</button>
    </div>
  </div>
</div>

<script>
  function initTiger() {
    const containers = document.querySelectorAll('.hiddentiger-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btn = container.querySelector('.btn-toggle-tiger-stripes');
      const overlay = container.querySelector('.tiger-overlay-stripes');

      let active = false;

      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        active = !active;
        if (overlay) {
          if (active) {
            overlay.classList.replace('opacity-0', 'opacity-100');
            btn.textContent = "Hide Text Stripes 🐅";
          } else {
            overlay.classList.replace('opacity-100', 'opacity-0');
            btn.textContent = "Reveal Text Stripes 🐅";
          }
        }
      });
    });
  }

  initTiger();
  document.addEventListener('astro:page-load', initTiger);
</script>
