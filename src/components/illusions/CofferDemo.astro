---
// src/components/illusions/CofferDemo.astro
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;

// Metrics
const cofferW = 72;
const cofferH = 72;
const border = 20;
const offset = 16;
const gridW = 388;

// Borders coordinates indices (0 to 4)
const borderIndices = [0, 1, 2, 3, 4];

// Coffers grid (row=0..3, col=0..3)
const coffers = [];
for (let r = 0; r < 4; r++) {
  for (let c = 0; c < 4; c++) {
    coffers.push({
      x: offset + border + c * (cofferW + border),
      y: offset + border + r * (cofferH + border)
    });
  }
}

// 16 Hidden circles at intersections: row=1..4, col=1..4 (which is index 1, 2, 3, 4)
const circles = [];
for (let r = 1; r <= 4; r++) {
  for (let c = 1; c <= 4; c++) {
    circles.push({
      cx: offset + c * (cofferW + border) + border / 2,
      cy: offset + r * (cofferH + border) + border / 2
    });
  }
}
---

<div class="coffer-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  
  <div class="relative flex flex-col items-center justify-center bg-slate-900 rounded-xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[380px] p-6 pb-28">
    
    <!-- SVG Area (Exactly 420x420 px, background #1a1a1a) -->
    <svg class="coffer-svg w-full max-w-[360px] h-auto aspect-square select-none overflow-visible rounded-lg shadow-lg border border-slate-950 bg-[#1a1a1a]" viewBox="0 0 420 420" width="420" height="420">
      
      <defs>
        <!-- Vertical gradient for horizontal stripes (Step 2) -->
        <linearGradient id="coffer-h-stripe-grad" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#222222" />
          <stop offset="50%" stop-color="#888888" />
          <stop offset="100%" stop-color="#222222" />
        </linearGradient>

        <!-- Horizontal gradient for vertical stripes (Step 3) -->
        <linearGradient id="coffer-v-stripe-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#222222" />
          <stop offset="50%" stop-color="#888888" />
          <stop offset="100%" stop-color="#222222" />
        </linearGradient>
      </defs>

      <!-- Step 0: Canvas Background -->
      <rect x="0" y="0" width="420" height="420" fill="#1a1a1a" />

      <!-- Step 2: Draw horizontal border stripes (5 of them) -->
      {borderIndices.map(row => (
        <rect 
          x={offset} 
          y={offset + row * (cofferH + border)} 
          width={gridW} 
          height={border} 
          fill="url(#coffer-h-stripe-grad)" 
        />
      ))}

      <!-- Step 3: Draw vertical border stripes (5 of them) -->
      {borderIndices.map(col => (
        <rect 
          x={offset + col * (cofferW + border)} 
          y={offset} 
          width={border} 
          height={gridW} 
          fill="url(#coffer-v-stripe-grad)" 
        />
      ))}

      <!-- Step 4: Draw 16 coffer panels on top -->
      {coffers.map(panel => (
        <g>
          <!-- Outer rect: width=72, height=72, fill=#2d2d2d -->
          <rect x={panel.x} y={panel.y} width="72" height="72" fill="#2d2d2d" />
          <!-- Middle rect (inset 6px): width=60, height=60, fill=#1a1a1a -->
          <rect x={panel.x + 6} y={panel.y + 6} width="60" height="60" fill="#1a1a1a" />
          <!-- Inner rect (inset 12px): width=48, height=48, fill=#262626 -->
          <rect x={panel.x + 12} y={panel.y + 12} width="48" height="48" fill="#262626" />
          <!-- Innermost rect (inset 18px): width=36, height=36, fill=#1a1a1a -->
          <rect x={panel.x + 18} y={panel.y + 18} width="36" height="36" fill="#1a1a1a" />
        </g>
      ))}

      <!-- Step 5: Reveal circles (hidden by default) -->
      <g class="coffer-circles hidden">
        {circles.map(c => (
          <ellipse 
            cx={c.cx} 
            cy={c.cy} 
            rx="28" 
            ry="28" 
            stroke="#7C3AED" 
            stroke-width="2" 
            fill="none" 
          />
        ))}
      </g>
    </svg>

    <!-- Quiz & Controls Interface -->
    {!isCard && (
      <div class="absolute bottom-3 left-3 right-3 flex flex-col items-center gap-2 z-20">
        <!-- Input guessing form -->
        <div class="flex items-center gap-2 w-full max-w-[280px] bg-slate-950/80 px-3 py-1.5 rounded-xl border border-slate-800">
          <label for="coffer-guess-input" class="text-[10px] font-bold text-slate-400 uppercase whitespace-nowrap">CIRCLES FOUND:</label>
          <input 
            type="number" 
            id="coffer-guess-input" 
            class="input-coffer-guess w-14 bg-slate-900 border border-slate-700 text-center font-bold text-white text-xs rounded p-1" 
            min="0"
            value="0" 
          />
          <button class="btn-coffer-check bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-bold px-3 py-1 rounded border-none cursor-pointer transition-colors shadow">
            Submit
          </button>
        </div>

        <div class="flex gap-2">
          <button class="btn-reveal-coffer bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-bold px-4 py-2 rounded-lg border-none cursor-pointer transition-colors shadow">
            Reveal
          </button>
        </div>
      </div>
    )}
  </div>

  <!-- Feedback Panel -->
  {!isCard && (
    <div class="coffer-feedback mt-3 text-center text-xs font-semibold text-slate-700 dark:text-slate-350 min-h-6 max-w-md hidden">
      <span class="coffer-status text-emerald-500 font-bold"></span>
    </div>
  )}
</div>

<script>
  function initCoffer() {
    const containers = document.querySelectorAll('.coffer-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const circlesGroup = container.querySelector('.coffer-circles');
      const input = container.querySelector('.input-coffer-guess') as HTMLInputElement;
      const btnCheck = container.querySelector('.btn-coffer-check');
      const btnReveal = container.querySelector('.btn-reveal-coffer');
      const feedback = container.querySelector('.coffer-feedback') as HTMLElement;
      const statusSpan = container.querySelector('.coffer-status') as HTMLElement;

      let circlesRevealed = false;

      btnReveal?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        circlesRevealed = !circlesRevealed;

        if (circlesRevealed) {
          circlesGroup?.classList.remove('hidden');
          if (btnReveal) btnReveal.textContent = 'Hide';
        } else {
          circlesGroup?.classList.add('hidden');
          if (btnReveal) btnReveal.textContent = 'Reveal';
        }
      });

      btnCheck?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const val = parseInt(input.value || '0');
        feedback?.classList.remove('hidden');

        // Show circles to prove answer
        circlesGroup?.classList.remove('hidden');
        circlesRevealed = true;
        if (btnReveal) btnReveal.textContent = 'Hide';

        if (val === 16) {
          if (statusSpan) {
            statusSpan.textContent = 'Correct! ✓ There are exactly 16 circles hidden at the crossings.';
            statusSpan.className = 'coffer-status text-emerald-500 font-bold';
          }
        } else {
          if (statusSpan) {
            statusSpan.textContent = `Not quite! You guessed ${val}. There are actually 16 circles hidden.`;
            statusSpan.className = 'coffer-status text-rose-500 font-bold';
          }
        }
      });
    });
  }

  initCoffer();
  document.addEventListener('astro:page-load', initCoffer);
</script>
