---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;

// Coffer Illusion Parameters
// 5x5 grid of coffers in a 400x400 SVG
// This creates 4x4 = 16 internal intersections where circles will be placed on Reveal.
const gridSize = 5;
const cellSize = 80;

const coffers = [];
for (let r = 0; r < gridSize; r++) {
  for (let c = 0; c < gridSize; c++) {
    coffers.push({
      cx: cellSize / 2 + c * cellSize,
      cy: cellSize / 2 + r * cellSize
    });
  }
}

// 16 intersections (centers of circles)
const intersections = [];
for (let r = 0; r < gridSize - 1; r++) {
  for (let c = 0; c < gridSize - 1; c++) {
    intersections.push({
      cx: cellSize + c * cellSize,
      cy: cellSize + r * cellSize
    });
  }
}
---

<div class="coffer-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[420px] p-6 pb-24">
    
    <!-- SVG Area (Exactly 400x400 px, Grayscale only) -->
    <svg class="w-full max-w-[360px] h-auto aspect-square select-none overflow-visible rounded-lg shadow-md border border-slate-300" viewBox="0 0 400 400">
      
      <!-- Base Background (Grayscale) -->
      <rect x="0" y="0" width="400" height="400" fill="#7f7f7f" />

      <!-- Draw 5x5 coffers of nested squares to create the 3D relief ceiling panel pattern -->
      <!-- Bas-relief borders: outer #555555, middle #888888, inner #BBBBBB, innermost #444444 -->
      {coffers.map(cof => (
        <g>
          <!-- Outer coffer square -->
          <rect x={cof.cx - 40} y={cof.cy - 40} width="80" height="80" fill="#555555" stroke="#888888" stroke-width="2" />
          <!-- First nested inner square -->
          <rect x={cof.cx - 28} y={cof.cy - 28} width="56" height="56" fill="#888888" stroke="#bbbbbb" stroke-width="2" />
          <!-- Second nested inner square -->
          <rect x={cof.cx - 18} y={cof.cy - 18} width="36" height="36" fill="#bbbbbb" stroke="#444444" stroke-width="2" />
          <!-- Center nested inner square -->
          <rect x={cof.cx - 8} y={cof.cy - 8} width="16" height="16" fill="#444444" stroke="#555555" stroke-width="1.5" />
        </g>
      ))}

      <!-- Vertical and horizontal grid line separators (grooves) to blend stripes -->
      <g stroke="#ffffff" stroke-width="1.5" opacity="0.3">
        <line x1="80" y1="0" x2="80" y2="400" />
        <line x1="160" y1="0" x2="160" y2="400" />
        <line x1="240" y1="0" x2="240" y2="400" />
        <line x1="320" y1="0" x2="320" y2="400" />
        <line x1="0" y1="80" x2="400" y2="80" />
        <line x1="0" y1="160" x2="400" y2="160" />
        <line x1="0" y1="240" x2="400" y2="240" />
        <line x1="0" y1="320" x2="400" y2="320" />
      </g>

      <!-- Pulsing Purple Highlights (Reveals all 16 circles, hidden by default) -->
      <g class="coffer-circles-overlay opacity-0 transition-opacity duration-300 pointer-events-none">
        {intersections.map(ins => (
          <g>
            <circle 
              class="coffer-pulse-circle stroke-[#7C3AED] stroke-[3.5] fill-none"
              cx={ins.cx} 
              cy={ins.cy} 
              r="40" 
              style="animation: pulse-ring-coffer 2s infinite ease-in-out;"
            />
            <circle 
              class="coffer-pulse-circle stroke-[#7C3AED] stroke-[2.5] fill-none"
              cx={ins.cx} 
              cy={ins.cy} 
              r="28" 
              style="animation: pulse-ring-coffer 2s infinite ease-in-out 0.4s;"
            />
          </g>
        ))}
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-2 w-11/12 px-4 flex flex-col gap-1.5 bg-white/95 dark:bg-slate-900/90 p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm z-20">
      <div class="flex items-center gap-2 w-full justify-between">
        <div class="flex items-center gap-1.5">
          <span class="text-[10px] text-slate-700 dark:text-slate-350 font-bold uppercase whitespace-nowrap">Circles Found:</span>
          <input type="number" class="input-coffer-guess bg-white dark:bg-slate-950 border border-slate-300 dark:border-slate-800 text-slate-800 dark:text-white rounded text-[11px] px-2 py-1 w-14 focus:outline-none" placeholder="0" min="0" />
          <button class="btn-coffer-check bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-bold text-[11px] px-4 py-2 rounded-lg border-none transition-all shadow-sm cursor-pointer">
            Submit
          </button>
        </div>
        <button class="btn-reveal-coffer text-[11px] font-bold px-4 py-2 rounded-lg border-none bg-[#7C3AED] hover:bg-[#6D28D9] text-white transition-all cursor-pointer">
          Reveal
        </button>
      </div>

      <!-- Feedback (hidden by default) -->
      <div class="coffer-feedback-panel hidden flex items-center justify-between text-[10px] font-bold mt-1 text-slate-700 dark:text-slate-300 border-t border-slate-200 dark:border-slate-800 pt-1.5">
        <span>Guess: <span class="coffer-user-guess font-mono text-[#7C3AED]">0</span></span>
        <span class="coffer-feedback-status text-[#7C3AED]">Correct ✓</span>
        <button class="btn-coffer-try-again bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[9px] px-2.5 py-1 rounded border-none transition-all cursor-pointer">
          Try Again 🔄
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes pulse-ring-coffer {
    0% { stroke-width: 2.5; opacity: 0.6; }
    50% { stroke-width: 4.5; opacity: 1; stroke: #a78bfa; }
    100% { stroke-width: 2.5; opacity: 0.6; }
  }
</style>

<script>
  function initCoffer() {
    const containers = document.querySelectorAll('.coffer-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const circlesGroup = container.querySelector('.coffer-circles-overlay') as HTMLElement;
      const input = container.querySelector('.input-coffer-guess') as HTMLInputElement;
      const btnCheck = container.querySelector('.btn-coffer-check');
      const btnReveal = container.querySelector('.btn-reveal-coffer');
      const btnReset = container.querySelector('.btn-coffer-try-again');
      const feedback = container.querySelector('.coffer-feedback-panel') as HTMLElement;
      const userGuessSpan = container.querySelector('.coffer-user-guess') as HTMLElement;
      const statusSpan = container.querySelector('.coffer-feedback-status') as HTMLElement;

      let circlesRevealed = false;

      // Toggle Manual Reveal
      btnReveal?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        circlesRevealed = !circlesRevealed;

        if (circlesRevealed) {
          circlesGroup.classList.remove('opacity-0');
          circlesGroup.classList.add('opacity-100');
          btnReveal.textContent = 'Hide Circles';
        } else {
          circlesGroup.classList.remove('opacity-100');
          circlesGroup.classList.add('opacity-0');
          btnReveal.textContent = 'Reveal';
        }
      });

      // Submit Guess
      btnCheck?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        const val = parseInt(input.value || '0');
        if (userGuessSpan) userGuessSpan.textContent = val.toString();
        
        feedback.classList.remove('hidden');
        
        // Show pulsing circles to prove truth
        circlesGroup.classList.remove('opacity-0');
        circlesGroup.classList.add('opacity-100');

        if (val === 16) {
          statusSpan.textContent = 'Correct! ✓';
          statusSpan.className = 'coffer-feedback-status font-bold text-emerald-600 font-mono text-[10px]';
        } else {
          statusSpan.textContent = 'Incorrect ✗ (There are 16 circles)';
          statusSpan.className = 'coffer-feedback-status font-bold text-rose-500 font-mono text-[10px]';
        }
      });

      // Reset
      btnReset?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        input.value = '';
        feedback.classList.add('hidden');
        circlesGroup.classList.remove('opacity-100');
        circlesGroup.classList.add('opacity-0');
        circlesRevealed = false;
        if (btnReveal) {
          btnReveal.textContent = 'Reveal';
        }
      });
    });
  }

  initCoffer();
  document.addEventListener('astro:page-load', initCoffer);
</script>
