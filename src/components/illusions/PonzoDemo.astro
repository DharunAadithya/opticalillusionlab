---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="ponzo-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-slate-900 rounded-xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[300px] md:min-h-[360px] p-6 pb-20">
    
    <!-- SVG Area -->
    <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible p-4" viewBox="0 0 200 200">
      <!-- Perspective Lines (Railroad tracks in neon indigo) -->
      <line x1="25" y1="180" x2="90" y2="20" stroke="#6366f1" stroke-width="4.5" stroke-linecap="round" />
      <line x1="175" y1="180" x2="110" y2="20" stroke="#6366f1" stroke-width="4.5" stroke-linecap="round" />
      
      <!-- Ties / Sleepers -->
      <line x1="32" y1="160" x2="168" y2="160" stroke="#475569" stroke-width="2.5" />
      <line x1="45" y1="130" x2="155" y2="130" stroke="#475569" stroke-width="2.5" />
      <line x1="58" y1="100" x2="142" y2="100" stroke="#475569" stroke-width="2.5" />
      <line x1="70" y1="75" x2="130" y2="75" stroke="#475569" stroke-width="2.5" />
      <line x1="82" y1="50" x2="118" y2="50" stroke="#475569" stroke-width="2.5" />

      <!-- Vertical guidelines (Reveal Truth) -->
      <line class="ponzo-guide opacity-0 transition-opacity duration-300" x1="75" y1="10" x2="75" y2="195" stroke="#a855f7" stroke-width="1.5" stroke-dasharray="4,4" />
      <line class="ponzo-guide opacity-0 transition-opacity duration-300" x1="125" y1="10" x2="125" y2="195" stroke="#a855f7" stroke-width="1.5" stroke-dasharray="4,4" />

      <!-- Bottom Bar (Fixed, Yellow #eab308) -->
      <rect class="ponzo-bar-bottom" x="75" y="142" width="50" height="8" fill="#eab308" rx="1.5" />
      
      <!-- Top Bar (Slideable, Yellow #eab308) -->
      <!-- Originally at y=60, slides down to y=142 -->
      <rect class="ponzo-bar-top transition-transform duration-300 ease-out" x="75" y="60" width="50" height="8" fill="#eab308" rx="1.5" />
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-2 w-11/12 px-4 flex flex-col gap-1 bg-slate-950/80 p-2 rounded-xl border border-white/5 shadow z-20">
      <div class="flex items-center justify-between">
        <button class="btn-toggle-ponzo text-[10px] font-bold px-2.5 py-1.5 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 transition-all">
          Show Guidelines
        </button>
      </div>

      <div class="flex items-center gap-2 w-full mt-1">
        <span class="text-[9px] text-slate-500 font-bold uppercase whitespace-nowrap">Slide Bar:</span>
        <input type="range" min="0" max="100" value="0" class="ponzo-slider w-full h-1 bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-600 focus:outline-none" />
      </div>
    </div>
  </div>
</div>

<script>
  function initPonzo() {
    const containers = document.querySelectorAll('.ponzo-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const guides = container.querySelectorAll('.ponzo-guide');
      const btnToggle = container.querySelector('.btn-toggle-ponzo');
      const barTop = container.querySelector('.ponzo-bar-top') as SVGElement;
      const slider = container.querySelector('.ponzo-slider') as HTMLInputElement;

      let guidesActive = false;

      // Toggle guidelines
      btnToggle?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        guidesActive = !guidesActive;

        guides.forEach(g => {
          if (guidesActive) {
            g.classList.remove('opacity-0');
            g.classList.add('opacity-100');
          } else {
            g.classList.remove('opacity-100');
            g.classList.add('opacity-0');
          }
        });

        if (btnToggle) {
          btnToggle.textContent = guidesActive ? 'Hide Guidelines' : 'Show Guidelines';
          btnToggle.classList.toggle('bg-purple-600', guidesActive);
          btnToggle.classList.toggle('text-white', guidesActive);
        }
      });

      // Handle slide
      slider?.addEventListener('input', (e) => {
        const val = parseFloat((e.target as HTMLInputElement).value); // 0 to 100
        // Top bar originally at y=60, bottom is at y=142. Difference is 82px.
        const dy = (val / 100) * 82;
        barTop.style.transform = `translateY(${dy}px)`;
      });
    });
  }

  initPonzo();
  document.addEventListener('astro:page-load', initPonzo);
</script>
