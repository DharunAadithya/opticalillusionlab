---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="penrose-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[380px] p-6 pb-20">
    
    <!-- SVG Area (300x300 px) -->
    <svg class="w-full max-w-[300px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 300 300">
      <defs>
        <!-- Subtle drop shadow filter -->
        <filter id="drop-shadow-penrose" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="2" dy="4" stdDeviation="4" flood-color="#000000" flood-opacity="0.25" />
        </filter>
      </defs>

      <!-- Faint isometric grid (Toggled via button) -->
      <g class="penrose-grid hidden stroke-slate-300 stroke-[0.5] opacity-40 pointer-events-none">
        <!-- Vertical grid lines -->
        <line x1="50" y1="0" x2="50" y2="300" />
        <line x1="100" y1="0" x2="100" y2="300" />
        <line x1="150" y1="0" x2="150" y2="300" />
        <line x1="200" y1="0" x2="200" y2="300" />
        <line x1="250" y1="0" x2="250" y2="300" />
        <!-- 30-degree slanted lines -->
        <line x1="0" y1="50" x2="300" y2="223.2" />
        <line x1="0" y1="100" x2="300" y2="273.2" />
        <line x1="0" y1="0" x2="300" y2="173.2" />
        <line x1="0" y1="150" x2="260" y2="300" />
        <line x1="0" y1="-50" x2="300" y2="123.2" />
        <line x1="0" y1="200" x2="173.2" y2="300" />
        <!-- 150-degree slanted lines -->
        <line x1="300" y1="50" x2="0" y2="223.2" />
        <line x1="300" y1="100" x2="0" y2="273.2" />
        <line x1="300" y1="0" x2="0" y2="173.2" />
        <line x1="300" y1="150" x2="40" y2="300" />
        <line x1="300" y1="-50" x2="0" y2="123.2" />
        <line x1="300" y1="200" x2="126.8" y2="300" />
      </g>

      <!-- Penrose Triangle Group with Drop Shadow -->
      <g class="penrose-g origin-center" transform="translate(150, 150) scale(1.1)" filter="url(#drop-shadow-penrose)">
        <!-- 
          Grayscale Scheme:
          - TOP faces: lightest gray #E0E0E0
          - LEFT faces: medium gray #A0A0A0
          - RIGHT faces: darkest gray #606060
        -->
        
        <!-- Limb 1 (Bottom bar) -->
        <!-- Left face (medium gray #A0A0A0) -->
        <polygon points="-30,92 30,58 90,-68 90,-34 30,92 -30,126" fill="#A0A0A0" />
        <!-- Top face (lightest gray #E0E0E0) -->
        <polygon points="30,92 90,58 30,24 -30,58" fill="#E0E0E0" />
        
        <!-- Limb 2 (Left bar) -->
        <!-- Left face (medium gray #A0A0A0) -->
        <polygon points="0,-120 30,-102 30,58 -30,92 -30,-68" fill="#A0A0A0" />
        <!-- Right face (darkest gray #606060) -->
        <polygon points="30,-102 90,-68 30,-34 -30,-68" fill="#606060" />
        
        <!-- Limb 3 (Right bar) -->
        <!-- Left face (medium gray #A0A0A0) -->
        <polygon points="-30,126 30,92 -90,-68 -90,-102 -30,-68 -30,126" fill="#A0A0A0" />
        <!-- Top face (lightest gray #E0E0E0) -->
        <polygon points="-30,-68 -90,-102 -30,-136 30,-102" fill="#E0E0E0" />
        
        <!-- Corner shading overlays to enhance 3D realism -->
        <polygon points="-30,-68 -30,-40 -50,-55" fill="rgba(0,0,0,0.15)" />
        <polygon points="30,58 30,30 50,45" fill="rgba(0,0,0,0.15)" />
        <polygon points="30,-102 10,-85 30,-75" fill="rgba(0,0,0,0.1)" />
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2 px-4 z-20">
      <button class="btn-toggle-grid bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-black px-4 py-2 rounded-lg border-none transition-colors shadow cursor-pointer">
        Show Grid
      </button>
    </div>
  </div>
</div>

<script>
  function initPenrose() {
    const containers = document.querySelectorAll('.penrose-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btnGrid = container.querySelector('.btn-toggle-grid');
      const grid = container.querySelector('.penrose-grid');

      let gridActive = false;

      btnGrid?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        gridActive = !gridActive;

        if (grid) {
          grid.classList.toggle('hidden', !gridActive);
        }
        if (btnGrid) {
          btnGrid.textContent = gridActive ? 'Hide Grid' : 'Show Grid';
        }
      });
    });
  }

  initPenrose();
  document.addEventListener('astro:page-load', initPenrose);
</script>
