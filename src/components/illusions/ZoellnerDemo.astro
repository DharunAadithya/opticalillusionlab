---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;

// Generate parallel lines at -45 degrees (slope = -1)
// Spaced to fill the entire 500x400 viewBox
const lineSpacing = 75; // spaced out nicely
const offsets = [];
for (let offset = -100; offset <= 900; offset += lineSpacing) {
  offsets.push(offset);
}

const lines = offsets.map((offset, idx) => {
  // Line formula: y = -x + offset
  const x1 = -50;
  const y1 = 50 + offset;
  const x2 = 550;
  const y2 = -550 + offset;
  
  // Cross hatch: alternating vertical (even index) and horizontal (odd index)
  // Spacing along the line: 25px intervals
  const hatches = [];
  for (let cx = -50; cx <= 550; cx += 28) {
    const cy = -cx + offset;
    
    // Check if the hatch center lies inside the viewBox (plus some bleed)
    if (cx >= -10 && cx <= 510 && cy >= -10 && cy <= 410) {
      const isVertical = idx % 2 === 0;
      if (isVertical) {
        // Vertical hatch: x stays cx, y varies
        hatches.push({
          x1: cx,
          y1: cy - 14,
          x2: cx,
          y2: cy + 14
        });
      } else {
        // Horizontal hatch: y stays cy, x varies
        hatches.push({
          x1: cx - 14,
          y1: cy,
          x2: cx + 14,
          y2: cy
        });
      }
    }
  }
  
  return { x1, y1, x2, y2, hatches };
});
---

<div class="zoellner-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[380px] p-0">
    
    <!-- SVG Area (500x400 px, White background, indigo lines) -->
    <svg class="w-full h-full min-h-[380px] select-none overflow-hidden" viewBox="0 0 500 400">
      <defs>
        <clipPath id="zoellner-viewport">
          <rect x="0" y="0" width="500" height="400" />
        </clipPath>
      </defs>

      <!-- Draw all elements clipped to the viewport -->
      <g clip-path="url(#zoellner-viewport)">
        <!-- Background fill: Pure White -->
        <rect x="0" y="0" width="500" height="400" fill="#FFFFFF" />

        <!-- Main Parallel Lines (4px stroke, color #312E81 - Indigo) -->
        <g class="zoellner-main-lines stroke-[#312E81] stroke-[5] stroke-linecap-round">
          {lines.map(line => (
            <line x1={line.x1} y1={line.y1} x2={line.x2} y2={line.y2} />
          ))}
        </g>

        <!-- Crossing Hatches Group (3px stroke, color #312E81, hidden on reveal) -->
        <g class="zoellner-hatches stroke-[#312E81] stroke-[3.5] stroke-linecap-round transition-opacity duration-300">
          {lines.map(line => 
            line.hatches.map(h => (
              <line x1={h.x1} y1={h.y1} x2={h.x2} y2={h.y2} />
            ))
          )}
        </g>

        <!-- Guide Lines: Parallel lines in red, shown on reveal, overlaying the main lines to prove alignment -->
        <g class="zoellner-guides hidden stroke-[#EF4444] stroke-[2] stroke-linecap-round stroke-dasharray-[6,4]">
          {lines.map(line => (
            <line x1={line.x1} y1={line.y1} x2={line.x2} y2={line.y2} />
          ))}
        </g>
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 z-20">
      <button class="btn-reveal-zoellner bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-black px-4 py-2 rounded-lg border-none transition-colors shadow cursor-pointer">
        Reveal Parallel Lines
      </button>
    </div>
  </div>

  <!-- Instructions -->
  <div class="mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center w-full max-w-md">
    <p class="text-xs text-slate-700 dark:text-slate-350 leading-relaxed">
      <strong>Instruction:</strong> Observe the long diagonal lines. Do they look tilted or non-parallel? Click "Reveal Parallel Lines" to overlay red guide lines and hide the cross-hatches, proving the lines are parallel.
    </p>
  </div>
</div>

<script>
  function initZoellner() {
    const containers = document.querySelectorAll('.zoellner-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btn = container.querySelector('.btn-reveal-zoellner');
      const hatches = container.querySelector('.zoellner-hatches') as HTMLElement;
      const guides = container.querySelector('.zoellner-guides') as HTMLElement;

      let isRevealed = false;

      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        isRevealed = !isRevealed;

        if (isRevealed) {
          if (hatches) hatches.style.opacity = '0';
          setTimeout(() => {
            if (isRevealed) hatches?.classList.add('hidden');
          }, 300);
          guides?.classList.remove('hidden');
          if (btn) btn.textContent = 'Reset Pattern';
        } else {
          hatches?.classList.remove('hidden');
          setTimeout(() => {
            if (!isRevealed) {
              if (hatches) hatches.style.opacity = '1';
            }
          }, 10);
          guides?.classList.add('hidden');
          if (btn) btn.textContent = 'Reveal Parallel Lines';
        }
      });
    });
  }

  initZoellner();
  document.addEventListener('astro:page-load', initZoellner);
</script>
