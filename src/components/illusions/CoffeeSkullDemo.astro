---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="coffeeskull-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-[#0C101A] rounded-2xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[380px] p-4 pb-20">
    
    <!-- High-Fidelity Coffee Foam Cup SVG -->
    <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 200 200">
      <defs>
        <!-- Gradients for coffee and froth -->
        <radialGradient id="coffee-base" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#4E2F1D" />
          <stop offset="70%" stop-color="#2D1A10" />
          <stop offset="100%" stop-color="#140B07" />
        </radialGradient>
        <linearGradient id="foam-color" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#FFFDF9" />
          <stop offset="50%" stop-color="#F5EBE6" />
          <stop offset="100%" stop-color="#E2D0C4" />
        </linearGradient>
        <filter id="foam-blur" x="-10%" y="-10%" width="120%" height="120%">
          <feGaussianBlur stdDeviation="1.5" />
        </filter>
        <filter id="glow-orange" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
      </defs>

      <!-- Coffee Cup Rim (Outer circle) -->
      <circle cx="100" cy="100" r="92" fill="#E2E8F0" stroke="#94A3B8" stroke-width="4" />
      <circle cx="100" cy="100" r="88" fill="#FFFFFF" stroke="#CBD5E1" stroke-width="2" />
      
      <!-- Inside Coffee Liquid -->
      <circle cx="100" cy="100" r="80" fill="url(#coffee-base)" />
      
      <!-- Coffee foam froth patterns (Forms the Skull shape) -->
      <!-- Outer dome foam (Skull top head) -->
      <path 
        d="M 40,90 
           C 40,40 160,40 160,90 
           C 160,110 155,120 145,135
           C 135,125 130,130 135,145
           C 132,150 128,155 125,160
           C 120,165 110,165 105,170
           C 95,170 85,165 80,160
           C 72,155 68,150 65,145
           C 70,130 65,125 55,135
           C 45,120 40,110 40,90 Z" 
        fill="url(#foam-color)" 
        opacity="0.88" 
        filter="url(#foam-blur)" 
      />

      <!-- Eye Sockets: Two dark brown circles (froth gaps representing saucers/cups inside) -->
      <circle cx="75" cy="90" r="16" fill="#2D1A10" stroke="#E2D0C4" stroke-width="1.5" filter="url(#foam-blur)" />
      <circle cx="125" cy="90" r="16" fill="#2D1A10" stroke="#E2D0C4" stroke-width="1.5" filter="url(#foam-blur)" />
      
      <!-- Eye shine highlights (little coffee bubbles) -->
      <circle cx="71" cy="86" r="2" fill="#EAD8C9" opacity="0.6" />
      <circle cx="121" cy="86" r="2" fill="#EAD8C9" opacity="0.6" />

      <!-- Nasal cavity gap (Heart/Leaf shape in center) -->
      <path d="M 100,114 Q 93,122 100,128 Q 107,122 100,114" fill="#2D1A10" filter="url(#foam-blur)" />

      <!-- Teeth lines (grooves in bottom froth) -->
      <g stroke="#2D1A10" stroke-width="2" stroke-linecap="round" opacity="0.75" filter="url(#foam-blur)">
        <line x1="88" y1="152" x2="88" y2="162" />
        <line x1="94" y1="152" x2="94" y2="164" />
        <line x1="100" y1="152" x2="100" y2="165" />
        <line x1="106" y1="152" x2="106" y2="164" />
        <line x1="112" y1="152" x2="112" y2="162" />
      </g>

      <!-- Shimmer/reflection on coffee surface -->
      <path d="M 35,45 Q 60,30 90,30" fill="none" stroke="#FFFDF9" stroke-width="1" opacity="0.3" stroke-linecap="round" />

      <!-- Highlights Overlay: Foam art (Blue) -->
      <g class="coffee-overlay-foam opacity-0 transition-opacity duration-300 pointer-events-none" filter="url(#glow-orange)">
        <circle cx="75" cy="90" r="19" fill="none" stroke="#3B82F6" stroke-width="3" />
        <circle cx="125" cy="90" r="19" fill="none" stroke="#3B82F6" stroke-width="3" />
        <text x="100" y="65" fill="#60A5FA" font-size="8" font-weight="900" text-anchor="middle">Latte Foam Art ☕</text>
      </g>

      <!-- Highlights Overlay: Skull shape (Red) -->
      <g class="coffee-overlay-skull opacity-0 transition-opacity duration-300 pointer-events-none" filter="url(#glow-orange)">
        <path 
          d="M 40,90 C 40,40 160,40 160,90 C 160,110 155,120 145,135 C 135,125 130,130 135,145 L 125,160 L 100,168 L 75,160 L 65,145 C 70,130 65,125 55,135 C 45,120 40,110 40,90 Z" 
          fill="none" 
          stroke="#EF4444" 
          stroke-width="3" 
        />
        <text x="100" y="25" fill="#F87171" font-size="9" font-weight="900" text-anchor="middle">Hidden Skull 💀</text>
      </g>
    </svg>

    <!-- Overlay Toggle Controls inside container -->
    <div class="absolute bottom-2 flex gap-2 z-20">
      <button class="btn-toggle-coffee-foam bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[9px] font-black px-3 py-1.5 rounded-lg border-none transition-colors cursor-pointer uppercase">Show Foam ☕</button>
      <button class="btn-toggle-coffee-skull bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[9px] font-black px-3 py-1.5 rounded-lg border-none transition-colors cursor-pointer uppercase">Show Skull 💀</button>
    </div>
  </div>
</div>

<script>
  function initCoffee() {
    const containers = document.querySelectorAll('.coffeeskull-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btnF = container.querySelector('.btn-toggle-coffee-foam');
      const btnS = container.querySelector('.btn-toggle-coffee-skull');
      const overlayF = container.querySelector('.coffee-overlay-foam');
      const overlayS = container.querySelector('.coffee-overlay-skull');

      let fActive = false;
      let sActive = false;

      btnF?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        fActive = !fActive;
        if (overlayF) {
          if (fActive) {
            overlayF.classList.replace('opacity-0', 'opacity-100');
            btnF.textContent = "Hide Foam ☕";
          } else {
            overlayF.classList.replace('opacity-100', 'opacity-0');
            btnF.textContent = "Show Foam ☕";
          }
        }
      });

      btnS?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        sActive = !sActive;
        if (overlayS) {
          if (sActive) {
            overlayS.classList.replace('opacity-0', 'opacity-100');
            btnS.textContent = "Hide Skull 💀";
          } else {
            overlayS.classList.replace('opacity-100', 'opacity-0');
            btnS.textContent = "Show Skull 💀";
          }
        }
      });
    });
  }

  initCoffee();
  document.addEventListener('astro:page-load', initCoffee);
</script>
