---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="mcgurk-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-slate-50 dark:bg-slate-100 rounded-xl overflow-hidden border border-slate-300 shadow-inner w-full min-h-[440px] p-6 pb-28">
    
    <!-- Blind screen for audio-only mode -->
    <div class="mcgurk-blind-screen absolute inset-0 bg-slate-950 flex flex-col items-center justify-center hidden z-10 transition-opacity duration-300">
      <span class="text-4xl animate-pulse">🙈</span>
      <span class="text-[10px] text-purple-400 font-bold mt-3 uppercase tracking-widest">Audio-Only Mode (Eyes Closed)</span>
      <p class="text-xs text-slate-400 mt-1 max-w-[200px] text-center">Listen carefully without looking. You should hear "BA" clearly.</p>
    </div>

    <!-- Realistic SVG Face Portrait (Anatomically correct, 3D gradient shading) -->
    <svg class="w-full max-w-[220px] h-auto aspect-[5/6] select-none overflow-visible p-2" viewBox="0 0 300 360">
      <defs>
        <!-- Skin Gradient for 3D depth -->
        <radialGradient id="skin-gradient-mcgurk" cx="50%" cy="40%" r="60%" fx="40%" fy="30%">
          <stop offset="0%" stop-color="#fff1f2" />
          <stop offset="60%" stop-color="#fed7aa" />
          <stop offset="100%" stop-color="#f59e0b" stop-opacity="0.9" />
        </radialGradient>
        <!-- Shadow Gradient under chin -->
        <linearGradient id="neck-gradient" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" stop-color="#d97706" />
          <stop offset="100%" stop-color="#b45309" />
        </linearGradient>
      </defs>

      <!-- Neck & Shoulders -->
      <path d="M 100,260 L 100,330 C 100,350 50,350 40,360 L 260,360 C 250,350 200,350 200,330 L 200,260 Z" fill="url(#neck-gradient)" />
      
      <!-- Ears -->
      <!-- Left Ear -->
      <path d="M 80,150 C 65,150 65,210 80,210 Z" fill="#f59e0b" stroke="#d97706" stroke-width="1" />
      <path d="M 80,165 C 72,165 72,195 80,195 Z" fill="#d97706" />
      <!-- Right Ear -->
      <path d="M 220,150 C 235,150 235,210 220,210 Z" fill="#f59e0b" stroke="#d97706" stroke-width="1" />
      <path d="M 220,165 C 228,165 228,195 220,195 Z" fill="#d97706" />

      <!-- Head Structure -->
      <path d="M 80,180 C 80,260 110,295 150,295 C 190,295 220,260 220,180 C 220,95 190,70 150,70 C 110,70 80,95 80,180 Z" fill="url(#skin-gradient-mcgurk)" stroke="#b45309" stroke-width="1" />

      <!-- Hair outline -->
      <path d="M 75,160 C 70,110 100,50 150,50 C 200,50 230,110 225,160 C 215,130 190,85 150,85 C 110,85 85,130 75,160 Z" fill="#111827" />

      <!-- Eyebrows -->
      <path d="M 98,122 Q 118,110 135,123" stroke="#111827" stroke-width="3" stroke-linecap="round" fill="none" />
      <path d="M 165,123 Q 182,110 202,122" stroke="#111827" stroke-width="3" stroke-linecap="round" fill="none" />

      <!-- Eyes -->
      <!-- Left Eye -->
      <path d="M 100,135 Q 117,124 134,135 Q 117,146 100,135 Z" fill="#ffffff" stroke="#1e293b" stroke-width="1.5" />
      <circle cx="117" cy="135" r="7.5" fill="#2563eb" /> <!-- Iris -->
      <circle cx="117" cy="135" r="4" fill="#09090b" /> <!-- Pupil -->
      <circle cx="119.5" cy="132.5" r="1.5" fill="#ffffff" /> <!-- Highlight -->
      <!-- Right Eye -->
      <path d="M 166,135 Q 183,124 200,135 Q 183,146 166,135 Z" fill="#ffffff" stroke="#1e293b" stroke-width="1.5" />
      <circle cx="183" cy="135" r="7.5" fill="#2563eb" /> <!-- Iris -->
      <circle cx="183" cy="135" r="4" fill="#09090b" /> <!-- Pupil -->
      <circle cx="185.5" cy="132.5" r="1.5" fill="#ffffff" /> <!-- Highlight -->

      <!-- Nose Bridge & Nostrils -->
      <path d="M 144,125 Q 146,180 137,208 Q 150,218 163,208 Q 154,180 156,125 Z" fill="#ea580c" opacity="0.12" />
      <path d="M 134,204 Q 138,211 144,208" stroke="#78350f" stroke-width="1.8" fill="none" stroke-linecap="round" />
      <path d="M 166,204 Q 162,211 156,208" stroke="#78350f" stroke-width="1.8" fill="none" stroke-linecap="round" />

      <!-- Oral Cavity & Teeth & Tongue inside Mouth -->
      <g class="mcgurk-mouth-group">
        <!-- Cavity background -->
        <path class="mc-cavity" d="M 110,240 Q 150,225 190,240 Q 150,255 110,240 Z" fill="#580512" stroke="none" />
        <!-- Upper Teeth -->
        <path class="mc-teeth" d="M 125,237 Q 150,234 175,237 L 173,243 Q 150,239 127,243 Z" fill="#ffffff" />
        <!-- Tongue -->
        <path class="mc-tongue opacity-0" d="M 132,253 Q 150,242 168,253 Q 150,263 132,253 Z" fill="#f87171" />
      </g>

      <!-- Upper Lip & Lower Lip (Mouth starts closed / "BA" lips-pressed shape) -->
      <!-- We animate the path points of these lips -->
      <path 
        class="mc-lip-upper transition-all duration-300" 
        d="M 110,240 Q 135,232 150,234 Q 165,232 190,240 Q 165,235 150,237 Q 135,235 110,240 Z" 
        fill="#dc2626" 
        stroke="#991b1b" 
        stroke-width="1.5" 
      />
      <path 
        class="mc-lip-lower transition-all duration-300" 
        d="M 110,240 Q 150,245 190,240 Q 150,243 110,240 Z" 
        fill="#f43f5e" 
        stroke="#dc2626" 
        stroke-width="1.5" 
      />
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-2 w-11/12 px-4 flex flex-col gap-1.5 bg-slate-900/90 py-2.5 rounded-xl border border-slate-800 z-20">
      
      <!-- Video / Audio Toggle Modes -->
      <div class="grid grid-cols-2 gap-2 w-full mb-1">
        <button data-mode="GA" class="btn-mcgurk-mode text-[9px] font-bold py-1.5 rounded-lg bg-purple-655 text-white border border-purple-500/20 shadow">
          Mouth says "GA" (Eyes Open)
        </button>
        <button data-mode="BLIND" class="btn-mcgurk-mode text-[9px] font-bold py-1.5 rounded-lg text-slate-400 bg-slate-800 hover:text-white border border-slate-700">
          Audio Only (Eyes Closed)
        </button>
      </div>

      <!-- Play Trigger -->
      <button class="btn-play-mcgurk w-full text-center font-bold text-[10px] py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white transition-all shadow flex items-center justify-center gap-1">
        <svg class="h-2.5 w-2.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <span>Play Sound</span>
      </button>
    </div>
  </div>

  <!-- Interactive Question & Voting (Type 2 Compliant) -->
  <div class="mcgurk-voting-panel w-full mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center max-w-md">
    <p class="text-xs font-bold text-slate-800 dark:text-white mb-2">
      Watch the mouth carefully. What vocal sound do you hear?
    </p>
    <div class="flex justify-center gap-2 mb-3">
      <button class="btn-mcgurk-vote bg-white dark:bg-slate-800 hover:bg-purple-650 text-slate-700 dark:text-slate-200 hover:text-white border border-slate-300 dark:border-slate-700 font-bold px-3 py-1.5 rounded-lg text-xs transition-all" data-vote="BA">BA</button>
      <button class="btn-mcgurk-vote bg-white dark:bg-slate-800 hover:bg-purple-650 text-slate-700 dark:text-slate-200 hover:text-white border border-slate-300 dark:border-slate-700 font-bold px-3 py-1.5 rounded-lg text-xs transition-all" data-vote="GA">GA</button>
      <button class="btn-mcgurk-vote bg-white dark:bg-slate-800 hover:bg-purple-650 text-slate-700 dark:text-slate-200 hover:text-white border border-slate-300 dark:border-slate-700 font-bold px-3 py-1.5 rounded-lg text-xs transition-all" data-vote="DA">DA</button>
      <button class="btn-mcgurk-vote bg-white dark:bg-slate-800 hover:bg-purple-650 text-slate-700 dark:text-slate-200 hover:text-white border border-slate-300 dark:border-slate-700 font-bold px-3 py-1.5 rounded-lg text-xs transition-all" data-vote="OTHER">Something Else</button>
    </div>
    
    <!-- Revealed Truth (Injected dynamically) -->
    <div class="mcgurk-reveal-box hidden p-3 bg-purple-500/10 border border-purple-500/20 rounded-lg text-xs text-left leading-relaxed text-slate-700 dark:text-slate-300">
      <strong>Revealed:</strong> The audio synthesizer plays a clear <strong class="text-purple-400">"BA"</strong> sound. However:
      <ul class="list-disc pl-4 mt-1 space-y-1">
        <li>When looking at the mouth executing a <strong class="text-purple-400">"GA"</strong> gesture, your brain merges the auditory "BA" and visual "GA" to hallucinate a third sound: <strong class="text-emerald-500">"DA"</strong>!</li>
        <li>Close your eyes (or click "Audio Only") and listen again. You will hear the exact same sound shift instantly back to a clean <strong class="text-emerald-500">"BA"</strong>!</li>
      </ul>
    </div>
  </div>
</div>

<script>
  function initMcGurk() {
    const containers = document.querySelectorAll('.mcgurk-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const blindScreen = container.querySelector('.mcgurk-blind-screen') as HTMLElement;
      const cavity = container.querySelector('.mc-cavity') as SVGPathElement;
      const lipUpper = container.querySelector('.mc-lip-upper') as SVGPathElement;
      const lipLower = container.querySelector('.mc-lip-lower') as SVGPathElement;
      const tongue = container.querySelector('.mc-tongue') as SVGPathElement;

      const modeBtns = container.querySelectorAll('.btn-mcgurk-mode');
      const btnPlay = container.querySelector('.btn-play-mcgurk');
      const voteBtns = container.querySelectorAll('.btn-mcgurk-vote');
      const revealBox = container.querySelector('.mcgurk-reveal-box');

      let currentMode = 'GA'; // Default is mouth says "GA"

      // Mode Selector Toggle
      modeBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();

          const mode = btn.getAttribute('data-mode') || 'GA';
          currentMode = mode;

          modeBtns.forEach(b => {
            b.className = 'btn-mcgurk-mode text-[9px] font-bold py-1.5 rounded-lg text-slate-400 bg-slate-800 hover:text-white border border-slate-700';
          });
          btn.className = 'btn-mcgurk-mode text-[9px] font-bold py-1.5 rounded-lg bg-purple-650 text-white border border-purple-500/20 shadow';

          if (mode === 'BLIND') {
            blindScreen?.classList.remove('hidden');
          } else {
            blindScreen?.classList.add('hidden');
          }
        });
      });

      // Vote Selector Trigger Reveal
      voteBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();

          voteBtns.forEach(b => {
            b.classList.remove('bg-purple-650', 'text-white');
            b.classList.add('bg-white', 'dark:bg-slate-800', 'text-slate-700', 'dark:text-slate-200');
          });

          btn.classList.remove('bg-white', 'dark:bg-slate-800', 'text-slate-700', 'dark:text-slate-200');
          btn.classList.add('bg-purple-650', 'text-white');

          revealBox?.classList.remove('hidden');
        });
      });

      // Web Audio API Formant Synthesizer for "BA"
      // Noise burst (B plosive release) + Voiced glottal formants (A vowel)
      function playBA() {
        try {
          const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
          const playTime = audioCtx.currentTime;

          // 1. Noise Burst for the B plosive consonant
          const noiseLength = 0.025; // 25ms
          const noiseBuffer = audioCtx.createBuffer(1, audioCtx.sampleRate * noiseLength, audioCtx.sampleRate);
          const noiseData = noiseBuffer.getChannelData(0);
          for (let i = 0; i < noiseData.length; i++) {
            noiseData[i] = Math.random() * 2 - 1;
          }
          
          const noiseNode = audioCtx.createBufferSource();
          noiseNode.buffer = noiseBuffer;

          const noiseFilter = audioCtx.createBiquadFilter();
          noiseFilter.type = 'bandpass';
          noiseFilter.frequency.value = 400; // Low frequency release burst
          noiseFilter.Q.value = 2;

          const noiseGain = audioCtx.createGain();
          noiseGain.gain.setValueAtTime(0.35, playTime);
          noiseGain.gain.exponentialRampToValueAtTime(0.001, playTime + noiseLength);

          noiseNode.connect(noiseFilter);
          noiseFilter.connect(noiseGain);
          noiseGain.connect(audioCtx.destination);

          // 2. Sawtooth Voiced source for vowel "A"
          const osc = audioCtx.createOscillator();
          osc.type = 'sawtooth';
          
          // Pitch drops slightly like natural speech
          osc.frequency.setValueAtTime(140, playTime + 0.01);
          osc.frequency.exponentialRampToValueAtTime(95, playTime + 0.28);

          // Formant Filter 1 (F1 for A: ~730Hz)
          const f1 = audioCtx.createBiquadFilter();
          f1.type = 'bandpass';
          f1.frequency.setValueAtTime(730, playTime);
          f1.Q.setValueAtTime(8, playTime);

          // Formant Filter 2 (F2 for A: ~1200Hz)
          const f2 = audioCtx.createBiquadFilter();
          f2.type = 'bandpass';
          f2.frequency.setValueAtTime(1220, playTime);
          f2.Q.setValueAtTime(6, playTime);

          const voicedGain = audioCtx.createGain();
          // Delayed start for plosive release
          voicedGain.gain.setValueAtTime(0, playTime);
          voicedGain.gain.linearRampToValueAtTime(0.7, playTime + 0.04);
          voicedGain.gain.exponentialRampToValueAtTime(0.001, playTime + 0.28);

          osc.connect(f1);
          osc.connect(f2);
          f1.connect(voicedGain);
          f2.connect(voicedGain);
          voicedGain.connect(audioCtx.destination);

          noiseNode.start(playTime);
          osc.start(playTime + 0.01);
          osc.stop(playTime + 0.3);
        } catch (err) {
          console.error("McGurk audio synth failed: ", err);
        }
      }

      // Mouth movements
      function executeMouthMorphism(mode: string) {
        if (!cavity || !lipUpper || !lipLower || !tongue) return;

        if (mode === 'GA') {
          // Animate a throat open "GA" mouth movement (lips open, tongue visible, jaw drops)
          // Default Upper Lip: M 110,240 Q 135,232 150,234 Q 165,232 190,240 Q 165,235 150,237 Q 135,235 110,240 Z
          // Default Lower Lip: M 110,240 Q 150,245 190,240 Q 150,243 110,240 Z
          
          // Move 1: Drop jaw wide
          cavity.setAttribute('d', 'M 110,240 Q 150,200 190,240 Q 150,285 110,240 Z');
          lipUpper.setAttribute('d', 'M 110,240 Q 135,212 150,215 Q 165,212 190,240 Q 165,223 150,225 Q 135,223 110,240 Z');
          lipLower.setAttribute('d', 'M 110,240 Q 150,285 190,240 Q 150,250 110,240 Z');
          tongue.classList.remove('opacity-0');

          setTimeout(() => {
            // Move 2: Return to closed mouth rest state
            cavity.setAttribute('d', 'M 110,240 Q 150,225 190,240 Q 150,255 110,240 Z');
            lipUpper.setAttribute('d', 'M 110,240 Q 135,232 150,234 Q 165,232 190,240 Q 165,235 150,237 Q 135,235 110,240 Z');
            lipLower.setAttribute('d', 'M 110,240 Q 150,245 190,240 Q 150,243 110,240 Z');
            tongue.classList.add('opacity-0');
          }, 350);
        } else {
          // Audio only mode - just press lips together representing "BA" consonant release
          lipUpper.setAttribute('d', 'M 110,240 Q 135,238 150,239 Q 165,238 190,240 Q 165,239 150,239 Z');
          lipLower.setAttribute('d', 'M 110,240 Q 150,241 190,240 Q 150,241 110,240 Z');
          
          setTimeout(() => {
            // Open slightly
            cavity.setAttribute('d', 'M 110,240 Q 150,225 190,240 Q 150,255 110,240 Z');
            lipUpper.setAttribute('d', 'M 110,240 Q 135,225 150,228 Q 165,225 190,240 Q 165,232 150,234 Q 135,232 110,240 Z');
            lipLower.setAttribute('d', 'M 110,240 Q 150,252 190,240 Q 150,245 110,240 Z');
          }, 40);

          setTimeout(() => {
            // Close
            cavity.setAttribute('d', 'M 110,240 Q 150,225 190,240 Q 150,255 110,240 Z');
            lipUpper.setAttribute('d', 'M 110,240 Q 135,232 150,234 Q 165,232 190,240 Q 165,235 150,237 Q 135,235 110,240 Z');
            lipLower.setAttribute('d', 'M 110,240 Q 150,245 190,240 Q 150,243 110,240 Z');
          }, 350);
        }
      }

      btnPlay?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        playBA();
        executeMouthMorphism(currentMode);
      });
    });
  }

  initMcGurk();
  document.addEventListener('astro:page-load', initMcGurk);
</script>
