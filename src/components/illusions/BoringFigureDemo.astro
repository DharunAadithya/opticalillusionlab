---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="boringfigure-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-[#0d1527] rounded-2xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[380px] p-4 pb-20">
    
    <!-- High-Fidelity SVG Viewbox 0 0 200 200 -->
    <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 200 200">
      <defs>
        <!-- Shading gradients -->
        <linearGradient id="hat-grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#4F46E5" />
          <stop offset="100%" stop-color="#312E81" />
        </linearGradient>
        <linearGradient id="skin-grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#FFFFFF" />
          <stop offset="100%" stop-color="#E2E8F0" />
        </linearGradient>
        <filter id="glow-filter" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
      </defs>

      <!-- Draw Hat & Hair (top curve of skull? No, hat of woman) -->
      <path d="M 40,55 C 40,25 150,15 160,50 C 165,70 170,110 145,135 Z" fill="url(#hat-grad)" stroke="#1E1B4B" stroke-width="2" />
      
      <!-- Elegant feather on hat -->
      <path d="M 125,50 Q 145,10 125,2 C 105,10 120,40 125,50 Z" fill="#F1F5F9" stroke="#94A3B8" stroke-width="1" />

      <!-- Back hair (draping down) -->
      <path d="M 145,135 Q 165,160 145,185 L 125,185 Q 140,160 135,135 Z" fill="#1E293B" />

      <!-- Face Silhouette (Grayscale / skin shading) -->
      <!-- Profile contour: nose, cheek, eye lash, ear, neck -->
      <path d="M 85,50 
               C 65,70 70,100 80,105
               C 85,107 88,110 83,115
               C 88,125 84,135 88,142
               C 92,150 96,155 105,165
               C 125,185 140,185 145,185
               L 145,135
               C 135,120 125,80 125,50 Z" 
        fill="url(#skin-grad)" 
        stroke="#1E293B" 
        stroke-width="1.5" 
      />

      <!-- Choker neckband (Young woman choker / old woman mouth) -->
      <path d="M 98,148 Q 110,150 122,146" fill="none" stroke="#EF4444" stroke-width="3" stroke-linecap="round" />

      <!-- Ear / Eye (Young woman ear / old woman eye) -->
      <!-- It is positioned at (110, 110) -->
      <path d="M 109,106 C 105,103 103,107 105,112 C 107,115 112,113 110,108 Z" fill="#FFFFFF" stroke="#1E293B" stroke-width="1.5" />
      <circle cx="108.5" cy="109.5" r="1.5" fill="#1E293B" />

      <!-- Eyelash / Wrinkle (Young woman eyelash / old woman nose fold) -->
      <path d="M 81,95 Q 77,98 73,101" fill="none" stroke="#1E293B" stroke-width="1.5" stroke-linecap="round" />

      <!-- Fur Collar (bottom drapery) -->
      <path d="M 80,175 C 100,195 150,195 170,175 C 180,160 185,140 180,125 L 145,135 C 135,160 100,165 80,175 Z" fill="#475569" stroke="#1E293B" stroke-width="1.5" />

      <!-- Young Woman Highlights Overlay -->
      <g class="boring-overlay-young opacity-0 transition-opacity duration-300 pointer-events-none" filter="url(#glow-filter)">
        <!-- Highlight young ear and choker -->
        <circle cx="108" cy="110" r="10" fill="none" stroke="#3B82F6" stroke-width="2.5" />
        <path d="M 98,148 Q 110,150 122,146" fill="none" stroke="#3B82F6" stroke-width="4.5" stroke-linecap="round" />
        <text x="140" y="98" fill="#60A5FA" font-size="8" font-weight="900">Young Ear 👱‍♀️</text>
        <text x="140" y="160" fill="#60A5FA" font-size="8" font-weight="900">Necklace 📿</text>
      </g>

      <!-- Old Woman Highlights Overlay -->
      <g class="boring-overlay-old opacity-0 transition-opacity duration-300 pointer-events-none" filter="url(#glow-filter)">
        <!-- Highlight old nose and eye -->
        <path d="M 85,50 C 65,70 70,100 80,105 C 85,107 88,110 83,115" fill="none" stroke="#EF4444" stroke-width="3" />
        <circle cx="108" cy="110" r="4" fill="#EF4444" />
        <text x="40" y="92" fill="#F87171" font-size="8" font-weight="900">Old Nose 👵</text>
        <text x="125" y="122" fill="#F87171" font-size="8" font-weight="900">Old Eye 👁️</text>
      </g>
    </svg>

    <!-- Overlay Toggle Controls inside container -->
    <div class="absolute bottom-2 flex gap-2 z-20">
      <button class="btn-toggle-boring-young bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[9px] font-black px-3 py-1.5 rounded-lg border-none transition-colors cursor-pointer uppercase">Show Young 👱‍♀️</button>
      <button class="btn-toggle-boring-old bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[9px] font-black px-3 py-1.5 rounded-lg border-none transition-colors cursor-pointer uppercase">Show Old 👵</button>
    </div>
  </div>
</div>

<script>
  function initBoring() {
    const containers = document.querySelectorAll('.boringfigure-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btnY = container.querySelector('.btn-toggle-boring-young');
      const btnO = container.querySelector('.btn-toggle-boring-old');
      const overlayY = container.querySelector('.boring-overlay-young');
      const overlayO = container.querySelector('.boring-overlay-old');

      let yActive = false;
      let oActive = false;

      btnY?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        yActive = !yActive;
        if (overlayY) {
          if (yActive) {
            overlayY.classList.replace('opacity-0', 'opacity-100');
            btnY.textContent = "Hide Young 👱‍♀️";
            // Hide old if active
            if (oActive && btnO && overlayO) {
              oActive = false;
              overlayO.classList.replace('opacity-100', 'opacity-0');
              btnO.textContent = "Show Old 👵";
            }
          } else {
            overlayY.classList.replace('opacity-100', 'opacity-0');
            btnY.textContent = "Show Young 👱‍♀️";
          }
        }
      });

      btnO?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        oActive = !oActive;
        if (overlayO) {
          if (oActive) {
            overlayO.classList.replace('opacity-0', 'opacity-100');
            btnO.textContent = "Hide Old 👵";
            // Hide young if active
            if (yActive && btnY && overlayY) {
              yActive = false;
              overlayY.classList.replace('opacity-100', 'opacity-0');
              btnY.textContent = "Show Young 👱‍♀️";
            }
          } else {
            overlayO.classList.replace('opacity-100', 'opacity-0');
            btnO.textContent = "Show Old 👵";
          }
        }
      });
    });
  }

  initBoring();
  document.addEventListener('astro:page-load', initBoring);
</script>
