---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="kanizsa-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[380px] p-6 pb-20">
    
    <!-- SVG Area (Exactly 400x320) -->
    <svg class="w-full max-w-[360px] h-auto aspect-[5/4] select-none overflow-visible rounded-lg" viewBox="0 0 400 320">
      <!-- Background: Solid White -->
      <rect x="0" y="0" width="400" height="320" fill="#FFFFFF" />

      <!-- Three Pac-Man shapes at the corners of an implied upward-pointing equilateral triangle -->
      <!-- Top Corner: (200, 60) - Notch points down (90 deg) -->
      <g transform="translate(200, 60)">
        <path 
          class="pacman-shape fill-[#000000] transition-transform duration-500 ease-out" 
          d="M 0,0 L 38.971,-22.5 A 45,45 0 1,1 38.971,22.5 Z" 
          transform="rotate(90)"
          data-base-rot="90"
        />
      </g>

      <!-- Bottom-Left Corner: (100, 233.2) - Notch points up-right (-30 deg) -->
      <g transform="translate(100, 233.2)">
        <path 
          class="pacman-shape fill-[#000000] transition-transform duration-500 ease-out" 
          d="M 0,0 L 38.971,-22.5 A 45,45 0 1,1 38.971,22.5 Z" 
          transform="rotate(-30)"
          data-base-rot="-30"
        />
      </g>

      <!-- Bottom-Right Corner: (300, 233.2) - Notch points up-left (-150 deg) -->
      <g transform="translate(300, 233.2)">
        <path 
          class="pacman-shape fill-[#000000] transition-transform duration-500 ease-out" 
          d="M 0,0 L 38.971,-22.5 A 45,45 0 1,1 38.971,22.5 Z" 
          transform="rotate(-150)"
          data-base-rot="-150"
        />
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2 px-4 z-20">
      <button class="btn-rotate-pacmen bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-black px-4 py-2 rounded-lg border-none transition-colors shadow cursor-pointer">
        Rotate Pac-Men
      </button>
    </div>
  </div>

  <!-- Instructions -->
  <div class="mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center w-full max-w-md">
    <p class="text-xs text-slate-755 dark:text-slate-300 leading-relaxed">
      <strong>Instruction:</strong> Click "Rotate Pac-Men" to rotate their mouths 45° away. Notice how the illusory white triangle completely vanishes when the notches are misaligned.
    </p>
  </div>
</div>

<script>
  function initKanizsa() {
    const containers = document.querySelectorAll('.kanizsa-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btn = container.querySelector('.btn-rotate-pacmen');
      const pacmen = container.querySelectorAll('.pacman-shape');

      let isRotated = false;

      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        isRotated = !isRotated;

        pacmen.forEach(el => {
          const baseRot = parseInt(el.getAttribute('data-base-rot') || '0');
          const newRot = isRotated ? baseRot + 45 : baseRot;
          el.setAttribute('transform', `rotate(${newRot})`);
        });

        if (btn) {
          btn.textContent = isRotated ? 'Align Pac-Men' : 'Rotate Pac-Men';
        }
      });
    });
  }

  initKanizsa();
  document.addEventListener('astro:page-load', initKanizsa);
</script>
