---
// src/components/illusions/RotatingSnakesDemo.astro
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="snakes-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[380px] p-6 pb-28">
    
    <!-- SVG Area (Exactly 584x444 px) -->
    <svg 
      class="snakes-svg w-full max-w-[500px] h-auto aspect-[584/444] select-none overflow-visible rounded-lg" 
      viewBox="0 0 584 444"
      width="584"
      height="444"
      style="background: #ffffff;"
    >
      <!-- Group where JS will inject the paths and center dots -->
      <g class="snakes-content-group"></g>

      <!-- Stabilization Grid Overlay (2px black grid lines, hidden by default) -->
      <g class="snakes-grid-overlay hidden pointer-events-none">
        <!-- Vertical grid lines -->
        <line x1="152" y1="0" x2="152" y2="444" stroke="#000000" stroke-width="2" />
        <line x1="300" y1="0" x2="300" y2="444" stroke="#000000" stroke-width="2" />
        <line x1="448" y1="0" x2="448" y2="444" stroke="#000000" stroke-width="2" />
        <!-- Horizontal grid lines -->
        <line x1="0" y1="152" x2="584" y2="152" stroke="#000000" stroke-width="2" />
        <line x1="0" y1="300" x2="584" y2="300" stroke="#000000" stroke-width="2" />
      </g>
    </svg>

    <!-- Info text note -->
    {!isCard && (
      <p class="absolute bottom-16 text-[11px] text-red-650 font-bold text-center px-4">
        ⚠ 100% static image. Zero animation. All motion is in your visual cortex.
      </p>
    )}

    <!-- Controls Panel -->
    {!isCard && (
      <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2 px-4 z-20">
        <button class="btn-toggle-grid bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[11px] font-bold px-5 py-2.5 rounded-lg border-none transition-colors shadow cursor-pointer">
          Show Grid
        </button>
      </div>
    )}
  </div>
</div>

<script>
  function initRotatingSnakes() {
    const containers = document.querySelectorAll('.snakes-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const contentGroup = container.querySelector('.snakes-content-group');
      if (!contentGroup) return;

      const cols = 4, rows = 3, D = 140, gap = 8;
      const CW_COLORS  = [...Array(3).fill('#000000'),
                          ...Array(3).fill('#606060'),
                          ...Array(3).fill('#ffffff'),
                          ...Array(3).fill('#b0b0b0')];
      const CCW_COLORS = [...CW_COLORS].reverse();
      const RINGS = [{ro:70,ri:55},{ro:55,ri:40},{ro:40,ri:25},{ro:25,ri:12}];

      function wedge(cx: number, cy: number, ro: number, ri: number, a1: number, a2: number){
        const r=Math.PI/180;
        const cos1=Math.cos(a1*r),sin1=Math.sin(a1*r);
        const cos2=Math.cos(a2*r),sin2=Math.sin(a2*r);
        const lg=(a2-a1)>180?1:0;
        return [
          `M${cx+ro*cos1},${cy+ro*sin1}`,
          `A${ro},${ro} 0 ${lg} 1 ${cx+ro*cos2},${cy+ro*sin2}`,
          `L${cx+ri*cos2},${cy+ri*sin2}`,
          `A${ri},${ri} 0 ${lg} 0 ${cx+ri*cos1},${cy+ri*sin1}`,
          'Z'
        ].join(' ');
      }

      let html = '';
      for(let row=0;row<rows;row++){
        for(let col=0;col<cols;col++){
          const cx = gap + D/2 + col*(D+gap);
          const cy = gap + D/2 + row*(D+gap);
          const isAlt = (col+row)%2===1;
          for(let ri=0;ri<4;ri++){
            const {ro,ri:rin}=RINGS[ri];
            const isCW = (ri%2===0) !== isAlt;
            const colors = isCW ? CW_COLORS : CCW_COLORS;
            for(let seg=0;seg<12;seg++){
              const a1=seg*30, a2=(seg+1)*30;
              const segs = isCW ? seg : (11-seg);
              const color = colors[segs];
              html += `<path d="${wedge(cx,cy,ro,rin,a1,a2)}" fill="${color}" stroke="none"/>`;
            }
          }
          // Center black dot
          html += `<circle cx="${cx}" cy="${cy}" r="10" fill="#000000"/>`;
          html += `<circle cx="${cx}" cy="${cy}" r="4" fill="#ffffff"/>`;
        }
      }
      contentGroup.innerHTML = html;

      // Handle Grid Toggle
      const btn = container.querySelector('.btn-toggle-grid');
      const gridOverlay = container.querySelector('.snakes-grid-overlay');
      let gridActive = false;

      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        gridActive = !gridActive;
        gridOverlay?.classList.toggle('hidden', !gridActive);
        if (btn) btn.textContent = gridActive ? 'Hide Grid' : 'Show Grid';
      });
    });
  }

  initRotatingSnakes();
  document.addEventListener('astro:page-load', initRotatingSnakes);
</script>
