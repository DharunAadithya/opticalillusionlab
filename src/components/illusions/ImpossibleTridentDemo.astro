---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="trident-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[300px] p-6 pb-20">
    
    <!-- SVG Area (426x240 px, Horizontal Blivet) -->
    <svg class="w-full max-w-[420px] h-auto aspect-[426/240] select-none overflow-visible" viewBox="0 0 426 240">
      <defs>
        <!-- Premium drop shadow for the trident -->
        <filter id="trident-shadow" x="-5%" y="-5%" width="110%" height="110%">
          <feDropShadow dx="2" dy="4" stdDeviation="4" flood-color="#1e1b4b" flood-opacity="0.15" />
        </filter>
        
        <!-- Soft gradient for the cylinders -->
        <linearGradient id="blivet-gradient" x1="0" y1="1" x2="0" y2="0">
          <stop offset="0%" stop-color="#E2E8F0" />
          <stop offset="50%" stop-color="#F8FAFC" />
          <stop offset="100%" stop-color="#CBD5E1" />
        </linearGradient>
      </defs>

      <g filter="url(#trident-shadow)" transform="translate(15, 210) scale(0.08, -0.08)">
        <!-- 1. Fill areas -->
        <!-- Cylinder 1, 2, 3 fills -->
        <path 
          fill="url(#blivet-gradient)"
          stroke="none"
          d="M474.343,689.423
            C474.343,759.49,444.077,800,400,800
            C381.941,800,361.564,793.2,340,778.846
            C265.804,729.459,205.657,609.351,205.657,510.577
            C205.657,440.51,235.923,400,280,400
            C298.059,400,318.436,406.8,340,421.154
            C414.196,470.541,474.343,590.649,474.343,689.423Z
            M474.343,1489.423
            C474.343,1559.49,444.077,1600,400,1600
            C381.941,1600,361.564,1593.2,340,1578.846
            C265.804,1529.459,205.657,1409.351,205.657,1310.577
            C205.657,1240.51,235.923,1200,280,1200
            C298.059,1200,318.436,1206.8,340,1221.154
            C414.196,1270.541,474.343,1390.649,474.343,1489.423Z
            M474.343,2289.423
            C474.343,2359.49,444.077,2400,400,2400
            C381.941,2400,361.564,2393.2,340,2378.846
            C265.804,2329.459,205.657,2209.351,205.657,2110.577
            C205.657,2040.51,235.923,2000,280,2000
            C298.059,2000,318.436,2006.8,340,2021.154
            C414.196,2070.541,474.343,2190.649,474.343,2289.423Z"
        />
        <path fill="url(#blivet-gradient)" stroke="none" d="M4400,2000V1200H4200V1600Z" />
        
        <!-- Big rectangular background body block for left side -->
        <path fill="url(#blivet-gradient)" stroke="none" d="M280,2000 H400 V2400 H280 Z" />
        <path fill="url(#blivet-gradient)" stroke="none" d="M280,1200 H400 V1600 H280 Z" />
        <path fill="url(#blivet-gradient)" stroke="none" d="M280,400 H4800 L5000,800 H400 L280,400 Z" />

        <!-- 2. Outline strokes (Matte Dark Blue) -->
        <g stroke="#1E1B4B" stroke-width="46" stroke-linejoin="round" stroke-linecap="round" fill="none">
          <path d="M400,2400H5000V800L4800,400H280" />
          <path d="M280,2000H4400V1200H280" />
          <path d="M4400,2000L4200,1600V1200" />
          <path d="M5000,800H400" />
          <path d="M4200,1600H400" />
        </g>
      </g>

      <!-- 3. Colored Tracing Paths (Toggled on click, coordinates matching transform) -->
      <g transform="translate(15, 210) scale(0.08, -0.08)" fill="none" stroke-width="60" stroke-linecap="round" stroke-linejoin="round" class="trident-traces hidden">
        <!-- Outer Outer loop (Red) -->
        <path class="stroke-rose-500 stroke-dasharray-[80,60]" d="M400,2400H5000V800L4800,400H280" />
        <!-- Middle prong split (Green) -->
        <path class="stroke-emerald-500 stroke-dasharray-[80,60]" d="M280,2000H4400V1200H280" />
        <!-- Impossible corner morph (Blue) -->
        <path class="stroke-blue-500 stroke-dasharray-[80,60]" d="M4400,2000L4200,1600V1200" />
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-2 left-0 right-0 flex justify-center gap-2 px-4 z-20">
      <button class="btn-trace-trident bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[11px] font-bold px-5 py-2.5 rounded-lg border-none transition-colors shadow-sm cursor-pointer">
        Trace Paths
      </button>
    </div>
  </div>

  <!-- Instructions -->
  <div class="mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center w-full max-w-md">
    <p class="text-xs text-slate-700 dark:text-slate-350 leading-relaxed">
      <strong>Instruction:</strong> Look at the flat prongs on the left versus the cylindrical prongs on the right. Click "Trace Paths" to highlight the continuous outlines and see how the columns impossibly shift columns!
    </p>
  </div>
</div>

<script>
  function initTrident() {
    const containers = document.querySelectorAll('.trident-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btnTrace = container.querySelector('.btn-trace-trident');
      const tracesGroup = container.querySelector('.trident-traces');

      let traceActive = false;

      btnTrace?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        traceActive = !traceActive;

        if (tracesGroup) {
          if (traceActive) {
            tracesGroup.classList.remove('hidden');
          } else {
            tracesGroup.classList.add('hidden');
          }
        }

        if (btnTrace) {
          btnTrace.textContent = traceActive ? 'Hide Traces' : 'Trace Paths';
        }
      });
    });
  }

  initTrident();
  document.addEventListener('astro:page-load', initTrident);
</script>
