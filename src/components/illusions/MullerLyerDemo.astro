---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="muller-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-slate-150 dark:bg-slate-950/20 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-inner w-full min-h-[300px] md:min-h-[360px] p-6 pb-16">
    
    <!-- SVG Area -->
    <svg class="w-full max-w-[280px] h-auto aspect-square select-none overflow-visible rounded-lg shadow-md border border-slate-200 dark:border-slate-850 bg-white dark:bg-slate-950 p-4" viewBox="0 0 200 200">
      <!-- Measurement Guidelines -->
      <line class="muller-guide opacity-0 transition-opacity duration-300" x1="40" y1="20" x2="40" y2="180" stroke="#f43f5e" stroke-width="1.5" stroke-dasharray="3,3" />
      <line class="muller-guide opacity-0 transition-opacity duration-300" x1="160" y1="20" x2="160" y2="180" stroke="#f43f5e" stroke-width="1.5" stroke-dasharray="3,3" />

      <!-- Top Line: Fixed inward-facing arrows (makes it look shorter) -->
      <g class="muller-line-group text-[#3b82f6]">
        <line x1="40" y1="65" x2="160" y2="65" stroke="currentColor" stroke-width="3.5" />
        <!-- Left fins -->
        <line x1="40" y1="65" x2="55" y2="50" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
        <line x1="40" y1="65" x2="55" y2="80" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
        <!-- Right fins -->
        <line x1="160" y1="65" x2="145" y2="50" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
        <line x1="160" y1="65" x2="145" y2="80" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
      </g>

      <!-- Bottom Line: Morphing/Slider-adjusted arrows -->
      <g class="muller-line-group text-[#3b82f6]">
        <line x1="40" y1="125" x2="160" y2="125" stroke="currentColor" stroke-width="3.5" />
        <!-- Left morphing fins (dynamic paths changed by script) -->
        <line class="fin-l1" x1="40" y1="125" x2="25" y2="110" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
        <line class="fin-l2" x1="40" y1="125" x2="25" y2="140" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
        <!-- Right morphing fins -->
        <line class="fin-r1" x1="160" y1="125" x2="175" y2="110" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
        <line class="fin-r2" x1="160" y1="125" x2="175" y2="140" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" />
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-2 w-11/12 px-4 flex flex-col items-center gap-1.5 z-20">
      <div class="flex w-full items-center justify-between">
        <button class="btn-toggle-guides text-[10px] font-bold px-2.5 py-1.5 rounded-lg border border-slate-300 dark:border-slate-700 bg-white/95 dark:bg-slate-900/90 text-slate-700 dark:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 shadow-sm transition-all">
          Show Measurement Rules
        </button>
      </div>

      <div class="flex items-center gap-2 w-full">
        <span class="text-[9px] text-slate-500 font-bold uppercase whitespace-nowrap">Fins Angle:</span>
        <input type="range" min="-1" max="1" step="0.1" value="1" class="muller-slider w-full h-1 bg-slate-250 dark:bg-slate-800 rounded-lg appearance-none cursor-pointer accent-purple-600 focus:outline-none" />
      </div>
    </div>
  </div>
</div>

<script>
  function initMuller() {
    const containers = document.querySelectorAll('.muller-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const guides = container.querySelectorAll('.muller-guide');
      const btnGuides = container.querySelector('.btn-toggle-guides');
      const slider = container.querySelector('.muller-slider') as HTMLInputElement;

      const finL1 = container.querySelector('.fin-l1') as SVGLineElement;
      const finL2 = container.querySelector('.fin-l2') as SVGLineElement;
      const finR1 = container.querySelector('.fin-r1') as SVGLineElement;
      const finR2 = container.querySelector('.fin-r2') as SVGLineElement;

      let guidesActive = false;

      // Toggle rules
      btnGuides?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        guidesActive = !guidesActive;

        guides.forEach(g => {
          if (guidesActive) {
            g.classList.remove('opacity-0');
            g.classList.add('opacity-100');
          } else {
            g.classList.remove('opacity-100');
            g.classList.add('opacity-0');
          }
        });

        if (btnGuides) {
          btnGuides.textContent = guidesActive ? 'Hide Measurement Rules' : 'Show Measurement Rules';
          btnGuides.classList.toggle('bg-purple-600', guidesActive);
          btnGuides.classList.toggle('text-white', guidesActive);
        }
      });

      // Handle morphing slider
      slider?.addEventListener('input', (e) => {
        const val = parseFloat((e.target as HTMLInputElement).value); // Range from -1 (inward) to +1 (outward)
        
        // Base coordinate shifts
        // Center of left fin is (40, 125), right fin is (160, 125)
        const dx = 15 * val;
        
        // Morph fins
        finL1.setAttribute('x2', (40 - dx).toString());
        finL2.setAttribute('x2', (40 - dx).toString());
        finR1.setAttribute('x2', (160 + dx).toString());
        finR2.setAttribute('x2', (160 + dx).toString());
      });
    });
  }

  initMuller();
  document.addEventListener('astro:page-load', initMuller);
</script>
