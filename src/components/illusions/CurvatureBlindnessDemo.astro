---
// src/components/illusions/CurvatureBlindnessDemo.astro
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;

// Generate baselines for the wavy lines (filling 300px height with 14px vertical spacing)
const lineYCoords = [];
for (let y = 10; y <= 290; y += 14) {
  lineYCoords.push(y);
}

// Helper to generate a continuous sinusoidal path
// amplitude 15px, wavelength 60px
const generateSinePath = (y: number) => {
  let d = `M -30,${y}`;
  for (let cx = -30; cx < 450; cx += 60) {
    d += ` C ${cx + 7.5},${y} ${cx + 7.5},${y - 15} ${cx + 15},${y - 15}`;
    d += ` C ${cx + 22.5},${y - 15} ${cx + 22.5},${y} ${cx + 30},${y}`;
    d += ` C ${cx + 37.5},${y} ${cx + 37.5},${y + 15} ${cx + 45},${y + 15}`;
    d += ` C ${cx + 52.5},${y + 15} ${cx + 52.5},${y} ${cx + 60},${y}`;
  }
  return d;
};

const lines = lineYCoords.map((y, idx) => ({
  y,
  path: generateSinePath(y),
  isOdd: idx % 2 === 1
}));
---

<div class="curvature-blindness-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-slate-900 rounded-xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[360px] p-6 pb-20">
    <!-- SVG Area (Exactly 400x300 px) -->
    <svg class="curvature-svg w-full max-w-[380px] h-auto aspect-[4/3] select-none overflow-visible rounded-lg shadow-lg border border-slate-950 bg-white" viewBox="0 0 400 300" width="400" height="300">
      <defs>
        <!-- Sharp diagonal clip-path for White region (0 to ~133.3px width) -->
        <clipPath id="clip-white">
          <polygon points="0,0 100,0 166.6,300 0,300" />
        </clipPath>

        <!-- Sharp diagonal clip-path for Gray region (~133.3px to ~266.6px width) -->
        <clipPath id="clip-gray">
          <polygon points="100,0 233.3,0 300,300 166.6,300" />
        </clipPath>

        <!-- Sharp diagonal clip-path for Black region (~266.6px to 400px width) -->
        <clipPath id="clip-black">
          <polygon points="233.3,0 400,0 400,300 300,300" />
        </clipPath>
      </defs>

      <!-- Illusion Display Group -->
      <g class="illusion-display-group">
        <!-- 1. Backgrounds -->
        <polygon points="0,0 100,0 166.6,300 0,300" fill="#FFFFFF" />
        <polygon points="100,0 233.3,0 300,300 166.6,300" fill="#808080" />
        <polygon points="233.3,0 400,0 400,300 300,300" fill="#000000" />

        <!-- 2. Lines in White Region (clipped, stroke #FFFFFF, width 3px - invisible) -->
        <g clip-path="url(#clip-white)" stroke="#FFFFFF" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
          {lines.map(line => (
            <path d={line.path} />
          ))}
        </g>

        <!-- 3. Lines in Gray Region (clipped, alternating white/black, width 3px - where the illusion occurs) -->
        <g clip-path="url(#clip-gray)" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
          {lines.map(line => (
            <path d={line.path} stroke={line.isOdd ? "#FFFFFF" : "#000000"} />
          ))}
        </g>

        <!-- 4. Lines in Black Region (clipped, stroke #000000, width 3px - invisible) -->
        <g clip-path="url(#clip-black)" stroke="#000000" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
          {lines.map(line => (
            <path d={line.path} />
          ))}
        </g>
      </g>

      <!-- True Geometry Overlay Group (Hidden by default, shown when toggled) -->
      <g class="true-geometry-group hidden">
        <!-- White background -->
        <rect x="0" y="0" width="400" height="300" fill="#FFFFFF" />
        <!-- All lines drawn identically in #808080 with 3px stroke -->
        <g stroke="#808080" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round">
          {lines.map(line => (
            <path d={line.path} />
          ))}
        </g>
      </g>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2 px-4 z-20">
      <button class="btn-toggle-geometry bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[11px] font-bold px-5 py-2.5 rounded-lg border-none transition-colors shadow cursor-pointer">
        Show True Geometry
      </button>
    </div>
  </div>
</div>

<script>
  function initCurvatureBlindness() {
    const containers = document.querySelectorAll('.curvature-blindness-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btn = container.querySelector('.btn-toggle-geometry');
      const illusionGroup = container.querySelector('.illusion-display-group');
      const trueGroup = container.querySelector('.true-geometry-group');

      let showingTrue = false;

      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        showingTrue = !showingTrue;

        if (showingTrue) {
          illusionGroup?.classList.add('hidden');
          trueGroup?.classList.remove('hidden');
          if (btn) btn.textContent = 'Show Illusion';
        } else {
          illusionGroup?.classList.remove('hidden');
          trueGroup?.classList.add('hidden');
          if (btn) btn.textContent = 'Show True Geometry';
        }
      });
    });
  }

  initCurvatureBlindness();
  document.addEventListener('astro:page-load', initCurvatureBlindness);
</script>
