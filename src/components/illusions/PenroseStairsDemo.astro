---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="stairs-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[420px] p-6 pb-24">
    
    <!-- SVG Area (372x283 px as defined by staircase.svg) -->
    <svg class="w-full max-w-[370px] h-auto aspect-[372/283] select-none overflow-visible" viewBox="0 0 372 283">
      <defs>
        <!-- Top of a step -->
        <path id="top" d="m0,0 37,18 -37,18 -37,-18 z" />
        
        <!-- Arrow marker -->
        <marker id="arrow" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" fill="#7C3AED" />
        </marker>
        
        <!-- Glow filter for walker/tracer -->
        <filter id="stairs-glow" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
      </defs>

      <!-- Isometric Stairs Geometry from staircase.svg -->
      <g stroke="#334155" stroke-width="1" stroke-linejoin="round" fill="#FFFFFF">
        <!-- Render Treads first, with painter's algorithm ordering -->
        <use href="#top" x="242" y="18" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="205" y="28" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="168" y="38" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="131" y="48" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="94" y="58" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="57" y="68" class="stair-tread hover:fill-slate-100 transition-colors" />
        
        <!-- Inner riser section -->
        <path fill="#94A3B8" d="m279,36 -37,18 v-8 l-37,18 v-8 l-37,18 v-8 l-37,18 v-8 l-37,18 v77 h185 z" />
        
        <use href="#top" x="279" y="43" class="stair-tread hover:fill-slate-100 transition-colors" />
        <path fill="#94A3B8" d="m316,61 v7 l-37,18 v-7 z" />
        <path fill="#CBD5E1" d="m316,104 -37,-18 v-7 l-37,-18 v99 h74 z" />
        
        <use href="#top" x="94" y="78" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="131" y="88" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="168" y="98" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="205" y="108" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="242" y="118" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="279" y="93" class="stair-tread hover:fill-slate-100 transition-colors" />
        <use href="#top" x="316" y="68" class="stair-tread hover:fill-slate-100 transition-colors" />
        
        <!-- Right riser wall -->
        <path fill="#94A3B8" d="m353,86 -37,18 v7 l-37,18 v7 l-37,18 v113 l111,-54 z" />
        <!-- Left riser wall -->
        <path fill="#CBD5E1" d="m20,159 v-73 l37,18 v-8 l37,18 v-8 l37,18 v-8 l37,18 v-8 l37,18 v-8 l37,18 v113 z" />
      </g>

      <!-- Dotted Tracing Path representing the endless loop centers -->
      <path 
        class="stairs-trace hidden stroke-[#7C3AED] stroke-[3.5] stroke-linecap-round stroke-dasharray-[6,4] fill-none" 
        d="M 242,36 L 205,46 L 168,56 L 131,66 L 94,76 L 57,86 L 94,96 L 131,106 L 168,116 L 205,126 L 242,136 L 279,111 L 316,86 L 279,61 Z"
        style="animation: stairs-dash 1s linear infinite;"
      />

      <!-- Glowing Walker Dot -->
      <circle class="stairs-dot hidden" r="7" fill="#7C3AED" filter="url(#stairs-glow)">
        <animateMotion 
          class="stairs-motion-anim"
          dur="6s" 
          repeatCount="indefinite" 
          path="M 242,36 L 205,46 L 168,56 L 131,66 L 94,76 L 57,86 L 94,96 L 131,106 L 168,116 L 205,126 L 242,136 L 279,111 L 316,86 L 279,61 Z"
        />
      </circle>
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-3 px-4 z-20">
      <button class="btn-trace-stairs bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[11px] font-bold px-5 py-2.5 rounded-lg border-none transition-colors shadow-sm cursor-pointer">
        Trace Path
      </button>
      <button class="btn-reverse-stairs hidden bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[11px] font-bold px-5 py-2.5 rounded-lg border-none transition-colors shadow-sm cursor-pointer">
        Reverse Direction
      </button>
    </div>
  </div>

  <!-- Instructions -->
  <div class="mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center w-full max-w-md">
    <p class="text-xs text-slate-700 dark:text-slate-350 leading-relaxed">
      <strong>Instruction:</strong> Observe the staircase. It climbs endlessly upward in a closed loop. Click "Trace Path" to see the endless loop center path and follow the walking guide.
    </p>
  </div>
</div>

<style>
  @keyframes stairs-dash {
    to {
      stroke-dashoffset: -10;
    }
  }
</style>

<script>
  function initStairs() {
    const containers = document.querySelectorAll('.stairs-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btnTrace = container.querySelector('.btn-trace-stairs');
      const btnReverse = container.querySelector('.btn-reverse-stairs');
      const trace = container.querySelector('.stairs-trace');
      const dot = container.querySelector('.stairs-dot');
      const motionAnim = container.querySelector('.stairs-motion-anim');

      let traceActive = false;
      let forward = true;

      const pathForward = "M 242,36 L 205,46 L 168,56 L 131,66 L 94,76 L 57,86 L 94,96 L 131,106 L 168,116 L 205,126 L 242,136 L 279,111 L 316,86 L 279,61 Z";
      const pathReverse = "M 242,36 L 279,61 L 316,86 L 279,111 L 242,136 L 205,126 L 168,116 L 131,106 L 94,96 L 57,86 L 94,76 L 131,66 L 168,56 L 205,46 Z";

      btnTrace?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        traceActive = !traceActive;
        
        if (trace) trace.classList.toggle('hidden', !traceActive);
        if (dot) dot.classList.toggle('hidden', !traceActive);
        if (btnReverse) btnReverse.classList.toggle('hidden', !traceActive);
        
        if (btnTrace) btnTrace.textContent = traceActive ? 'Untrace Path' : 'Trace Path';
      });

      btnReverse?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        forward = !forward;
        
        if (motionAnim) {
          motionAnim.setAttribute('path', forward ? pathForward : pathReverse);
          // Restart animation to apply new path
          const svg = container.querySelector('svg');
          if (svg) {
            svg.setCurrentTime(0);
          }
        }
        if (btnReverse) btnReverse.textContent = forward ? 'Reverse Direction' : 'Forward Direction';
      });
    });
  }

  initStairs();
  document.addEventListener('astro:page-load', initStairs);
</script>
