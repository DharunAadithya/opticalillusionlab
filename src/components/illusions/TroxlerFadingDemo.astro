---
// src/components/illusions/TroxlerFadingDemo.astro
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;

// Generate 12 dots evenly spaced on a circle of radius 150px, centered at (210, 210)
const dots = Array.from({ length: 12 }).map((_, i) => {
  const angle = (i * 30 * Math.PI) / 180;
  return {
    cx: 210 + 150 * Math.cos(angle),
    cy: 210 + 150 * Math.sin(angle),
    index: i
  };
});
---

<div class="troxler-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  
  <div class="relative flex flex-col items-center justify-center w-full min-h-[440px] bg-[#E8E8E8] rounded-xl overflow-hidden border border-slate-300 shadow-inner p-6 pb-16">
    <!-- SVG Area (420x420 px) -->
    <svg class="w-full max-w-[360px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 420 420" width="420" height="420">
      <defs>
        <!-- Gaussian blur for soft, blurry edges (stdDeviation=6) -->
        <filter id="fuzzy-blur-troxler">
          <feGaussianBlur stdDeviation="6" />
        </filter>
      </defs>

      <!-- Faint guide circle outline (radius exactly 150px, centered at (210, 210)) -->
      <circle cx="210" cy="210" r="150" stroke="#AAAAAA" stroke-width="1" stroke-dasharray="4,4" fill="none" />

      <!-- Center fixation cross (+) size 20px, stroke-width 2px, color #222222 -->
      <line x1="200" y1="210" x2="220" y2="210" stroke="#222222" stroke-width="2" stroke-linecap="round" />
      <line x1="210" y1="200" x2="210" y2="220" stroke="#222222" stroke-width="2" stroke-linecap="round" />
      
      <!-- Circle of 12 soft, blurry pink dots (radius 18px, fill #FFB3C6) -->
      <g class="troxler-dots-group">
        {dots.map(dot => (
          <circle 
            cx={dot.cx} 
            cy={dot.cy} 
            r="18" 
            fill="#FFB3C6" 
            class="troxler-dot" 
            style="opacity: 1; transition: opacity 0.3s ease-in-out;"
            filter="url(#fuzzy-blur-troxler)" 
            data-index={dot.index}
          />
        ))}
      </g>
    </svg>
  </div>

  <!-- Instruction Box & Feedback -->
  <div class="mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center w-full max-w-md">
    <p class="text-xs text-slate-700 dark:text-slate-350 leading-relaxed font-bold">
      There is NO green dot in this image. Your brain creates it.
    </p>
    <p class="text-[11px] text-slate-500 dark:text-slate-400 leading-relaxed mt-1.5">
      Fix your gaze on the cross. Don't move your eyes. After a few seconds, the traveling gap will appear to become a phantom green dot chasing the gap around the ring due to neural adaptation.
    </p>
  </div>
</div>

<script>
  function initTroxler() {
    const containers = document.querySelectorAll('.troxler-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const dots = Array.from(container.querySelectorAll('.troxler-dot')) as HTMLElement[];
      if (dots.length === 0) return;

      const N = 12;
      let step = 0;
      
      // Start: fade dot 0 immediately
      dots[0].style.opacity = '0';

      const intervalId = setInterval(() => {
        // Restore previous dot
        dots[step].style.opacity = '1';
        // Advance
        step = (step + 1) % N;
        // Fade new dot
        dots[step].style.opacity = '0';
      }, 500);

      // Clean up interval if container leaves DOM
      const observer = new MutationObserver(() => {
        if (!document.body.contains(container)) {
          clearInterval(intervalId);
          observer.disconnect();
        }
      });
      observer.observe(document.body, { childList: true, subtree: true });
    });
  }

  // Run on load
  initTroxler();
  document.addEventListener('astro:page-load', initTroxler);
</script>
