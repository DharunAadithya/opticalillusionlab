---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="vh-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-slate-50 dark:bg-slate-100 rounded-xl overflow-hidden border border-slate-300 shadow-inner w-full min-h-[380px] p-6 pb-20">
    
    <!-- SVG Area (Exactly 300x220 px) -->
    <svg class="w-full max-w-[300px] h-auto aspect-[300/220] select-none overflow-visible rounded-lg shadow-md border border-slate-200 bg-white p-4" viewBox="0 0 300 220">
      <!-- Grid ruler lines in background for reference -->
      <g stroke="rgba(100,116,139,0.08)" stroke-width="1">
        <line x1="50" y1="0" x2="50" y2="220" />
        <line x1="200" y1="0" x2="200" y2="220" />
        <line x1="125" y1="0" x2="125" y2="220" />
        <line x1="0" y1="160" x2="300" y2="160" />
        <line x1="0" y1="140" x2="300" y2="140" />
      </g>

      <!-- Horizontal Base Line (Blue) -->
      <!-- Length = 150px (from x=50 to x=200) -->
      <line x1="50" y1="160" x2="200" y2="160" stroke="#3b82f6" stroke-width="5" stroke-linecap="round" />
      
      <!-- Vertical Line (Red) -->
      <!-- Length = 150px (from y=160 up to y=10) -->
      <line 
        class="vh-vertical" 
        x1="125" y1="160" 
        x2="125" y2="10" 
        stroke="#f43f5e" 
        stroke-width="5" 
        stroke-linecap="round" 
        style="transform-origin: 125px 160px; transition: transform 1s cubic-bezier(0.4, 0, 0.2, 1);" 
      />
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 z-20 flex gap-2">
      <button class="btn-compare-vh text-[10px] font-bold px-3 py-1.5 rounded-lg border border-slate-300 bg-white hover:bg-slate-50 text-slate-700 transition-all shadow-sm">
        Compare Lines
      </button>
      <button class="btn-reset-vh hidden text-[10px] font-bold px-3 py-1.5 rounded-lg border border-slate-350 bg-white hover:bg-slate-50 text-slate-700 transition-all shadow-sm">
        Reset
      </button>
    </div>
  </div>

  <!-- Length Label & Instructions -->
  <div class="mt-3 p-3 bg-white/40 dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800 rounded-xl text-center w-full max-w-md">
    <div class="vh-label text-xs font-bold text-slate-800 dark:text-white h-5 mb-1 opacity-0 transition-opacity duration-500">
      Both lines: 150px
    </div>
    <p class="text-xs text-slate-755 dark:text-slate-300 leading-relaxed">
      <strong>Instruction:</strong> Does the vertical line look longer than the horizontal line? Click "Compare Lines" to rotate it parallel and side-by-side with the horizontal line for a direct comparison.
    </p>
  </div>
</div>

<script>
  function initVH() {
    const containers = document.querySelectorAll('.vh-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const verticalLine = container.querySelector('.vh-vertical') as HTMLElement;
      const btnCompare = container.querySelector('.btn-compare-vh');
      const btnReset = container.querySelector('.btn-reset-vh');
      const label = container.querySelector('.vh-label') as HTMLElement;

      btnCompare?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (verticalLine) {
          // Rotate 90deg and translate so it lies parallel (20px above) and aligned with the base line
          verticalLine.style.transform = 'translate(-75px, -20px) rotate(90deg)';
        }

        btnCompare.classList.add('hidden');
        btnReset?.classList.remove('hidden');

        if (label) {
          label.classList.remove('opacity-0');
          label.classList.add('opacity-100');
        }
      });

      btnReset?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (verticalLine) {
          verticalLine.style.transform = '';
        }

        btnCompare?.classList.remove('hidden');
        btnReset.classList.add('hidden');

        if (label) {
          label.classList.remove('opacity-100');
          label.classList.add('opacity-0');
        }
      });
    });
  }

  initVH();
  document.addEventListener('astro:page-load', initVH);
</script>
