---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="hiddentrees-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-[#070c18] rounded-2xl overflow-hidden border border-slate-800 shadow-inner w-full min-h-[420px] p-6 pb-24">
    
    <!-- High-Fidelity SVG of Forest Etching with 6 Hidden Faces -->
    <svg class="w-full max-w-[340px] h-auto aspect-square select-none overflow-visible" viewBox="0 0 300 300">
      <defs>
        <!-- Soft highlight glow -->
        <filter id="glow-highlight" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur stdDeviation="3" result="blur" />
          <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
        <!-- Vintage paper styling -->
        <linearGradient id="trees-bg" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#1E293B" />
          <stop offset="100%" stop-color="#0F172A" />
        </linearGradient>
      </defs>

      <!-- Background backing -->
      <rect x="10" y="10" width="280" height="280" fill="url(#trees-bg)" rx="16" stroke="#334155" stroke-width="2" />

      <!-- Moon in sky (provides silhouette contrast) -->
      <circle cx="150" cy="80" r="45" fill="#F8FAFC" opacity="0.12" />

      <!-- Forest floor roots -->
      <path d="M 10,270 Q 150,260 290,270 L 290,290 L 10,290 Z" fill="#020617" />

      <!-- Left Tree Trunk (Forms Face 1 on outer contour, and Face 3 on inner contour) -->
      <!-- Outer contour profile 1 facing left -->
      <!-- Inner contour profile 3 facing right -->
      <path 
        d="M 10,270 
           C 25,240 35,210 35,180 
           C 35,160 30,150 22,145
           C 32,140 37,135 34,120
           C 38,110 34,100 45,95
           C 55,90 60,60 50,30
           C 65,45 75,70 75,100
           C 75,120 82,125 90,128
           C 82,132 80,140 85,150
           C 80,160 84,170 80,185
           C 85,215 95,245 110,270 Z" 
        fill="#1e293b" 
        stroke="#475569" 
        stroke-width="1.5" 
      />

      <!-- Right Tree Trunk (Forms Face 2 on outer contour, and Face 4 on inner contour) -->
      <path 
        d="M 290,270 
           C 275,240 265,210 265,180 
           C 265,160 270,150 278,145
           C 268,140 263,135 266,120
           C 262,110 266,100 255,95
           C 245,90 240,60 250,30
           C 235,45 225,70 225,100
           C 225,120 218,125 210,128
           C 218,132 220,140 215,150
           C 220,160 216,170 220,185
           C 215,215 205,245 190,270 Z" 
        fill="#1e293b" 
        stroke="#475569" 
        stroke-width="1.5" 
      />

      <!-- Center Tree Trunk (Forms Face 5 and Face 6 on roots/base) -->
      <path 
        d="M 125,270 
           C 135,240 140,210 140,160 
           C 140,130 135,110 145,50
           C 155,50 150,130 150,160
           C 150,210 155,240 165,270 Z" 
        fill="#0f172a" 
        stroke="#475569" 
        stroke-width="1.5" 
      />

      <!-- Branch details / Etching lines -->
      <path d="M 60,70 Q 30,50 20,40" stroke="#475569" stroke-width="1" fill="none" />
      <path d="M 230,70 Q 260,50 280,40" stroke="#475569" stroke-width="1" fill="none" />
      <path d="M 145,100 Q 115,80 100,70" stroke="#475569" stroke-width="1" fill="none" />
      <path d="M 150,100 Q 180,80 195,70" stroke="#475569" stroke-width="1" fill="none" />

      <!-- Interactive face click targets (invisible stroke width 10, highlights in glowing green) -->
      
      <!-- Face 1 (Left Trunk Outer - Young face profile facing left) -->
      <path d="M 35,180 C 35,160 30,150 22,145 C 32,140 37,135 34,120 C 38,110 34,100 45,95" fill="none" stroke="transparent" stroke-width="10" class="face-target cursor-pointer" data-idx="1" />
      <path id="tree-hl-1" d="M 35,180 C 35,160 30,150 22,145 C 32,140 37,135 34,120 C 38,110 34,100 45,95" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity pointer-events-none" filter="url(#glow-highlight)" />

      <!-- Face 2 (Right Trunk Outer - Young face profile facing right) -->
      <path d="M 265,180 C 265,160 270,150 278,145 C 268,140 263,135 266,120 C 262,110 266,100 255,95" fill="none" stroke="transparent" stroke-width="10" class="face-target cursor-pointer" data-idx="2" />
      <path id="tree-hl-2" d="M 265,180 C 265,160 270,150 278,145 C 268,140 263,135 266,120 C 262,110 266,100 255,95" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity pointer-events-none" filter="url(#glow-highlight)" />

      <!-- Face 3 (Left Trunk Inner - Old man profile facing right) -->
      <path d="M 75,100 C 75,120 82,125 90,128 C 82,132 80,140 85,150 C 80,160 84,170 80,185" fill="none" stroke="transparent" stroke-width="10" class="face-target cursor-pointer" data-idx="3" />
      <path id="tree-hl-3" d="M 75,100 C 75,120 82,125 90,128 C 82,132 80,140 85,150 C 80,160 84,170 80,185" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity pointer-events-none" filter="url(#glow-highlight)" />

      <!-- Face 4 (Right Trunk Inner - Old man profile facing left) -->
      <path d="M 225,100 C 225,120 218,125 210,128 C 218,132 220,140 215,150 C 220,160 216,170 220,185" fill="none" stroke="transparent" stroke-width="10" class="face-target cursor-pointer" data-idx="4" />
      <path id="tree-hl-4" d="M 225,100 C 225,120 218,125 210,128 C 218,132 220,140 215,150 C 220,160 216,170 220,185" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity pointer-events-none" filter="url(#glow-highlight)" />

      <!-- Face 5 (Center Trunk Left - Profile facing left) -->
      <path d="M 125,270 C 135,240 140,210 140,160" fill="none" stroke="transparent" stroke-width="10" class="face-target cursor-pointer" data-idx="5" />
      <path id="tree-hl-5" d="M 125,270 C 135,240 140,210 140,160" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity pointer-events-none" filter="url(#glow-highlight)" />

      <!-- Face 6 (Center Trunk Right - Profile facing right) -->
      <path d="M 165,270 C 155,240 150,210 150,160" fill="none" stroke="transparent" stroke-width="10" class="face-target cursor-pointer" data-idx="6" />
      <path id="tree-hl-6" d="M 165,270 C 155,240 150,210 150,160" fill="none" stroke="#22c55e" stroke-width="2.5" class="opacity-0 transition-opacity pointer-events-none" filter="url(#glow-highlight)" />
    </svg>

    <!-- Overlay Toggle Controls inside container -->
    <div class="absolute bottom-2 flex flex-col items-center gap-1.5 z-20 w-11/12 max-w-xs bg-slate-900/90 border border-slate-800 p-2.5 rounded-xl">
      <div class="flex items-center justify-between w-full text-[10px] font-bold text-slate-350">
        <span>Faces Found: <span class="faces-found-indicator text-green-400 font-mono">0</span>/6</span>
        <button class="btn-reset-trees bg-purple-600 hover:bg-purple-500 text-white text-[9px] font-black px-2.5 py-1 rounded border-none cursor-pointer">Reset 🔄</button>
      </div>
    </div>
  </div>
</div>

<script>
  function initTrees() {
    const containers = document.querySelectorAll('.hiddentrees-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const targets = container.querySelectorAll('.face-target');
      const countEl = container.querySelector('.faces-found-indicator');
      const resetBtn = container.querySelector('.btn-reset-trees');
      
      let foundSet = new Set();

      targets.forEach(target => {
        target.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const idx = target.getAttribute('data-idx');
          if (idx && !foundSet.has(idx)) {
            foundSet.add(idx);
            const hl = container.querySelector(`#tree-hl-${idx}`);
            if (hl) hl.classList.replace('opacity-0', 'opacity-100');
            
            if (countEl) countEl.textContent = foundSet.size.toString();
            
            // Dispatch custom event to let parent pages know (optional but useful)
            const event = new CustomEvent('faceFound', { detail: { count: foundSet.size } });
            container.dispatchEvent(event);
          }
        });
      });

      resetBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        foundSet.clear();
        if (countEl) countEl.textContent = "0";
        for (let i = 1; i <= 6; i++) {
          const hl = container.querySelector(`#tree-hl-${i}`);
          if (hl) hl.classList.replace('opacity-100', 'opacity-0');
        }
      });
    });
  }

  initTrees();
  document.addEventListener('astro:page-load', initTrees);
</script>
