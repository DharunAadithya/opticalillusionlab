---
interface Props {
  isCard?: boolean;
}

const { isCard = false } = Astro.props;
---

<div class="poggendorff-container flex flex-col items-center w-full select-none" data-is-card={isCard ? "true" : "false"}>
  <div class="relative flex flex-col items-center justify-center bg-white rounded-xl overflow-hidden border border-slate-200 shadow-inner w-full min-h-[380px] p-6 pb-20">
    
    <div class="mb-4 text-center max-w-sm">
      <p class="text-xs font-bold text-slate-800">
        Which colored line (red or blue) is the true continuation of the black line? Click to reveal.
      </p>
    </div>

    <!-- SVG Area (Exactly 500x400) -->
    <svg class="pogg-svg w-full max-w-[400px] h-auto aspect-[5/4] select-none overflow-visible" viewBox="0 0 500 400">
      <!-- Background of SVG is white -->
      <rect x="0" y="0" width="500" height="400" fill="#FFFFFF" />

      <!-- Left Black Line segment -->
      <line class="stroke-black stroke-[4] stroke-linecap-round" x1="110" y1="0" x2="210" y2="200" />
      
      <!-- Right Red Line (True continuation) -->
      <line class="stroke-[#EF4444] stroke-[3] stroke-linecap-round" x1="290" y1="360" x2="310" y2="400" />
      
      <!-- Right Blue Line (Offset, parallel) -->
      <line class="stroke-[#3B82F6] stroke-[3] stroke-linecap-round" x1="290" y1="340" x2="320" y2="400" />

      <!-- Intercepting Gray Rectangle -->
      <rect class="pogg-rect fill-[#999999] shadow-md transition-opacity duration-300" x="210" y="25" width="80" height="350" rx="4" />

      <!-- Thin red connecting line (Shown on reveal, drawn over the rectangle) -->
      <line class="pogg-connector hidden stroke-[#EF4444] stroke-[1.5] stroke-dasharray-[3,3]" x1="210" y1="200" x2="290" y2="360" />
    </svg>

    <!-- Controls Panel -->
    <div class="absolute bottom-3 z-20 flex gap-3">
      <button class="btn-reveal-pogg bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-black px-4 py-2 rounded-lg border-none transition-colors shadow-sm cursor-pointer">
        Reveal Answer
      </button>
      <button class="btn-reset-pogg hidden bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[10px] font-black px-4 py-2 rounded-lg border-none transition-colors shadow-sm cursor-pointer">
        Reset
      </button>
    </div>
  </div>

  <!-- Feedback Text -->
  <div class="pogg-feedback mt-3 text-center text-xs font-semibold text-slate-650 h-5">
    <!-- Feedback injected here -->
  </div>
</div>

<script>
  function initPoggendorff() {
    const containers = document.querySelectorAll('.poggendorff-container');
    containers.forEach(container => {
      if (container.getAttribute('data-initialized') === 'true') return;
      container.setAttribute('data-initialized', 'true');

      const btnReveal = container.querySelector('.btn-reveal-pogg');
      const btnReset = container.querySelector('.btn-reset-pogg');
      const connector = container.querySelector('.pogg-connector');
      const feedback = container.querySelector('.pogg-feedback');

      btnReveal?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        connector?.classList.remove('hidden');
        btnReveal?.classList.add('hidden');
        btnReset?.classList.remove('hidden');

        if (feedback) {
          feedback.innerHTML = '<span class="text-emerald-600 font-bold">Revealed:</span> The <span class="text-[#EF4444] font-bold">Red line</span> is the true straight continuation! The blue line is parallel but offset.';
        }
      });

      btnReset?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        connector?.classList.add('hidden');
        btnReveal?.classList.remove('hidden');
        btnReset?.classList.add('hidden');

        if (feedback) {
          feedback.innerHTML = '';
        }
      });
    });
  }

  initPoggendorff();
  document.addEventListener('astro:page-load', initPoggendorff);
</script>
