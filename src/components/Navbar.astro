---
// src/components/Navbar.astro
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/famous", label: "Famous" },
  { href: "/moving", label: "Moving" },
  { href: "/hidden", label: "Hidden" },
  { href: "/for-kids", label: "Kids" },
  { href: "/color", label: "Color" },
  { href: "/test", label: "Test" },
];

const dropdownLinks = [
  { href: "/what-do-you-see", label: "What Do You See?" },
  { href: "/drawings", label: "Drawings" },
  { href: "/generator", label: "Generator" },
  { href: "/how-they-work", label: "How They Work" },
];
---

<header class="sticky top-0 z-50 w-full border-b border-indigo-100/10 bg-slate-900/80 dark:bg-slate-950/80 backdrop-blur-md transition-colors duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8 h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center space-x-2 group">
      <img
        src="/favicon-96x96.png"
        alt="Optical Illusion Lab Logo"
        class="w-9 h-9 rounded-xl shadow-[0_0_10px_rgba(147,51,234,0.5)] transition-transform duration-300 group-hover:scale-105"
      />
      <span class="font-display text-xl font-bold bg-gradient-to-r from-purple-400 to-indigo-400 bg-clip-text text-transparent dark:from-purple-300 dark:to-indigo-300 group-hover:from-purple-300 group-hover:to-indigo-300 transition-all duration-300">
        Optical Illusion Lab
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all duration-200"
        >
          {link.label}
        </a>
      ))}

      <!-- Dropdown Menu -->
      <div class="relative group py-2">
        <button class="flex items-center space-x-1 px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all duration-200 focus:outline-none">
          <span>More</span>
          <svg class="h-4 w-4 transition-transform group-hover:rotate-185" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute right-0 top-full mt-1 w-56 origin-top-right rounded-xl border border-indigo-950/20 bg-slate-900 p-2 shadow-xl opacity-0 scale-95 pointer-events-none group-hover:opacity-100 group-hover:scale-100 group-hover:pointer-events-auto transition-all duration-200 z-50">
          {dropdownLinks.map((link) => (
            <a
              href={link.href}
              class="block rounded-lg px-4 py-2.5 text-sm text-slate-300 hover:text-white hover:bg-indigo-600/20 transition-colors duration-150"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Right Controls: Dark Mode & Hamburger -->
    <div class="flex items-center space-x-4">
      <!-- Dark Mode Toggle Button -->
      <button
        id="theme-toggle"
        aria-label="Toggle Dark Mode"
        class="relative flex h-10 w-10 items-center justify-center rounded-xl border border-indigo-100/10 bg-slate-800/50 text-indigo-400 hover:text-indigo-300 dark:text-purple-400 dark:hover:text-purple-300 hover:bg-white/5 shadow-inner transition-all duration-300 focus:outline-none"
      >
        <!-- Moon Icon (shows in light mode, i.e., when dark class is NOT on html) -->
        <svg id="theme-toggle-dark-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
        <!-- Sun Icon (shows in dark mode, i.e., when dark class IS on html) -->
        <svg id="theme-toggle-light-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m2.828 0l-.707-.707m12.728-12.728l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
      </button>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        aria-label="Open Mobile Menu"
        class="flex md:hidden h-10 w-10 items-center justify-center rounded-xl border border-indigo-100/10 bg-slate-800/50 text-slate-300 hover:bg-white/5 transition-all duration-200 focus:outline-none"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu (Hidden by default) -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-indigo-100/10 bg-slate-900/95 dark:bg-slate-950/95 transition-all duration-200"
  >
    <div class="space-y-1 px-4 py-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-2.5 text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all"
        >
          {link.label}
        </a>
      ))}
      <hr class="border-indigo-100/10 my-2" />
      <div class="px-3 py-1 text-xs font-bold text-slate-500 uppercase tracking-wider">More Illusions</div>
      {dropdownLinks.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg px-3 py-2 text-base text-slate-300 hover:text-white hover:bg-white/5 transition-all"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Mobile menu interaction code
  const mobileMenuBtn = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
